<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>
  <%= typeof title !=='undefined' ? title : 'Company Dashboard | Conneto' %>
</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
  rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  (function () {
    const t = localStorage.getItem('conneto-theme') || 'light';
    document.documentElement.setAttribute('data-theme', t);
  })();

  function toggleTheme() {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('conneto-theme', next);

    document.querySelectorAll('#themeToggle i').forEach(icon => {
      icon.className = next === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const current = document.documentElement.getAttribute('data-theme');
    document.querySelectorAll('#themeToggle i').forEach(icon => {
      icon.className = current === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
    });

    document.querySelectorAll('#themeToggle').forEach(btn => {
      btn.addEventListener('click', toggleTheme);
    });

    // Mobile Sidebar Toggle
    const sidebar = document.querySelector('.sidebar');
    const mobileMenuBtn = document.createElement('button');
    mobileMenuBtn.className = 'mobile-menu-btn';
    mobileMenuBtn.innerHTML = '<i class="fas fa-bars"></i>';

    // Insert after logo in topbar
    const logo = document.querySelector('.logo');
    if (logo && logo.parentNode) {
      logo.parentNode.insertBefore(mobileMenuBtn, logo.nextSibling);
    }

    mobileMenuBtn.addEventListener('click', () => {
      sidebar.classList.toggle('active');
      const isActive = sidebar.classList.contains('active');
      mobileMenuBtn.innerHTML = isActive ? '<i class="fas fa-times"></i>' : '<i class="fas fa-bars"></i>';

      if (isActive) {
        const overlay = document.createElement('div');
        overlay.className = 'sidebar-overlay';
        document.body.appendChild(overlay);
        overlay.style.display = 'block';
        overlay.addEventListener('click', () => {
          sidebar.classList.remove('active');
          mobileMenuBtn.innerHTML = '<i class="fas fa-bars"></i>';
          overlay.remove();
        });
      } else {
        const overlay = document.querySelector('.sidebar-overlay');
        if (overlay) overlay.remove();
      }
    });
  });
</script>
<style>
  :root {
    --coral: #D95F3B;
    --coral-light: #F07A56;
    --rose: #B5384A;
    --amber: #C8831A;
    --amber-light: #E8A030;
    --sage: #5A7A5C;
    --sage-light: #7A9E7C;
    --terra: #A0522D;
    --terra-light: #C4723F;
    --cream: #FAF3E8;
    --cream2: #F5EAD8;
    --warm-white: #FFF8F0;
    --ink: #2C1A0E;
    --ink2: #4A2E1A;
    --text: #3D2B1F;
    --text-muted: #7A5C4A;
    --border: rgba(160, 82, 45, 0.15);
    --shadow: rgba(44, 26, 14, 0.12);
    --card-bg: rgba(255, 248, 240, 0.95);
    --nav-bg: rgba(250, 243, 232, 0.97);
    --section-alt: #F5EAD8;

    /* Compatibility mappings */
    --primary: var(--coral);
    --primary-light: rgba(217, 95, 59, 0.1);
    --bg: var(--cream);
    --bg-alt: var(--cream2);
    --border-light: var(--border);
    --card-border: var(--border);
    --gradient-1: linear-gradient(135deg, var(--coral), var(--rose));
    --gradient-2: linear-gradient(135deg, var(--amber), var(--terra));
    --gradient-primary: linear-gradient(135deg, var(--coral), var(--rose));
    --gradient-success: linear-gradient(135deg, var(--sage), var(--sage-light));
    --gradient-warning: linear-gradient(135deg, var(--amber), var(--amber-light));
    --gradient-sky: linear-gradient(135deg, var(--terra), var(--terra-light));
  }

  [data-theme="dark"] {
    --cream: #1C0F08;
    --cream2: #251508;
    --warm-white: #1A0D06;
    --ink: #FAF3E8;
    --ink2: #F0E0C8;
    --text: #E8D5BC;
    --text-muted: #B8937A;
    --border: rgba(200, 131, 26, 0.2);
    --shadow: rgba(0, 0, 0, 0.4);
    --card-bg: rgba(37, 21, 8, 0.95);
    --nav-bg: rgba(28, 15, 8, 0.98);
    --section-alt: #201008;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0
  }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--cream);
    color: var(--text);
    transition: background 0.4s, color 0.4s;
    overflow-x: hidden
  }

  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 70px;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 40px;
    z-index: 1000;
    transition: .3s;
  }

  .logo {
    font-family: 'Outfit', sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--ink);
    text-decoration: none;
  }

  .logo span {
    color: var(--coral)
  }

  /* Mobile Responsiveness Improvements */
  .mobile-menu-btn {
    display: none;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--coral);
    color: #fff;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    border: none;
    cursor: pointer;
    transition: .3s;
  }

  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 999;
    display: none;
  }

  @media (max-width: 992px) {
    .topbar {
      padding: 0 20px;
    }

    .topbar-right .topbar-btn:nth-child(2),
    .topbar-right .topbar-btn:nth-child(3) {
      display: none;
    }

    .user-info {
      display: none;
    }

    .sidebar {
      left: -280px;
      z-index: 1001;
      height: 100vh;
      top: 0;
      width: 280px;
      box-shadow: 20px 0 40px rgba(0, 0, 0, 0.2);
    }

    .sidebar.active {
      left: 0;
    }

    .main-layout {
      display: block;
      padding-top: 70px;
    }

    .content {
      padding: 20px !important;
    }

    .mobile-menu-btn {
      display: flex;
      margin-left: 15px;
    }
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }

    .dashboard-grid {
      grid-template-columns: 1fr !important;
    }

    .page-header {
      text-align: left;
      padding: 0 20px;
    }

    .page-title {
      font-size: 1.8rem;
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr !important;
    }
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .topbar-btn {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--card-bg);
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    transition: .3s;
    position: relative;
  }

  .topbar-btn:hover {
    background: var(--border);
    color: var(--coral);
    transform: translateY(-2px);
  }

  .topbar-btn .badge {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 8px;
    height: 8px;
    background: var(--rose);
    border-radius: 50%;
    border: 2px solid var(--card-bg);
  }

  .user-menu {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 6px 16px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 14px;
  }

  .user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--coral), var(--rose));
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 700;
    font-family: 'Outfit', sans-serif;
  }

  .user-info {
    text-align: left;
  }

  .user-name {
    font-weight: 700;
    font-size: 13.5px;
    color: var(--ink);
    line-height: 1.2;
  }

  .user-role {
    font-size: 11px;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .main-layout {
    display: flex;
    padding-top: 70px;
    min-height: 100vh;
    position: relative;
  }

  .sidebar {
    width: 260px;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    border-right: 1px solid var(--border);
    padding: 30px 20px;
    position: fixed;
    height: calc(100vh - 70px);
    overflow-y: auto;
    transition: .3s;
  }

  .sidebar-section {
    margin-bottom: 30px;
  }

  .sidebar-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    padding: 0 12px;
    margin-bottom: 15px;
  }

  .nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 12px;
    text-decoration: none;
    color: var(--text);
    font-weight: 600;
    font-size: 14.5px;
    transition: .3s;
  }

  .nav-link:hover {
    background: var(--border);
    color: var(--coral);
  }

  .nav-link.active {
    background: linear-gradient(135deg, var(--coral), var(--rose));
    color: #fff;
    box-shadow: 0 8px 16px rgba(217, 95, 59, 0.25);
  }

  .nav-link i {
    width: 20px;
    text-align: center;
    font-size: 16px;
  }

  .content {
    flex: 1;
    margin-left: 260px;
    padding: 40px;
    position: relative;
    z-index: 1;
  }

  .page-header {
    margin-bottom: 40px;
  }

  .page-title {
    font-family: 'Outfit', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .page-subtitle {
    color: var(--text-muted);
    font-size: 16px;
    font-weight: 500;
  }

  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 30px;
    box-shadow: 0 10px 30px var(--shadow);
    position: relative;
    overflow: hidden;
  }

  /* Dashboard aesthetics */
  .dashboard-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: var(--cream);
    overflow: hidden;
  }

  .blob {
    position: absolute;
    filter: blur(100px);
    border-radius: 50%;
    opacity: 0.15;
    transition: .5s;
    animation: move-blobs 25s infinite alternate ease-in-out;
  }

  .blob-1 {
    top: -10%;
    right: -5%;
    width: 500px;
    height: 500px;
    background: var(--coral-light);
    animation-duration: 30s;
  }

  .blob-2 {
    bottom: -10%;
    left: -5%;
    width: 600px;
    height: 600px;
    background: var(--sage-light);
    animation-delay: -5s;
    animation-duration: 35s;
  }

  .blob-3 {
    top: 40%;
    left: 30%;
    width: 400px;
    height: 400px;
    background: var(--amber-light);
    opacity: 0.1;
    animation-delay: -10s;
  }

  @keyframes move-blobs {
    0% {
      transform: translate(0, 0) scale(1) rotate(0deg);
    }

    33% {
      transform: translate(50px, 30px) scale(1.05) rotate(120deg);
    }

    66% {
      transform: translate(-30px, 50px) scale(0.95) rotate(240deg);
    }

    100% {
      transform: translate(0, 0) scale(1) rotate(360deg);
    }
  }

  @media (max-width: 1200px) {
    .sidebar {
      width: 85px;
      padding: 25px 12px;
    }

    .sidebar-title,
    .nav-link span {
      display: none;
    }

    .nav-link {
      justify-content: center;
    }

    .content {
      margin-left: 85px;
    }
  }

  @media (max-width: 768px) {
    .sidebar {
      transform: translateX(-100%);
      width: 260px;
      height: calc(100vh - 70px);
      top: 70px;
      z-index: 1050;
    }

    .sidebar.open {
      transform: translateX(0);
    }

    .sidebar-title,
    .nav-link span {
      display: block;
    }

    .nav-link {
      justify-content: flex-start;
    }

    .content {
      margin-left: 0;
      padding: 30px 20px;
    }

    .topbar {
      padding: 0 20px;
    }

    .page-title {
      font-size: 1.8rem;
    }

    .mobile-toggle {
      display: flex !important;
      width: 40px;
      height: 40px;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      color: var(--ink);
      cursor: pointer;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--card-bg);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const topbarRight = document.querySelector('.topbar-right');
    const toggle = document.createElement('div');
    toggle.className = 'mobile-toggle';
    toggle.style.display = 'none';
    toggle.style.marginRight = '10px';
    toggle.innerHTML = '<i class="fas fa-bars"></i>';

    const topbar = document.querySelector('.topbar');
    const logo = document.querySelector('.logo');
    logo.parentNode.insertBefore(toggle, logo.nextSibling);

    const sidebar = document.querySelector('.sidebar');
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      sidebar.classList.toggle('open');
      toggle.innerHTML = sidebar.classList.contains('open') ? '<i class="fas fa-times"></i>' : '<i class="fas fa-bars"></i>';
    });

    document.addEventListener('click', (e) => {
      if (sidebar.classList.contains('open') && !sidebar.contains(e.target) && !toggle.contains(e.target)) {
        sidebar.classList.remove('open');
        toggle.innerHTML = '<i class="fas fa-bars"></i>';
      }
    });
  });
</script>