<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us — Conneto Internship Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script>
        (function () {
            const t = localStorage.getItem('conneto-theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    <style>
        :root {
            --coral: #D95F3B;
            --coral-light: #F07A56;
            --rose: #B5384A;
            --amber: #C8831A;
            --amber-light: #E8A030;
            --sage: #5A7A5C;
            --sage-light: #7A9E7C;
            --terra: #A0522D;
            --terra-light: #C4723F;
            --cream: #FAF3E8;
            --cream2: #F5EAD8;
            --warm-white: #FFF8F0;
            --ink: #2C1A0E;
            --ink2: #4A2E1A;
            --text: #3D2B1F;
            --text-muted: #7A5C4A;
            --border: rgba(160, 82, 45, 0.15);
            --shadow: rgba(44, 26, 14, 0.12);
            --card-bg: rgba(255, 248, 240, 0.95);
            --nav-bg: rgba(250, 243, 232, 0.97);
            --section-alt: #F5EAD8;
            --footer-bg: #1E0E05;
        }

        [data-theme="dark"] {
            --cream: #1C0F08;
            --cream2: #251508;
            --warm-white: #1A0D06;
            --ink: #FAF3E8;
            --ink2: #F0E0C8;
            --text: #E8D5BC;
            --text-muted: #B8937A;
            --border: rgba(200, 131, 26, 0.2);
            --shadow: rgba(0, 0, 0, 0.4);
            --card-bg: rgba(37, 21, 8, 0.95);
            --nav-bg: rgba(28, 15, 8, 0.98);
            --section-alt: #201008;
            --footer-bg: #0E0704;
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html {
            scroll-behavior: smooth
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--cream);
            color: var(--text);
            transition: background .4s, color .4s;
            overflow-x: hidden
        }

        .loader {
            position: fixed;
            inset: 0;
            background: var(--cream);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity .5s, visibility .5s
        }

        .loader.hide {
            opacity: 0;
            visibility: hidden;
            pointer-events: none
        }

        .loader-logo {
            font-family: 'Outfit', sans-serif;
            font-size: 3.5rem;
            font-weight: 800;
            color: var(--ink);
            letter-spacing: -1px
        }

        .loader-logo span {
            color: var(--coral)
        }

        .loader-dots {
            display: flex;
            gap: 10px;
            margin-top: 18px
        }

        .loader-dots div {
            width: 11px;
            height: 11px;
            border-radius: 50%;
            background: var(--coral);
            animation: dotBounce .6s infinite alternate
        }

        .loader-dots div:nth-child(2) {
            animation-delay: .15s;
            background: var(--amber)
        }

        .loader-dots div:nth-child(3) {
            animation-delay: .3s;
            background: var(--sage)
        }

        @keyframes dotBounce {
            from {
                transform: translateY(0)
            }

            to {
                transform: translateY(-10px);
                opacity: .5
            }
        }

        /* SHINE EFFECT */
        .shine-box {
            position: relative;
            overflow: hidden;
        }

        .shine-box::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -150%;
            width: 200%;
            height: 200%;
            background: linear-gradient(to right,
                    rgba(255, 255, 255, 0) 0%,
                    rgba(255, 255, 255, 0.4) 50%,
                    rgba(255, 255, 255, 0) 100%);
            transform: rotate(30deg);
            animation: shine-anim 4s infinite;
            pointer-events: none;
        }

        @keyframes shine-anim {
            0% {
                left: -150%;
            }

            20% {
                left: 150%;
            }

            100% {
                left: 150%;
            }
        }

        .topbar {
            background: var(--terra);
            color: #fff;
            padding: 8px 0;
            font-size: 13px;
            font-weight: 500
        }

        .topbar .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 8px
        }

        .topbar-contact {
            display: flex;
            gap: 20px;
            flex-wrap: wrap
        }

        .topbar-contact a {
            color: rgba(255, 255, 255, .85);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: color .3s
        }

        .topbar-contact a:hover {
            color: #fff
        }

        .nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: var(--nav-bg);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
            transition: all .3s
        }

        .nav.scrolled {
            box-shadow: 0 4px 24px var(--shadow)
        }

        .nav .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            max-width: 1260px;
            margin: 0 auto
        }

        .logo {
            font-family: 'Outfit', sans-serif;
            font-size: 1.9rem;
            font-weight: 800;
            color: var(--ink);
            text-decoration: none;
            letter-spacing: -.5px
        }

        .logo span {
            color: var(--coral)
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 10px;
            list-style: none
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text);
            font-weight: 600;
            font-size: 14.5px;
            padding: 7px 14px;
            border-radius: 8px;
            transition: all .3s;
            position: relative
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 2px;
            left: 14px;
            right: 14px;
            height: 2px;
            background: var(--coral);
            border-radius: 2px;
            transform: scaleX(0);
            transition: transform .3s
        }

        .nav-links a:hover::after,
        .nav-links a.active::after {
            transform: scaleX(1)
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: var(--coral)
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 10px
        }

        .theme-btn {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: var(--card-bg);
            color: var(--amber);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            transition: all .3s
        }

        .theme-btn:hover {
            background: var(--amber);
            color: #fff;
            transform: rotate(20deg)
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 11px 26px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            text-decoration: none;
            cursor: pointer;
            border: none;
            transition: all .3s;
            font-family: 'Inter', sans-serif
        }

        .btn-outline {
            background: transparent;
            border: 1.5px solid var(--coral);
            color: var(--coral)
        }

        .btn-outline:hover {
            background: var(--coral);
            color: #fff
        }

        .btn-fill {
            background: linear-gradient(135deg, var(--coral), var(--rose));
            color: #fff;
            box-shadow: 0 4px 16px rgba(217, 95, 59, .3)
        }

        .btn-fill:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(217, 95, 59, .4)
        }

        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 8px;
            border: none;
            background: transparent
        }

        .hamburger span {
            display: block;
            width: 24px;
            height: 2px;
            background: var(--ink);
            border-radius: 2px;
            transition: all .3s
        }

        .container {
            max-width: 1260px;
            margin: 0 auto;
            padding: 0 24px
        }

        .section {
            padding: 100px 0
        }

        .section-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--coral);
            margin-bottom: 14px
        }

        .section-tag::before,
        .section-tag::after {
            content: '';
            width: 28px;
            height: 2px;
            background: var(--coral);
            border-radius: 2px
        }

        .section-title {
            font-family: 'Outfit', sans-serif;
            font-size: clamp(1.9rem, 4vw, 3rem);
            font-weight: 800;
            color: var(--ink);
            line-height: 1.18;
            letter-spacing: -.5px;
            margin-bottom: 18px
        }

        .section-title em {
            font-style: italic;
            color: var(--coral)
        }

        .section-title span {
            color: var(--amber)
        }

        .section-sub {
            font-size: 16px;
            color: var(--text-muted);
            line-height: 1.75;
            max-width: 560px
        }

        .text-center {
            text-align: center
        }

        .text-center .section-sub {
            margin-left: auto;
            margin-right: auto
        }

        .text-center .section-tag {
            justify-content: center
        }

        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity .7s ease, transform .7s ease
        }

        .fade-up.visible {
            opacity: 1;
            transform: translateY(0)
        }

        .scale-in {
            opacity: 0;
            transform: scale(.95);
            transition: opacity .6s ease, transform .6s ease
        }

        .scale-in.visible {
            opacity: 1;
            transform: scale(1)
        }

        .stagger:nth-child(1) {
            transition-delay: .1s
        }

        .stagger:nth-child(2) {
            transition-delay: .2s
        }

        .stagger:nth-child(3) {
            transition-delay: .3s
        }

        .stagger:nth-child(4) {
            transition-delay: .4s
        }

        /* PAGE HERO */
        .page-hero {
            position: relative;
            padding: 160px 0 90px;
            overflow: hidden
        }

        .page-hero-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1531482615713-2afd69097998?w=1600&q=85');
            background-size: cover;
            background-position: center;
            background-attachment: fixed
        }

        .page-hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(42, 20, 8, .82) 0%, rgba(160, 82, 45, .55) 60%, rgba(90, 122, 92, .4) 100%)
        }

        .page-hero-inner {
            position: relative;
            z-index: 2
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
            font-size: 13px;
            font-weight: 500
        }

        .breadcrumb a {
            color: rgba(255, 255, 255, .7);
            text-decoration: none;
            transition: .3s
        }

        .breadcrumb a:hover {
            color: var(--amber-light)
        }

        .breadcrumb span {
            color: rgba(255, 255, 255, .4)
        }

        .breadcrumb .current {
            color: var(--amber-light)
        }

        .page-title {
            font-family: 'Outfit', sans-serif;
            font-size: clamp(2.8rem, 6vw, 4.5rem);
            font-weight: 800;
            color: #fff;
            line-height: 1.1;
            letter-spacing: -1px;
            text-shadow: 0 2px 20px rgba(0, 0, 0, .3)
        }

        .page-title em {
            font-style: italic;
            color: var(--amber-light)
        }

        /* ABOUT INTRO */
        .about-intro {
            background: var(--warm-white)
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center
        }

        .about-imgs {
            position: relative;
            height: 540px
        }

        .about-img1 {
            position: absolute;
            top: 0;
            left: 0;
            width: 72%;
            height: 78%;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px var(--shadow)
        }

        .about-img1 img,
        .about-img2 img {
            width: 100%;
            height: 100%;
            object-fit: cover
        }

        .about-img2 {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 52%;
            height: 50%;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 16px 48px var(--shadow);
            border: 4px solid var(--warm-white)
        }

        .about-badge {
            position: absolute;
            top: 46%;
            left: 54%;
            transform: translate(-50%, -50%);
            background: linear-gradient(135deg, var(--coral), var(--rose));
            color: #fff;
            padding: 18px 24px;
            border-radius: 16px;
            text-align: center;
            box-shadow: 0 12px 40px rgba(217, 95, 59, .35);
            z-index: 3
        }

        .about-badge-num {
            font-family: 'Outfit', sans-serif;
            font-size: 2.4rem;
            font-weight: 800;
            line-height: 1
        }

        .about-badge-text {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 3px;
            opacity: .9
        }

        .about-points {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 24px 0
        }

        .about-point {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: 14px;
            font-weight: 500;
            color: var(--text)
        }

        .about-point i {
            color: var(--sage);
            margin-top: 3px;
            flex-shrink: 0
        }

        /* MISSION VISION */
        .mission-vision {
            position: relative;
            padding: 100px 0;
            overflow: hidden
        }

        .mv-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1497366811353-6870744d04b2?w=1600&q=80');
            background-size: cover;
            background-position: center;
            background-attachment: fixed
        }

        .mv-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(42, 20, 8, .88), rgba(90, 122, 92, .8))
        }

        .mv-inner {
            position: relative;
            z-index: 2
        }

        .mv-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 36px;
            margin-top: 56px
        }

        .mv-card {
            background: rgba(255, 248, 240, .06);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 248, 240, .15);
            border-radius: 24px;
            padding: 48px 40px;
            transition: all .4s
        }

        .mv-card:hover {
            background: rgba(255, 248, 240, .1);
            border-color: rgba(255, 248, 240, .25);
            transform: translateY(-8px);
            box-shadow: 0 24px 64px rgba(0, 0, 0, .3)
        }

        .mv-icon {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--coral), var(--amber));
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            box-shadow: 0 8px 28px rgba(217, 95, 59, .35)
        }

        .mv-icon i {
            font-size: 26px;
            color: #fff
        }

        .mv-card h3 {
            font-family: 'Outfit', sans-serif;
            font-size: 1.6rem;
            font-weight: 800;
            color: #fff;
            margin-bottom: 16px
        }

        .mv-card p {
            color: rgba(255, 255, 255, .75);
            line-height: 1.8;
            font-size: 15px
        }

        /* WHY CHOOSE */
        .why-choose {
            background: var(--section-alt)
        }

        .why-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            margin-top: 52px
        }

        .why-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 36px 28px;
            border: 1px solid var(--border);
            transition: all .4s;
            text-align: center;
            position: relative;
            overflow: hidden
        }

        .why-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--coral), var(--amber));
            transform: scaleX(0);
            transition: transform .4s
        }

        .why-card:hover::after {
            transform: scaleX(1)
        }

        .why-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 60px var(--shadow)
        }

        .why-icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(217, 95, 59, .1), rgba(200, 131, 26, .1));
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            border: 2px solid rgba(217, 95, 59, .15);
            transition: .4s
        }

        .why-card:hover .why-icon {
            background: linear-gradient(135deg, var(--coral), var(--amber));
            border-color: transparent
        }

        .why-icon i {
            font-size: 26px;
            color: var(--coral);
            transition: .4s
        }

        .why-card:hover .why-icon i {
            color: #fff
        }

        .why-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 12px
        }

        .why-text {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.7
        }

        /* STATS */
        .stats-bar {
            background: linear-gradient(135deg, var(--coral) 0%, var(--rose) 50%, var(--terra) 100%);
            padding: 64px 0
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0
        }

        .stat-item {
            text-align: center;
            padding: 10px 24px;
            border-right: 1px solid rgba(255, 255, 255, .2)
        }

        .stat-item:last-child {
            border-right: none
        }

        .stat-num {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 800;
            color: #fff;
            line-height: 1;
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 2px
        }

        .stat-num sup {
            font-size: 1.4rem;
            font-weight: 700
        }

        .stat-label {
            font-size: 13px;
            color: rgba(255, 255, 255, .8);
            margin-top: 6px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px
        }

        /* TEAM */
        .team-section {
            background: var(--warm-white)
        }

        .team-grid {
            display: grid;
            grid-template-columns: 5fr 7fr;
            gap: 72px;
            align-items: start
        }

        .team-cards {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 22px
        }

        .team-card {
            background: var(--card-bg);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--border);
            transition: all .4s;
            position: relative
        }

        .team-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 60px var(--shadow)
        }

        .team-img {
            height: 260px;
            overflow: hidden;
            position: relative
        }

        .team-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .6s
        }

        .team-card:hover .team-img img {
            transform: scale(1.06)
        }

        .team-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, transparent 40%, rgba(42, 20, 8, .8));
            display: flex;
            align-items: flex-end;
            justify-content: center;
            padding: 16px;
            gap: 8px;
            opacity: 0;
            transition: .4s
        }

        .team-card:hover .team-overlay {
            opacity: 1
        }

        .team-overlay a {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: rgba(255, 255, 255, .12);
            backdrop-filter: blur(8px);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            transition: .3s;
            text-decoration: none;
            border: 1px solid rgba(255, 255, 255, .2)
        }

        .team-overlay a:hover {
            background: var(--coral)
        }

        .team-info {
            padding: 18px 20px
        }

        .team-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 3px
        }

        .team-role {
            font-size: 12px;
            color: var(--coral);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .5px
        }

        /* PROCESS */
        .process-section {
            background: var(--section-alt)
        }

        .process-grid {
            display: grid;
            grid-template-columns: 5fr 7fr;
            gap: 72px;
            align-items: start
        }

        .process-steps {
            display: flex;
            flex-direction: column;
            gap: 0;
            margin-top: 8px
        }

        .process-step {
            display: flex;
            gap: 24px;
            padding: 28px 0;
            border-bottom: 1px solid var(--border);
            position: relative
        }

        .process-step:last-child {
            border-bottom: none
        }

        .process-step-left {
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0
        }

        .step-num {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--coral), var(--amber));
            color: #fff;
            font-family: 'Playfair Display', serif;
            font-weight: 800;
            font-size: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 4px 16px rgba(217, 95, 59, .3)
        }

        .step-line {
            width: 2px;
            flex: 1;
            background: linear-gradient(to bottom, rgba(217, 95, 59, .3), transparent);
            margin-top: 8px;
            min-height: 30px
        }

        .process-step:last-child .step-line {
            display: none
        }

        .step-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 8px
        }

        .step-text {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.7
        }

        /* TESTIMONIALS */
        .testi-section {
            background: var(--warm-white)
        }

        .testi-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-top: 52px
        }

        .testi-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 36px 30px;
            border: 1px solid var(--border);
            position: relative;
            transition: all .4s
        }

        .testi-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 60px var(--shadow)
        }

        .testi-quote {
            font-size: 2.8rem;
            font-family: 'Playfair Display', serif;
            color: var(--coral);
            opacity: .3;
            line-height: 1;
            margin-bottom: 14px
        }

        .testi-text {
            font-size: 15px;
            color: var(--text);
            line-height: 1.75;
            font-style: italic;
            margin-bottom: 24px
        }

        .testi-stars {
            display: flex;
            gap: 3px;
            color: var(--amber);
            margin-bottom: 16px
        }

        .testi-author {
            display: flex;
            align-items: center;
            gap: 12px;
            border-top: 1px solid var(--border);
            padding-top: 18px
        }

        .testi-author img {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--coral)
        }

        .testi-author-name {
            font-weight: 700;
            color: var(--ink);
            font-size: 15px
        }

        .testi-author-role {
            font-size: 12px;
            color: var(--text-muted)
        }

        /* NEWSLETTER */
        .newsletter {
            position: relative;
            padding: 90px 0;
            overflow: hidden
        }

        .nl-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=1600&q=80');
            background-size: cover;
            background-position: center
        }

        .nl-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(160, 82, 45, .92), rgba(90, 122, 92, .85))
        }

        .nl-inner {
            position: relative;
            z-index: 2;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 64px;
            align-items: center
        }

        .nl-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.2;
            margin-bottom: 12px
        }

        .nl-sub {
            font-size: 15px;
            color: rgba(255, 255, 255, .8);
            line-height: 1.65
        }

        .nl-form {
            display: flex;
            gap: 12px;
            flex-direction: column
        }

        .nl-input-wrap {
            display: flex;
            gap: 0;
            background: rgba(255, 255, 255, .12);
            border: 1px solid rgba(255, 255, 255, .25);
            border-radius: 12px;
            overflow: hidden;
            backdrop-filter: blur(8px)
        }

        .nl-input {
            flex: 1;
            padding: 15px 20px;
            background: transparent;
            border: none;
            outline: none;
            color: #fff;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif
        }

        .nl-input::placeholder {
            color: rgba(255, 255, 255, .6)
        }

        .nl-submit {
            padding: 15px 28px;
            background: var(--amber);
            color: #fff;
            font-weight: 700;
            font-size: 14px;
            border: none;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            transition: .3s
        }

        .nl-submit:hover {
            background: var(--amber-light)
        }

        .nl-note {
            font-size: 12px;
            color: rgba(255, 255, 255, .65)
        }

        /* FOOTER */
        .footer {
            background: var(--footer-bg);
            color: rgba(255, 248, 240, .75);
            padding: 80px 0 0
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.4fr 1fr 1fr;
            gap: 60px;
            padding-bottom: 60px
        }

        .footer-brand p {
            font-size: 14px;
            line-height: 1.75;
            margin: 18px 0 24px;
            color: rgba(255, 248, 240, .65)
        }

        .footer-contact-item {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 14px;
            font-size: 13px
        }

        .footer-contact-item i {
            color: var(--coral);
            margin-top: 2px;
            flex-shrink: 0
        }

        .footer-contact-item a {
            color: rgba(255, 248, 240, .75);
            text-decoration: none
        }

        .footer-contact-item a:hover {
            color: var(--amber-light)
        }

        .footer-col h4 {
            font-family: 'Playfair Display', serif;
            font-size: 1.05rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 22px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--coral);
            display: inline-block
        }

        .footer-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px
        }

        .footer-links a {
            font-size: 13.5px;
            color: rgba(255, 248, 240, .65);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: .3s
        }

        .footer-links a::before {
            content: '';
            width: 6px;
            height: 6px;
            background: var(--coral);
            border-radius: 50%;
            flex-shrink: 0;
            transition: .3s
        }

        .footer-links a:hover {
            color: var(--amber-light);
            padding-left: 4px
        }

        .footer-bottom {
            border-top: 1px solid rgba(255, 248, 240, .08);
            padding: 22px 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 14px
        }

        .footer-copy {
            font-size: 13px
        }

        .footer-copy a {
            color: var(--amber-light);
            text-decoration: none
        }

        .footer-social {
            display: flex;
            gap: 10px
        }

        .footer-social a {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: rgba(255, 248, 240, .07);
            color: rgba(255, 248, 240, .6);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            text-decoration: none;
            transition: .3s
        }

        .footer-social a:hover {
            background: var(--coral);
            color: #fff
        }

        .scroll-top {
            position: fixed;
            bottom: 28px;
            right: 28px;
            width: 46px;
            height: 46px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--coral), var(--rose));
            color: #fff;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            box-shadow: 0 6px 24px rgba(217, 95, 59, .4);
            opacity: 0;
            visibility: hidden;
            transform: translateY(20px);
            transition: .4s;
            z-index: 500
        }

        .scroll-top.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0)
        }

        .scroll-top:hover {
            transform: translateY(-3px)
        }

        .mobile-nav {
            position: fixed;
            inset: 0;
            background: var(--ink);
            z-index: 2000;
            display: flex;
            flex-direction: column;
            padding: 32px 28px;
            transform: translateX(100%);
            transition: transform .4s cubic-bezier(.4, 0, .2, 1)
        }

        .mobile-nav.open {
            transform: translateX(0)
        }

        .mobile-nav-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 40px
        }

        .mobile-close {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: rgba(255, 248, 240, .08);
            color: #fff;
            border: none;
            cursor: pointer;
            font-size: 20px;
            display: flex;
            align-items: center;
            justify-content: center
        }

        .mobile-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 6px
        }

        .mobile-links a {
            text-decoration: none;
            color: rgba(255, 248, 240, .85);
            font-size: 1.5rem;
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            padding: 10px 0;
            display: block;
            border-bottom: 1px solid rgba(255, 248, 240, .08);
            transition: .3s
        }

        .mobile-links a:hover {
            color: var(--coral)
        }

        .mobile-nav-bottom {
            margin-top: auto;
            display: flex;
            flex-direction: column;
            gap: 12px
        }

        @media(max-width:1024px) {

            .about-grid,
            .mv-grid,
            .nl-inner,
            .team-grid,
            .process-grid {
                grid-template-columns: 1fr
            }

            .why-grid,
            .testi-grid {
                grid-template-columns: repeat(2, 1fr)
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr)
            }

            .about-imgs {
                height: 420px
            }

            .team-cards {
                grid-template-columns: repeat(3, 1fr)
            }
        }

        @media(max-width:768px) {

            .nav-links,
            .nav-right .btn-outline,
            .nav-right .btn-fill {
                display: none
            }

            .hamburger {
                display: flex
            }

            .page-hero {
                padding: 120px 0 60px;
                text-align: center;
            }

            .page-hero h1 {
                font-size: 2rem;
            }

            .process-grid,
            .testi-grid,
            .pricing-grid,
            .blog-grid {
                grid-template-columns: 1fr
            }

            .footer-grid {
                grid-template-columns: 1fr;
                text-align: center;
            }

            .footer-links {
                align-items: center;
            }

            .features-grid,
            .team-grid {
                grid-template-columns: 1fr
            }

            .topbar .container {
                justify-content: center;
                text-align: center;
            }

            .topbar-msg {
                font-size: 11px;
            }

            .topbar-contact {
                display: none
            }

            .container {
                padding: 0 15px;
            }

            .logo {
                font-size: 1.6rem;
            }
        }

        @media(max-width:480px) {
            .page-hero h1 {
                font-size: 1.8rem;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
    <% if (typeof user !=='undefined' && user) { %>
        <style>
            @media(max-width:768px) {
                .nav-right .btn-fill {
                    display: inline-flex !important;
                    padding: 8px 16px;
                    font-size: 13px;
                }
            }
        </style>
        <% } %>
