<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete Your Profile | Conneto</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --coral: #D95F3B;
            --coral-light: #F07A56;
            --rose: #B5384A;
            --amber: #C8831A;
            --amber-light: #E8A030;
            --sage: #5A7A5C;
            --sage-light: #7A9E7C;
            --terra: #A0522D;
            --terra-light: #C4723F;
            --cream: #FAF3E8;
            --cream2: #F5EAD8;
            --warm-white: #FFF8F0;
            --ink: #2C1A0E;
            --ink2: #4A2E1A;
            --text: #3D2B1F;
            --text-muted: #7A5C4A;
            --border: rgba(160, 82, 45, 0.15);
            --shadow: rgba(44, 26, 14, 0.12);
            --card-bg: rgba(255, 248, 240, 0.95);
        }

        [data-theme="dark"] {
            --cream: #1C0F08;
            --cream2: #251508;
            --warm-white: #1A0D06;
            --ink: #FAF3E8;
            --ink2: #F0E0C8;
            --text: #E8D5BC;
            --text-muted: #B8937A;
            --border: rgba(200, 131, 26, 0.2);
            --shadow: rgba(0, 0, 0, 0.4);
            --card-bg: rgba(37, 21, 8, 0.95);
        }

        * { box-sizing: border-box; margin: 0; padding: 0 }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--cream);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .setup-box {
            width: 100%;
            max-width: 540px;
            padding: 40px;
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 24px;
            box-shadow: 0 10px 40px var(--shadow);
            position: relative;
            overflow: hidden;
        }

        .setup-box::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; height: 4px;
            background: linear-gradient(90deg, var(--coral), var(--amber), var(--rose));
        }

        .header { text-align: center; margin-bottom: 30px; }
        .header h1 { font-family: 'Outfit', sans-serif; font-size: 2rem; color: var(--ink); margin-bottom: 8px; }
        .header p { color: var(--text-muted); font-size: 15px; }

        .profile-summary {
            display: flex;
            align-items: center;
            gap: 15px;
            background: rgba(217, 95, 59, 0.05);
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 30px;
            border: 1px dashed var(--coral);
        }
        .profile-summary i { font-size: 24px; color: var(--coral); }
        .profile-info h4 { font-size: 14px; margin-bottom: 2px; }
        .profile-info p { font-size: 12px; color: var(--text-muted); }

        .role-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }

        .role-card {
            background: var(--warm-white);
            border: 2px solid var(--border);
            padding: 20px;
            border-radius: 18px;
            cursor: pointer;
            transition: .3s;
            text-align: center;
            position: relative;
        }
        .role-card:hover { border-color: var(--amber); transform: translateY(-3px); }
        .role-card i { font-size: 28px; margin-bottom: 12px; color: var(--text-muted); }
        .role-card h4 { font-size: 16px; margin-bottom: 4px; color: var(--ink); }
        .role-card p { font-size: 11px; color: var(--text-muted); }

        .role-card.selected {
            border-color: var(--coral);
            background: rgba(217, 95, 59, 0.05);
        }
        .role-card.selected i { color: var(--coral); }
        .role-card input { display: none; }

        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; font-size: 11px; font-weight: 700; color: var(--ink); margin-bottom: 6px; text-transform: uppercase; }
        .form-input {
            width: 100%;
            padding: 12px 16px;
            background: var(--warm-white);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            font-family: inherit;
            font-size: 14px;
            color: var(--ink);
            transition: .3s;
            outline: none;
        }
        .form-input:focus { border-color: var(--coral); }
        .form-input::placeholder { color: var(--text-muted); opacity: 0.5; }

        .btn-finish {
            width: 100%; padding: 16px;
            background: linear-gradient(135deg, var(--coral), var(--rose));
            color: #fff; border: none; border-radius: 12px;
            font-family: inherit; font-size: 16px; font-weight: 800;
            cursor: pointer; transition: .3s;
            margin-top: 10px;
        }
        .btn-finish:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(217, 95, 59, 0.3); }

        .error-box {
            padding: 12px; background: rgba(181, 56, 74, 0.1);
            color: var(--rose); border: 1px solid var(--rose);
            border-radius: 8px; margin-bottom: 20px; font-size: 13px;
        }

        #companyFields { animation: slideDown 0.4s ease-out; }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

        .doc-section {
            background: rgba(44, 26, 14, 0.03);
            padding: 15px;
            border-radius: 12px;
            margin-top: 15px;
            border: 1px solid var(--border);
        }
    </style>
</head>

<body>
    <div class="setup-box">
        <div class="header">
            <h1>Almost There!</h1>
            <p>One last step to set up your Conneto account.</p>
        </div>

        <div class="profile-summary">
            <i class="fab fa-google"></i>
            <div class="profile-info">
                <h4>Linked Account</h4>
                <p><%= profile.emails[0].value %></p>
            </div>
        </div>

        <% if (error) { %>
            <div class="error-box"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
        <% } %>

        <form action="/auth/google/complete" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label>Tell us who you're as</label>
                <div class="role-grid">
                    <label class="role-card selected" id="roleS">
                        <input type="radio" name="role" value="student" checked>
                        <i class="fas fa-graduation-cap"></i>
                        <h4>Candidate</h4>
                        <p>I'm looking for internship opportunities.</p>
                    </label>
                    <label class="role-card" id="roleC">
                        <input type="radio" name="role" value="company">
                        <i class="fas fa-university"></i>
                        <h4>Company</h4>
                        <p>I want to hire great student talent.</p>
                    </label>
                </div>
            </div>

            <div id="companyFields" style="display: none;">
                <div class="form-group">
                    <label>Official Company Name</label>
                    <input type="text" name="companyName" class="form-input" placeholder="e.g. Acme Innovations">
                </div>
                <div class="form-group">
                    <label>Company Type</label>
                    <select name="companyType" id="companyType" class="form-input">
                        <option value="">Select Company Type</option>
                        <option value="Private Limited">Private Limited</option>
                        <option value="Public Limited">Public Limited</option>
                        <option value="Proprietorship">Proprietorship</option>
                        <option value="Partnership">Partnership</option>
                        <option value="Branch Office">Branch Office</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                
                <div id="docUploads" class="doc-section" style="display: none; margin-bottom:18px">
                    <!-- Dynamic fields will be added here via JS -->
                </div>

                <div class="form-group">
                    <label>CIN/Registration Number</label>
                    <input type="text" name="cin" class="form-input" placeholder="21-digit CIN">
                </div>
                <div class="form-group">
                    <label>Primary Phone Number</label>
                    <input type="tel" name="phone" class="form-input" placeholder="e.g. 9876543210">
                </div>
                <div class="form-group">
                    <label>Headquarters Address</label>
                    <textarea name="companyAddress" class="form-input" placeholder="Full registered address" style="min-height: 80px;"></textarea>
                </div>
            </div>

            <button type="submit" class="btn-finish">Complete Setup <i class="fas fa-arrow-right" style="margin-left:8px"></i></button>
        </form>
    </div>

    <script>
        const roleS = document.getElementById('roleS');
        const roleC = document.getElementById('roleC');
        const companyFields = document.getElementById('companyFields');
        const companyTypeSelect = document.getElementById('companyType');
        const docUploads = document.getElementById('docUploads');
        const mainInputs = companyFields.querySelectorAll('input:not([type="file"]), select, textarea');

        function updateUI(role) {
            if (role === 'company') {
                roleC.classList.add('selected');
                roleS.classList.remove('selected');
                companyFields.style.display = 'block';
                mainInputs.forEach(i => i.required = true);
            } else {
                roleS.classList.add('selected');
                roleC.classList.remove('selected');
                companyFields.style.display = 'none';
                mainInputs.forEach(i => i.required = false);
            }
        }

        companyTypeSelect.addEventListener('change', (e) => {
            const type = e.target.value;
            docUploads.innerHTML = '';
            
            if (!type) {
                docUploads.style.display = 'none';
                return;
            }

            docUploads.style.display = 'block';
            if (type === 'Private Limited' || type === 'Public Limited') {
                docUploads.innerHTML = `
                    <div class="form-group">
                        <label>Upload PAN Card Copy</label>
                        <input type="file" name="pan_card" class="form-input" required accept=".pdf,image/*">
                    </div>
                    <div class="form-group">
                        <label>Certificate of Incorporation</label>
                        <input type="file" name="incorporation_cert" class="form-input" required accept=".pdf,image/*">
                    </div>
                `;
            } else if (type === 'Branch Office') {
                docUploads.innerHTML = `
                    <div class="form-group">
                        <label>Branch Authorization Document</label>
                        <input type="file" name="branch_auth" class="form-input" required accept=".pdf,image/*">
                    </div>
                `;
            } else {
                docUploads.innerHTML = `
                    <div class="form-group">
                        <label>Supporting Identity Document</label>
                        <input type="file" name="identity_doc" class="form-input" required accept=".pdf,image/*">
                    </div>
                `;
            }
        });

        roleS.addEventListener('click', () => updateUI('student'));
        roleC.addEventListener('click', () => updateUI('company'));
    </script>
</body>
</html>
