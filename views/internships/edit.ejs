<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/dashboard/company_head', { title: 'Edit Internship | Conneto' }) %>
        <style>
            .form-card {
                background: var(--card-bg);
                border: 1px solid var(--card-border);
                border-radius: 24px;
                padding: 40px;
                max-width: 900px;
                margin: 0 auto;
            }

            .form-header {
                margin-bottom: 32px;
                border-bottom: 1px solid var(--card-border);
                padding-bottom: 20px;
            }

            .form-header h2 {
                font-size: 1.75rem;
                font-weight: 700;
                color: white;
                font-family: 'Clash Display', sans-serif;
            }

            .form-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 24px;
            }

            .form-group {
                margin-bottom: 20px;
            }

            .form-group.full {
                grid-column: span 2;
            }

            .label {
                display: block;
                margin-bottom: 10px;
                font-weight: 600;
                color: #E2E8F0;
                font-size: 0.95rem;
            }

            .inp,
            .sel,
            .txt {
                width: 100%;
                padding: 14px 16px;
                background: var(--bg);
                border: 1px solid var(--card-border);
                border-radius: 12px;
                color: white;
                font-family: inherit;
                font-size: 1rem;
                transition: all 0.3s;
            }

            .inp:focus,
            .sel:focus,
            .txt:focus {
                border-color: var(--primary);
                outline: none;
            }

            .txt {
                min-height: 120px;
                resize: vertical;
            }

            .btn-save {
                width: 100%;
                padding: 16px;
                background: var(--gradient-primary);
                color: white;
                border: none;
                border-radius: 14px;
                font-size: 1.1rem;
                font-weight: 700;
                cursor: pointer;
                transition: all 0.3s;
                margin-top: 20px;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
            }

            .toggle-row {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-top: 24px;
                padding: 20px;
                background: rgba(255, 255, 255, 0.02);
                border-radius: 16px;
                border: 1px solid var(--card-border);
            }

            /* Switch */
            .switch {
                position: relative;
                display: inline-block;
                width: 50px;
                height: 26px;
            }

            .switch input {
                opacity: 0;
                width: 0;
                height: 0;
            }

            .slider {
                position: absolute;
                cursor: pointer;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background-color: #333;
                transition: .4s;
                border-radius: 34px;
            }

            .slider:before {
                position: absolute;
                content: "";
                height: 18px;
                width: 18px;
                left: 4px;
                bottom: 4px;
                background-color: white;
                transition: .4s;
                border-radius: 50%;
            }

            input:checked+.slider {
                background-color: var(--primary);
            }

            input:checked+.slider:before {
                transform: translateX(24px);
            }
        </style>
</head>

<body>
    <%- include('../partials/dashboard/company_sidebar', { activePage: 'internships' }) %>

        <div class="page-header">
            <h1 class="page-title">Edit Opening</h1>
            <p class="page-subtitle">Update the details of your internship posting</p>
        </div>

        <div class="form-card">
            <div class="form-header">
                <h2>Internship Information</h2>
            </div>

            <form action="/company/internships/<%= internship._id %>" method="POST">
                <div class="form-grid">
                    <div class="form-group full">
                        <label class="label">Internship Title</label>
                        <input type="text" name="title" class="inp" value="<%= internship.title %>" required>
                    </div>

                    <div class="form-group">
                        <label class="label">Location</label>
                        <input type="text" name="location" class="inp" value="<%= internship.location %>">
                    </div>

                    <div class="form-group">
                        <label class="label">Work Type</label>
                        <select name="type" class="sel">
                            <option value="remote" <%=internship.type==='remote' ? 'selected' : '' %>>Remote</option>
                            <option value="on-site" <%=internship.type==='on-site' ? 'selected' : '' %>>On-site</option>
                            <option value="hybrid" <%=internship.type==='hybrid' ? 'selected' : '' %>>Hybrid</option>
                        </select>
                    </div>

                    <div class="form-group full">
                        <label class="label">Description</label>
                        <textarea name="description" class="txt" required><%= internship.description %></textarea>
                    </div>

                    <div class="form-group">
                        <label class="label">Duration</label>
                        <input type="text" name="duration" class="inp" value="<%= internship.duration %>">
                    </div>

                    <div class="form-group">
                        <label class="label">Stipend (INR/Month)</label>
                        <input type="number" name="stipend" class="inp" value="<%= internship.stipend %>">
                    </div>

                    <div class="form-group">
                        <label class="label">Openings</label>
                        <input type="number" name="openings" class="inp" value="<%= internship.openings %>" min="1">
                    </div>

                    <div class="form-group">
                        <label class="label">Deadline</label>
                        <input type="date" name="deadline" class="inp"
                            value="<%= internship.deadline ? internship.deadline.toISOString().split('T')[0] : '' %>">
                    </div>

                    <div class="form-group full">
                        <label class="label">Skills (Comma separated)</label>
                        <input type="text" name="skills" class="inp"
                            value="<%= internship.skills ? internship.skills.join(', ') : '' %>">
                    </div>
                </div>

                <div class="toggle-row">
                    <label class="switch">
                        <input type="checkbox" name="isActive" <%=internship.isActive ? 'checked' : '' %>>
                        <span class="slider"></span>
                    </label>
                    <div>
                        <div style="color: white; font-weight: 600;">Active Status</div>
                        <div style="font-size: 0.85rem; color: var(--text-muted);">Toggle visibility of this posting
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-save">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </form>
        </div>

        <!-- Closed by partial: </main> </div> -->
        </main>
        </div>
</body>

</html>