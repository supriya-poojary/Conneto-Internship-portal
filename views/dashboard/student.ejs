                                padding-bottom: 10px;
                            }

                            .app-table-container td {
                                border: none !important;
                                border-bottom: 1px solid rgba(0,0,0,0.03) !important;
                                position: relative;
                                padding: 15px 20px !important;
                            }
                            
                            .app-table-container td:last-child {
                                border-bottom: none !important;
                            }
                            
                            .app-table-container td:before {
                                display: block;
                                margin-bottom: 10px;
                                font-weight: 800;
                                color: var(--text-muted);
                                text-transform: uppercase;
                                font-size: 11px;
                                letter-spacing: 0.5px;
                            }

                            /* Provide mobile labels */
                            .app-table-container td:nth-of-type(1):before { content: "Role & Company"; }
                            .app-table-container td:nth-of-type(2):before { content: "Applied Date"; }
                            .app-table-container td:nth-of-type(3):before { content: "Application Progress"; }
                            .app-table-container td:nth-of-type(4):before { content: "Actions"; }
                        }
                        </style>
                        <div class="app-table-container" style="overflow-x:auto; background:var(--card-bg); border-radius:15px; border:1px solid var(--border); box-shadow: 0 4px 20px rgba(0,0,0,0.03);">
                            <table style="width:100%; border-collapse:collapse; text-align:left; min-width:800px;">
                                <thead>
                                    <tr style="background:rgba(0,0,0,0.02); border-bottom:1px solid var(--border); font-size:12px; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px;">
                                        <th style="padding:15px 20px; font-weight:700;">Role & Company</th>
                                        <th style="padding:15px 20px; font-weight:700;">Applied Date</th>
                                        <th style="padding:15px 20px; font-weight:700;">Application Progress</th>
                                        <th style="padding:15px 20px; font-weight:700;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% applications.forEach(function(app) { %>
                                        <% 
                                        var cName = app.internship ? ((app.internship.company && app.internship.company.companyName) ? app.internship.company.companyName : (app.internship.companyName || '')) : ''; 
                                        
                                        let statusColor = "var(--text-muted)";
                                        let statusBg = "rgba(0,0,0,0.05)";
                                        let statusIcon = "fas fa-paper-plane";
                                        let statusText = "Applied";
                                        let progressPercent = 25;
                                        let progressLabel = "1 / 4";

                                        if (app.status === 'under_review') {
                                            statusColor = "var(--coral)"; statusBg = "rgba(217,95,59,0.1)"; statusIcon = "fas fa-search"; statusText = "Under Review"; progressPercent = 50; progressLabel = "2 / 4";
                                        } else if (app.status === 'shortlisted') {
                                            statusColor = "var(--amber)"; statusBg = "rgba(245,158,11,0.1)"; statusIcon = "fas fa-star"; statusText = "Shortlisted"; progressPercent = 50; progressLabel = "2 / 4";
                                        } else if (app.status === 'interview_scheduled') {
                                            statusColor = "var(--amber)"; statusBg = "rgba(245,158,11,0.1)"; statusIcon = "fas fa-calendar-alt"; statusText = "Interview Scheduled"; progressPercent = 75; progressLabel = "3 / 4";
                                        } else if (app.status === 'selected') {
                                            statusColor = "var(--sage)"; statusBg = "rgba(90,122,92,0.1)"; statusIcon = "fas fa-check-circle"; statusText = "Selected & Ready to Write Diary"; progressPercent = 100; progressLabel = "4 / 4";
                                        } else if (app.status === 'rejected') {
                                            statusColor = "var(--rose)"; statusBg = "rgba(181,56,74,0.1)"; statusIcon = "fas fa-times-circle"; statusText = "Rejected"; progressPercent = 100; progressLabel = "0 / 4";
                                        }
                                        %>
                                        <tr style="border-bottom:1px solid var(--border); transition:0.3s;" onmouseover="this.style.background='rgba(0,0,0,0.02)'" onmouseout="this.style.background='transparent'">
                                            <td style="padding:20px; vertical-align:middle;">
                                                <div style="display:flex; align-items:center; gap:15px;">
                                                    <div style="width:45px; height:45px; flex-shrink:0; border-radius:12px; background:linear-gradient(135deg, var(--coral), #ff8a65); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:20px; box-shadow:0 4px 10px rgba(217,95,59,0.2);">
                                                        <%= cName ? cName.charAt(0).toUpperCase() : 'C' %>
                                                    </div>
                                                    <div>
                                                        <div style="font-weight:800; color:var(--ink); font-size:15px; margin-bottom:4px;"><%= app.internship ? app.internship.title : 'Internship' %></div>
                                                        <div style="color:var(--text-muted); font-size:13px; font-weight:600;"><i class="fas fa-building" style="margin-right:6px;"></i><%= cName || 'Company' %></div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td style="padding:20px; vertical-align:middle; color:var(--ink); font-size:14px; font-weight:600;">
                                                <div style="display:flex; align-items:center; gap:8px;">
                                                    <div style="width:30px; height:30px; border-radius:8px; background:rgba(0,0,0,0.03); display:flex; align-items:center; justify-content:center; color:var(--text-muted)">
                                                        <i class="far fa-calendar-alt"></i>
                                                    </div>
                                                    <%= new Date(app.appliedAt).toLocaleDateString('en-US', { day:'numeric', month:'short', year:'numeric' }) %>
                                                </div>
                                            </td>
                                            <td style="padding:20px; vertical-align:middle;">
                                                <div style="display:flex; flex-direction:column; gap:10px; min-width:200px; max-width:260px;">
                                                    <div style="display:flex; justify-content:space-between; align-items:center; font-size:12px;">
                                                        <span style="font-weight:800; color:<%= statusColor %>; background:<%= statusBg %>; padding:6px 14px; border-radius:100px;">
                                                            <i class="<%= statusIcon %>" style="margin-right:6px;"></i><%= statusText %>
                                                        </span>
                                                        <span style="font-weight:800; color:<%= statusColor %>;"><%= progressLabel %></span>
                                                    </div>
                                                    <div style="width:100%; height:8px; background:rgba(0,0,0,0.05); border-radius:10px; overflow:hidden;">
                                                        <div style="width:<%= progressPercent %>%; height:100%; background:<%= statusColor %>; border-radius:10px; transition:width 1.5s cubic-bezier(0.1,0,0,1);"></div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td style="padding:20px; vertical-align:middle;">
                                                <div style="display:flex; flex-direction:column; gap:8px; align-items:flex-start;">
                                                    <% if (app.status === 'interview_scheduled') { %>
                                                        <div style="font-size:12px; font-weight:700; color:var(--ink); background:rgba(245,158,11,0.05); padding:8px 12px; border-radius:8px; border:1px dashed var(--amber);">
                                                            <i class="fas fa-clock" style="color:var(--amber); margin-right:6px;"></i> <%= new Date(app.interviewDate).toLocaleString('en-IN', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                                                        </div>
                                                        <% if (!app.rescheduleRequest) { %>
                                                            <div class="reschedule-wrapper" style="position:relative;">
                                                                <button onclick="this.nextElementSibling.style.display='block'; this.style.display='none'" class="view-btn reschedule-trigger" style="background:none; color:var(--amber); border:1px solid var(--amber); padding:8px 14px; font-size:12px; border-radius:8px; font-weight:700; transition:0.3s; cursor:pointer;" onmouseover="this.style.background='var(--amber)'; this.style.color='#fff'" onmouseout="this.style.background='none'; this.style.color='var(--amber)'">Request Reschedule</button>
                                                                <div class="reschedule-popup" style="display:none; position:absolute; right:0; top:100%; background:var(--card-bg); padding:18px; border-radius:14px; border:1px solid var(--border); box-shadow:0 15px 50px rgba(0,0,0,0.15); z-index:1000; width:280px; margin-top:10px;">
                                                                    <form action="/student/applications/<%= app._id %>/reschedule" method="POST">
                                                                        <label style="font-size:12px; font-weight:800; color:var(--ink); display:block; margin-bottom:8px;">Suggest New Time:</label>
                                                                        <input type="datetime-local" name="suggestedDate" required style="width:100%; border:1px solid var(--border); border-radius:10px; padding:10px; font-size:13px; margin-bottom:12px; background:var(--bg); color:var(--text); outline:none; transition:0.3s;" onfocus="this.style.borderColor='var(--amber)'" onblur="this.style.borderColor='var(--border)'">
                                                                        <textarea name="reason" placeholder="Reason for rescheduling..." required style="width:100%; border:1px solid var(--border); border-radius:10px; padding:10px; font-size:13px; min-height:80px; margin-bottom:12px; background:var(--bg); color:var(--text); font-family:inherit; outline:none; transition:0.3s; resize:vertical;" onfocus="this.style.borderColor='var(--amber)'" onblur="this.style.borderColor='var(--border)'"></textarea>
                                                                        <div style="display:flex; gap:10px;">
                                                                            <button type="submit" style="background:var(--amber); color:#fff; border:none; border-radius:10px; padding:10px; font-size:12px; font-weight:800; flex:1; cursor:pointer; transition:0.3s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">Send Request</button>
                                                                            <button type="button" onclick="const w = this.closest('.reschedule-wrapper'); w.querySelector('.reschedule-popup').style.display='none'; w.querySelector('.reschedule-trigger').style.display='inline-flex';" style="background:var(--bg); border:1px solid var(--border); color:var(--text); border-radius:10px; padding:10px 14px; font-size:12px; font-weight:800; cursor:pointer; transition:0.3s;" onmouseover="this.style.background='var(--border)'" onmouseout="this.style.background='var(--bg)'">Cancel</button>
                                                                        </div>
                                                                    </form>
                                                                </div>
                                                            </div>
                                                        <% } else { %>
                                                            <span style="font-size:12px; color:var(--amber); background:rgba(245,158,11,0.1); padding:8px 12px; border-radius:8px; font-weight:800;"><i class="fas fa-history" style="margin-right:6px;"></i> Reschedule Pending</span>
                                                        <% } %>
                                                    <% } else if (app.status === 'selected') { %>
                                                        <% if (app.certificateReleased) { %>
                                                            <a href="<%= app.certificateUrl %>" download class="view-btn" style="background:var(--sage); color:#fff; border:none; padding:10px 18px; font-size:13px; border-radius:100px; box-shadow:0 6px 20px rgba(90,122,92,0.3); font-weight:700; transition:0.3s;" onmouseover="this.style.transform='translateY(-2px)';" onmouseout="this.style.transform='translateY(0)';"><i class="fas fa-download" style="margin-right:8px;"></i> Download Certificate</a>
                                                        <% } else { %>
                                                            <a href="/student/dashboard?tab=diary_history&viewInternshipId=<%= app.internship._id %>" class="view-btn" style="background:rgba(90,122,92,0.1); border:1px solid var(--sage); color:var(--sage); padding:10px 18px; font-size:13px; border-radius:100px; font-weight:700; transition:0.3s;" onmouseover="this.style.background='var(--sage)'; this.style.color='#fff';" onmouseout="this.style.background='rgba(90,122,92,0.1)'; this.style.color='var(--sage)';"><i class="fas fa-chart-line" style="margin-right:8px;"></i> View Progress</a>
                                                        <% } %>
                                                    <% } else if (['applied', 'under_review', 'shortlisted'].includes(app.status)) { %>
                                                        <form action="/student/applications/<%= app._id %>/withdraw" method="POST" onsubmit="return confirm('Are you sure you want to withdraw this application?')">
                                                            <button type="submit" class="view-btn" style="background:rgba(181,56,74,0.1); color:var(--rose); border:none; padding:8px 14px; font-size:12px; border-radius:8px; font-weight:700; transition:0.3s; cursor:pointer;" onmouseover="this.style.background='var(--rose)'; this.style.color='#fff';" onmouseout="this.style.background='rgba(181,56,74,0.1)'; this.style.color='var(--rose)';"><i class="fas fa-times" style="margin-right:6px;"></i> Withdraw</button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } else { %>
                            <div style="text-align:center; padding:60px 20px">
                                <i class="fas fa-file-alt"
                                    style="font-size:3rem; color:var(--border); margin-bottom:20px"></i>
                                <h2>No applications yet</h2>
                                <p style="color:var(--text-muted); margin-bottom:30px">Start applying to see them here.
                                </p>
                                <a href="/internships" class="view-btn"
                                    style="background:var(--coral); color:#fff; padding:12px 24px">Explore
                                    Internships</a>
                            </div>
                            <% } %>
                </div>
                <% } else if (activePage==='profile' ) { %>
                    <div id="successBanner"
                        style="display:none; background:var(--sage); color:#fff; padding:15px 25px; border-radius:15px; margin-bottom:25px; align-items:center; gap:15px; animation: slideIn 0.4s ease-out">
                        <i class="fas fa-check-circle" style="font-size:1.2rem"></i>
                        <div style="font-weight:600">Portfolio Updated Successfully! All changes are now live.</div>
                    </div>
                    <script>
                        (function () {
                            const params = new URLSearchParams(window.location.search);
                            if (params.get('success') !== null && params.get('success') !== '') {
                                const banner = document.getElementById('successBanner');
                                if (banner) {
                                    banner.style.display = 'flex';
                                    // Remove ?success=true from URL without reload
                                    const url = new URL(window.location.href);
                                    url.searchParams.delete('success');
                                    window.history.replaceState({}, '', url.toString());
                                    // Auto-hide after 4s
                                    setTimeout(() => { banner.style.opacity = '0'; banner.style.transition = 'opacity 0.5s'; setTimeout(() => banner.style.display = 'none', 500); }, 4000);
                                }
                            }
                        })();
                    </script>
                    <header class="header">
                        <div class="header-left">
                            <h1>My <span>Portfolio</span></h1>
                            <p class="header-subtitle">Increase your visibility by completing your profile details.</p>
                            <div style="display:flex; align-items:center; gap:15px; margin-top:10px">
                                <div
                                    style="flex:1; max-width:200px; height:6px; background:var(--border); border-radius:10px; overflow:hidden">
                                    <div
                                        style="width:<%= profile.completionPercentage || 0 %>%; height:100%; background:var(--coral); transition:.5s">
                                    </div>
                                </div>
                                <span style="font-size:12px; font-weight:800; color:var(--coral)">
                                    <%= profile.completionPercentage || 0 %>% Complete
                                </span>
                            </div>
                        </div>
                    </header>

                    <div style="margin-top:20px">
                        <div class="card reveal" style="padding: 40px; border-radius: 30px;">
                            <form id="profileForm" action="/student/profile/update" method="POST"
                                enctype="multipart/form-data">
                                <div
                                    style="display:flex; align-items:center; gap:30px; margin-bottom:40px; padding-bottom:30px; border-bottom:1px solid var(--border)">
                                    <div class="profile-avatar"
                                        style="width:120px; height:120px; font-size:3rem; flex-shrink:0">
                                        <%= user.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <div style="flex:1">
                                        <h2
                                            style="font-size:2rem; margin-bottom:5px; font-family:'Playfair Display', serif">
                                            <%= user.name %>
                                        </h2>
                                        <p style="color:var(--text-muted); font-weight:600; font-size:1.1rem">
                                            <%= user.email %>
                                        </p>
                                        <% if (profile && profile.resumeUrl) { %>
                                            <div style="margin-top:15px">
                                                <a href="/view-resume?url=<%= encodeURIComponent(profile.resumeUrl) %>" target="_blank"
                                                    style="display:inline-flex; align-items:center; gap:8px; background:rgba(90,122,92,0.1); color:var(--sage); padding:8px 16px; border-radius:10px; text-decoration:none; font-size:13px; font-weight:700">
                                                    <i class="fas fa-file-pdf"></i> View Current Resume
                                                </a>
                                            </div>
                                            <% } %>
                                                <div class="skill-tags" style="margin-top:10px">
                                                    <% if (profile && profile.skills && profile.skills.length> 0) { %>
                                                        <% profile.skills.forEach(s=> { %>
                                                            <span class="skill-tag"
                                                                style="padding: 6px 15px; font-size: 13px;">
                                                                <%= s %>
                                                            </span>
                                                            <% }) %>
                                                                <% } %>
                                                </div>
                                    </div>
                                </div>

                                <h4 class="portfolio-section-title" style="margin-top:0"><i
                                        class="fas fa-user-circle"></i> Identity & Contact</h4>
                                <div class="portfolio-grid"
                                    style="grid-template-columns: 1fr 1fr 1fr; gap: 30px; margin-bottom: 30px;">
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Full Name *</label>
                                        <input type="text" name="name" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px;" value="<%= user.name %>"
                                            required>
                                    </div>
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Email Address *</label>
                                        <input type="email" name="email" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px;" value="<%= user.email %>"
                                            required>
                                    </div>
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Current Status *</label>
                                        <select name="memberStatus" id="memberStatus" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px; height: auto;" required>
                                            <option value="Student" <%=(profile.memberStatus==='Student' ||
                                                !profile.memberStatus) ? 'selected' : '' %>>Student (Learning Engineer)
                                            </option>
                                            <option value="Graduate" <%=profile.memberStatus==='Graduate' ? 'selected'
                                                : '' %>>Graduate (Completed Degree)</option>
                                            <option value="Professional" <%=profile.memberStatus==='Professional'
                                                ? 'selected' : '' %>>Working Professional</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr 1fr; gap: 30px;">
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Date of Birth *</label>
                                        <input type="date" name="dob" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px;"
                                            value="<%= profile.dob ? new Date(profile.dob).toISOString().split('T')[0] : '' %>"
                                            required>
                                    </div>
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Gender *</label>
                                        <select name="gender" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px; height: auto;" required>
                                            <option value="">Select Gender</option>
                                            <option value="Male" <%=profile.gender==='Male' ? 'selected' : '' %>
                                                >Male</option>
                                            <option value="Female" <%=profile.gender==='Female' ? 'selected' : '' %>
                                                >Female</option>
                                            <option value="Other" <%=profile.gender==='Other' ? 'selected' : '' %>>Other
                                            </option>
                                        </select>
                                    </div>
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Phone Number *</label>
                                        <input type="text" name="phone" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px;"
                                            value="<%= profile.phone || '' %>" placeholder="+91 99000 00000" required>
                                    </div>
                                </div>

                                <div id="academicAndBasics">
                                    <h4 class="portfolio-section-title"><i class="fas fa-id-card"></i> Candidate
                                        Background (Common)</h4>
                                    <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                                        <div class="portfolio-group">
                                            <label class="portfolio-label">Highest Qualification / Degree *</label>
                                            <select name="degree" class="portfolio-input"
                                                style="padding: 15px 20px; font-size: 16px; height: auto;" required>
                                                <option value="">Select Degree</option>
                                                <option value="B.E / B.Tech" <%=profile.degree==='B.E / B.Tech'
                                                    ? 'selected' : '' %>>B.E / B.Tech</option>
                                                <option value="M.E / M.Tech" <%=profile.degree==='M.E / M.Tech'
                                                    ? 'selected' : '' %>>M.E / M.Tech</option>
                                                <option value="BCA" <%=profile.degree==='BCA' ? 'selected' : '' %>>BCA
                                                </option>
                                                <option value="MCA" <%=profile.degree==='MCA' ? 'selected' : '' %>>MCA
                                                </option>
                                                <option value="B.Sc" <%=profile.degree==='B.Sc' ? 'selected' : '' %>
                                                    >B.Sc</option>
                                                <option value="M.Sc" <%=profile.degree==='M.Sc' ? 'selected' : '' %>
                                                    >M.Sc</option>
                                                <option value="Diploma" <%=profile.degree==='Diploma' ? 'selected' : ''
                                                    %>>Diploma</option>
                                                <option value="MBA" <%=profile.degree==='MBA' ? 'selected' : '' %>>MBA
                                                </option>
                                                <option value="Other" <%=profile.degree==='Other' ? 'selected' : '' %>
                                                    >Other</option>
                                            </select>
                                        </div>
                                        <div class="portfolio-group">
                                            <label class="portfolio-label">Field / Department *</label>
                                            <input type="text" name="department" class="portfolio-input"
                                                style="padding: 15px 20px; font-size: 16px;"
                                                value="<%= profile.department || '' %>"
                                                placeholder="e.g. Computer Science or Marketing" required>
                                        </div>
                                    </div>

                                    <div id="studentOnlyFields"
                                        style="<%= (profile.memberStatus === 'Student' || !profile.memberStatus) ? '' : 'display:none' %>">
                                        <h4 class="portfolio-section-title"><i class="fas fa-university"></i> Academic
                                            Records (Students Only)</h4>
                                        <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Identification (USN / ID) *</label>
                                                <input type="text" name="usn" class="portfolio-input student-req"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.usn || '' %>" placeholder="Student ID Number"
                                                    <%=(profile.memberStatus==='Student' || !profile.memberStatus)
                                                    ? 'required' : '' %>>
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">University / College *</label>
                                                <input type="text" name="college" class="portfolio-input student-req"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.college || '' %>"
                                                    placeholder="Current Institution"
                                                    <%=(profile.memberStatus==='Student' || !profile.memberStatus)
                                                    ? 'required' : '' %>>
                                            </div>
                                        </div>
                                        <div class="portfolio-grid"
                                            style="grid-template-columns: 1fr 1fr 1fr; gap:30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Current Semester *</label>
                                                <select name="semester" class="portfolio-input student-req"
                                                    style="padding: 15px 20px; font-size: 16px; height: auto;"
                                                    <%=(profile.memberStatus==='Student' || !profile.memberStatus)
                                                    ? 'required' : '' %>>
                                                    <option value="">Select Semester</option>
                                                    <% [1,2,3,4,5,6,7,8].forEach(s=> { %>
                                                        <option value="<%= s %>" <%=(profile.semester==s) ? 'selected'
                                                            : '' %>><%= s %>
                                                                <%= s===1 ? 'st' : s===2 ? 'nd' : s===3 ? 'rd' : 'th' %>
                                                                    Semester</option>
                                                        <% }) %>
                                                </select>
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Graduation Year *</label>
                                                <select name="year" class="portfolio-input student-req"
                                                    style="padding: 15px 20px; font-size: 16px; height: auto;"
                                                    <%=(profile.memberStatus==='Student' || !profile.memberStatus)
                                                    ? 'required' : '' %>>
                                                    <option value="">Select Year</option>
                                                    <% const currentYear=new Date().getFullYear(); for(let y=currentYear
                                                        - 1; y <=currentYear + 6; y++) { %>
                                                        <option value="<%= y %>" <%=(profile.year==y) ? 'selected' : ''
                                                            %>><%= y %>
                                                        </option>
                                                        <% } %>
                                                </select>
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Current GPA / CGPA *</label>
