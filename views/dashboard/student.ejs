                                                        style="min-height:80px"></textarea>
                                                </div>
                                            </div>

                                            <h4 class="portfolio-section-title"
                                                style="font-size:1.1rem; margin-top:10px;"><i class="fas fa-code"></i>
                                                Skills</h4>
