<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,800;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <script>
    (function () {
      const t = localStorage.getItem('conneto-theme') || 'light';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
  <style>
    :root {
      --coral: #D95F3B;
      --coral-light: #F07A56;
      --rose: #B5384A;
      --amber: #C8831A;
      --amber-light: #E8A030;
      --sage: #5A7A5C;
      --sage-light: #7A9E7C;
      --terra: #A0522D;
      --terra-light: #C4723F;
      --cream: #FAF3E8;
      --cream2: #F5EAD8;
      --warm-white: #FFF8F0;
      --ink: #2C1A0E;
      --ink2: #4A2E1A;
      --text: #3D2B1F;
      --text-muted: #7A5C4A;
      --border: rgba(160, 82, 45, 0.15);
      --shadow: rgba(44, 26, 14, 0.12);
      --card-bg: rgba(255, 248, 240, 0.95);
      --nav-bg: rgba(250, 243, 232, 0.97);
      --section-alt: #F5EAD8;
      --footer-bg: #1E0E05;
    }

    [data-theme="dark"] {
      --cream: #1C0F08;
      --cream2: #251508;
      --warm-white: #1A0D06;
      --ink: #FAF3E8;
      --ink2: #F0E0C8;
      --text: #E8D5BC;
      --text-muted: #B8937A;
      --border: rgba(200, 131, 26, 0.2);
      --shadow: rgba(0, 0, 0, 0.4);
      --card-bg: rgba(37, 21, 8, 0.95);
      --nav-bg: rgba(28, 15, 8, 0.98);
      --section-alt: #201008;
      --footer-bg: #0E0704;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    html {
      scroll-behavior: smooth
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--text);
      transition: background .4s, color .4s;
      overflow-x: hidden
    }

    /* BASIC UI ELEMENTS COPIED FROM INDEX.EJS FOR CONSISTENCY */
    .loader {
      position: fixed;
      inset: 0;
      background: var(--cream);
      z-index: 9999;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: opacity .5s, visibility .5s
    }

    .loader.hide {
      opacity: 0;
      visibility: hidden;
      pointer-events: none
    }

    .loader-logo {
      font-family: 'Playfair Display', serif;
      font-size: 3.5rem;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -1px
    }

    .loader-logo span {
      color: var(--coral)
    }

    .loader-dots {
      display: flex;
      gap: 10px;
      margin-top: 18px
    }

    .loader-dots div {
      width: 11px;
      height: 11px;
      border-radius: 50%;
      background: var(--coral);
      animation: dotBounce .6s infinite alternate
    }

    .loader-dots div:nth-child(2) {
      animation-delay: .15s;
      background: var(--amber)
    }

    .loader-dots div:nth-child(3) {
      animation-delay: .3s;
      background: var(--sage)
    }

    @keyframes dotBounce {
      from {
        transform: translateY(0)
      }

      to {
        transform: translateY(-10px);
        opacity: .5
      }
    }

    .topbar {
      background: var(--terra);
      color: #fff;
      padding: 8px 0;
      font-size: 13px;
      font-weight: 500
    }

    .topbar .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px
    }

    .topbar-contact {
      display: flex;
      gap: 20px;
      flex-wrap: wrap
    }

    .topbar-contact a {
      color: rgba(255, 255, 255, .85);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 5px;
      transition: color .3s
    }

    .topbar-contact a:hover {
      color: #fff
    }

    .nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: var(--nav-bg);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      transition: all .3s
    }

    .nav.scrolled {
      box-shadow: 0 4px 24px var(--shadow)
    }

    .nav .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      max-width: 1260px;
      margin: 0 auto
    }

    .logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.9rem;
      font-weight: 800;
      color: var(--ink);
      text-decoration: none;
      letter-spacing: -.5px
    }

    .logo span {
      color: var(--coral)
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 10px;
      list-style: none
    }

    .nav-links a {
      text-decoration: none;
      color: var(--text);
      font-weight: 600;
      font-size: 14.5px;
      padding: 7px 14px;
      border-radius: 8px;
      transition: all .3s;
      position: relative
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: 2px;
      left: 14px;
      right: 14px;
      height: 2px;
      background: var(--coral);
      border-radius: 2px;
      transform: scaleX(0);
      transition: transform .3s
    }

    .nav-links a:hover::after,
    .nav-links a.active::after {
      transform: scaleX(1)
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: var(--coral)
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 10px
    }

    .theme-btn {
      width: 42px;
      height: 42px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--card-bg);
      color: var(--amber);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      transition: all .3s
    }

    .theme-btn:hover {
      background: var(--amber);
      color: #fff;
      transform: rotate(20deg)
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 11px 26px;
      border-radius: 10px;
      font-weight: 600;
      font-size: 14px;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: all .3s;
      font-family: 'DM Sans', sans-serif
    }

    .btn-outline {
      background: transparent;
      border: 1.5px solid var(--coral);
      color: var(--coral)
    }

    .btn-outline:hover {
      background: var(--coral);
      color: #fff
    }

    .btn-fill {
      background: linear-gradient(135deg, var(--coral), var(--rose));
      color: #fff;
      box-shadow: 0 4px 16px rgba(217, 95, 59, .3)
    }

    .btn-fill:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(217, 95, 59, .4)
    }

    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 8px;
      border: none;
      background: transparent
    }

    .hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--ink);
      border-radius: 2px;
      transition: all .3s
    }

    .container {
      max-width: 1260px;
      margin: 0 auto;
      padding: 0 24px
    }

    /* PAGE HERO */
    .page-hero {
      position: relative;
      padding: 160px 0 90px;
      overflow: hidden;
      text-align: center;
    }

    .page-hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=1600&q=85');
      background-size: cover;
      background-position: center;
      background-attachment: fixed
    }

    .page-hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(42, 20, 8, .82) 0%, rgba(160, 82, 45, .55) 60%, rgba(90, 122, 92, .4) 100%)
    }

    .page-hero-inner {
      position: relative;
      z-index: 2
    }

    .page-hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 5vw, 3.5rem);
      font-weight: 800;
      color: #fff;
      margin-bottom: 12px
    }

    .page-hero p {
      color: rgba(255, 255, 255, 0.8);
      max-width: 600px;
      margin: 0 auto;
      font-size: 17px
    }

    /* BROWSE CONTENT */
    .browse-section {
      padding: 80px 0;
      background-image: radial-gradient(var(--border) 1px, transparent 1px);
      background-size: 30px 30px;
      position: relative;
    }

    [data-theme="dark"] .browse-section {
      background-image: radial-gradient(rgba(200, 131, 26, 0.1) 1.5px, transparent 1.5px);
    }

    .filters-bar {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 32px;
      margin-bottom: 50px;
      box-shadow: 0 10px 40px var(--shadow)
    }

    .filters-form {
      display: flex;
      gap: 16px;
      align-items: center;
      flex-wrap: wrap
    }

    .filter-group {
      flex: 1;
      min-width: 200px;
      position: relative
    }

    .filter-group i {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--coral);
      font-size: 14px
    }

    .filter-input {
      width: 100%;
      padding: 14px 16px 14px 44px;
      border: 1.5px solid var(--border);
      border-radius: 12px;
      background: var(--cream);
      font-family: inherit;
      font-size: 14px;
      outline: none;
      transition: .3s;
      color: var(--text)
    }

    .filter-input:focus {
      border-color: var(--coral);
      background: var(--card-bg);
      box-shadow: 0 0 0 4px rgba(217, 95, 59, 0.08)
    }

    .internships-list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px
    }

    .int-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 32px;
      transition: all .4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      display: flex;
      gap: 28px;
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }

    .int-card::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -10%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, var(--coral) 0%, transparent 70%);
      opacity: 0.03;
      pointer-events: none;
      transition: 0.5s;
    }

    [data-theme="dark"] .int-card::before {
      opacity: 0.08;
      background: radial-gradient(circle, var(--amber) 0%, transparent 70%);
    }

    .int-card:hover {
      transform: translateY(-8px) scale(1.01);
      box-shadow: 0 25px 50px var(--shadow);
      border-color: var(--coral)
    }

    .int-card:hover::before {
      transform: scale(1.5);
      opacity: 0.08;
    }

    .int-card:active {
      transform: scale(0.98);
      background: rgba(217, 95, 59, 0.05);
      transition: 0.1s;
    }

    [data-theme="dark"] .int-card:active {
        background: rgba(200, 131, 26, 0.1);
    }

    .int-logo {
      width: 70px;
      height: 70px;
      border-radius: 18px;
      background: linear-gradient(135deg, var(--coral), var(--rose));
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-family: 'Playfair Display', serif;
      font-weight: 800;
      font-size: 28px;
      flex-shrink: 0
    }

    .int-content {
      flex: 1
    }

    .int-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 12px
    }

    .int-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--ink);
      text-decoration: none;
      transition: .3s
    }

    .int-title:hover {
      color: var(--coral)
    }

    .int-company {
      font-weight: 700;
      color: var(--coral);
      font-size: 14px;
      display: block;
      margin-top: 4px
    }

    .int-badge {
      padding: 5px 14px;
      background: rgba(90, 122, 92, 0.1);
      color: var(--sage);
      border-radius: 50px;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .5px
    }

    .int-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 20px;
      color: var(--text-muted);
      font-size: 14px;
      font-weight: 500
    }

    .int-meta i {
      color: var(--terra);
      margin-right: 6px
    }

    .int-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 24px
    }

    .tag {
      padding: 5px 14px;
      background: var(--cream);
      border: 1px solid var(--border);
      border-radius: 10px;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-muted)
    }

    /* MOBILE NAV */
    .mobile-nav {
      position: fixed;
      inset: 0;
      background: var(--ink);
      z-index: 2000;
      display: flex;
      flex-direction: column;
      padding: 32px 28px;
      transform: translateX(100%);
      transition: transform .4s cubic-bezier(0.4, 0, 0.2, 1)
    }

    .mobile-nav.open {
      transform: translateX(0)
    }

    .mobile-nav-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 40px
    }

    .mobile-close {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: rgba(255, 248, 240, 0.08);
      color: #fff;
      border: none;
      cursor: pointer;
      font-size: 20px;
      display: flex;
      align-items: center;
      justify-content: center
    }

    .mobile-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px
    }

    .mobile-links a {
      text-decoration: none;
      color: rgba(255, 248, 240, 0.85);
      font-size: 1.5rem;
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      padding: 10px 0;
      display: block;
      border-bottom: 1px solid rgba(255, 248, 240, 0.08)
    }

    /* FOOTER */
    .footer {
      background: var(--footer-bg);
      color: rgba(255, 248, 240, 0.75);
      padding: 80px 0 0
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 60px;
      padding-bottom: 60px
    }

    .footer-col h4 {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 22px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--coral);
      display: inline-block
    }

    .footer-links {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px
    }

    .footer-links a {
      font-size: 13.5px;
      color: rgba(255, 248, 240, 0.65);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: .3s
    }

    .footer-links a:hover {
      color: var(--amber-light);
      padding-left: 4px
    }

    .footer-bottom {
      border-top: 1px solid rgba(255, 248, 240, 0.08);
      padding: 22px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 14px
    }

    .footer-copy {
      font-size: 13px
    }

    /* RESPONSIVE */
    @media(max-width:768px) {

      .nav-links,
      .nav-right .btn-outline,
      .nav-right .btn-fill {
        display: none
      }

      .hamburger {
        display: flex
      }

      .int-card {
        flex-direction: column;
        gap: 20px
      }

      .int-header {
        flex-direction: column;
        gap: 12px
      }

      .int-logo {
        width: 60px;
        height: 60px;
        font-size: 24px
      }

      .filters-form {
        flex-direction: column;
        align-items: stretch
      }

      .btn-filter {
        width: 100%
      }

      .footer-grid {
        grid-template-columns: 1fr;
        text-align: center
      }

      .footer-links {
        align-items: center
      }

      .topbar-contact {
        display: none
      }

      .container {
        padding: 0 15px
      }

      .logo {
        font-size: 1.6rem
      }

      .page-hero {
        padding: 120px 0 60px
      }
    }
  </style>
  <% if (user) { %>
    <style>
      @media(max-width:768px) {
        .nav-right .btn-fill {
          display: inline-flex !important;
          padding: 8px 16px;
          font-size: 13px;
        }
      }
    </style>
    <% } %>
</head>

<body>

  <!-- LOADER -->
  <div class="loader" id="loader">
    <div class="loader-logo">Conn<span>eto</span></div>
    <div class="loader-dots">
      <div></div>
      <div></div>
      <div></div>
    </div>
  </div>
  <script>
    (function() {
        const entry = performance.getEntriesByType('navigation')[0];
        const isReload = entry && entry.type === 'reload';
        const isFirstVisit = !sessionStorage.getItem('conneto_visited');
        if (!isReload && !isFirstVisit) {
            const ldr = document.getElementById('loader');
            if(ldr) { ldr.style.display = 'none'; ldr.classList.add('hide'); }
        }
    })();
  </script>

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="container">
      <span class="topbar-msg">Explore <%= internships.length %>+ Active Opportunities Available Today</span>
      <div class="topbar-contact">
        <a href="mailto:connect@algoorbit.in"><i class="fas fa-envelope"></i>connect@algoorbit.in</a>
        <a href="#"><i class="fas fa-map-marker-alt"></i>Karkala, Karnataka</a>
      </div>
    </div>
  </div>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <div class="container">
      <a href="/" class="logo">Conn<span>eto</span></a>
      <ul class="nav-links">
        <li><a href="/" class="<%= title === 'Conneto — Find Your Internship' ? 'active' : '' %>">Home</a></li>
        <li><a href="/internships" class="<%= title.includes('Internships') ? 'active' : '' %>">Internships</a></li>
        <li><a href="/about" class="<%= title.includes('About') ? 'active' : '' %>">About Us</a></li>
        <li><a href="/contact" class="<%= title.includes('Contact') ? 'active' : '' %>">Contact</a></li>
      </ul>
      <div class="nav-right">
        <button class="theme-btn" id="themeToggle" title="Toggle theme"><i class="fas fa-moon"></i></button>
        <% if (user) { %>
          <a href="/<%= user.role %>/dashboard" class="btn btn-fill">Dashboard</a>
          <% } else { %>
            <a href="/auth/login" class="btn btn-outline">Login</a>
            <a href="/auth/register" class="btn btn-fill">Sign Up</a>
            <% } %>
              <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
      </div>
    </div>
  </nav>

  <!-- MOBILE NAV -->
  <div class="mobile-nav" id="mobileNav">
    <div class="mobile-nav-header">
      <a href="/" class="logo" style="color:#fff">Conn<span>eto</span></a>
      <button class="mobile-close" id="mobileClose"><i class="fas fa-times"></i></button>
    </div>
    <ul class="mobile-links">
      <li><a href="/">Home</a></li>
      <li><a href="/internships">Internships</a></li>
      <li><a href="/about">About Us</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
    <div class="mobile-nav-bottom"
      style="margin-top:auto; display:flex; flex-direction:column; gap:12px; padding:20px 0">
      <% if (!user) { %>
        <a href="/auth/login" class="btn btn-outline" style="border-color:rgba(255,248,240,0.3);color:#fff">Login</a>
        <a href="/auth/register" class="btn btn-fill">Sign Up</a>
        <% } else { %>
          <a href="/<%= user.role %>/dashboard" class="btn btn-fill">Go to Dashboard</a>
          <% } %>
    </div>
  </div>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-inner">
      <h1>Explore <em>Opportunities</em></h1>
      <p>Your dream internship is just a search away. Connect with top companies and jumpstart your professional career
        today.</p>
    </div>
  </section>

  <!-- BROWSE SECTION -->
  <section class="browse-section">
    <div class="container">
      <div class="filters-bar">
        <form class="filters-form" action="/internships" method="GET">
          <div class="filter-group">
            <i class="fas fa-search"></i>
            <input type="text" name="search" class="filter-input" placeholder="Role, skills or company..."
              value="<%= filters.search || '' %>">
          </div>
          <div class="filter-group">
            <i class="fas fa-map-marker-alt"></i>
            <input type="text" name="location" class="filter-input" placeholder="City or Remote..."
              value="<%= filters.location || '' %>">
          </div>
          <button type="submit" class="btn btn-fill btn-filter">Search Internships</button>
        </form>
      </div>

      <div class="internships-list">
        <% if (internships && internships.length> 0) { %>
          <% internships.forEach(function(item) { %>
            <div class="int-card">
              <div class="int-logo">
                <% var cmName=(item.company && (item.company.companyName || item.company.name)) || item.companyName
                  || 'CO' ; %>
                  <%= cmName.charAt(0).toUpperCase() %>
              </div>
              <div class="int-content">
                <div class="int-header">
                  <div>
                    <a href="/internships/<%= item._id %>" class="int-title">
                      <%= item.title %>
                    </a>
                    <span class="int-company">
                      <%= cmName %>
                    </span>
                  </div>
                  <div style="display:flex; gap:10px; align-items:center">
                    <% if (typeof appliedIds !=='undefined' && appliedIds && appliedIds.includes(item._id.toString())) {
                      %>
                      <span class="int-badge" style="background:rgba(90,122,92,0.1); color:var(--sage)">Applied</span>
                      <% } %>
                        <span class="int-badge">
                          <%= item.type || 'Internship' %>
                        </span>
                  </div>
                </div>

                <div class="int-meta">
                  <span><i class="fas fa-map-marker-alt"></i>
                    <%= item.location || 'Remote' %>
                  </span>
                  <span><i class="fas fa-clock"></i>
                    <%= item.duration || '3 Months' %>
                  </span>
                  <span><i class="fas fa-rupee-sign"></i>
                    <%= item.stipend ? item.stipend + '/mo' : 'Unpaid' %>
                  </span>
                </div>

                <div class="int-tags">
                  <% if (item.skills) { %>
                    <% item.skills.slice(0, 4).forEach(skill=> { %>
                      <span class="tag">
                        <%= skill %>
                      </span>
                      <% }) %>
                        <% } %>
                </div>

                <div style="display:flex; justify-content:space-between; align-items:center">
                  <span style="font-size:12px; color:var(--text-muted)">Posted <%= new
                      Date(item.createdAt).toLocaleDateString() %></span>
                  <a href="/internships/<%= item._id %>" class="btn btn-outline"
                    style="padding:8px 20px; font-size:13px">View Details</a>
                </div>
              </div>
            </div>
            <% }); %>
              <% } else { %>
                <div
                  style="text-align:center; padding:100px 20px; background:var(--card-bg); border-radius:30px; border:1.5px dashed var(--border)">
                  <i class="fas fa-search" style="font-size:3rem; color:var(--border); margin-bottom:20px"></i>
                  <h2 style="font-family:'Playfair Display',serif; margin-bottom:10px">No matching internships found
                  </h2>
                  <p style="color:var(--text-muted); margin-bottom:24px">Try adjusting your filters or search keywords.
                  </p>
                  <a href="/internships" class="btn btn-fill">Clear All Filters</a>
                </div>
                <% } %>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <a href="/" class="logo" style="color:#fff;font-size:2rem">Conn<span style="color:var(--coral)">eto</span></a>
          <p style="margin-top:15px; font-size:14px; line-height:1.6">Connecting future talent with industry leaders.
            Our platform simplifies the internship hunt for students and hiring for companies.</p>
        </div>
        <div class="footer-col">
          <h4>Resources</h4>
          <ul class="footer-links">
            <li><a href="/">Home</a></li>
            <li><a href="/internships">Browse Internships</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Legal</h4>
          <ul class="footer-links">
            <li><a href="#">Privacy Policy</a></li>
            <li><a href="#">Terms of Service</a></li>
            <li><a href="#">Help Center</a></li>
            <li><a href="#">Support</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-copy">© 2026 <a href="/" style="color:var(--amber-light); text-decoration:none">Conneto</a>.
          All rights reserved.</div>
        <div style="display:flex; gap:15px">
          <a href="#" style="color:#fff; opacity:0.6"><i class="fab fa-linkedin"></i></a>
          <a href="#" style="color:#fff; opacity:0.6"><i class="fab fa-twitter"></i></a>
          <a href="#" style="color:#fff; opacity:0.6"><i class="fab fa-instagram"></i></a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // LOADER
    // LOADER Logic
    window.addEventListener('load', () => {
        const loader = document.getElementById('loader');
        const entry = performance.getEntriesByType('navigation')[0];
        const navigationType = entry ? entry.type : '';
        const isReload = navigationType === 'reload';
        const isFirstVisit = !sessionStorage.getItem('conneto_visited');

        if (isReload || isFirstVisit) {
            // Show loader for 1.2s on INITIAL START or REFRESH
            setTimeout(() => {
                loader.classList.add('hide');
                sessionStorage.setItem('conneto_visited', 'true');
            }, 1200);
        } else {
            // Direct redirect for header links
            loader.style.display = 'none';
            loader.classList.add('hide');
        }
    });

    // THEME
    const themeBtn = document.getElementById('themeToggle');
    const html = document.documentElement;
    function updateThemeIcon() { 
        if (!themeBtn) return;
        themeBtn.innerHTML = html.getAttribute('data-theme') === 'dark' ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>'; 
    }
    if (themeBtn) {
        themeBtn.addEventListener('click', () => {
          const current = html.getAttribute('data-theme');
          const next = current === 'dark' ? 'light' : 'dark';
          html.setAttribute('data-theme', next);
          localStorage.setItem('conneto-theme', next);
          updateThemeIcon();
        });
    }
    updateThemeIcon();

    // NAV SCROLL
    window.addEventListener('scroll', () => {
      const nav = document.getElementById('nav');
      if (nav) nav.classList.toggle('scrolled', window.scrollY > 50);
    });

    // MOBILE NAV
    const hamburger = document.getElementById('hamburger');
    const mobileNav = document.getElementById('mobileNav');
    const mobileClose = document.getElementById('mobileClose');
    if (hamburger) hamburger.addEventListener('click', () => mobileNav.classList.add('open'));
    if (mobileClose) mobileClose.addEventListener('click', () => mobileNav.classList.remove('open'));

    // SCROLL ANIMATION
    const cards = document.querySelectorAll('.int-card');
    const scrollObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)' } });
    }, { threshold: 0.1 });
    cards.forEach(c => {
      c.style.opacity = '0'; c.style.transform = 'translateY(30px)'; c.style.transition = 'all .6s ease';
      scrollObserver.observe(c);
    });
  </script>
</body>

</html>