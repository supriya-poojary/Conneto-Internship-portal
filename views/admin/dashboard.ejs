<!DOCTYPE html>
<html lang="en" data-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script>
        (function () {
            const t = localStorage.getItem('conneto-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    <style>
        :root {
            --coral: #D95F3B;
            --coral-light: #F07A56;
            --rose: #B5384A;
            --amber: #C8831A;
            --amber-light: #E8A030;
            --sage: #5A7A5C;
            --sage-light: #7A9E7C;
            --bg: #0a0806;
            --sidebar-bg: rgba(18, 12, 8, 0.95);
            --card-bg: rgba(25, 18, 12, 0.85);
            --text: #E8D5BC;
            --text-muted: #B8937A;
            --ink: #FAF3E8;
            --border: rgba(217, 95, 59, 0.15);
            --sidebar-width: 280px;
            --sidebar-collapsed: 80px;
            --overlay-bg: rgba(10, 5, 2, 0.98);
        }

        [data-theme="light"] {
            --bg: #F5F7FA;
            --sidebar-bg: rgba(255, 255, 255, 0.98);
            --card-bg: rgba(255, 255, 255, 0.95);
            --text: #3D2B1F;
            --text-muted: #7A5C4A;
            --ink: #2C1A0E;
            --border: rgba(160, 82, 45, 0.1);
            --overlay-bg: rgba(255, 255, 255, 0.98);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            transition: .4s;
        }

        /* Animated Background */
        .admin-bg {
            position: fixed;
            inset: 0;
            z-index: -10;
            overflow: hidden;
        }

        .admin-bg-img {
            position: absolute;
            top: -5%;
            left: -5%;
            width: 110%;
            height: 110%;
            background-image: url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            filter: brightness(0.2) saturate(0.4);
            animation: slow-glide 60s infinite linear;
        }

        [data-theme="light"] .admin-bg-img {
            filter: brightness(0.9) saturate(0.6) opacity(0.3);
        }

        @keyframes slow-glide {
            0% {
                transform: scale(1) translate(0, 0);
            }

            50% {
                transform: scale(1.1) translate(2%, 1%);
            }

            100% {
                transform: scale(1) translate(0, 0);
            }
        }

        .layout-container {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Logic */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            backdrop-filter: blur(30px);
            display: flex;
            flex-direction: column;
            position: sticky;
            top: 0;
            height: 100vh;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1000;
        }

        .sidebar.collapsed {
            width: var(--sidebar-collapsed);
        }

        .sidebar-header {
            padding: 30px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            overflow: hidden;
        }

        .logo {
            font-family: 'Outfit', sans-serif;
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--ink);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            white-space: nowrap;
        }

        .logo span {
            color: var(--coral);
        }

        .sidebar.collapsed .logo span {
            display: none;
        }

        .toggle-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            color: var(--amber);
            width: 32px;
            height: 32px;
            border-radius: 8px;
            cursor: pointer;
            transition: .3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .toggle-btn:hover {
            background: var(--coral);
            color: #fff;
        }

        .nav-menu {
            padding: 20px 15px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex: 1;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 14px 18px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 15px;
            transition: .3s;
            white-space: nowrap;
            border: none;
            background: transparent;
            cursor: pointer;
            width: 100%;
        }

        .nav-item i {
            width: 20px;
            font-size: 18px;
            text-align: center;
        }

        .nav-item:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--ink);
        }

        .nav-item.active {
            background: rgba(217, 95, 59, 0.15);
            color: var(--coral);
        }

        .sidebar.collapsed .nav-item span {
            display: none;
        }

        .sidebar-footer {
            padding: 24px;
            border-top: 1px solid var(--border);
        }

        .logout-link {
            color: var(--rose);
            text-decoration: none;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .sidebar.collapsed .logout-link span {
            display: none;
        }

        /* Main Panel */
        .main-panel {
            flex: 1;
            padding: 40px;
            position: relative;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .header-top h1 {
            font-family: 'Outfit';
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--ink);
        }

        .theme-btn {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--card-bg);
            color: var(--amber);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            transition: .3s;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            padding: 24px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 20px;
            backdrop-filter: blur(15px);
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            background: rgba(217, 95, 59, 0.1);
            color: var(--coral);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
        }

        .stat-val {
            font-size: 28px;
            font-weight: 800;
            color: var(--ink);
            font-family: 'Outfit';
        }

        .stat-label {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .company-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
            gap: 24px;
        }

        .company-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 24px;
            overflow: hidden;
            transition: .3s;
            backdrop-filter: blur(15px);
        }

        .company-card:hover {
            transform: translateY(-5px);
            border-color: var(--coral);
        }

        .card-head {
            padding: 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .card-head h2 {
            font-family: 'Outfit';
            font-size: 1.2rem;
            color: var(--ink);
            margin-bottom: 4px;
        }

        .card-head p {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 600;
        }

        .status-pill {
            padding: 5px 12px;
            border-radius: 50px;
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .status-pill.pending {
            background: rgba(200, 131, 26, 0.15);
            color: var(--amber);
        }

        .status-pill.approved {
            background: rgba(90, 122, 92, 0.15);
            color: var(--sage);
        }

        .card-body {
            padding: 24px;
            display: grid;
            gap: 15px;
        }

        .card-info {
            display: flex;
            gap: 12px;
        }

        .card-info i {
            color: var(--coral);
            font-size: 16px;
            margin-top: 2px;
        }

        .card-info span {
            font-size: 14px;
            color: var(--text);
            font-weight: 600;
        }

        .card-footer {
            padding: 20px 24px;
            background: rgba(255, 255, 255, 0.03);
            display: flex;
            gap: 10px;
            border-top: 1px solid var(--border);
        }

        .btn-action {
            padding: 10px;
            border-radius: 10px;
            font-weight: 800;
            cursor: pointer;
            border: none;
            font-size: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: .3s;
        }

        .btn-approve {
            background: var(--sage);
            color: #fff;
            flex: 2;
        }

        .btn-reject {
            background: rgba(181, 56, 74, 0.1);
            color: var(--rose);
            border: 1px solid rgba(181, 56, 74, 0.15);
            flex: 1;
        }

        .btn-view {
            background: rgba(255, 255, 255, 0.05);
            color: var(--ink);
            border: 1px solid var(--border);
        }

        /* Profile Viewer Overlay */
        .overlay {
            position: fixed;
            inset: 0;
            background: var(--overlay-bg);
            z-index: 2000;
            display: none;
            overflow-y: auto;
            backdrop-filter: blur(20px);
            animation: slideUp 0.5s cubic-bezier(0.18, 0.89, 0.32, 1.28);
        }

        @keyframes slideUp {
            from {
                transform: translateY(100%);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .overlay-content {
            max-width: 1100px;
            margin: 0 auto;
            padding: 100px 40px;
            position: relative;
        }

        .close-btn {
            position: fixed;
            top: 40px;
            right: 40px;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--card-bg);
            border: 1px solid var(--border);
            color: var(--coral);
            cursor: pointer;
            z-index: 2100;
            font-size: 20px;
            transition: .3s;
        }

        .close-btn:hover {
            background: var(--coral);
            color: #fff;
            transform: rotate(90deg);
        }

        .profile-hero {
            text-align: center;
            margin-bottom: 60px;
        }

        .profile-hero .logo-box {
            width: 140px;
            height: 140px;
            border-radius: 40px;
            background: linear-gradient(135deg, var(--coral), var(--rose));
            margin: 0 auto 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: #fff;
            font-family: 'Outfit';
            font-weight: 800;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.3);
        }

        .profile-hero h2 {
            font-family: 'Outfit';
            font-size: 4rem;
            color: var(--ink);
            font-weight: 800;
        }

        .profile-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 40px;
        }

        .p-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            padding: 40px;
            border-radius: 32px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
        }

        .p-card h3 {
            font-size: 12px;
            text-transform: uppercase;
            color: var(--coral);
            letter-spacing: 2px;
            margin-bottom: 30px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 10px;
        }

        .p-row {
            margin-bottom: 25px;
        }

        .p-label {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 5px;
            display: block;
        }

        .p-val {
            font-size: 1.3rem;
            color: var(--ink);
            font-weight: 700;
        }

        /* Rejection Dialog */
        .dialog-layer {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            z-index: 3000;
            display: none;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(10px);
        }

        .dialog-box {
            background: var(--bg);
            border: 1px solid var(--rose);
            padding: 50px;
            border-radius: 40px;
            width: 95%;
            max-width: 550px;
            text-align: center;
            box-shadow: 0 0 100px rgba(181, 56, 74, 0.2);
        }

        .dialog-box i {
            font-size: 64px;
            color: var(--rose);
            margin-bottom: 25px;
        }

        .dialog-input {
            width: 100%;
            padding: 24px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            color: var(--ink);
            font-family: inherit;
            font-size: 1.1rem;
            resize: none;
            margin: 30px 0;
            outline: none;
        }

        .dialog-btns {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .dialog-btn {
            padding: 18px;
            border-radius: 15px;
            font-weight: 800;
            cursor: pointer;
            border: none;
            font-size: 16px;
            transition: .3s;
        }

        .page-section {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        .page-section.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>
    <div class="admin-bg">
        <div class="admin-bg-img"></div>
    </div>

    <div class="layout-container">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <a href="/" class="logo"><i class="fas fa-tower-broadcast"></i> <span>Conn<span>eto</span></span></a>
                <button class="toggle-btn" onclick="toggleSidebar()"><i class="fas fa-chevron-left"
                        id="toggleIcon"></i></button>
            </div>
            <nav class="nav-menu">
                <button onclick="showPage('pending')" class="nav-item active" id="nav-pending"><i
                        class="fas fa-user-shield"></i> <span>Verification Queue</span></button>
                <button onclick="showPage('approved')" class="nav-item" id="nav-approved"><i class="fas fa-city"></i>
                    <span>Verified Network</span></button>
            </nav>
            <div class="sidebar-footer">
                <a href="/auth/logout" class="logout-link"><i class="fas fa-power-off"></i> <span>Exit Admin</span></a>
            </div>
        </aside>

        <main class="main-panel">
            <!-- PENDING SECTION -->
            <section id="pending-page" class="page-section active">
                <div class="header-top">
                    <h1>Administrative Review</h1>
                    <button class="theme-btn" id="themeBtn"><i class="fas fa-moon"></i></button>
                </div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-file-signature"></i></div>
                        <div>
                            <div class="stat-val">
                                <%= pendingCompanies.length %>
                            </div>
                            <div class="stat-label">Pending Reviews</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon" style="background:rgba(90, 122, 92, 0.1); color:var(--sage);"><i
                                class="fas fa-check-double"></i></div>
                        <div>
                            <div class="stat-val">
                                <%= approvedCompanies.length %>
                            </div>
                            <div class="stat-label">Global Partners</div>
                        </div>
                    </div>
                </div>

                <div class="company-grid">
                    <% if (pendingCompanies.length===0) { %>
                        <div
                            style="grid-column:1/-1; text-align:center; padding:100px; background:var(--card-bg); border-radius:40px; border:2px dashed var(--border);">
                            <i class="fas fa-coffee"
                                style="font-size:60px; color:var(--text-muted); opacity:0.3; margin-bottom:20px;"></i>
                            <h2 style="font-family:'Outfit'; color:var(--ink);">All tasks completed</h2>
                            <p style="color:var(--text-muted); margin-top:10px;">Queue is currently empty. Enjoy your
                                break!</p>
                        </div>
                        <% } else { %>
                            <% pendingCompanies.forEach(company=> { %>
                                <div class="company-card">
                                    <div class="card-head">
                                        <div>
                                            <h2>
                                                <%= company.companyName %>
                                            </h2>
                                            <p>
                                                <%= company.email %>
                                            </p>
                                        </div>
                                        <span class="status-pill pending">Pending</span>
                                    </div>
                                    <div class="card-body">
                                        <div class="card-info"><i class="fas fa-fingerprint"></i><span>
                                                <%= company.cin %>
                                            </span></div>
                                        <div class="card-info"><i class="fas fa-user-tie"></i><span>
                                                <%= company.name %>
                                            </span></div>
                                    </div>
                                    <div class="card-footer">
                                        <form action="/admin/approve/<%= company._id %>" method="POST" style="flex:2;">
                                            <button type="submit" class="btn-action btn-approve"><i
                                                    class="fas fa-check"></i> Accept</button>
                                        </form>
                                        <button class="btn-action btn-reject"
                                            onclick="triggerReject('<%= company._id %>')"><i
                                                class="fas fa-times"></i></button>
                                        <button class="btn-action btn-view"
                                            onclick="openProfile('<%= company._id %>')"><i
                                                class="fas fa-expand"></i></button>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } %>
                </div>
            </section>

            <!-- APPROVED SECTION -->
            <section id="approved-page" class="page-section">
                <div class="header-top">
                    <h1>Active Ecosystem</h1>
                </div>
                <div class="company-grid">
                    <% approvedCompanies.forEach(company=> { %>
                        <div class="company-card">
                            <div class="card-head">
                                <div>
                                    <h2>
                                        <%= company.companyName %>
                                    </h2>
                                    <p>
                                        <%= company.email %>
                                    </p>
                                </div>
                                <span class="status-pill approved">Verified</span>
                            </div>
                            <div class="card-body">
                                <div class="card-info"><i class="fas fa-fingerprint"></i><span>
                                        <%= company.cin %>
                                    </span></div>
                                <div class="card-info"><i class="fas fa-phone"></i><span>
                                        <%= company.phone %>
                                    </span></div>
                                <div class="card-info"><i class="fas fa-map-marker-alt"></i><span>
                                        <%= company.city || 'Remote' %>
                                    </span></div>
                            </div>
                            <div class="card-footer">
                                <button class="btn-action btn-view" style="width:100%;"
                                    onclick="openProfile('<%= company._id %>')"><i class="fas fa-address-card"></i> View
                                    Full Credentials</button>
                            </div>
                        </div>
                        <% }) %>
                </div>
            </section>
        </main>
    </div>

    <!-- PROFILE OVERLAY -->
    <div id="profileOverlay" class="overlay">
        <button class="close-btn" onclick="closeProfile()"><i class="fas fa-times"></i></button>
        <div class="overlay-content" id="profileContent"></div>
    </div>

    <!-- REJECT DIALOG -->
    <div id="rejectLayer" class="dialog-layer">
        <div class="dialog-box">
            <i class="fas fa-shield-halved"></i>
            <h2 style="font-family:'Outfit'; color:var(--ink); font-size:2rem;">Decline Partnership</h2>
            <p style="color:var(--text-muted); margin-top:10px;">Specify the exact reason for rejection correctly.</p>
            <form id="rejectForm" method="POST">
                <textarea name="reason" class="dialog-input"
                    placeholder="e.g. Identity documents do not meet compliance standards..." required></textarea>
                <div class="dialog-btns">
                    <button type="button" class="dialog-btn"
                        style="background:rgba(255,255,255,0.05); color:var(--text);"
                        onclick="closeReject()">Cancel</button>
                    <button type="submit" class="dialog-btn" style="background:var(--rose); color:#fff;">Confirm
                        Reject</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const COMPANIES = <% - JSON.stringify([...pendingCompanies, ...approvedCompanies].reduce((acc, c) => ({ ...acc, [c._id]: c }), {})) %>;

        function toggleSidebar() {
            const side = document.getElementById('sidebar');
            const icon = document.getElementById('toggleIcon');
            side.classList.toggle('collapsed');
            icon.className = side.classList.contains('collapsed') ? 'fas fa-chevron-right' : 'fas fa-chevron-left';
        }

        function showPage(id) {
            document.querySelectorAll('.page-section').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
            document.getElementById(id + '-page').classList.add('active');
            document.getElementById('nav-' + id).classList.add('active');
        }

        function triggerReject(id) {
            document.getElementById('rejectForm').action = `/admin/reject/${id}`;
            document.getElementById('rejectLayer').style.display = 'flex';
        }

        function closeReject() {
            document.getElementById('rejectLayer').style.display = 'none';
        }

        function openProfile(id) {
            const c = COMPANIES[id];
            if (!c) return;
            const content = `
                    <div style="max-width: 1000px; margin: 0 auto; background: var(--sidebar-bg); border: 1px solid var(--border); border-radius: 40px; overflow: hidden; box-shadow: 0 40px 120px rgba(0,0,0,0.6); animation: slideUp 0.6s cubic-bezier(0.23, 1, 0.32, 1);">
                        
                        <!-- Premium Header Section -->
                        <div style="background: linear-gradient(135deg, rgba(217, 95, 59, 0.15), rgba(181, 56, 74, 0.08)); padding: 80px 60px; border-bottom: 1px solid var(--border); position: relative; overflow: hidden;">
                            <div style="position: absolute; top: -50px; right: -50px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(217, 95, 59, 0.1) 0%, transparent 70%); border-radius: 50%;"></div>
                            <span class="status-pill ${c.status.toLowerCase()}" style="position: absolute; top: 40px; right: 60px; padding: 15px 30px; font-size: 14px; letter-spacing: 2px; z-index: 10; font-weight: 800; border: 1px solid rgba(255,255,255,0.1);">${c.status}</span>
                            
                            <div style="display: flex; gap: 50px; align-items: center; position: relative; z-index: 5;">
                                <div style="width: 140px; height: 140px; flex-shrink: 0; border-radius: 45px; background: linear-gradient(135deg, var(--coral), var(--rose)); display: flex; align-items: center; justify-content: center; font-size: 70px; color: #fff; font-family: 'Outfit'; font-weight: 800; box-shadow: 0 30px 60px rgba(217, 95, 59, 0.4);">
                                    ${c.companyName.charAt(0)}
                                </div>
                                <div style="flex: 1; word-break: break-word;">
                                    <h2 style="font-family: 'Outfit'; font-size: 3.5rem; color: var(--ink); font-weight: 800; line-height: 1; margin-bottom: 15px; text-shadow: 0 10px 30px rgba(0,0,0,0.2);">${c.companyName}</h2>
                                    <p style="color: var(--text-muted); font-size: 18px; font-weight: 500; display: flex; align-items: center; gap: 10px;"><i class="fas fa-map-marker-alt" style="color:var(--coral)"></i> ${c.companyAddress}</p>
                                </div>
                            </div>
                        </div>

                        <!-- Professional Data Insights -->
                        <div style="padding: 60px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; border-bottom: 1px solid var(--border); padding-bottom: 20px;">
                                <h4 style="font-size: 15px; text-transform: uppercase; letter-spacing: 4px; color: var(--coral); font-weight: 800;">Official Identity & Records</h4>
                            </div>
                            
                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 30px; margin-bottom: 60px;">
                                <div style="background: var(--bg); border: 1px solid var(--border); border-radius: 30px; padding: 35px; display: flex; gap: 25px; align-items: center; transition: 0.3s;" onmouseover="this.style.borderColor='var(--coral)'" onmouseout="this.style.borderColor='var(--border)'">
                                    <div style="width: 70px; height: 70px; flex-shrink: 0; background: rgba(217, 95, 59, 0.12); border-radius: 20px; color: var(--coral); display: flex; align-items: center; justify-content: center; font-size: 28px;"><i class="fas fa-fingerprint"></i></div>
                                    <div style="word-break: break-word;">
                                        <span style="font-size: 12px; color: var(--text-muted); font-weight: 800; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 5px;">CIN (Corporate ID)</span>
                                        <div style="color: var(--ink); font-weight: 800; font-family: 'Outfit'; font-size: 1.5rem;">${c.cin}</div>
                                    </div>
                                </div>
                                <div style="background: var(--bg); border: 1px solid var(--border); border-radius: 30px; padding: 35px; display: flex; gap: 25px; align-items: center; transition: 0.3s;" onmouseover="this.style.borderColor='var(--amber)'" onmouseout="this.style.borderColor='var(--border)'">
                                    <div style="width: 70px; height: 70px; flex-shrink: 0; background: rgba(200, 131, 26, 0.12); border-radius: 20px; color: var(--amber); display: flex; align-items: center; justify-content: center; font-size: 28px;"><i class="fas fa-calendar-check"></i></div>
                                    <div>
                                        <span style="font-size: 12px; color: var(--text-muted); font-weight: 800; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 5px;">Activation Date</span>
                                        <div style="color: var(--ink); font-weight: 800; font-family: 'Outfit'; font-size: 1.5rem;">${new Date(c.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
                                    </div>
                                </div>
                            </div>

                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; border-bottom: 1px solid var(--border); padding-bottom: 20px;">
                                <h4 style="font-size: 15px; text-transform: uppercase; letter-spacing: 4px; color: var(--coral); font-weight: 800;">Primary Liaison</h4>
                            </div>
                            
                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px;">
                                <div style="background: var(--card-bg); border: 1px solid var(--border); border-radius: 30px; padding: 35px; word-break: break-word;">
                                    <span style="font-size: 11px; color: var(--text-muted); font-weight: 800; text-transform: uppercase; display: block; margin-bottom: 15px; letter-spacing: 1px;">Registered Email</span>
                                    <div style="color: var(--ink); font-weight: 700; font-size: 1.2rem;">${c.email}</div>
                                </div>
                                <div style="background: var(--card-bg); border: 1px solid var(--border); border-radius: 30px; padding: 35px; word-break: break-word;">
                                    <span style="font-size: 11px; color: var(--text-muted); font-weight: 800; text-transform: uppercase; display: block; margin-bottom: 15px; letter-spacing: 1px;">Contact Line</span>
                                    <div style="color: var(--ink); font-weight: 700; font-size: 1.2rem;">${c.phone}</div>
                                </div>
                                <div style="background: var(--card-bg); border: 1px solid var(--border); border-radius: 30px; padding: 35px; word-break: break-word;">
                                    <span style="font-size: 11px; color: var(--text-muted); font-weight: 800; text-transform: uppercase; display: block; margin-bottom: 15px; letter-spacing: 1px;">Authorized Signatory</span>
                                    <div style="color: var(--ink); font-weight: 700; font-size: 1.2rem;">${c.name}</div>
                                </div>
                            </div>
                        </div>
                    </div>
            `;
            const overlay = document.getElementById('profileOverlay');
            const contentDiv = document.getElementById('profileContent');

            contentDiv.className = "overlay-content"; // Restore generic padding/max-width
            contentDiv.innerHTML = content;
            overlay.style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function closeProfile() {
            document.getElementById('profileOverlay').style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        // Theme Support
        const themeBtn = document.getElementById('themeBtn');
        function updateThemeIcon() {
            const t = document.documentElement.getAttribute('data-theme');
            themeBtn.innerHTML = t === 'dark' ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
        }
        themeBtn.addEventListener('click', () => {
            const current = document.documentElement.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('conneto-theme', next);
            updateThemeIcon();
        });
        updateThemeIcon();
    </script>
</body>

</html>