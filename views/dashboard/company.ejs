                padding: 30px 20px !important;
                border-radius: 24px !important;
                border-width: 2px !important;
            }
            #diaryModal .app-modal-body-scroll div[style*="grid-template-columns: 1fr 1fr"] {
                grid-template-columns: 1fr !important;
                gap: 15px !important;
            }
            #diaryModal .app-modal-body-scroll div[style*="padding: 25px"] {
                padding: 15px !important;
            }
            #diaryModal .app-modal-body-scroll div[style*="font-size: 1.25rem"] {
                font-size: 1.1rem !important;
            }
            #diaryModal .app-modal-body-scroll div[style*="font-size: 1rem"] {
                font-size: 0.95rem !important;
            }
            #diaryModal .app-modal-body-scroll .eval-btn-group {
                grid-template-columns: 1fr !important;
            }
            #diaryModal .app-modal-body-scroll button {
                padding: 15px !important;
                font-size: 1rem !important;
            }

            /* Diary Evaluation List Responsiveness */
            .diary-student-header {
                flex-direction: column !important;
                text-align: left !important;
                gap: 15px !important;
            }
            .diary-student-header > div:last-child {
                text-align: left !important;
            }
            .diary-row-content {
                grid-template-columns: 1fr !important;
                gap: 15px !important;
                padding: 20px !important;
            }
            .diary-row-item {
                flex-direction: column !important;
            }
            .diary-row-item > div:first-child {
                width: 100% !important;
                height: 6px !important;
            }
            .diary-row-content > div:last-child {
                justify-content: space-between !important;
                border-left: none !important;
                border-top: 1px solid var(--border) !important;
                padding-left: 0 !important;
                padding-top: 15px !important;
                width: 100% !important;
            }
            .diary-row-content > div:last-child > div:last-child {
                border-left: none !important;
                padding-left: 0 !important;
            }
            .filter-buttons {
                overflow-x: auto !important;
                white-space: nowrap !important;
                padding-bottom: 5px !important;
                width: 100% !important;
            }
            .upload-section form > div {
                flex-direction: column !important;
                align-items: stretch !important;
            }
            .upload-section form button {
                width: 100% !important;
            }
            .diary-student-header h3 {
                font-size: 1.5rem !important;
            }
            .diary-student-header div[style*="font-size:24px"] {
                font-size: 18px !important;
            }
        }
    </style>
    <!-- Diary Details Modal -->
    <div id="diaryModal" class="app-modal">
        <div class="app-modal-content" style="max-width: 100vw; width: 100vw; height: 100vh; max-height: 100vh; border-radius: 0; background: var(--bg);">
            <div class="app-modal-header" style="padding: 25px 40px; background: linear-gradient(135deg, #1C0F08, #2C1A0E); border-bottom: 2px solid var(--coral); box-shadow: 0 4px 20px rgba(0,0,0,0.3); z-index: 10;">
                <div onclick="closeDiaryModal()" style="position: absolute; top: 20px; right: 30px; width: 40px; height: 40px; background: rgba(255,255,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.3)'" onmouseout="this.style.background='rgba(255,255,255,0.15)'">
                    <i class="fas fa-times" style="font-size: 1.2rem;"></i>
                </div>
                <h2 id="diaryModalTitle" style="font-family:'Playfair Display', serif; margin: 0; font-size: 1.8rem;">Diary Log Evaluation</h2>
                <p style="margin-top: 5px; opacity: 0.8; font-weight: 500; font-size: 14px;"><i class="far fa-calendar-alt" style="margin-right: 5px;"></i> Professional Work Tracking & Feedback Session</p>
            </div>
            
            <div class="app-modal-body-scroll" style="padding: 60px; max-width: 100vw; width: 100%; position: relative; background: url('/images/diary_modal_bg.png') no-repeat center center; background-size: cover; background-attachment: fixed;">
                <!-- Professional Overlay for Readability -->
                <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(28, 15, 8, 0.6), rgba(44, 26, 14, 0.4)); z-index: 1;"></div>
                
                <div style="position: relative; z-index: 2; max-width: 1100px; margin: 0 auto; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); border: 3px solid var(--border); border-radius: 40px; padding: 60px; box-shadow: 0 50px 100px rgba(0,0,0,0.5);">
                    <!-- Elegant Header Decor -->
                    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 6px; background: linear-gradient(90deg, var(--coral), var(--amber), var(--sage));"></div>
                    
                    <div id="diaryModalBody" style="font-size: 1.1rem; line-height: 1.9; color: var(--text)">
                        <!-- Dynamic Content (Already contains its own boxes, now wrapped) -->
                    </div>
                    
                    <div id="evalSection" style="margin-top: 20px; padding-top: 30px; border-top: 1.5px dashed var(--border);">
                        <!-- Dynamic Evaluation Form -->
                    </div>

                    <div id="diaryModalFooter" style="margin-top: 40px; display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.02); padding: 20px 30px; border-radius: 16px; border: 1.5px solid var(--border); display: none;">
                        <span id="diaryModalStatus"></span>
                        <span id="diaryModalHours"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function openDiaryModal(id, summary, learnings, hours, status, remarks, skills) {
            const modal = document.getElementById('diaryModal');
            const body = document.getElementById('diaryModalBody');
            const evalSection = document.getElementById('evalSection');
            const statusEl = document.getElementById('diaryModalStatus');
            const hoursEl = document.getElementById('diaryModalHours');

            body.innerHTML = `
                <!-- Professional Header Section -->
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; animation: fadeInDown 0.5s ease-out;">
                    <div style="background: var(--card-bg); border: 2px solid var(--border); border-radius: 20px; padding: 25px; display: flex; align-items: center; gap: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
                        <div style="width: 60px; height: 60px; border-radius: 12px; background: ${status === 'approved' ? 'rgba(16, 185, 129, 0.1)' : status === 'rejected' ? 'rgba(239, 68, 68, 0.1)' : 'rgba(217, 95, 59, 0.1)'}; display: flex; align-items: center; justify-content: center; color: ${status === 'approved' ? '#10B981' : status === 'rejected' ? '#EF4444' : '#D95F3B'}; font-size: 1.5rem;">
                            <i class="fas ${status === 'approved' ? 'fa-check-circle' : status === 'rejected' ? 'fa-times-circle' : 'fa-clock'}"></i>
                        </div>
                        <div>
                            <div style="font-size: 11px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 4px;">Log Status</div>
                            <div style="font-size: 1.1rem; font-weight: 800; color: var(--ink);">${status.toUpperCase()}</div>
                        </div>
                    </div>
                    <div style="background: var(--card-bg); border: 2px solid var(--border); border-radius: 20px; padding: 25px; display: flex; align-items: center; gap: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
                        <div style="width: 60px; height: 60px; border-radius: 12px; background: rgba(99, 102, 241, 0.1); display: flex; align-items: center; justify-content: center; color: #6366F1; font-size: 1.5rem;">
                            <i class="fas fa-hourglass-half"></i>
                        </div>
                        <div>
                            <div style="font-size: 11px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 4px;">Duration</div>
                            <div style="font-size: 1.1rem; font-weight: 800; color: var(--ink);">${hours} HOURS</div>
                        </div>
                    </div>
                </div>

                <!-- Main Content Box -->
                <div style="background: var(--card-bg); border: 2px solid var(--border); border-radius: 24px; padding: 40px; margin-bottom: 30px; position: relative; animation: fadeInUp 0.5s ease-out; box-shadow: 0 10px 30px rgba(0,0,0,0.02);">
                    <div style="position: absolute; top: -12px; left: 30px; background: #D95F3B; color: white; padding: 4px 15px; border-radius: 8px; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Session Narrative</div>
                    
                    <div style="margin-bottom: 35px;">
                        <div style="font-size: 12px; font-weight: 900; color: var(--text-muted); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 15px; display: flex; align-items: center; gap: 8px;">
                            <span style="width: 8px; height: 8px; border-radius: 50%; background: #D95F3B;"></span> Work Summary
                        </div>
                        <div style="font-size: 1.25rem; font-weight: 600; color: var(--ink); line-height: 1.7; font-family: 'Playfair Display', serif;">
                            ${summary}
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; padding-top: 30px; border-top: 1px solid var(--border);">
                        <div>
                            <div style="font-size: 11px; font-weight: 900; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                                <i class="fas fa-lightbulb" style="color: #10B981;"></i> Key Learnings
                            </div>
                            <div style="font-size: 1rem; color: var(--text); line-height: 1.6; background: rgba(16, 185, 129, 0.03); padding: 20px; border-radius: 12px; border-left: 4px solid #10B981;">
                                ${learnings}
                            </div>
                        </div>
                        <div>
                            <div style="font-size: 11px; font-weight: 900; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                                <i class="fas fa-code-branch" style="color: #6366F1;"></i> Tech Stack & Skills
                            </div>
                            <div style="font-size: 1rem; color: var(--text); line-height: 1.6; background: rgba(99, 102, 241, 0.03); padding: 20px; border-radius: 12px; border-left: 4px solid #6366F1;">
                                ${skills || 'Professional Industry Implementation'}
                            </div>
                        </div>
                    </div>
                </div>

                <style>
                    @keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
                    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
                </style>
            `;

            if (status === 'pending') {
                evalSection.innerHTML = `
                    <div style="margin-top: 20px; animation: fadeInUp 0.7s ease-out;">
                        <div style="background: var(--card-bg); border: 2px solid var(--border); border-radius: 24px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); position: relative;">
                            <div style="position: absolute; top: -12px; left: 30px; background: var(--amber); color: white; padding: 4px 15px; border-radius: 8px; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Evaluation & Feedback</div>
                            
                            <form action="/company/diary/evaluate/${id}" method="POST">
                                <div style="margin-bottom: 25px;">
                                    <label style="display: block; font-size: 12px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px;">Executive Remarks</label>
                                    <textarea name="remarks" placeholder="Provide professional guidance, coaching notes, or reasons for rejection..." required style="width: 100%; height: 120px; padding: 25px; border-radius: 16px; border: 2px solid var(--border); background: var(--bg); color: var(--text); font-family: inherit; font-size: 1rem; outline: none; transition: 0.3s; resize: none; line-height: 1.6;" onfocus="this.style.borderColor='var(--coral)'; this.style.background='white';"></textarea>
                                </div>

                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                                    <button type="submit" name="status" value="approved" style="background: var(--sage); color: white; border: none; padding: 20px; border-radius: 12px; font-weight: 800; font-size: 1.1rem; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 12px;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 10px 20px rgba(90,122,92,0.2)';" onmouseout="this.style.transform='translateY(0)';">
                                        <i class="fas fa-check-double"></i> Approve Work Log
                                    </button>
                                    <button type="submit" name="status" value="rejected" style="background: rgba(239, 68, 68, 0.1); color: #EF4444; border: 2px solid #EF4444; padding: 20px; border-radius: 12px; font-weight: 800; font-size: 1.1rem; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 12px;" onmouseover="this.style.background='#EF4444'; this.style.color='white'; this.style.transform='translateY(-2px)';" onmouseout="this.style.background='rgba(239, 68, 68, 0.1)'; this.style.color='#EF4444'; this.style.transform='translateY(0)';">
                                        <i class="fas fa-undo"></i> Request Refinement
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                `;
            } else {
                evalSection.innerHTML = `
                    <div style="margin-top: 20px; animation: fadeInUp 0.7s ease-out;">
                        <div style="background: var(--card-bg); border: 2px solid var(--border); border-radius: 24px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.02); position: relative;">
                            <div style="position: absolute; top: -12px; left: 30px; background: var(--text-muted); color: white; padding: 4px 15px; border-radius: 8px; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Assessment History</div>
                            
                            <div style="font-size: 12px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px;">Executive Feedback</div>
                            <div style="font-size: 1.1rem; color: var(--ink); line-height: 1.6; padding: 25px; background: var(--bg); border: 1px dashed var(--border); border-radius: 16px; font-style: italic;">
                                "${remarks || 'Professional assessment completed without specific annotated feedback.'}"
                            </div>
                        </div>
                    </div>
                `;
            }

            statusEl.style.display = 'none';
            hoursEl.style.display = 'none';
            document.getElementById('diaryModalFooter').style.display = 'none';
            
            modal.classList.add('active');
            document.body.style.overflow = 'hidden'; // Lock Body Scroll
        }

        function closeDiaryModal() {
            document.getElementById('diaryModal').classList.remove('active');
            document.body.style.overflow = ''; // Restore Body Scroll
        }

        window.onclick = function(event) {
            const profileModal = document.getElementById('profileModal');
            const diaryModal = document.getElementById('diaryModal');
            if (event.target == profileModal) profileModal.classList.remove('active');
            if (event.target == diaryModal) diaryModal.classList.remove('active');
        }
    </script>
</body>

</html>