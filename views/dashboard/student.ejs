                                                    style="background: var(--bg); border: 1px solid var(--border); margin-bottom: 35px; box-shadow: 0 10px 25px rgba(0,0,0,0.02);">
                                                    <div style="margin-bottom: 15px;">
                                                        <div
                                                            style="font-size: 11px; font-weight: 800; color: var(--coral); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px;">
