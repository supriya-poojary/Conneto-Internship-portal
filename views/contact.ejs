                            onmouseover="this.style.background='#0075ff';this.style.color='#fff'"
                            onmouseout="this.style.background='rgba(0,117,255,0.08)';this.style.color='var(--tj-primary)'">WA</a>
                    </div>
                </div>

                <!-- Form -->
                <div class="contact-form-box">
                    <h3>Send Us a Message</h3>
                    <p class="sub">Fill in the form below and our team will get back to you within 24 hours.</p>
                    <form id="contactForm">
                        <div class="form-row">
                            <div class="form-group">
                                <label for="cf-name">Full Name</label>
                                <input type="text" id="cf-name" class="form-input" placeholder="Your full name"
                                    required>
                            </div>
                            <div class="form-group">
                                <label for="cf-email">Email Address</label>
                                <input type="email" id="cf-email" class="form-input" placeholder="name@example.com"
                                    required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="cf-role">I am a...</label>
                            <select id="cf-role" class="form-select">
                                <option value="">Select your role</option>
                                <option>Student looking for internships</option>
                                <option>Company looking to hire interns</option>
                                <option>Other enquiry</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="cf-subject">Subject</label>
                            <input type="text" id="cf-subject" class="form-input" placeholder="What is this regarding?"
                                required>
                        </div>
                        <div class="form-group">
                            <label for="cf-msg">Your Message</label>
                            <textarea id="cf-msg" class="form-textarea" placeholder="Tell us how we can help..."
                                required></textarea>
                        </div>
                        <button type="submit" class="btn-submit">Send Message →</button>
                        <div class="success-msg" id="successMsg">✅ Thank you! We will get back to you within 24 hours.
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

