<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us — Conneto Internship Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script>
        (function () {
            const t = localStorage.getItem('conneto-theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    <style>
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --coral: #D95F3B;
            --coral-light: #F07A56;
            --rose: #B5384A;
            --amber: #C8831A;
            --amber-light: #E8A030;
            --sage: #5A7A5C;
            --sage-light: #7A9E7C;
            --terra: #A0522D;
            --terra-light: #C4723F;
            --cream: #FAF3E8;
            --cream2: #F5EAD8;
            --warm-white: #FFF8F0;
            --ink: #2C1A0E;
            --ink2: #4A2E1A;
            --text: #3D2B1F;
            --text-muted: #7A5C4A;
            --border: rgba(160, 82, 45, 0.15);
            --shadow: rgba(44, 26, 14, 0.12);
            --card-bg: rgba(255, 248, 240, 0.95);
            --nav-bg: rgba(250, 243, 232, 0.97);
            --section-alt: #F5EAD8;
            --footer-bg: #1E0E05;

            /* Compatibility with old Contact page naming */
            --bg: var(--cream);
            --bg2: var(--cream2);
            --surface: var(--card-bg);
            --surface2: var(--warm-white);
            --text2: var(--text-muted);
            --text3: var(--text-muted);
            --terracotta: var(--terra);
            --warm-gold: var(--amber);
        }

        [data-theme="dark"] {
            --cream: #1C0F08;
            --cream2: #251508;
            --warm-white: #1A0D06;
            --ink: #FAF3E8;
            --ink2: #F0E0C8;
            --text: #E8D5BC;
            --text-muted: #B8937A;
            --border: rgba(200, 131, 26, 0.2);
            --shadow: rgba(0, 0, 0, 0.4);
            --card-bg: rgba(37, 21, 8, 0.95);
            --nav-bg: rgba(28, 15, 8, 0.98);
            --section-alt: #201008;
            --footer-bg: #0E0704;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            transition: background 0.4s, color 0.4s;
        }

        .loader {
            position: fixed;
            inset: 0;
            background: var(--bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 0.5s, visibility 0.5s;
        }

        .loader.gone {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }

        .loader-brand {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 800;
        }

        .loader-brand span {
            color: var(--coral);
        }

        .loader-dots {
            display: flex;
            gap: 8px;
            margin-top: 16px;
        }

        .loader-dots span {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--coral);
            animation: dot-bounce 0.6s infinite alternate;
        }

        .loader-dots span:nth-child(2) {
            animation-delay: 0.15s;
        }

        .loader-dots span:nth-child(3) {
            animation-delay: 0.3s;
        }

        @keyframes dot-bounce {
            from {
                transform: translateY(0);
                opacity: 1;
            }

            to {
                transform: translateY(-10px);
                opacity: 0.4;
            }
        }

        .topbar {
            background: var(--terra);
            color: #fff;
            padding: 8px 0;
            font-size: 13px;
            font-weight: 500
        }

        .topbar-inner {
            max-width: 1240px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .topbar-contacts {
            display: flex;
            gap: 24px;
        }

        .topbar-contacts a {
            color: rgba(255, 255, 255, 0.85);
            text-decoration: none;
        }

        .topbar-contacts a:hover {
            color: var(--coral);
        }

        nav {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--nav-bg);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
        }

        .nav-inner {
            max-width: 1240px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 72px;
        }

        .nav-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.7rem;
            font-weight: 800;
            text-decoration: none;
            color: var(--text);
        }

        .nav-logo span {
            color: var(--coral);
        }

        .nav-links {
            display: flex;
            gap: 32px;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text2);
            font-weight: 500;
            font-size: 15px;
            transition: color 0.2s;
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: var(--coral);
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn-outline {
            padding: 10px 22px;
            border: 1.5px solid var(--coral);
            color: var(--coral);
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.2s;
        }

        .btn-outline:hover {
            background: var(--coral);
            color: #fff;
        }

        .btn-solid {
            padding: 10px 22px;
            background: var(--coral);
            color: #fff;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.2s;
        }

        .btn-solid:hover {
            background: var(--rose);
            transform: translateY(-1px);
        }

        .theme-btn {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--surface2);
            border: 1.5px solid var(--border);
            color: var(--amber);
            font-size: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }

        .theme-btn:hover {
            background: var(--amber);
            color: #fff;
            transform: rotate(20deg);
        }

        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            color: var(--text);
            font-size: 22px;
            cursor: pointer;
        }

        /* PAGE HERO */
        .page-hero {
            min-height: 380px;
            position: relative;
            display: flex;
            align-items: center;
            overflow: hidden;
        }

        .page-hero-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1557804506-669a67965ba0?w=1600&q=80');
            background-size: cover;
            background-position: center;
        }

        .page-hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(44, 24, 16, 0.9) 0%, rgba(184, 92, 56, 0.8) 50%, rgba(44, 24, 16, 0.75) 100%);
        }

        .page-hero-content {
            position: relative;
            z-index: 1;
            max-width: 1240px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .page-hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 6px 16px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.8);
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 16px;
        }

        .page-hero h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 800;
            color: #fff;
            line-height: 1.1;
            margin-bottom: 16px;
        }

        .page-hero h1 em {
            color: #FDB97D;
            font-style: normal;
        }

        .page-hero p {
            color: rgba(255, 255, 255, 0.8);
            font-size: 17px;
            max-width: 500px;
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 24px;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.6);
        }

        .breadcrumb a {
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
        }

        .breadcrumb a:hover {
            color: #FDB97D;
        }

        .breadcrumb span {
            color: rgba(255, 255, 255, 0.4);
        }

        section {
            padding: 100px 0;
        }

        .container {
            max-width: 1240px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .section-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--coral);
            margin-bottom: 16px;
        }

        .section-tag::before,
        .section-tag::after {
            content: '';
            width: 30px;
            height: 2px;
            background: var(--coral);
            opacity: 0.5;
        }

        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 800;
            line-height: 1.2;
            color: var(--text);
            margin-bottom: 16px;
        }

        .section-title em {
            color: var(--coral);
            font-style: normal;
        }

        .section-sub {
            font-size: 16px;
            color: var(--text2);
            line-height: 1.7;
        }

        /* CONTACT INFO CARDS */
        .contact-info-section {
            background: var(--bg);
            padding: 70px 0;
        }

        .contact-info-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        .contact-info-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 36px;
            text-align: center;
            transition: transform 0.3s, box-shadow 0.3s;
            position: relative;
            overflow: hidden;
        }

        .contact-info-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }

        .contact-info-card:nth-child(1)::before {
            background: var(--coral);
        }

        .contact-info-card:nth-child(2)::before {
            background: var(--amber);
        }

        .contact-info-card:nth-child(3)::before {
            background: var(--sage);
        }

        .contact-info-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 24px 48px var(--shadow);
        }

        .contact-info-icon {
            width: 68px;
            height: 68px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            margin: 0 auto 20px;
        }

        .contact-info-card:nth-child(1) .contact-info-icon {
            background: rgba(224, 90, 58, 0.12);
            color: var(--coral);
        }

        .contact-info-card:nth-child(2) .contact-info-icon {
            background: rgba(212, 130, 10, 0.12);
            color: var(--amber);
        }

        .contact-info-card:nth-child(3) .contact-info-icon {
            background: rgba(92, 122, 92, 0.12);
            color: var(--sage);
        }

        .contact-info-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 10px;
        }

        .contact-info-text {
            font-size: 14px;
            color: var(--text2);
            line-height: 1.7;
        }

        .contact-info-text a {
            color: var(--coral);
            text-decoration: none;
        }

        /* MAIN CONTACT SECTION */
        .contact-main-section {
            background: var(--bg2);
        }

        .contact-main-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: start;
        }

        /* FORM */
        .contact-form-wrap {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 48px;
            box-shadow: 0 24px 48px var(--shadow);
        }

        .form-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--text);
            margin-bottom: 8px;
        }

        .form-sub {
            font-size: 14px;
            color: var(--text2);
            margin-bottom: 32px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--text2);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-input {
            width: 100%;
            padding: 14px 18px;
            background: var(--surface2);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-size: 15px;
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        .form-input:focus {
            border-color: var(--coral);
            box-shadow: 0 0 0 3px rgba(224, 90, 58, 0.1);
        }

        .form-input::placeholder {
            color: var(--text3);
        }

        textarea.form-input {
            min-height: 140px;
            resize: vertical;
        }

        select.form-input {
            cursor: pointer;
        }

        .form-submit {
            width: 100%;
            padding: 16px;
            background: var(--coral);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .form-submit:hover {
            background: var(--rose);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(224, 90, 58, 0.35);
        }

        /* CONTACT SIDE */
        .contact-side {
            position: relative;
        }

        .contact-side-image {
            border-radius: 20px;
            overflow: hidden;
            margin-bottom: 28px;
        }

        .contact-side-image img {
            width: 100%;
            height: 280px;
            object-fit: cover;
        }

        .contact-detail-item {
            display: flex;
            gap: 16px;
            align-items: flex-start;
            padding: 20px;
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 14px;
            margin-bottom: 14px;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .contact-detail-item:hover {
            border-color: var(--coral);
            box-shadow: 0 8px 24px var(--shadow);
        }

        .contact-detail-icon {
            width: 44px;
            height: 44px;
            flex-shrink: 0;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .contact-detail-item:nth-child(1) .contact-detail-icon {
            background: rgba(224, 90, 58, 0.12);
            color: var(--coral);
        }

        .contact-detail-item:nth-child(2) .contact-detail-icon {
            background: rgba(212, 130, 10, 0.12);
            color: var(--amber);
        }

        .contact-detail-item:nth-child(3) .contact-detail-icon {
            background: rgba(92, 122, 92, 0.12);
            color: var(--sage);
        }

        .contact-detail-title {
            font-weight: 700;
            font-size: 14px;
            color: var(--text);
            margin-bottom: 4px;
        }

        .contact-detail-text {
            font-size: 13px;
            color: var(--text2);
            line-height: 1.6;
        }

        .contact-detail-text a {
            color: var(--coral);
            text-decoration: none;
        }

        /* MAP */
        .map-section {
            padding: 0;
        }

        .map-wrap {
            height: 420px;
            background: var(--surface2);
            overflow: hidden;
            position: relative;
        }

        .map-wrap iframe {
            width: 100%;
            height: 100%;
            border: none;
            filter: var(--map-filter, none);
        }

        [data-theme="dark"] {
            --map-filter: invert(0.9) hue-rotate(180deg) saturate(0.8);
        }

        .map-overlay-card {
            position: absolute;
            top: 32px;
            left: 32px;
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px 24px;
            box-shadow: 0 16px 32px var(--shadow);
            max-width: 240px;
        }

        .map-overlay-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 8px;
        }

        .map-overlay-text {
            font-size: 13px;
            color: var(--text2);
            line-height: 1.6;
        }

        .map-overlay-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--surface2);
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 11px;
            font-weight: 600;
            color: var(--sage);
            margin-top: 12px;
        }

        /* FAQ */
        .faq-section {
            background: var(--bg2);
        }

        .faq-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: start;
            margin-top: 60px;
        }

        .faq-img {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 24px 48px var(--shadow);
        }

        .faq-img img {
            width: 100%;
            height: 480px;
            object-fit: cover;
        }

        .faq-list {
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .faq-item {
            border-bottom: 1px solid var(--border);
        }

        .faq-question {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            cursor: pointer;
            font-weight: 600;
            font-size: 15px;
            color: var(--text);
            transition: color 0.2s;
        }

        .faq-question:hover {
            color: var(--coral);
        }

        .faq-question i {
            font-size: 14px;
            color: var(--coral);
            transition: transform 0.3s;
        }

        .faq-item.open .faq-question i {
            transform: rotate(45deg);
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease;
        }

        .faq-item.open .faq-answer {
            max-height: 200px;
        }

        .faq-answer-inner {
            padding: 0 0 20px;
            font-size: 14px;
            color: var(--text2);
            line-height: 1.8;
        }

        /* NEWSLETTER */
        .newsletter-section {
            background: linear-gradient(135deg, var(--terracotta), var(--rose));
            padding: 80px 0;
            position: relative;
            overflow: hidden;
        }

        .newsletter-section::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1557804506-669a67965ba0?w=1600&q=80');
            background-size: cover;
            background-position: center;
            opacity: 0.06;
        }

        .newsletter-inner {
            position: relative;
            z-index: 1;
            text-align: center;
            max-width: 600px;
            margin: 0 auto;
        }

        .newsletter-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.4rem;
            font-weight: 800;
            color: #fff;
            margin-bottom: 12px;
        }

        .newsletter-sub {
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 32px;
        }

        .newsletter-form {
            display: flex;
            gap: 0;
            max-width: 460px;
            margin: 0 auto;
        }

        .newsletter-input {
            flex: 1;
            padding: 16px 20px;
            border: none;
            border-radius: 10px 0 0 10px;
            font-size: 14px;
            background: rgba(255, 255, 255, 0.95);
            color: #2C1810;
            outline: none;
        }

        .newsletter-submit {
            padding: 16px 28px;
            background: #2C1810;
            color: #fff;
            border: none;
            border-radius: 0 10px 10px 0;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s;
        }

        .newsletter-submit:hover {
            background: #1A0E0A;
        }

        footer {
            background: #1A0E0A;
            color: rgba(255, 255, 255, 0.7);
            padding: 70px 0 0;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr;
            gap: 60px;
            margin-bottom: 50px;
        }

        .footer-brand {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            font-weight: 800;
            color: #fff;
            margin-bottom: 16px;
        }

        .footer-brand span {
            color: var(--coral);
        }

        .footer-about {
            font-size: 14px;
            line-height: 1.8;
            margin-bottom: 20px;
        }

        .footer-contact-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            margin-bottom: 8px;
        }

        .footer-contact-item a {
