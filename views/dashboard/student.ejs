                                        <% if (profile.resumeUrl) { %>
                                            <i class="fas fa-check-circle" style="color:var(--sage)"></i> Resume already
                                            uploaded. Upload only if you want to update it.
                                            <% } else { %>
                                                <i class="fas fa-info-circle"></i> Resume is mandatory for 100% profile
                                                completion.
                                                <% } %>
