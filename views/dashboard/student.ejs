                                                    required>
                                            </div>

                                            <div style="text-align:right">
                                                <button type="submit" class="view-btn"
                                                    style="background:var(--coral); color:#fff; padding:12px 30px; font-size:1rem; border-radius:12px">
                                                    <i class="fas fa-save"></i> Save Entry
                                                </button>
                                            </div>
                                        </form>

                                        <script>
                                            function validateDiaryDate(elementId) {
                                                const dateVal = document.getElementById(elementId).value;
                                                if (dateVal) {
                                                    const d = new Date(dateVal);
                                                    if (d.getDay() === 0) {
                                                        Swal.fire({
                                                            icon: 'error',
                                                            title: 'Invalid Date',
                                                            text: 'Sundays are not permitted for diary entry logging. Please choose a weekday.',
                                                            confirmButtonColor: '#D95F3B'
                                                        });
                                                        return false;
                                                    }
                                                }
                                                return true;
                                            }
                                        </script>
