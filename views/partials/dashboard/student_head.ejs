    color: var(--rose);
  }

  .stat-value {
    font-family: 'Outfit', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--ink);
    line-height: 1.2;
  }

  .stat-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 30px;
  }

  .column {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 28px;
    box-shadow: 0 10px 30px var(--shadow);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .card-title i {
    color: var(--coral);
  }

  .view-btn {
    padding: 8px 16px;
    background: rgba(217, 95, 59, 0.1);
    color: var(--coral);
    border-radius: 10px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    transition: .3s;
  }

  .view-btn:hover {
    background: var(--coral);
    color: #fff;
    transform: translateY(-2px);
  }

  .internship-list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .internship-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    padding: 20px 12px;
    border-radius: 20px;
    border: 1px solid var(--border);
    transition: .3s;
    background: var(--card-bg);
    aspect-ratio: 1 / 1;
    justify-content: center;
    overflow: hidden;
  }

  .internship-item:hover {
    transform: translateY(-8px);
    border-color: var(--coral);
    box-shadow: 0 15px 40px var(--shadow);
  }

  .company-logo {
    width: 65px;
    height: 65px;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--amber), var(--terra));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Outfit', sans-serif;
    font-size: 26px;
    font-weight: 800;
    color: #fff;
    flex-shrink: 0;
    box-shadow: 0 6px 12px rgba(200, 131, 26, 0.2);
  }

  .internship-details {
    flex: 1;
  }

  .internship-details h4 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 4px;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .company-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--coral);
    margin-bottom: 8px;
  }

  .internship-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-top: 5px;
  }

  .meta-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--card-bg);
    padding: 4px 10px;
    border-radius: 8px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  .meta-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--card-bg);
    padding: 4px 10px;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .meta-tag i {
    color: var(--amber);
  }

  .profile-card {
    text-align: center;
    margin-bottom: 30px;
  }

  .profile-avatar {
    width: 90px;
    height: 90px;
    border-radius: 20px;
    background: linear-gradient(135deg, var(--coral), var(--rose));
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Outfit', sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: #fff;
    box-shadow: 0 10px 24px rgba(217, 95, 59, 0.3);
  }

  .profile-name {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--ink);
    margin-bottom: 4px;
  }

  .profile-email {
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .profile-status {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(90, 122, 92, 0.1);
    color: var(--sage);
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: 100px;
    border: 1px solid rgba(90, 122, 92, 0.2);
  }

  .progress-section {
    background: var(--cream);
    border-radius: 16px;
    padding: 20px;
    border: 1px solid var(--border);
  }

  .progress-title {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 12px;
  }

  .progress-bar {
    width: 100%;
    height: 8px;
    background: var(--card-bg);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--coral), var(--rose));
    border-radius: 10px;
  }

  .btn-primary {
    padding: 14px 24px;
    background: linear-gradient(135deg, var(--coral), var(--rose));
    color: #fff;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: .3s;
    box-shadow: 0 8px 24px rgba(217, 95, 59, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(217, 95, 59, 0.4);
  }

  @media (max-width: 1024px) {
    .sidebar {
      width: 85px;
      padding: 30px 10px;
    }

    .logo span,
    .nav-item span,
    .nav-section-label,
    .user-details {
      display: none;
    }

    .logo {
      padding: 0;
      text-align: center;
      font-size: 1.4rem;
    }

    .nav-item {
      justify-content: center;
      padding: 12px;
      margin-bottom: 8px;
    }

    .nav-item i {
      font-size: 18px;
    }

    .main-content {
      margin-left: 85px;
      padding: 30px 20px;
    }

    .user-card {
      padding: 8px;
      justify-content: center;
    }

    .logout-btn {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .sidebar {
      transform: translateX(-100%);
      width: 260px;
    }

    .sidebar.open {
      transform: translateX(0);
    }

    .logo span,
    .nav-item span,
    .nav-section-label,
    .user-details {
      display: block;
    }

    .logo {
      text-align: left;
      padding: 0 10px;
      font-size: 1.8rem;
    }

    .nav-item {
      justify-content: flex-start;
    }

    .main-content {
      margin-left: 0;
      padding: 80px 20px 40px;
    }

    .logout-btn {
      display: flex;
    }

    .mobile-toggle {
      display: flex !important;
      position: fixed;
      top: 20px;
      left: 20px;
      width: 45px;
      height: 45px;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      z-index: 1100;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      color: var(--ink);
      cursor: pointer;
      box-shadow: 0 4px 12px var(--shadow);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.createElement('div');
    toggle.className = 'mobile-toggle';
    toggle.style.display = 'none';
    toggle.innerHTML = '<i class="fas fa-bars"></i>';
    document.body.appendChild(toggle);

    const sidebar = document.querySelector('.sidebar');
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      sidebar.classList.toggle('open');
      toggle.innerHTML = sidebar.classList.contains('open') ? '<i class="fas fa-times"></i>' : '<i class="fas fa-bars"></i>';
    });

    document.addEventListener('click', (e) => {
      if (sidebar.classList.contains('open') && !sidebar.contains(e.target) && !toggle.contains(e.target)) {
        sidebar.classList.remove('open');
        toggle.innerHTML = '<i class="fas fa-bars"></i>';
      }
    });
  });
</script>