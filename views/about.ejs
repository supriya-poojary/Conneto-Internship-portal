<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/solvior/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/conneto.css" />
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/odometer.js/0.4.8/themes/odometer-theme-minimal.min.css" />
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <style>
        :root {
            --bg-dark: #ffffff;
            --bg-darker: #f1f5f9;
            --accent: #2563eb;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
            --nav-bg: rgba(255, 255, 255, 0.9);
            --card-bg: #ffffff;
        }

        [data-theme="dark"] {
            --bg-dark: #030a16;
            --bg-darker: #01050b;
            --accent: #38bdf8;
            --text-main: #f4f4f5;
            --text-muted: #888;
            --border-color: var(--border-color);
            --nav-bg: rgba(3, 10, 22, 0.9);
            --card-bg: rgba(255, 255, 255, 0.03);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            transition: background-color 0.3s, color 0.3s;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            font-family: 'Playfair Display', serif;
            font-weight: 400;
            color: var(--text-main) !important;
        }

        /* Lenis */
        html.lenis {
            height: auto;
        }

        .lenis.lenis-smooth {
            scroll-behavior: auto;
        }

        /* Nav */
        .c-nav {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            transition: all 0.4s ease;
            padding: 20px 0;
            mix-blend-mode: difference;
        }

        .c-nav.scrolled {
            background: var(--nav-bg);
            backdrop-filter: blur(10px);
            padding: 15px 0;
            mix-blend-mode: normal;
            border-bottom: 1px solid var(--border-color);
        }

        .c-nav-inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 40px;
        }

        .c-nav-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text-main);
            text-decoration: none;
            letter-spacing: 1px;
        }

        .c-nav-logo span {
            color: var(--accent);
            font-style: italic;
        }

        .c-nav-links {
            display: flex;
            gap: 40px;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .c-nav-links a {
            color: var(--text-main);
            text-decoration: none;
            font-size: 0.85rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            position: relative;
        }

        .c-nav-links a::after {
            content: '';
            position: absolute;
            width: 0;
            height: 1px;
            bottom: -6px;
            left: 50%;
            background: var(--accent);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .c-nav-links a:hover::after,
        .c-nav-links a.active::after {
            width: 100%;
        }

        .c-nav-actions {
            display: flex;
            gap: 15px;
        }

        .btn-luxury {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            font-weight: 500;
            color: var(--text-main);
            padding: 12px 28px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 4px;
            transition: all 0.3s;
            text-decoration: none;
        }

        .btn-luxury:hover {
            background: #fff;
            color: var(--bg-dark);
        }

        .btn-luxury-solid {
            background: var(--accent);
            border-color: var(--accent);
        }

        .btn-luxury-solid:hover {
            background: #005ecc;
            border-color: #005ecc;
            color: var(--text-main);
        }

        /* Page Hero */
        .page-hero {
            padding: 15rem 0 5rem;
            text-align: center;
        }

        .page-hero-title {
            font-size: clamp(3rem, 7vw, 6rem);
            line-height: 1;
            letter-spacing: -0.02em;
            margin-bottom: 2rem;
            color: var(--text-main);
            text-transform: uppercase;
        }

        .page-hero-title span {
            color: var(--accent);
            font-style: italic;
        }

        .page-hero-sub {
            font-family: 'Inter', sans-serif;
            font-size: 1.1rem;
            color: var(--text-muted);
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.8;
            font-weight: 300;
        }

        /* Mission Image Reveal */
        .reveal-sec {
            height: 80vh;
            margin: 5rem 0;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            color: var(--bg-dark);
        }

        .reveal-bg {
            position: absolute;
            inset: 0;
            overflow: hidden;
            clip-path: inset(15% 15% 15% 15%);
        }

        .reveal-bg img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(20%);
        }

        .reveal-content {
            z-index: 10;
            text-align: center;
        }

        .reveal-text {
            font-family: 'Playfair Display', serif;
            font-size: clamp(3rem, 8vw, 8rem);
            line-height: 0.9;
            color: var(--text-main);
            font-style: italic;
            text-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        /* Marquee */
        .marquee-container {
            padding: 4rem 0;
            background: var(--bg-darker);
            overflow: hidden;
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            white-space: nowrap;
        }

        .marquee-inner {
            display: flex;
        }

        .marquee-text {
            font-family: 'Playfair Display', serif;
            font-size: clamp(3rem, 6vw, 6rem);
            text-transform: uppercase;
            font-style: italic;
            padding: 0 2vw;
            color: rgba(255, 255, 255, 0.8);
        }

        .sec-padding {
            padding: 10rem 0;
        }

        .sec-title {
            font-size: clamp(2.5rem, 5vw, 4.5rem);
            line-height: 1.1;
            margin-bottom: 4rem;
        }

        .sec-title span {
            color: var(--accent);
            font-style: italic;
        }

        /* Story Grid */
        .story-text {
            color: var(--text-muted);
            font-size: 1.1rem;
            line-height: 1.8;
            font-weight: 300;
            margin-bottom: 2rem;
        }

        .story-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .story-img-wrap {
            overflow: hidden;
            height: 600px;
            position: relative;
        }

        .story-img {
            position: absolute;
            top: -15%;
            width: 100%;
            height: 130%;
            object-fit: cover;
            filter: grayscale(30%);
        }

        /* Values */
        .value-card {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 2rem;
            transition: transform 0.4s;
        }

        .value-card:hover {
            transform: translateY(-10px);
        }

        .value-num {
            font-size: 0.85rem;
            color: var(--accent);
            letter-spacing: 0.15em;
            margin-bottom: 1.5rem;
            display: block;
        }

        .value-title {
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
            color: var(--text-main);
        }

        .value-desc {
            color: var(--text-muted);
            line-height: 1.8;
            font-weight: 300;
            font-size: 1.05rem;
        }

        /* Footer */
        .c-footer {
            padding: 8rem 0 2rem;
            background: var(--bg-darker);
            border-top: 1px solid var(--border-color);
        }

        .f-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 6rem;
        }

        .f-title {
            font-size: clamp(2.5rem, 5vw, 5rem);
            line-height: 1;
        }

        .f-links {
            display: flex;
            gap: 3rem;
        }

        .f-links-col h6 {
            font-size: 0.85rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 2rem;
        }

        .f-links-col a {
            display: block;
            color: var(--text-muted);
            text-decoration: none;
            margin-bottom: 1rem;
            font-size: 0.95rem;
            transition: color 0.3s;
        }

        .f-links-col a:hover {
            color: var(--accent);
        }

        .f-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid var(--border-color);
            padding-top: 2rem;
        }

        .f-socials {
            display: flex;
            gap: 1.5rem;
        }

        .f-socials a {
            color: var(--text-main);
            opacity: 0.6;
            transition: all 0.3s;
            width: 20px;
        }

        .f-socials a:hover {
            opacity: 1;
            color: var(--accent);
            transform: translateY(-2px);
        }

        @media (max-width: 991px) {
            .c-nav-links {
                display: none;
            }

            .story-grid {
                grid-template-columns: 1fr;
            }

            .f-top {
                flex-direction: column;
                align-items: flex-start;
                gap: 4rem;
            }

            .reveal-bg {
                clip-path: inset(5%);
            }
        }
    </style>

    <!-- Prevent FOUT -> Pre-load Theme -->
    <script>
        (function () {
            var saved = localStorage.getItem('conneto-theme');
            if (saved !== 'light') {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>

<body>

    <!-- Nav -->
    <header class="c-nav">
        <div class="c-nav-inner">
            <a href="/" class="c-nav-logo">Con<span>neto</span></a>
            <ul class="c-nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/about" class="active">About</a></li>
                <li><a href="/internships">Internships</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
            <div class="c-nav-actions">
                <% if(user){ %>
                    <a href="/<%= user.role %>/dashboard" class="btn-luxury btn-luxury-solid">Dashboard</a>
                    <a href="/auth/logout" class="btn-luxury">Logout</a>
                    <% } else { %>
                        <a href="/auth/login" class="btn-luxury">Login</a>
                        <a href="/auth/register" class="btn-luxury btn-luxury-solid">Get Started</a>
                        <% } %>

                            <!-- Hamburger (mobile only) -->
                            <button class="c-hamburger-home" id="homeHamburger" onclick="openHomeDrawer()"
                                aria-label="Open menu">
                                <span></span><span></span><span></span>
                            </button>
            </div>
        </div>
    </header>

    <main>
        <!-- Intro -->
        <section class="page-hero">
            <div class="container">
                <h1 class="page-hero-title gsap-reveal">About <span>Us.</span></h1>
                <p class="page-hero-sub gsap-reveal-delay">Empowering the next generation of professionals by bridging
                    talented students with the opportunities they deserve.</p>
            </div>
        </section>

        <!-- Image Reveal -->
        <section class="reveal-sec">
            <div class="reveal-bg">
                <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=2400"
                    alt="Team">
            </div>
            <div class="reveal-content">
                <div class="reveal-text">Building<br>Bridges.</div>
            </div>
        </section>

        <!-- Our Story -->
        <section class="sec-padding">
            <div class="container">
                <div class="story-grid">
                    <div>
                        <h2 class="sec-title gsap-up">Our <span>Story</span>.</h2>
                        <p class="story-text gsap-up" style="transition-delay:0.1s;">At Conneto, we believe every
                            individual possesses the potential for greatness, provided they are given the right
                            platform. Founded on the frustration of finding quality internships in an ocean of noise, we
                            sought to bring clarity, elegance, and efficiency to the hiring space.</p>
                        <p class="story-text gsap-up" style="transition-delay:0.2s;">Today, we have matured into a
                            premier network, facilitating thousands of professional connections between elite talent and
                            verified corporate partners across India. This is just the beginning.</p>
                    </div>
                    <div class="story-img-wrap plx-wrapper">
                        <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&q=80&w=1600"
                            alt="Office" class="story-img plx-img">
                    </div>
                </div>
            </div>
        </section>


        <!-- Stats -->
        <section class="sec-padding"
            style="background: var(--bg-darker); border-bottom: 1px solid var(--border-color);">
            <div class="container">
                <div class="row style=" margin-top: 2rem;"">
                    <div class="col-md-3 text-center"
                        style="border-right: 1px solid var(--border-color); padding: 3rem 0;">
                        <div
                            style="font-family:'Playfair Display', serif; font-size:4rem; color: var(--text-main); margin-bottom:1rem;">
                            <span class="odometer" data-val="500">0</span>+</div>
                        <div
                            style="font-size:0.85rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--text-muted);">
                            Verified Partners</div>
                    </div>
                    <div class="col-md-3 text-center"
                        style="border-right: 1px solid var(--border-color); padding: 3rem 0;">
                        <div
                            style="font-family:'Playfair Display', serif; font-size:4rem; color: var(--text-main); margin-bottom:1rem;">
                            <span class="odometer" data-val="10000">0</span>+</div>
                        <div
                            style="font-size:0.85rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--text-muted);">
                            Students Placed</div>
                    </div>
                    <div class="col-md-3 text-center"
                        style="border-right: 1px solid var(--border-color); padding: 3rem 0;">
                        <div
                            style="font-family:'Playfair Display', serif; font-size:4rem; color: var(--text-main); margin-bottom:1rem;">
                            <span class="odometer" data-val="36">0</span></div>
                        <div
                            style="font-size:0.85rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--text-muted);">
                            Global Markets</div>
                    </div>
                    <div class="col-md-3 text-center" style="padding: 3rem 0;">
                        <div
                            style="font-family:'Playfair Display', serif; font-size:4rem; color: var(--text-main); margin-bottom:1rem;">
                            <span class="odometer" data-val="95">0</span>%</div>
                        <div
                            style="font-size:0.85rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--text-muted);">
                            Success Rate</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Marquee 1 -->
        <section class="marquee-container" style="background:var(--accent);color: var(--text-main);">
            <div class="marquee-inner" id="mq1">
                <div class="marquee-text" style="color: var(--text-main);">TRUST • TRANSPARENCY • QUALITY • VELOCITY •
                </div>
                <div class="marquee-text" style="color: var(--text-main);">TRUST • TRANSPARENCY • QUALITY • VELOCITY •
                </div>
                <div class="marquee-text" style="color: var(--text-main);">TRUST • TRANSPARENCY • QUALITY • VELOCITY •
                </div>
            </div>
        </section>

        <!-- Core Values -->
        <section class="sec-padding">
            <div class="container">
                <h2 class="sec-title gsap-up text-center">Core <span>Principles</span></h2>
                <div class="row gy-5 mt-5">
                    <div class="col-md-4">
                        <div class="value-card gsap-up">
                            <span class="value-num">01 — STUDENT FIRST</span>
                            <h4 class="value-title">Empathy</h4>
                            <p class="value-desc">Every architectural decision in our platform prioritizes the student
                                experience, ensuring seamless discovery.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="value-card gsap-up" style="transition-delay: 0.1s;">
                            <span class="value-num">02 — TRUST</span>
                            <h4 class="value-title">Verification</h4>
                            <p class="value-desc">Integrity is paramount. Every corporate partner undergoes rigorous
                                manual curation before accessing our network.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="value-card gsap-up" style="transition-delay: 0.2s;">
                            <span class="value-num">03 — INNOVATION</span>
                            <h4 class="value-title">Evolution</h4>
                            <p class="value-desc">We continuously refine our algorithmic matching to ensure precision
                                and speed in every placement.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="c-footer">
        <div class="container">
            <div class="f-top">
                <h2 class="f-title">Ready to<br><span>Elevate?</span></h2>
                <div class="f-links">
                    <div class="f-links-col">
                        <h6>Navigation</h6>
                        <a href="/">Home</a>
                        <a href="/about">About</a>
                        <a href="/internships">Internships</a>
                    </div>
                    <div class="f-links-col">
                        <h6>Network</h6>
                        <a href="/auth/register">Join as Student</a>
                        <a href="/auth/register">Join as Company</a>
                        <a href="/auth/login">Client Portal</a>
                    </div>
                </div>
            </div>
            <div class="f-bottom">
                <div style="color:var(--text-muted); font-size: 0.85rem; letter-spacing:1px;">© <%= new
                        Date().getFullYear() %> Conneto. All Rights Reserved.</div>
                <div class="f-socials">
