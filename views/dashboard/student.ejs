                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Certifications</label>
                                        <input type="text" name="certifications" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px;"
                                            value="<%= profile.certifications || '' %>"
                                            placeholder="Google Cloud, AWS, Cisco...">
                                    </div>
                                </div>
                                <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Known Languages *</label>
                                        <input type="text" name="languages" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px;"
                                            value="<%= profile.languages || '' %>"
                                            placeholder="English, Hindi, Spanish..." required>
                                    </div>
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Interests / Hobbies *</label>
                                        <input type="text" name="interests" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px;"
                                            value="<%= profile.interests ? profile.interests.join(', ') : '' %>"
                                            placeholder="Open Source, AI Research, Photography..." required>
                                    </div>
                                </div>

                                <h4 class="portfolio-section-title"><i class="fas fa-link"></i> Social Proof &
                                    Links</h4>
                                <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr 1fr; gap: 30px;">
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">LinkedIn URL *</label>
                                        <input type="text" name="linkedin" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px;"
                                            value="<%= profile.linkedin || '' %>" placeholder="linkedin.com/in/username"
                                            required>
                                    </div>
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">GitHub Profile *</label>
                                        <input type="text" name="github" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px;"
                                            value="<%= profile.github || '' %>" placeholder="github.com/username"
                                            required>
                                    </div>
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Portfolio / Bio Link *</label>
                                        <input type="text" name="portfolio" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px;"
                                            value="<%= profile.portfolio || '' %>" placeholder="yourwebsite.com"
                                            required>
                                    </div>
                                </div>
                                <div class="portfolio-group">
                                    <label class="portfolio-label">Professional Bio / Tagline *</label>
                                    <input type="text" name="bio" class="portfolio-input"
                                        style="padding: 15px 20px; font-size: 16px;" value="<%= profile.bio || '' %>"
                                        placeholder="Aspiring Software Engineer passionate about..." required>
                                </div>

                                <h4 class="portfolio-section-title"><i class="fas fa-file-pdf"></i> Resume Documents
                                </h4>
                                <div class="portfolio-group">
                                    <label class="portfolio-label">Upload Resume (PDF) *</label>
                                    <input type="file" name="resume" class="portfolio-input" accept="application/pdf"
                                        style="padding: 12px 20px; font-size: 15px; border-style: dashed;"
