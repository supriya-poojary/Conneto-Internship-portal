                    <div class="site-logo">
                        <a href="/"
                            style="font-family: 'Libre Franklin', serif; font-size: 1.8rem; font-weight: 800; color: var(--tj-dark); text-decoration: none;">
                            Con<span style="color: var(--tj-primary);">neto</span>
                        </a>
                    </div>
                    <!-- Desktop Nav -->
                    <nav style="display: flex; gap: 32px; list-style: none;" class="d-none d-lg-flex">
                        <a href="/"
                            style="font-weight: 600; color: var(--tj-dark); text-decoration: none; font-size: 15px; transition: color 0.3s;"
                            onmouseover="this.style.color='#0075ff'" onmouseout="this.style.color=''">Home</a>
                        <a href="/about"
                            style="font-weight: 600; color: var(--tj-dark); text-decoration: none; font-size: 15px; transition: color 0.3s;"
                            onmouseover="this.style.color='#0075ff'" onmouseout="this.style.color=''">About</a>
                        <a href="/internships"
                            style="font-weight: 600; color: var(--tj-dark); text-decoration: none; font-size: 15px; transition: color 0.3s;"
                            onmouseover="this.style.color='#0075ff'" onmouseout="this.style.color=''">Internships</a>
                        <a href="/contact"
                            style="font-weight: 600; color: var(--tj-primary); text-decoration: none; font-size: 15px;">Contact</a>
                    </nav>
                    <!-- Auth Buttons -->
                    <div class="conneto-nav-auth">
                        <% if (user) { %>
                            <a href="/<%= user.role %>/dashboard" class="btn-nav-signup">Dashboard</a>
                            <a href="/auth/logout" class="btn-nav-login">Logout</a>
                            <% } else { %>
                                <a href="/auth/login" class="btn-nav-login d-none d-md-inline">Login</a>
                                <a href="/auth/register" class="btn-nav-signup">Get Started</a>
                                <% } %>


                                    <!-- Hamburger (mobile only) -->
                                    <button class="c-hamburger-home" id="homeHamburger" onclick="openHomeDrawer()"
                                        aria-label="Open menu">
                                        <span></span><span></span><span></span>
                                    </button>
                    </div>
                </div>
            </div>
            <!-- Mobile Nav -->

        </div>
    </header>
    <!-- ===== END HEADER ===== -->

    <!-- ===== PAGE HEADER ===== -->
    <div class="contact-page-header">
        <h1>Get In Touch</h1>
        <p>We are always ready to help students launch careers and companies find top talent.</p>
        <div class="breadcrumb-bar">
            <a href="/">Home</a>
            <span>/</span>
            <span style="color: rgba(255,255,255,0.9);">Contact</span>
        </div>
    </div>

    <!-- ===== CONTACT MAIN ===== -->
    <section class="contact-section">
        <div class="container">
            <div class="contact-grid">
                <!-- Info Cards -->
                <div>
                    <span class="sec-tag">Contact Information</span>
                    <h2 class="sec-h2">Multiple Ways to Reach Us</h2>
                    <p class="sec-p" style="margin-bottom: 32px;">Our dedicated team responds within 24 business hours
                        to every message we receive.</p>

                    <div class="info-card">
                        <div class="info-icon">📍</div>
                        <div>
                            <h4>Visit Our Office</h4>
                            <p>Algoorbit Innovations Private Limited<br>Karkala, Karnataka, India — 574122</p>
                        </div>
                    </div>
                    <div class="info-card">
                        <div class="info-icon">✉</div>
                        <div>
                            <h4>Email Us</h4>
                            <a href="mailto:connect@algoorbit.in">connect@algoorbit.in</a>
                            <p style="margin-top: 4px;">We respond within 24 business hours</p>
                        </div>
                    </div>
                    <div class="info-card">
                        <div class="info-icon">📞</div>
                        <div>
                            <h4>Call Us</h4>
                            <div style="display: flex; flex-direction: column; gap: 4px;">
                                <a href="tel:+919482119446">+91 94821 19446</a>
                                <a href="tel:+919380719446">+91 93807 19446</a>
                            </div>
                            <p style="margin-top: 4px;">Mon - Sat, 9AM — 6PM IST</p>
                        </div>
                    </div>
                    <div class="info-card">
                        <div class="info-icon">🕐</div>
                        <div>
                            <h4>Business Hours</h4>
                            <p>Monday — Saturday: 9:00 AM — 6:00 PM IST<br>Sunday: Closed</p>
                        </div>
                    </div>

                    <!-- Social links -->
