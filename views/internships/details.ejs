<!DOCTYPE html>
<html lang="en">

<head>
    <% if (user && user.role==='company' ) { %>
        <%- include('../partials/dashboard/company_head', { title: internship.title + ' | Conneto' }) %>
            <% } else { %>
                <%- include('../partials/dashboard/student_head', { title: internship.title + ' | Conneto' }) %>
                    <% } %>
                        <style>
                            :root {
                                --coral: #D95F3B;
                                --coral-light: #F07A56;
                                --rose: #B5384A;
                                --amber: #C8831A;
                                --amber-light: #E8A030;
                                --sage: #5A7A5C;
                                --sage-light: #7A9E7C;
                                --terra: #A0522D;
                                --terra-light: #C4723F;
                                --cream: #FAF3E8;
                                --cream2: #F5EAD8;
                                --warm-white: #FFF8F0;
                                --ink: #2C1A0E;
                                --ink2: #4A2E1A;
                                --text: #3D2B1F;
                                --text-muted: #7A5C4A;
                                --border: rgba(160, 82, 45, 0.15);
                                --shadow: rgba(44, 26, 14, 0.12);
                                --card-bg: rgba(255, 248, 240, 0.95);
                                --nav-bg: rgba(250, 243, 232, 0.97);
                                --section-alt: #F5EAD8;
                                --footer-bg: #1E0E05;
                            }

                            [data-theme="dark"] {
                                --cream: #1C0F08;
                                --cream2: #251508;
                                --warm-white: #1A0D06;
                                --ink: #FAF3E8;
                                --ink2: #F0E0C8;
                                --text: #E8D5BC;
                                --text-muted: #B8937A;
                                --border: rgba(200, 131, 26, 0.2);
                                --shadow: rgba(0, 0, 0, 0.4);
                                --card-bg: rgba(37, 21, 8, 0.95);
                                --nav-bg: rgba(28, 15, 8, 0.98);
                                --section-alt: #201008;
                                --footer-bg: #0E0704;
                            }

                            *,
                            *::before,
                            *::after {
                                box-sizing: border-box;
                                margin: 0;
                                padding: 0
                            }

                            body {
                                font-family: 'Inter', sans-serif;
                                background: transparent !important;
                                color: var(--text);
                                transition: all 0.4s;
                                overflow-x: hidden;
                                min-height: 100vh;
                                position: relative;
                            }

                            /* BASIC UI ELEMENTS */
                            .loader {
                                position: fixed;
                                inset: 0;
                                background: var(--cream);
                                z-index: 9999;
                                display: flex;
                                flex-direction: column;
                                align-items: center;
                                justify-content: center;
                                transition: opacity .5s, visibility .5s
                            }

                            .loader.hide {
                                opacity: 0;
                                visibility: hidden;
                                pointer-events: none
                            }

                            .loader-logo {
                                font-family: 'Outfit', sans-serif;
                                font-size: 3.5rem;
                                font-weight: 800;
                                color: var(--ink);
                                letter-spacing: -1px
                            }

                            .loader-logo span {
                                color: var(--coral)
                            }

                            .loader-dots {
                                display: flex;
                                gap: 10px;
                                margin-top: 18px
                            }

                            .loader-dots div {
                                width: 11px;
                                height: 11px;
                                border-radius: 50%;
                                background: var(--coral);
                                animation: dotBounce .6s infinite alternate
                            }

                            .loader-dots div:nth-child(2) {
                                animation-delay: .15s;
                                background: var(--amber)
                            }

                            .loader-dots div:nth-child(3) {
                                animation-delay: .3s;
                                background: var(--sage)
                            }

                            @keyframes dotBounce {
                                from {
                                    transform: translateY(0)
                                }

                                to {
                                    transform: translateY(-10px);
                                    opacity: .5
                                }
                            }

                            .topbar {
                                background: var(--terra);
                                color: #fff;
                                padding: 8px 0;
                                font-size: 13px;
                                font-weight: 500
                            }

                            .topbar .container {
                                display: flex;
                                align-items: center;
                                justify-content: space-between;
                                padding: 0 24px;
                                max-width: 1260px;
                                margin: 0 auto
                            }

                            .topbar-msg {
                                letter-spacing: .3px
                            }

                            .nav {
                                position: sticky;
                                top: 0;
                                z-index: 1000;
                                background: var(--nav-bg);
                                backdrop-filter: blur(16px);
                                border-bottom: 1px solid var(--border);
                                transition: all .3s
                            }

                            .nav.scrolled {
                                box-shadow: 0 4px 24px var(--shadow)
                            }

                            .nav .container {
                                display: flex;
                                align-items: center;
                                justify-content: space-between;
                                padding: 16px 20px;
                                max-width: 1260px;
                                margin: 0 auto
                            }

                            .logo {
                                font-family: 'Outfit', sans-serif;
                                font-size: 1.9rem;
                                font-weight: 800;
                                color: var(--ink);
                                text-decoration: none;
                                letter-spacing: -.5px
                            }

                            .logo span {
                                color: var(--coral)
                            }

                            .nav-links {
                                display: flex;
                                align-items: center;
                                gap: 10px;
                                list-style: none
                            }

                            .nav-links a {
                                text-decoration: none;
                                color: var(--text);
                                font-weight: 600;
                                font-size: 14.5px;
                                padding: 7px 14px;
                                border-radius: 8px;
                                transition: all .3s
                            }

                            .nav-links a:hover {
                                color: var(--coral)
                            }

                            .nav-right {
                                display: flex;
                                align-items: center;
                                gap: 10px
                            }

                            .theme-btn {
                                width: 42px;
                                height: 42px;
                                border-radius: 10px;
                                border: 1px solid var(--border);
                                background: var(--card-bg);
                                color: var(--amber);
                                cursor: pointer;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                font-size: 16px;
                                transition: all .3s
                            }

                            .theme-btn:hover {
                                background: var(--amber);
                                color: #fff
                            }

                            .btn {
                                display: inline-flex;
                                align-items: center;
                                gap: 8px;
                                padding: 11px 26px;
                                border-radius: 10px;
                                font-weight: 600;
                                font-size: 14px;
                                text-decoration: none;
                                cursor: pointer;
                                border: none;
                                transition: all .3s
                            }

                            .btn-outline {
                                background: transparent;
                                border: 1.5px solid var(--coral);
                                color: var(--coral)
                            }

                            .btn-outline:hover {
                                background: var(--coral);
                                color: #fff
                            }

                            .btn-fill {
                                background: linear-gradient(135deg, var(--coral), var(--rose));
                                color: #fff;
                                box-shadow: 0 4px 16px rgba(217, 95, 59, .3)
                            }

                            .hamburger {
                                display: none;
                                flex-direction: column;
                                gap: 5px;
                                padding: 8px;
                                border: none;
                                background: transparent
                            }

                            .hamburger span {
                                display: block;
                                width: 24px;
                                height: 2px;
                                background: var(--ink);
                                border-radius: 2px
                            }

                            .container {
                                max-width: 1000px;
                                margin: 0 auto;
                                padding: 0 24px
                            }

                            /* PAGE HERO */
                            .page-hero {
                                position: relative;
                                padding: 120px 0 60px;
                                overflow: hidden;
                                text-align: center;
                                margin-bottom: 40px
                            }

                            .page-hero-bg {
                                position: absolute;
                                inset: 0;
                                background-image: url('https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80');
                                background-size: cover;
                                background-position: center;
                                opacity: 0.3;
                                z-index: 1;
                            }

                            [data-theme="dark"] .page-hero-bg {
                                opacity: 0.25;
                                filter: contrast(1.1) brightness(0.6);
                            }

                            .page-hero::before {
                                content: '';
                                position: absolute;
                                inset: 0;
                                background: linear-gradient(135deg, var(--ink) 0%, var(--terra) 100%);
                                z-index: 0;
                            }

                            .page-hero-inner {
                                position: relative;
                                z-index: 2
                            }

                            .page-hero h1 {
                                font-family: 'Outfit', sans-serif;
                                font-size: clamp(2rem, 5vw, 3rem);
                                font-weight: 800;
                                color: #fff;
                                margin-bottom: 10px
                            }

                            /* DETAILS CARD */
                            .details-card {
                                background: var(--card-bg);
                                border-radius: 28px;
                                border: 1px solid var(--border);
                                padding: 40px;
                                margin-bottom: 32px;
                                box-shadow: 0 10px 40px var(--shadow);
                            }

                            .comp-header {
                                display: flex;
                                gap: 30px;
                                margin-bottom: 40px;
                                padding-bottom: 40px;
                                border-bottom: 1px solid var(--border);
                            }

                            .comp-logo {
                                width: 90px;
                                height: 90px;
                                border-radius: 22px;
                                background: linear-gradient(135deg, var(--coral), var(--rose));
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                font-size: 2.2rem;
                                font-weight: 800;
                                color: #fff;
                                flex-shrink: 0;
                            }

                            .comp-info h1 {
                                font-family: 'Outfit', sans-serif;
                                font-size: 2.4rem;
                                font-weight: 800;
                                color: var(--ink);
                                margin-bottom: 8px;
                                line-height: 1.2;
                            }

                            .comp-info .company-name {
                                font-size: 1.2rem;
                                color: var(--coral);
                                font-weight: 700;
                            }

                            .grid-info {
                                display: grid;
                                grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
                                gap: 20px;
                                margin-bottom: 48px;
                            }

                            .info-box {
                                padding: 24px;
                                border-radius: 20px;
                                background: var(--cream2);
                                border: 1px solid var(--border);
                                transition: .3s;
                            }

                            .info-box:hover {
                                transform: translateY(-4px);
                                border-color: var(--coral);
                            }

                            .info-box i {
                                color: var(--coral);
                                font-size: 1.4rem;
                                margin-bottom: 14px;
                                display: block;
                            }

                            .info-box .lbl {
                                font-size: 0.75rem;
                                color: var(--text-muted);
                                font-weight: 800;
                                text-transform: uppercase;
                                letter-spacing: 1px;
                                margin-bottom: 6px;
                            }

                            .info-box .val {
                                font-size: 1.15rem;
                                font-weight: 800;
                                color: var(--ink);
                            }

                            .sec {
                                margin-bottom: 48px;
                            }

                            .sec-title {
                                font-family: 'Outfit', sans-serif;
                                font-size: 1.7rem;
                                font-weight: 800;
                                color: var(--ink);
                                margin-bottom: 24px;
                                display: flex;
                                align-items: center;
                                gap: 12px;
                            }

                            .sec-title::after {
                                content: '';
                                flex: 1;
                                height: 1px;
                                background: var(--border);
                            }

                            .desc {
                                line-height: 1.8;
                                color: var(--text);
                                font-size: 1.1rem;
                            }

                            .tag-pill {
                                display: inline-block;
                                padding: 7px 18px;
                                border-radius: 50px;
                                background: rgba(217, 95, 59, 0.1);
                                color: var(--coral);
                                font-size: 0.85rem;
                                font-weight: 700;
                                margin: 0 10px 10px 0;
                            }

                            .form-sec {
                                padding: 44px;
                                border-radius: 28px;
                                background: var(--cream2);
                                border: 1.5px dashed var(--border);
                            }

                            .inp-field {
                                width: 100%;
                                padding: 15px 18px;
                                border-radius: 14px;
                                border: 1.5px solid var(--border);
                                background: var(--card-bg);
                                font-family: inherit;
                                font-size: 15px;
                                color: var(--text);
                                margin-bottom: 24px;
                                outline: none;
                                transition: .3s;
                            }

                            .inp-field:focus {
                                border-color: var(--coral);
                                box-shadow: 0 0 0 5px rgba(217, 95, 59, 0.1);
                            }

                            .btn-submit {
                                display: inline-flex;
                                align-items: center;
                                justify-content: center;
                                gap: 12px;
                                width: 100%;
                                padding: 18px;
                                border-radius: 16px;
                                background: linear-gradient(135deg, var(--coral), var(--rose));
                                color: #fff;
                                border: none;
                                font-size: 1.15rem;
                                font-weight: 800;
                                cursor: pointer;
                                transition: .4s;
                                box-shadow: 0 8px 30px rgba(217, 95, 59, 0.3);
                            }

                            .btn-submit:hover {
                                transform: translateY(-3px);
                                box-shadow: 0 12px 40px rgba(217, 95, 59, 0.4);
                            }

                            .applied-card {
                                text-align: center;
                                padding: 50px;
                                border-radius: 24px;
                                background: rgba(90, 122, 92, 0.1);
                                border: 1px solid var(--sage);
                                color: var(--sage);
                            }

                            /* MOBILE NAV */
                            .mobile-nav {
                                position: fixed;
                                inset: 0;
                                background: var(--ink);
                                z-index: 2000;
                                display: flex;
                                flex-direction: column;
                                padding: 32px 28px;
                                transform: translateX(100%);
                                transition: transform .4s cubic-bezier(0.4, 0, 0.2, 1)
                            }

                            .mobile-nav.open {
                                transform: translateX(0)
                            }

                            .mobile-links a {
                                text-decoration: none;
                                color: rgba(255, 248, 240, 0.85);
                                font-size: 1.5rem;
                                font-family: 'Outfit', sans-serif;
                                font-weight: 700;
                                padding: 12px 0;
                                display: block;
                                border-bottom: 1px solid rgba(255, 248, 240, 0.08)
                            }

                            /* RESPONSIVE */
                            @media(max-width:768px) {

                                .nav-links,
                                .nav-right .btn {
                                    display: none
                                }

                                .hamburger {
                                    display: flex
                                }

                                .comp-header {
                                    flex-direction: column;
                                    text-align: center;
                                    align-items: center;
                                    gap: 20px
                                }

                                .info-box {
                                    text-align: center
                                }

                                .info-box i {
                                    margin: 0 auto 14px
                                }

                                .details-card {
                                    padding: 25px
                                }

                                .form-sec {
                                    padding: 25px
                                }
                            }
                        </style>
                        <% if (typeof user !=='undefined' && user) { %>
                            <style>
                                @media(max-width:768px) {
                                    .nav-right .btn-fill {
                                        display: inline-flex !important;
                                        padding: 8px 16px;
                                        font-size: 13px;
                                    }
                            </style>
                            <% } %>
                            <style>
                                /* DARK MODE DYNAMIC BACKGROUND */
                            .dm-bg-blobs { position: fixed; inset: 0; z-index: -1; overflow: hidden; display: none; pointer-events: none; }
                            [data-theme="dark"] .dm-bg-blobs { display: block; }
                            .blob { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.12; animation: move-blobs 25s infinite alternate ease-in-out; }
                            .blob-1 { width: 400px; height: 400px; background: var(--coral); top: -100px; left: -100px; }
                            .blob-2 { width: 500px; height: 500px; background: var(--amber); bottom: -150px; right: 10%; }
                            @keyframes move-blobs {
                                0% { transform: translate(0, 0) scale(1); }
                                50% { transform: translate(100px, 50px) scale(1.1); }
                                100% { transform: translate(-50px, 100px) scale(0.9); }
                            }
                        </style>
</head>

<body>
    <div class="dm-bg-blobs">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>
    <!-- LOADER -->
    <div class="loader" id="loader">
        <div class="loader-logo">Conn<span>eto</span></div>
        <div class="loader-dots">
            <div></div>
            <div></div>
            <div></div>
        </div>
    </div>
    <script>
        (function() {
            const entry = performance.getEntriesByType('navigation')[0];
            const isReload = entry && entry.type === 'reload';
            const isFirstVisit = !sessionStorage.getItem('conneto_visited');
            if (!isReload && !isFirstVisit) {
                const ldr = document.getElementById('loader');
                if(ldr) { ldr.style.display = 'none'; ldr.classList.add('hide'); }
            }
        })();
    </script>

    <section class="page-hero" style="padding: 80px 0 40px !important;">
        <div class="page-hero-bg"></div>
        <div class="container page-hero-inner">
            <h1>Internship <em>Details</em></h1>
        </div>
    </section>


    <div class="container">
        <div style="margin-bottom: 30px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 15px;">
            <a href="/internships" class="btn btn-outline" style="border-radius: 50px; padding: 10px 24px; display: inline-flex; align-items: center; gap: 10px; font-weight: 700;">
                <i class="fas fa-arrow-left"></i> Back to Internships
            </a>
            <div class="breadcrumb" style="font-size: 14px; font-weight: 600; color: var(--text-muted);">
                <a href="/" style="text-decoration: none; color: var(--coral);">Home</a> / 
                <a href="/internships" style="text-decoration: none; color: var(--coral);">Internships</a> / 
                <span><%= internship.title %></span>
            </div>
        </div>

        <div class="details-card">
            <div class="comp-header">
                <div class="comp-logo">
                    <% var cName=internship.companyName || (internship.company && (internship.company.companyName || internship.company.name)) || 'Company'; %>
                        <%= cName.charAt(0).toUpperCase() %>
                </div>
                <div class="comp-info">
                    <h1>
                        <%= internship.title %>
                    </h1>
                    <p class="company-name" style="font-size: 1.1rem; color: var(--primary); font-weight: 600;">
                        <%= cName %>
                    </p>
                    <div class="tags-row" style="margin-top: 10px;">
                        <span class="tag-pill" style="background: var(--primary-light); color: var(--primary);">
                            <%= internship.type %>
                        </span>
                    </div>
                </div>
            </div>

            <div class="grid-info">
                <div class="info-box">
                    <i class="fas fa-map-marker-alt"></i>
                    <div class="lbl">Location</div>
                    <div class="val">
                        <%= internship.location || 'Remote' %>
                    </div>
                </div>
                <div class="info-box">
                    <i class="fas fa-clock"></i>
                    <div class="lbl">Duration</div>
                    <div class="val">
                        <%= internship.duration || 'Flexible' %>
                    </div>
                </div>
                <div class="info-box">
                    <i class="fas fa-rupee-sign"></i>
                    <div class="lbl">
                        <% if (internship.paymentCategory === 'stipend') { %> Stipend 
                        <% } else if (internship.paymentCategory === 'paid') { %> Training Fee
                        <% } else { %> Payment <% } %>
                    </div>
                    <div class="val">
                        <% if (internship.paymentCategory === 'stipend') { %> ₹<%= internship.stipend %>/mo
                        <% } else if (internship.paymentCategory === 'paid') { %> ₹<%= internship.fee %> (One-time)
                        <% } else { %> Unpaid <% } %>
                    </div>
                </div>
                <div class="info-box">
                    <i class="fas fa-calendar-alt"></i>
                    <div class="lbl">Deadline</div>
                    <div class="val">
                        <%= internship.deadline ? new Date(internship.deadline).toLocaleDateString() : 'Rolling' %>
                    </div>
                </div>
            </div>

            <div class="sec">
                <h2 class="sec-title">About the Role</h2>
                <div class="desc">
                    <%= internship.description %>
                </div>
            </div>

            <% if (internship.skills && internship.skills.length> 0) { %>
                <div class="sec">
                    <h2 class="sec-title">Required Skills</h2>
                    <div class="skill-row">
                        <% internship.skills.forEach(skill=> { %>
                            <span class="tag-pill">
                                <%= skill %>
                            </span>
                            <% }) %>
                    </div>
                </div>
                <% } %>

                    <div class="form-sec">
                        <% if (user && user.role==='student' ) { %>
                            <% if (hasApplied) { %>
                                <div class="applied-card">
                                    <i class="fas fa-check-circle" style="font-size: 3rem; margin-bottom: 20px;"></i>
                                    <h2>Application Submitted</h2>
                                    <p>You have already applied for this position. Check your
                                        dashboard for updates.</p>
                                </div>
                                <% } else { %>
                                    <h2 class="sec-title" style="margin-bottom:6px">Apply to <em><%= internship.title %></em></h2>
                                    
                                    <!-- Portfolio Completion Gate -->
                                    <% var pct = studentProfile ? (studentProfile.completionPercentage || 0) : 0; %>
                                    <% if (pct < 100) { %>
                                        <div style="background: rgba(181,56,74,0.08); border: 1.5px solid var(--rose); border-radius: 22px; padding: 32px 24px; margin-bottom: 30px; text-align:center;">
                                            <div style="width:70px; height:70px; background:rgba(181,56,74,0.1); color:var(--rose); border-radius:20px; display:flex; align-items:center; justify-content:center; margin:0 auto 18px; font-size:2rem">
                                                <i class="fas fa-lock"></i>
                                            </div>
                                            <h3 style="color:var(--rose); margin-bottom:10px; font-size:1.4rem">Portfolio Incomplete (<%= pct %>%)</h3>
                                            <p style="color:var(--text-muted); margin-bottom:24px; font-size:14px; max-width:400px; margin-left:auto; margin-right:auto">Recruiters require <strong>100% profile completion</strong> to review your eligibility. Please complete all fields including Academic info, USN, and Location.</p>
                                            <a href="/student/dashboard?tab=profile" class="btn-submit" style="text-decoration:none; width:auto; padding:14px 32px; font-size:15px; display:inline-flex; background:var(--rose); color:#fff">
                                                <i class="fas fa-magic" style="margin-right:8px"></i> Complete Portfolio to Unlock
                                            </a>
                                        </div>
                                    <% } else { %>

                                    <!-- 100% Profile Complete Banner -->
                                    <div style="background: rgba(90,122,92,0.08); border: 1px solid var(--sage); border-radius: 16px; padding: 14px 22px; margin-bottom: 24px; display:flex; align-items:center; gap:10px;">
                                        <i class="fas fa-shield-alt" style="color:var(--sage); font-size:1.4rem;"></i>
                                        <div>
                                            <div style="font-weight:800; color:var(--sage); font-size:13px">100% Profile Complete</div>
                                            <div style="font-size:12px; color:var(--text-muted)">Your full profile will be sent to the recruiter automatically.</div>
                                        </div>
                                    </div>

                                    <form action="/internships/<%= internship._id %>/apply" method="POST" enctype="multipart/form-data">
                                        <!-- Hidden: auto-fill from profile -->
                                        <% if (studentProfile && studentProfile.skills && studentProfile.skills.length > 0) { %>
                                            <input type="hidden" name="studentSkills" value="<%= studentProfile.skills.join(', ') %>">
                                        <% } else { %>
                                            <div style="margin-bottom:20px">
                                                <label class="lbl" style="display:block; margin-bottom:8px; font-size:11px; font-weight:800; text-transform:uppercase; color:var(--text-muted)">Your Key Skills</label>
                                                <input type="text" name="studentSkills" class="inp-field" placeholder="e.g. React, Python, Figma..." style="margin-bottom:0">
                                            </div>
                                        <% } %>
                                        
                                        <!-- Review Your Profile -->
                                        <% if (studentProfile) { %>
                                        <div style="background: var(--card-bg); border: 1.5px solid var(--border); border-radius: 20px; padding: 24px; margin-bottom: 24px;">
                                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:18px;">
                                                <div style="font-size:11px; font-weight:900; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; border-left:3px solid var(--coral); padding-left:10px">
                                                    <i class="fas fa-id-badge"></i> Your Info — Sent to Recruiter
                                                </div>
                                                <a href="/student/dashboard?tab=profile" style="font-size:11px; color:var(--coral); font-weight:700; text-decoration:none"><i class="fas fa-pen"></i> Edit Profile</a>
                                            </div>
                                            
                                            <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 20px; font-size:13px;">
                                                <!-- Basic Info Group -->
                                                <div style="display:flex; flex-direction:column; gap:8px">
                                                    <div style="font-size:10px; font-weight:900; color:var(--coral); text-transform:uppercase">Basic Information</div>
                                                    <div style="display:flex; flex-direction:column; gap:4px">
                                                        <span style="font-size:10px; font-weight:800; color:var(--text-muted); text-transform:uppercase">Full Name / USN</span>
                                                        <span style="font-weight:700; color:var(--ink)"><%= user.name %> (<%= studentProfile.usn || 'N/A' %>)</span>
                                                    </div>
                                                    <div style="display:flex; flex-direction:column; gap:4px">
                                                        <span style="font-size:10px; font-weight:800; color:var(--text-muted); text-transform:uppercase">DOB / Gender</span>
                                                        <span style="font-weight:600; color:var(--ink)">
                                                            <%= studentProfile.dob ? new Date(studentProfile.dob).toLocaleDateString() : 'N/A' %> | <%= studentProfile.gender || 'N/A' %>
                                                        </span>
                                                    </div>
                                                </div>

                                                <!-- Academic Group -->
                                                <div style="display:flex; flex-direction:column; gap:8px">
                                                    <div style="font-size:10px; font-weight:900; color:var(--coral); text-transform:uppercase">Academic Details</div>
                                                    <div style="display:flex; flex-direction:column; gap:4px">
                                                        <span style="font-size:10px; font-weight:800; color:var(--text-muted); text-transform:uppercase">Course / Dept</span>
                                                        <span style="font-weight:600; color:var(--ink)"><%= studentProfile.degree || 'N/A' %> - <%= studentProfile.department || 'N/A' %></span>
                                                    </div>
                                                    <div style="display:flex; flex-direction:column; gap:4px">
                                                        <span style="font-size:10px; font-weight:800; color:var(--text-muted); text-transform:uppercase">Sem / GPA</span>
                                                        <span style="font-weight:600; color:var(--ink)">Sem <%= studentProfile.semester || 'N/A' %> | GPA <%= studentProfile.gpa || 'N/A' %></span>
                                                    </div>
                                                </div>

                                                <!-- Location Group -->
                                                <div style="display:flex; flex-direction:column; gap:8px">
                                                    <div style="font-size:10px; font-weight:900; color:var(--coral); text-transform:uppercase">Location</div>
                                                    <div style="display:flex; flex-direction:column; gap:4px">
                                                        <span style="font-size:10px; font-weight:800; color:var(--text-muted); text-transform:uppercase">Address</span>
                                                        <span style="font-weight:600; color:var(--ink)"><%= studentProfile.address || 'N/A' %></span>
                                                    </div>
                                                    <div style="display:flex; flex-direction:column; gap:4px">
                                                        <span style="font-size:10px; font-weight:800; color:var(--text-muted); text-transform:uppercase">City / State</span>
                                                        <span style="font-weight:600; color:var(--ink)"><%= studentProfile.city || 'N/A' %>, <%= studentProfile.state || 'N/A' %></span>
                                                    </div>
                                                </div>

                                                <!-- Additional Group -->
                                                <div style="display:flex; flex-direction:column; gap:8px">
                                                    <div style="font-size:10px; font-weight:900; color:var(--coral); text-transform:uppercase">Additional Info</div>
                                                    <div style="display:flex; flex-direction:column; gap:4px">
                                                        <span style="font-size:10px; font-weight:800; color:var(--text-muted); text-transform:uppercase">Interests</span>
                                                        <span style="font-weight:600; color:var(--ink)"><%= studentProfile.interests && studentProfile.interests.length > 0 ? studentProfile.interests.join(', ') : 'N/A' %></span>
                                                    </div>
                                                    <div style="display:flex; flex-direction:column; gap:4px">
                                                        <span style="font-size:10px; font-weight:800; color:var(--text-muted); text-transform:uppercase">College</span>
                                                        <span style="font-weight:600; color:var(--ink)"><%= studentProfile.college || 'N/A' %></span>
                                                    </div>
                                                </div>
                                            </div>

                                            <% if (studentProfile.skills && studentProfile.skills.length > 0) { %>
                                            <div style="margin-top:18px; padding-top:18px; border-top: 1px solid var(--border)">
                                                <span style="font-size:10px; font-weight:800; color:var(--text-muted); text-transform:uppercase; display:block; margin-bottom:8px">Skills Tracking</span>
                                                <div style="display:flex; flex-wrap:wrap; gap:6px">
                                                    <% studentProfile.skills.forEach(s => { %>
                                                        <span style="padding:4px 12px; background:rgba(217,95,59,0.08); color:var(--coral); border-radius:8px; font-size:11px; font-weight:800"><%= s %></span>
                                                    <% }) %>
                                                </div>
                                            </div>
                                            <% } %>
                                        </div>
                                        <% } %>

                                        <!-- The one question student must answer -->
                                        <div style="margin-bottom:20px">
                                            <label class="lbl" style="display:block; margin-bottom:8px; font-size:11px; font-weight:800; text-transform:uppercase; color:var(--text-muted)">Message to Recruiter *</label>
                                            <textarea name="question1Answer" class="inp-field" style="min-height: 130px; margin-bottom:0" placeholder="Write a short message explaining why you're a good fit for this internship..." required maxlength="1000"></textarea>
                                            <div style="text-align:right; font-size:11px; color:var(--text-muted); margin-top:4px" id="msgCount">0/1000</div>
                                        </div>
                                        
                                        <input type="hidden" name="question2Answer" value="Ready to start immediately">

                                        <label class="lbl" style="display: block; margin-bottom: 8px; font-size:11px; font-weight:800; text-transform:uppercase; color:var(--text-muted)">Resume (PDF) *</label>
                                        <% if (studentProfile && studentProfile.resumeUrl) { %>
                                        <div style="margin-bottom:14px; display:flex; align-items:center; gap:12px">
                                            <a href="/view-resume?url=<%= encodeURIComponent(studentProfile.resumeUrl) %>" target="_blank" style="font-size:13px; color:var(--sage); font-weight:700; text-decoration:none"><i class="fas fa-file-check"></i> Profile Resume Available</a>
                                            <span style="font-size:12px; color:var(--text-muted)">or upload a new one:</span>
                                        </div>
                                        <input type="file" name="resume" class="inp-field" accept="application/pdf" style="margin-bottom:24px">
                                        <% } else { %>
                                        <input type="file" name="resume" class="inp-field" accept="application/pdf" required style="margin-bottom:24px">
                                        <% } %>

                                        <button type="submit" class="btn-submit">
                                            <i class="fas fa-paper-plane"></i> Submit Application
                                        </button>
                                    </form>
                                    
                                    <% } %> <!-- end portfolio gate -->
                                    <% } %>
                                        <% } else if (!user) { %>
                                            <div style="text-align: center;">
                                                <h2 class="sec-title">Login to Apply</h2>
                                                <p class="desc" style="margin-bottom: 24px;">
                                                    Please login as a student to submit your
                                                    application.</p>
                                                <a href="/auth/login" class="btn-submit"
                                                    style="text-decoration: none;">Login Now</a>
                                            </div>
                                            <% } else { %>
                                                <div style="text-align: center;">
                                                    <h2 class="sec-title">Company View</h2>
                                                    <p class="desc">You are viewing this as a
                                                        company representative.</p>
                                                </div>
                                                <% } %>
                    </div>
        </div>

    </div>

    <script>
        // Message character counter
        const msgTextarea = document.querySelector('textarea[name="question1Answer"]');
        const msgCount = document.getElementById('msgCount');
        if (msgTextarea && msgCount) {
            msgTextarea.addEventListener('input', function() {
                msgCount.textContent = this.value.length + '/1000';
            });
        }

        // LOADER Logic
        window.addEventListener('load', () => {
            const loader = document.getElementById('loader');
            const entry = performance.getEntriesByType('navigation')[0];
            const navigationType = entry ? entry.type : '';
            const isReload = navigationType === 'reload';
            const isFirstVisit = !sessionStorage.getItem('conneto_visited');

            if (isReload || isFirstVisit) {
                // Show loader for 1.2s on INITIAL START or REFRESH
                setTimeout(() => {
                    loader.classList.add('hide');
                    sessionStorage.setItem('conneto_visited', 'true');
                }, 1200);
            } else {
                // Direct redirect for header links
                loader.style.display = 'none';
                loader.classList.add('hide');
            }
        });

        // THEME
        const themeToggle = document.getElementById('themeToggle');
        const html = document.documentElement;
        function updateTheme() {
            const t = html.getAttribute('data-theme');
            if (themeToggle) {
                themeToggle.innerHTML = t === 'dark' ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
            }
        }
        if (themeToggle) {
            themeToggle.addEventListener('click', () => {
                const current = html.getAttribute('data-theme');
                const next = current === 'dark' ? 'light' : 'dark';
                html.setAttribute('data-theme', next);
                localStorage.setItem('conneto-theme', next);
                updateTheme();
            });
        }
        updateTheme();

        // MOBILE NAV
        const hamburger = document.getElementById('hamburger');
        const mobileClose = document.getElementById('mobileClose');
        const mobileNav = document.getElementById('mobileNav');
        if (hamburger) hamburger.addEventListener('click', () => mobileNav.classList.add('open'));
        if (mobileClose) mobileClose.addEventListener('click', () => mobileNav.classList.remove('open'));
    </script>
</body>

</html>