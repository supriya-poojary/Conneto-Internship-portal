<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Internships | Conneto</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Poppins:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-main: #030a16;
            --bg-card: #0a162d;
            --bg-sidebar: #01050b;
            --accent: #38bdf8;
            --accent-glow: rgba(56, 189, 248, 0.3);
            --text-main: #f4f4f5;
            --text-muted: #94a3b8;
            --border: rgba(255, 255, 255, 0.1);
            --success: #10B981;
            --danger: #EF4444;
            --shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-main);
            color: var(--text-main);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        .header {
            background: var(--bg-sidebar);
            padding: 16px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-family: 'Poppins', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
            text-decoration: none;
        }

        .logo span {
            color: var(--accent);
        }

        .nav-links {
            display: flex;
            gap: 24px;
        }

        .nav-link {
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 600;
            transition: all 0.3s;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .nav-link:hover,
        .nav-link.active {
            color: #fff;
        }

        .container {
            max-width: 1200px;
            margin: 60px auto;
            padding: 0 40px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        h1 {
            font-family: 'Poppins', sans-serif;
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .btn-create {
            padding: 14px 28px;
            background: var(--accent);
            color: #fff;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s;
            box-shadow: 0 4px 15px var(--accent-glow);
        }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px var(--accent-glow);
            filter: brightness(1.1);
        }

        .internships-grid {
            display: grid;
            gap: 24px;
        }

        .internship-card {
            background: var(--bg-card);
            border-radius: 24px;
            padding: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid var(--border);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .internship-card:hover {
            transform: scale(1.01);
            border-color: rgba(56, 189, 248, 0.3);
            background: rgba(255, 255, 255, 0.015);
        }

        .internship-info h3 {
            font-size: 1.4rem;
            margin-bottom: 8px;
            color: #fff;
        }

        .internship-meta {
            display: flex;
            gap: 20px;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .status-pill {
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .status-active {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .status-inactive {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .stats-summary {
            display: flex;
            gap: 40px;
            text-align: center;
            padding: 0 40px;
            border-left: 1px solid var(--border);
            border-right: 1px solid var(--border);
        }

        .stat-item .count {
            display: block;
            font-size: 1.8rem;
            font-weight: 800;
            color: #fff;
        }

        .stat-item .label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
        }

        .actions {
            display: flex;
            gap: 12px;
        }

        .btn-action {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.2s;
            border: 1px solid var(--border);
            cursor: pointer;
            background: rgba(255, 255, 255, 0.03);
            font-size: 1.1rem;
        }

        .btn-edit {
            color: var(--accent);
        }

        .btn-edit:hover {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

        .btn-delete {
            color: var(--danger);
        }

        .btn-delete:hover {
            background: var(--danger);
            color: white;
            border-color: var(--danger);
        }

        .empty-state {
            text-align: center;
            padding: 100px 40px;
            background: var(--bg-card);
            border-radius: 32px;
            border: 2px dashed var(--border);
        }

        .empty-icon {
            font-size: 4rem;
            color: var(--text-muted);
            margin-bottom: 24px;
            opacity: 0.3;
        }
    </style>


    <!-- Prevent FOUT -> Pre-load Theme -->
    <script>
        (function () {
            var saved = localStorage.getItem('conneto-theme');
            if (saved !== 'light') {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>

<body>
    <header class="header">
        <a href="/" class="logo">Conneto</a>
        <nav class="nav-links">
            <a href="/company/dashboard" class="nav-link">Dashboard</a>
            <a href="/company/internships" class="nav-link active">Manage Internships</a>
            <a href="/company/applications" class="nav-link">Applications</a>
        </nav>
        <div style="display: flex; align-items: center; gap: 12px;">
            <div
                style="width: 36px; height: 36px; border-radius: 50%; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700;">
                <%= user.name.charAt(0) %>
            </div>
            <a href="/auth/logout" class="nav-link"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </header>

    <div class="container">
        <div class="page-header">
            <div>
                <h1>Manage Internships</h1>
                <p style="color: var(--text-muted);">Track and manage your internship postings</p>
            </div>
            <a href="/company/internships/create" class="btn-create">
                <i class="fas fa-plus"></i> Post New Internship
            </a>
        </div>

        <% if (internships && internships.length> 0) { %>
            <div class="internships-grid">
                <% internships.forEach(internship=> { %>
                    <div class="internship-card">
                        <div class="internship-info">
                            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                                <h3>
                                    <%= internship.title %>
                                </h3>
                                <span
                                    class="status-pill <%= internship.isActive ? 'status-active' : 'status-inactive' %>">
                                    <%= internship.isActive ? 'Active' : 'Inactive' %>
                                </span>
                            </div>
                            <div class="internship-meta">
                                <span><i class="fas fa-map-marker-alt"></i>
                                    <%= internship.location || 'Remote' %>
                                </span>
                                <span><i class="fas fa-clock"></i>
                                    <%= internship.duration %>
                                </span>
                                <span><i class="fas fa-calendar-alt"></i> Posted: <%= new
                                        Date(internship.createdAt).toLocaleDateString() %></span>
                            </div>
                        </div>

                        <div class="stats-summary">
                            <div class="stat-item">
                                <span class="count">
                                    <%= internship.stats.total %>
                                </span>
                                <span class="label">Applicants</span>
                            </div>
                            <div class="stat-item">
                                <span class="count">
                                    <%= internship.stats.selected %>
                                </span>
                                <span class="label">Hired</span>
                            </div>
                        </div>

                        <div class="actions">
                            <a href="/company/internships/<%= internship._id %>/edit" class="btn-action btn-edit"
                                title="Edit">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form action="/company/internships/<%= internship._id %>/delete" method="POST"
                                onsubmit="return confirm('Are you sure you want to delete this internship? All applications will also be removed.')"
                                style="margin: 0;">
                                <button type="submit" class="btn-action btn-delete" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                    <% }) %>
            </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-briefcase"></i></div>
                    <h2>No internships posted yet</h2>
                    <p style="color: var(--text-muted); margin-bottom: 24px;">Start by posting your first internship
                        opportunity!</p>
                    <a href="/company/internships/create" class="btn-create" style="display: inline-flex;">Post
                        Internship</a>
                </div>
                <% } %>
    </div>
</body>

</html>