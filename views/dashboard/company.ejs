                                                    &bull; Ends: <%= new Date(item.deadline).toLocaleString([], { dateStyle: 'medium', timeStyle: 'short' }) %>
                                                <% } %>
                                            </div>
                                        </div>
                                        <span class="status-pill active">
                                            <%= item.isActive ? 'Active' : 'Draft' %>
                                        </span>
                                    </div>
                                    <% }); %>
                                        <% } else { %>
                                            <div style="text-align:center; padding: 40px 0; color:var(--text-muted)">
                                                <p>You haven't posted any roles yet.</p>
                                                <a href="/company/internships/create"
                                                    style="color:var(--coral); font-weight:700; text-decoration:none; margin-top:10px; display:inline-block">Click
                                                    here to start →</a>
                                            </div>
                                            <% } %>
                        </div>
                    </div>

                    <div class="card reveal">
                        <div class="card-header">
                            <h2 class="card-title"><i class="fas fa-users-rays"></i> Recent Talent</h2>
                            <a href="/company/dashboard?tab=applications" class="view-btn">Pipeline Center</a>
                        </div>
                        <div class="item-list">
                            <% if (applicants && applicants.length> 0) { %>
                                <% applicants.slice(0, 4).forEach(function(app) { %>
                                    <div class="item-row">
                                        <div class="item-icon" style="background:var(--amber)">
                                            <%= app.student ? app.student.name.charAt(0).toUpperCase() : 'S' %>
                                        </div>
                                        <div style="flex:1">
                                            <div style="font-weight:700; color:var(--ink); font-size:15px">
                                                <%= app.student ? app.student.name : 'Unknown Candidate' %>
                                            </div>
                                            <div style="font-size:13px; color:var(--text-muted); font-weight:600">
                                                <%= app.internship ? app.internship.title : 'Internal Role' %>
                                            </div>
                                        </div>
                                        <span class="status-pill applied">
                                            <%= app.status ? app.status.replace(/_/g, ' ' ) : 'New' %>
                                        </span>
                                    </div>
                                    <% }); %>
                                        <% } else { %>
                                            <div style="text-align:center; padding: 40px 0; color:var(--text-muted)">
                                                <p>Awaiting new applications.</p>
                                            </div>
                                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="column" style="width: 100%;">
                    <div class="card reveal">
                        <div class="company-profile-card">
                            <div class="company-avatar-lg">
                                <%= user.name.charAt(0).toUpperCase() %>
                            </div>
                            <div class="company-display-name">
                                <%= user.companyName || user.name %>
                            </div>
                            <div class="company-display-email">
                                <%= user.email %>
                            </div>
                        </div>
                        <a href="/company/internships/create" class="post-btn">
                            <i class="fas fa-plus-circle"></i> Create New Opening
                        </a>
                    </div>

                    <div class="card reveal" style="background: var(--section-alt);">
                        <div class="card-header">
                            <h2 class="card-title" style="font-size:1.1rem"><i class="fas fa-bullseye"></i> Goal
                                Tracking</h2>
                        </div>
                        <% const total=stats ? stats.totalApplicants : 0; const pct=(n)=> total > 0 ? Math.round((n /
                            total) * 100) : 0; %>
                            <div style="display:flex; flex-direction:column; gap:20px">
                                <div class="progress-section">
                                    <div class="progress-title"><span>Review Phase</span><span>
                                            <%= pct(total - (stats ? stats.interviews + stats.hired : 0)) %>%
                                        </span></div>
                                    <div class="progress-bar">
                                        <div class="progress-fill"
                                            style="width: <%= pct(total - (stats ? stats.interviews + stats.hired : 0)) %>%">
                                        </div>
                                    </div>
                                </div>
                                <div class="progress-section">
                                    <div class="progress-title"><span>Interview Stage</span><span>
                                            <%= pct(stats ? stats.interviews : 0) %>%
                                        </span></div>
                                    <div class="progress-bar">
                                        <div class="progress-fill"
                                            style="width: <%= pct(stats ? stats.interviews : 0) %>%; background:var(--amber)">
                                        </div>
                                    </div>
                                </div>
                                <div class="progress-section">
                                    <div class="progress-title"><span>Final Selection</span><span>
                                            <%= pct(stats ? stats.hired : 0) %>%
                                        </span></div>
                                    <div class="progress-bar">
                                        <div class="progress-fill"
                                            style="width: <%= pct(stats ? stats.hired : 0) %>%; background:var(--sage)">
                                        </div>
                                    </div>
                                </div>
                            </div>
                    </div>
                </div>
            </div>

            <% } else if (activePage==='applications' ) { %>
                <div class="card reveal" style="margin-top: 20px;">
                    <% if (groupedApplications && groupedApplications.length> 0) { %>
                        <% groupedApplications.forEach(function(group) { %>
                            <div
                                style="margin-bottom: 30px; border-bottom: 2px solid var(--border); padding-bottom: 20px;">
                                <h3
                                    style="font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--coral); margin-bottom: 15px;">
                                    <%= group.internship.title %>
                                        <span
                                            style="font-size: 0.9rem; color: var(--text-muted); font-family: inherit;">(
                                            <%= group.applications.length %> Applicants)
                                        </span>
                                </h3>

                                <div class="item-list">
                                    <% group.applications.forEach(function(app) { %>
                                        <% var p=app.profile || {}; %>
                                            <div class="item-row"
                                                style="background: var(--card-bg); padding: 20px 24px;">
                                                <div class="item-icon" style="background: var(--sage);">
                                                    <%= app.student ? app.student.name.charAt(0).toUpperCase() : 'S' %>
                                                </div>
                                                <div style="flex:1">
                                                    <div style="font-weight:700; color:var(--ink); font-size:16px">
                                                        <%= app.student ? app.student.name : 'Candidate' %>
                                                    </div>
                                                    <div
                                                        style="font-size:12px; color:var(--text-muted); font-weight: 600;">
                                                        <%= p.college || 'University Not Shared' %> &bull; <%= p.degree
                                                                || 'Degree Unknown' %>
                                                    </div>
                                                </div>
                                                <div style="display:flex; align-items: center; gap: 20px;">
                                                    <span class="status-pill <%= app.status %>">
                                                        <%= app.status.replace(/_/g, ' ' ) %>
                                                    </span>
                                                    <% if (app.rescheduleRequest) { %>
                                                        <span class="notify-badge" style="background:var(--rose); color:#fff; padding:4px 10px; border-radius:100px; font-size:10px; font-weight:800; animation: pulse 2s infinite">
                                                            <i class="fas fa-calendar-alt"></i> RESCHEDULE
                                                        </span>
                                                    <% } %>
                                                    <button onclick="showProfile('<%= app._id %>')" class="view-btn">
                                                        <i class="fas fa-eye"></i> View Application
                                                    </button>
                                                </div>

                                                <script>
                                                    if (!window.candidateProfiles) window.candidateProfiles = {};
                                                    window.candidateProfiles['<%= app._id %>'] = <%- JSON.stringify({
                                                        id: app._id,
                                                        status: app.status,
                                                        name: app.student ? app.student.name : '',
                                                        email: app.student ? app.student.email : '',
                                                        phone: (app.student && app.student.phone) ? app.student.phone : (p.phone || ''),
                                                        college: p.college || '',
                                                        usn: p.usn || '',
                                                        degree: p.degree || '',
                                                        department: p.department || '',
                                                        semester: p.semester || '',
                                                        year: p.year || '',
                                                        gpa: p.gpa || '',
                                                        dob: p.dob || '',
                                                        gender: p.gender || '',
                                                        address: p.address || '',
                                                        city: p.city || '',
                                                        state: p.state || '',
                                                        country: p.country || '',
                                                        bio: p.bio || '',
                                                        experience: p.experience || '',
                                                        projects: p.projects || '',
                                                        interests: p.interests || [],
                                                        certifications: p.certifications || '',
                                                        languages: p.languages || '',
                                                        skills: p.skills || [],
                                                        linkedin: p.linkedin || '',
                                                        github: p.github || '',
                                                        coverLetter: app.coverLetter || '',
                                                        studentSkills: app.studentSkills || '',
                                                        q1: app.question1Answer || '',
                                                        q2: app.question2Answer || '',
                                                        appliedAt: app.appliedAt,
                                                        resumeUrl: app.resumeUrl,
                                                        interviewDate: app.interviewDate,
                                                        rescheduleRequest: app.rescheduleRequest || false,
                                                        rescheduleReason: app.rescheduleReason || '',
                                                        suggestedDate: app.suggestedInterviewDate
                                                    }) %>;
                                                </script>
                                            </div>
                                            <% }); %>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div style="text-align: center; padding: 60px 20px;">
                                        <i class="fas fa-users-slash"
                                            style="font-size: 3rem; color: var(--border); margin-bottom: 20px;"></i>
                                        <h2>No applications yet</h2>
                                        <p style="color: var(--text-muted); margin-bottom: 20px;">Applications for your
                                            internships will appear here.</p>
                                    </div>
                                    <% } %>
                </div>
                <% } else if (activePage==='internships' ) { %>
                    <style>
                        .btn-action-group {
                            display: flex;
                            gap: 8px;
                        }

                        .btn-mini {
                            width: 32px;
                            height: 32px;
                            border-radius: 8px;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            text-decoration: none;
                            font-size: 14px;
                            transition: .3s;
                        }

                        .btn-mini-edit {
                            background: rgba(217, 95, 59, 0.1);
                            color: var(--coral);
                        }

                        .btn-mini-del {
                            background: rgba(181, 56, 74, 0.1);
                            color: var(--rose);
                            border: none;
                            cursor: pointer;
                        }
                    </style>

                    <div class="card reveal" style="margin-top: 20px;">
                        <div
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                            <h2 class="card-title"><i class="fas fa-briefcase"></i> Managed Postings</h2>
                            <a href="/company/internships/create" class="view-btn"
                                style="background: var(--coral); color: #fff;">+ Post New</a>
                        </div>

                        <div class="item-list">
                            <% if (myInternships && myInternships.length> 0) { %>
                                <% myInternships.forEach(function(item) { %>
                                    <div class="item-row"
                                        style="background: var(--card-bg); flex-wrap: wrap; gap: 12px;">
                                        <div class="item-icon">
                                            <%= item.title.charAt(0).toUpperCase() %>
                                        </div>
                                        <div style="flex:1; min-width: 150px;">
                                            <div style="font-weight:700; color:var(--ink); font-size:16px">
                                                <%= item.title %>
                                            </div>
                                            <div style="font-size:13px; color:var(--text-muted); line-height: 1.4;">
                                                <%= item.location || 'Remote' %> &bull; <%= item.stats ?
                                                        item.stats.total : 0 %> Applicants
                                                <% if (item.deadline) { %>
                                                    &bull; <i class="far fa-clock"></i> Ends: <%= new Date(item.deadline).toLocaleString([], { dateStyle: 'medium', timeStyle: 'short' }) %>
                                                <% } %>
                                            </div>
                                        </div>
                                        <div
                                            style="display:flex; gap: 15px; align-items: center; justify-content: flex-end; flex: 1; min-width: 100px;">
                                            <span
                                                class="status-pill <%= item.isActive ? 'status-active' : 'status-draft' %>">
                                                <%= item.isActive ? 'Active' : 'Draft' %>
                                            </span>
                                            <div class="btn-action-group">
                                                <a href="/company/internships/<%= item._id %>/edit"
                                                    class="btn-mini btn-mini-edit" title="Edit"><i
                                                        class="fas fa-edit"></i></a>
                                                <form action="/company/internships/<%= item._id %>/delete" method="POST"
                                                    onsubmit="return confirm('Delete this posting?')">
                                                    <button type="submit" class="btn-mini btn-mini-del"
                                                        title="Delete"><i class="fas fa-trash"></i></button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                    <% }); %>
                                        <% } else { %>
                                            <div style="text-align: center; padding: 60px 20px;">
                                                <i class="fas fa-folder-open"
                                                    style="font-size: 3rem; color: var(--border); margin-bottom: 20px;"></i>
                                                <h2>No postings yet</h2>
                                                <a href="/company/internships/create"
                                                    style="color: var(--coral); font-weight: 700;">Post your first
                                                    internship →</a>
                                            </div>
                                            <% } %>
                        </div>
                    </div>
                    <% } else if (activePage === 'evaluations') { %>
                        <div class="card reveal" style="margin-top: 20px;">
                            <div class="card-header" style="display: flex; flex-direction: column; align-items: flex-start; gap: 20px;">
                                <div style="width: 100%;">
                                    <h2 class="card-title"><i class="fas fa-book-open"></i> Internship Diary Progress</h2>
                                    <p style="font-size: 0.9rem; color: var(--text-muted); font-weight: 500;">Select a student from the choice bar to review their daily logs and manage final evaluation.</p>
                                </div>
                                <div style="width: 100%; max-width: 500px; position: relative; margin-bottom: 10px;">
                                    <label style="display:block; font-size:11px; font-weight:800; color:var(--text-muted); text-transform:uppercase; margin-bottom:10px;">Target Student & Role</label>
                                    <div style="position: relative;">
                                        <select id="diaryStudentSelect" onchange="selectStudentDiary(this.value)" style="width:100%; padding:14px 18px; padding-right: 40px; border:2px solid var(--border); border-radius:14px; background:var(--card-bg); color:var(--text); font-family:inherit; outline:none; cursor:pointer; font-weight: 600; font-size: 14px; appearance: none; -webkit-appearance: none; box-shadow: 0 4px 15px rgba(0,0,0,0.02); transition: 0.3s;" onfocus="this.style.borderColor='var(--coral)'" onblur="this.style.borderColor='var(--border)'">
                                            <option value="" disabled selected>-- Click to Choose a Candidate --</option>
                                            <% if (evaluationData && evaluationData.length > 0) { %>
                                                <% evaluationData.forEach(function(studentData) { %>
                                                    <option value="<%= studentData.applicationId %>">
                                                        <%= studentData.student.name %> | <%= studentData.internship.title %>
                                                        <%= studentData.pendingCount > 0 ? ` [${studentData.pendingCount} Pending]` : '' %>
                                                    </option>
                                                <% }); %>
                                            <% } else { %>
                                                <option value="" disabled>No active interns found</option>
                                            <% } %>
                                        </select>
                                        <i class="fas fa-chevron-down" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: var(--coral); pointer-events: none; font-size: 14px;"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="diary-content" style="padding-top: 20px; border-top: 1px solid var(--border);">
                                <div id="noStudentChosen" class="empty-panel-msg" style="text-align: center; padding: 60px 20px; background: rgba(0,0,0,0.01); border-radius: 20px;">
                                    <i class="fas fa-hand-pointer" style="font-size: 3rem; color: var(--border); margin-bottom: 25px;"></i>
                                    <h2 style="font-family:'Playfair Display', serif; color: var(--ink)">Select a Student Above</h2>
                                    <p style="max-width: 350px; margin: 0 auto; margin-top: 10px; color: var(--text-muted)">Use the choice bar above to select an intern and view their daily evaluation data.</p>
                                </div>

                                <% if (evaluationData && evaluationData.length > 0) { %>
                                    <% evaluationData.forEach(function(studentData) { %>
                                        <div class="student-diary-details" id="details-<%= studentData.applicationId %>" style="display: none;">
                                            <div class="diary-student-header" style="margin-bottom: 30px; border-bottom: 1px solid var(--border); padding-bottom: 20px;">
                                                <div>
                                                    <h3 style="font-family:'Playfair Display', serif; font-size:1.8rem; margin:0; color:var(--ink)"><%= studentData.student.name %></h3>
                                                    <p style="font-size:14px; color:var(--text-muted); font-weight: 600; margin-top: 5px">
                                                        <i class="fas fa-id-card" style="margin-right: 8px"></i> Role: <%= studentData.internship.title %>
                                                    </p>
                                                </div>
                                                <div style="text-align:right">
                                                    <div style="font-size:11px; font-weight:800; color:var(--text-muted); text-transform:uppercase; margin-bottom:8px">Log Validation Progress</div>
                                                    <div style="font-size:24px; font-weight:900; color:var(--sage)"><%= studentData.approvedCount %> / <%= studentData.requiredDiaries %> Approved</div>
                                                </div>
                                            </div>

                                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap: wrap; gap: 15px;">
                                                <h4 class="portfolio-section-title" style="margin:0"><i class="fas fa-list-ul"></i> Candidate Logs</h4>
                                                <div class="filter-buttons" style="display:flex; gap:10px;">
                                                    <button type="button" onclick="filterLogs(this, 'all')" class="filter-btn active" style="padding: 6px 15px; border-radius: 20px; border: 1px solid var(--coral); background: var(--coral); color: white; cursor:pointer; font-size:12px; font-weight:700; transition:0.3s">All</button>
                                                    <button type="button" onclick="filterLogs(this, 'pending')" class="filter-btn" style="padding: 6px 15px; border-radius: 20px; border: 1px solid var(--border); background: var(--card-bg); color: var(--text-muted); cursor:pointer; font-size:12px; font-weight:700; transition:0.3s">Pending</button>
                                                    <button type="button" onclick="filterLogs(this, 'approved')" class="filter-btn" style="padding: 6px 15px; border-radius: 20px; border: 1px solid var(--border); background: var(--card-bg); color: var(--text-muted); cursor:pointer; font-size:12px; font-weight:700; transition:0.3s">Approved</button>
                                                    <button type="button" onclick="filterLogs(this, 'rejected')" class="filter-btn" style="padding: 6px 15px; border-radius: 20px; border: 1px solid var(--border); background: var(--card-bg); color: var(--text-muted); cursor:pointer; font-size:12px; font-weight:700; transition:0.3s">Rejected</button>
                                                </div>
                                            </div>

                                            <div class="diary-list" style="display: flex; flex-direction: column; gap: 15px;">
                                                <% if (studentData.entries.length > 0) { %>
                                                    <%
                                                        let approvedShowCount = 0;
                                                        const displayedEntries = studentData.entries.filter(entry => {
                                                            if (entry.status !== 'approved') return true;
                                                            if (approvedShowCount < 5) {
                                                                approvedShowCount++;
                                                                return true;
                                                            }
                                                            return false;
                                                        });
                                                    %>
                                                    <% displayedEntries.forEach(function(entry) { 
                                                        const colors = [
                                                            { accent: '#6366F1', grad: 'linear-gradient(135deg, #6366F1, #4338CA)' }, // Indigo
                                                            { accent: '#10B981', grad: 'linear-gradient(135deg, #10B981, #065F46)' }, // Emerald
                                                            { accent: '#F59E0B', grad: 'linear-gradient(135deg, #F59E0B, #B45309)' }, // Amber
                                                            { accent: '#EF4444', grad: 'linear-gradient(135deg, #EF4444, #991B1B)' }  // Crimson
                                                        ];
                                                        const appIdStr = (studentData && studentData.applicationId) ? studentData.applicationId.toString() : 'default';
                                                        const color = colors[appIdStr.charCodeAt(0) % colors.length];
                                                    %>
                                                        <div class="diary-row-item" data-status="<%= entry.status %>" style="position: relative; background: var(--card-bg); border-radius: 16px; border: 1px solid var(--border); overflow: hidden; display: flex; align-items: stretch; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 4px 15px rgba(0,0,0,0.02);" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 15px 35px rgba(0,0,0,0.08)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(0,0,0,0.02)';">
                                                            <div style="width: 8px; background: <%= color.grad %>; flex-shrink: 0;"></div>
                                                            <div class="diary-row-content" style="flex: 1; padding: 18px 25px; display: grid; grid-template-columns: minmax(140px, 1fr) 2fr auto; gap: 20px; align-items: center;">
                                                                
                                                                <div style="display: flex; flex-direction: column; gap: 5px;">
                                                                    <div style="font-weight: 800; color: var(--ink); font-size: 14px;">
                                                                        <i class="far fa-calendar-alt" style="color:<%= color.accent %>; margin-right:6px"></i> <%= new Date(entry.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                                                    </div>
                                                                    <% if (entry.status === 'approved') { %>
                                                                        <div style="font-size: 11px; color: var(--sage); font-weight: 700;"><i class="fas fa-check-double"></i> Verified <%= entry.evaluatedAt ? new Date(entry.evaluatedAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short' }) : '' %></div>
                                                                    <% } else if (entry.status === 'rejected') { %>
                                                                        <div style="font-size: 11px; color: var(--rose); font-weight: 700;"><i class="fas fa-exclamation-circle"></i> Revision Req</div>
                                                                    <% } else { %>
                                                                        <div style="font-size: 11px; color: var(--text-muted); font-weight: 700;"><i class="fas fa-hourglass-half"></i> Awaiting</div>
                                                                    <% } %>
