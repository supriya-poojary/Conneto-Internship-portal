<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <%- include('../partials/dashboard/student_head', { title: 'Member Portal | Student Dashboard' }) %>
        <style>
            .search-box {
                position: relative;
                width: 300px;
            }

            .search-box i {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 14px;
            }

            .search-box input {
                width: 100%;
                padding: 12px 16px 12px 45px;
                border: 1.5px solid var(--border);
                border-radius: 12px;
                background: var(--card-bg);
                font-family: inherit;
                font-size: 14px;
                outline: none;
                transition: .3s;
            }

            .search-box input:focus {
                border-color: var(--coral);
                box-shadow: 0 0 0 4px rgba(217, 95, 59, 0.08);
            }

            .header-btn {
                width: 44px;
                height: 44px;
                border-radius: 12px;
                border: 1px solid var(--border);
                background: var(--card-bg);
                color: var(--text-muted);
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 18px;
                transition: .3s;
                position: relative;
            }

            .header-btn:hover {
                background: var(--border);
                color: var(--coral);
                transform: translateY(-2px);
            }

            .dot {
                position: absolute;
                top: 10px;
                right: 10px;
                width: 8px;
                height: 8px;
                background: var(--rose);
                border-radius: 50%;
                border: 2px solid var(--card-bg);
            }

            .status-badge {
                padding: 4px 12px;
                border-radius: 100px;
                font-size: 11px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .status-badge.applied {
                background: rgba(200, 131, 26, 0.1);
                color: var(--amber);
            }

            .status-badge.under_review {
                background: rgba(160, 82, 45, 0.1);
                color: var(--terra);
            }

            .status-badge.shortlisted {
                background: rgba(90, 122, 92, 0.1);
                color: var(--sage);
            }

            .status-badge.interview_scheduled {
                background: rgba(217, 95, 59, 0.1);
                color: var(--coral);
                border: 1.5px solid var(--coral);
            }

            .status-badge.selected {
                background: rgba(90, 122, 92, 0.2);
                color: var(--sage);
                border: 1px solid var(--sage);
            }

            .status-badge.rejected {
                background: rgba(181, 56, 74, 0.1);
                color: var(--rose);
            }

            /* Animation for cards */
            .reveal {
                opacity: 0;
                transform: translateY(20px);
                transition: .6s cubic-bezier(0.1, 0, 0, 1);
            }

            .reveal.visible {
                opacity: 1;
                transform: translateY(0);
            }

            @media (max-width: 1024px) {
                .stats-row {
                    grid-template-columns: repeat(2, 1fr);
                    gap: 16px;
                }

                .dashboard-grid {
                    grid-template-columns: 1fr;
                    gap: 20px;
                }

                .header {
                    flex-direction: column;
                    align-items: stretch;
                    gap: 20px;
                    text-align: center;
                }

                .header-right {
                    flex-wrap: wrap;
                    justify-content: center;
                    gap: 12px;
                }

                .search-box {
                    width: 100%;
                    order: -1;
                }
            }

            @media (max-width: 768px) {
                .internship-item {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 16px;
                }

                .internship-meta {
                    flex-direction: column;
                    gap: 8px;
                }

                .action-buttons {
                    width: 100%;
                }

                .action-buttons button,
                .view-btn {
                    width: 100%;
                    text-align: center;
                }

                .header-left h1 {
                    font-size: 1.8rem;
                }

                .stat-value {
                    font-size: 1.5rem;
                }
            }

            @media (max-width: 500px) {
                .stats-row {
                    grid-template-columns: 1fr;
                }

                .stat-card {
                    padding: 20px;
                }
            }

            /* Portfolio Specific Styles */
            .portfolio-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 20px;
                margin-top: 10px;
            }

            .portfolio-group {
                margin-bottom: 20px;
            }

            .portfolio-label {
                display: block;
                font-size: 11px;
                font-weight: 800;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 8px;
            }

            .portfolio-input {
                width: 100%;
                padding: 12px 16px;
                border: 1.5px solid var(--border);
                border-radius: 12px;
                background: var(--card-bg);
                font-family: inherit;
                font-size: 14px;
                outline: none;
                transition: .3s;
            }

            .portfolio-input:focus {
                border-color: var(--coral);
                box-shadow: 0 0 0 4px rgba(217, 95, 59, 0.08);
            }

            .portfolio-textarea {
                min-height: 120px;
                resize: vertical;
            }

            .portfolio-section-title {
                font-family: 'Playfair Display', serif;
                font-size: 1.3rem;
                margin: 20px 0 15px;
                display: flex;
                align-items: center;
                gap: 10px;
                color: var(--ink);
            }

            .portfolio-section-title i {
                color: var(--coral);
                font-size: 1.1rem;
            }

            .skill-tags {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
                margin-top: 10px;
            }

            .skill-tag {
                background: rgba(217, 95, 59, 0.1);
                color: var(--coral);
                padding: 4px 12px;
                border-radius: 100px;
                font-size: 12px;
                font-weight: 600;
            }

            .browse-filters {
                display: flex;
                gap: 15px;
                margin-bottom: 25px;
                flex-wrap: wrap;
            }

            .filter-select {
                padding: 10px 15px;
                border-radius: 10px;
                border: 1.5px solid var(--border);
                background: var(--card-bg);
                font-size: 13px;
                font-weight: 600;
                color: var(--text);
                outline: none;
            }

            /* Application Modal */
            .app-modal {
                position: fixed;
                top:0; left:0; width:100%; height:100%;
                background: rgba(0,0,0,0.8);
                backdrop-filter: blur(10px);
                display:none; 
                align-items:center; justify-content:center;
                z-index: 2000;
                padding: 20px;
            }
            .app-modal.active { display:flex; }
            .app-modal-content {
                background: var(--card-bg);
                width: 100%;
                max-width: 600px;
                border-radius: 30px;
                padding: 40px;
                position: relative;
                box-shadow: 0 20px 50px rgba(0,0,0,0.3);
                border: 1px solid var(--border);
                max-height: 90vh;
                overflow-y: auto;
            }
            .app-modal-close {
                position: absolute;
                top: 25px;
                right: 25px;
                font-size: 20px;
                cursor: pointer;
                color: var(--text-muted);
            }
            .reschedule-box {
                background: rgba(217,95,59,0.05);
                border: 1px dashed var(--coral);
                border-radius: 15px;
                padding: 20px;
                margin-top: 20px;
            }
        </style>
</head>

<body>
    <%- include('../partials/dashboard/student_sidebar', { activePage: activePage }) %>




        <% if (activePage==='dashboard' ) { %>
            <header class="header">
                <div class="header-left">
                    <h1>Member <span>Portal</span></h1>
                    <p class="header-subtitle">Track your applications and explore new opportunities.</p>
                </div>
                <div class="header-right">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="globalSearch" placeholder="Search internships...">
                    </div>
                    <button class="header-btn" id="themeToggle" title="Toggle Theme">
                        <i class="fas fa-moon"></i>
                    </button>
                    <button class="header-btn">
                        <i class="fas fa-bell"></i>
                        <span class="dot"></span>
                    </button>
                    <a href="/student/dashboard?tab=profile" style="text-decoration:none">
                        <div class="user-avatar" title="My Portfolio">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                    </a>
                </div>
            </header>

            <div class="stats-row">
                <div class="stat-card reveal">
                    <div class="stat-icon blue"><i class="fas fa-file-invoice"></i></div>
                    <div class="stat-value">
                        <%= stats ? stats.total : 0 %>
                    </div>
                    <div class="stat-label">Applications</div>
                </div>
                <div class="stat-card reveal">
                    <div class="stat-icon green"><i class="fas fa-calendar-check"></i></div>
                    <div class="stat-value">
                        <%= stats ? stats.interviews : 0 %>
                    </div>
                    <div class="stat-label">Interviews</div>
                </div>
                <div class="stat-card reveal">
                    <div class="stat-icon yellow"><i class="fas fa-hourglass-half"></i></div>
                    <div class="stat-value">
                        <%= stats ? stats.pending : 0 %>
                    </div>
                    <div class="stat-label">In Review</div>
                </div>
                <div class="stat-card reveal">
                    <div class="stat-icon purple"><i class="fas fa-award"></i></div>
                    <div class="stat-value">
                        <%= stats ? stats.hired : 0 %>
                    </div>
                    <div class="stat-label">Offers</div>
                </div>
            </div>

            <div class="dashboard-grid">
                <div class="column">
                    <div class="card reveal">
                        <div class="card-header">
                            <h2 class="card-title"><i class="fas fa-magic"></i> Recent Openings</h2>
                            <a href="/internships" class="view-btn">Explore All</a>
                        </div>
                        <div class="internship-list recent-grid">
                            <% const
                                recentImages=[ 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=400&q=80'
                                , 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=400&q=80'
                                , 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=400&q=80'
                                , 'https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=400&q=80'
                                , 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=400&q=80'
                                , 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=400&q=80' ]; %>
                                <% if (internships && internships.length> 0) { %>
                                    <% internships.forEach(function(item, index) { %>
                                        <div class="int-card" onclick="location.href='/internships/<%= item._id %>'">
                                            <% const cName=item.companyName || (item.company &&
                                                (item.company.companyName || item.company.name)) || 'CO' ; %>
                                                <div class="int-card-image-container">
                                                    <img src="<%= recentImages[index % recentImages.length] %>"
                                                        class="int-card-image" alt="Job Image">
                                                    <div class="int-logo">
                                                        <%= cName.charAt(0).toUpperCase() %>
                                                    </div>
                                                </div>
                                                <div class="int-content">
                                                    <h4 class="int-title">
                                                        <%= item.title %>
                                                    </h4>
                                                    <div class="int-company">
                                                        <%= cName %>
                                                    </div>
                                                    <div class="int-meta">
                                                        <span><i class="fas fa-map-marker-alt"></i>
                                                            <%= item.location || 'Remote' %>
                                                        </span>
                                                        <span><i class="fas fa-clock"></i>
                                                            <%= item.duration || '3 Months' %>
                                                        </span>
                                                    </div>
                                                    <div class="int-tags">
                                                        <span class="tag">
                                                            <%= item.category || 'Tech' %>
                                                        </span>
                                                        <span class="tag">Active</span>
                                                    </div>
                                                </div>
                                        </div>
                                        <% }); %>
                                            <% } else { %>
                                                <div
                                                    style="text-align:center; padding: 50px 0; color:var(--text-muted)">
                                                    <i class="fas fa-folder-open"
                                                        style="font-size:3rem; opacity:0.2; margin-bottom:15px"></i>
                                                    <p>No matches yet. Keep exploring!</p>
                                                </div>
                                                <% } %>
                        </div>
                    </div>
                </div>

                <div class="column">
                    <div class="card reveal">
                        <div class="profile-card">
                            <div class="profile-avatar">
                                <%= user.name.charAt(0).toUpperCase() %>
                            </div>
                            <div class="profile-name">
                                <%= user.name %>
                            </div>
                            <div class="profile-email">
                                <%= user.email %>
                            </div>
                            <span class="profile-status">Verified Scholar</span>
                        </div>
                        <div class="progress-section">
                            <div class="progress-title">
                                <span>Portfolio Strength</span>
                                <span>
                                    <%= profile.completionPercentage || 0 %>%
                                </span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width:<%= profile.completionPercentage || 0 %>%;">
                                </div>
                            </div>
                            <p style="font-size:12px; color:var(--text-muted); margin-top:12px; font-weight:500">Refine
                                your bio and certifications for 2x more visibility.</p>
                        </div>
                        <a href="/student/dashboard?tab=profile" class="btn-primary"
                            style="display:flex; align-items:center; justify-content:center; gap:10px; width:100%; margin-top:24px;">
                            <i class="fas fa-magic"></i> Optimize Profile
                        </a>
                    </div>

                    <div class="card reveal"
                        style="background: linear-gradient(135deg, rgba(90,122,92,0.1), rgba(59,130,246,0.1)); border: 1px solid var(--border); backdrop-filter: blur(10px);">
                        <h4
                            style="color:var(--ink); font-family:'Outfit', sans-serif; font-size:1.3rem; font-weight:700; margin-bottom:12px">
                            Need Assistance?</h4>
                        <p
                            style="color:var(--text); font-size:14px; line-height:1.6; margin-bottom:18px; font-weight:500">
                            Our
                            career experts are here to help you land your first role. We provide 1-on-1 mentorship.</p>
                        <a href="/contact"
                            style="display:inline-block; background:var(--coral); color:#fff; padding:12px 24px; border-radius:12px; text-decoration:none; font-weight:700; font-size:13px; transition: .3s; text-align:center;">Book
                            Consultation</a>
                    </div>
                </div>
            </div>
            <% } else if (activePage==='applications' ) { %>
                <header class="header">
                    <div class="header-left">
                        <h1>My Applications</h1>
                        <p class="header-subtitle">Track all your internship applications in one place</p>
                    </div>
                    <div class="header-right">
                        <a href="/internships" class="view-btn"
                            style="padding:12px 20px; background:var(--coral); color:#fff">
                            <i class="fas fa-search"></i> Browse More
                        </a>
                    </div>
                </header>

                <div class="card reveal" style="margin-top:20px">
                    <% if (applications && applications.length> 0) { %>
                        <div class="internship-list applications-grid">
                            <% const
                                appImages=[ 'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=400&q=80'
                                , 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=400&q=80'
                                , 'https://images.unsplash.com/photo-1531482615713-2afd69097998?w=400&q=80'
                                , 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=400&q=80'
                                , 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=400&q=80' ]; %>
                                <% applications.forEach(function(app, index) { %>
                                    <div class="int-card" style="cursor: default;">
                                        <% var cName=app.internship ? ((app.internship.company &&
                                            app.internship.company.companyName) ? app.internship.company.companyName :
                                            (app.internship.companyName || '' )) : '' ; %>
                                            <div class="int-card-image-container" style="height: 100px;">
                                                <img src="<%= appImages[index % appImages.length] %>"
                                                    class="int-card-image" alt="Job Image">
                                                <div class="int-logo" style="width:36px; height:36px; font-size:14px;">
                                                    <%= cName ? cName.charAt(0).toUpperCase() : 'C' %>
                                                </div>
                                            </div>
                                            <div class="int-content" style="padding:15px;">
                                                <h4 class="int-title" style="font-size:15px;">
                                                    <%= app.internship ? app.internship.title : 'Internship' %>
                                                </h4>
                                                <div class="int-company" style="font-size:12px; margin-bottom:8px;">
                                                    <%= cName || 'Company' %>
                                                </div>

                                                 <div class="int-meta" style="font-size:11px; gap:8px;">
                                                    <span><i class="fas fa-calendar"></i>
                                                        <%= new Date(app.appliedAt).toLocaleDateString() %>
                                                    </span>
                                                    <span class="tag <%= app.status %>"
                                                        style="<%= app.status === 'selected' ? 'background:var(--sage)' : 'background:var(--coral)' %>; color:#fff; border:none; padding:4px 10px;">
                                                        <%= app.status === 'applied' ? 'In Processing' : app.status.replace(/_/g, ' ' ) %>
                                                    </span>
                                                </div>

                                                <% if (app.status==='interview_scheduled' ) { %>
                                                    <div style="margin-top:15px; background:rgba(217,95,59,0.05); padding:12px; border-radius:12px; border:1px solid var(--coral)">
                                                        <div style="font-weight:800; color:var(--coral); font-size:12px; margin-bottom:5px">
                                                            <i class="fas fa-calendar-alt"></i> INTERVIEW SCHEDULED
                                                        </div>
                                                        <div style="font-size:14px; font-weight:700; color:var(--ink)">
                                                            <%= new Date(app.interviewDate).toLocaleString('en-IN', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                                                        </div>
                                                        
                                                        <% if (!app.rescheduleRequest) { %>
                                                            <div style="margin-top:10px; border-top:1px solid var(--border); padding-top:10px">
                                                                <button onclick="this.nextElementSibling.style.display='block'; this.style.display='none'" class="view-btn" style="background:none; color:var(--coral); border:1px solid var(--coral); width:100%; font-size:10px">Request Reschedule</button>
                                                                <div style="display:none; margin-top:10px">
                                                                    <form action="/student/applications/<%= app._id %>/reschedule" method="POST">
                                                                        <div style="margin-bottom:8px">
                                                                            <label style="font-size:10px; font-weight:700; color:var(--text-muted); display:block; margin-bottom:4px">New Suggested Time:</label>
                                                                            <input type="datetime-local" name="suggestedDate" required style="width:100%; border:1px solid var(--border); border-radius:8px; padding:6px; font-size:12px; background:#fff">
                                                                        </div>
                                                                        <textarea name="reason" placeholder="Reason for rescheduling..." required style="width:100%; border:1px solid var(--border); border-radius:8px; padding:6px; font-size:12px; min-height:60px; margin-bottom:8px; background:#fff"></textarea>
                                                                        <button type="submit" class="view-btn" style="background:var(--coral); color:#fff; border:none; width:100%; font-size:11px">Send Request</button>
                                                                    </form>
                                                                </div>
                                                            </div>
                                                        <% } else { %>
                                                            <div style="margin-top:10px; background:rgba(181,56,74,0.1); padding:8px; border-radius:8px; font-size:10px; color:var(--rose); font-weight:600">
                                                                <i class="fas fa-history"></i> Reschedule Pending Review
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                <% } else if (app.status === 'selected') { %>
                                                    <div style="margin-top:12px; background:rgba(90,122,92,0.1); padding:12px; border-radius:12px; border:1px solid var(--sage); text-align:center">
                                                        <div style="color:var(--sage); font-weight:800; font-size:13px"><i class="fas fa-trophy"></i> Congratulations!</div>
                                                        <div style="font-size:11px; color:var(--text-muted); margin-top:4px">You have been selected for this role.</div>
                                                    </div>
                                                <% } %>

                                                <div class="action-buttons" style="margin-top:12px; display:flex; gap:8px;">
                                                    <% if (['applied', 'under_review', 'shortlisted'].includes(app.status)) { %>
                                                        <form action="/student/applications/<%= app._id %>/withdraw" method="POST" onsubmit="return confirm('Withdraw application?')">
                                                            <button type="submit" class="view-btn" style="padding:6px 12px; font-size:10px; background:rgba(181,56,74,0.1); color:var(--rose); border:none; width:100%">Withdraw Application</button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            </div>
                                    </div>
                                    <% }); %>
                        </div>
                        <% } else { %>
                            <div style="text-align:center; padding:60px 20px">
                                <i class="fas fa-file-alt"
                                    style="font-size:3rem; color:var(--border); margin-bottom:20px"></i>
                                <h2>No applications yet</h2>
                                <p style="color:var(--text-muted); margin-bottom:30px">Start applying to see them here.
                                </p>
                                <a href="/internships" class="view-btn"
                                    style="background:var(--coral); color:#fff; padding:12px 24px">Explore
                                    Internships</a>
                            </div>
                            <% } %>
                </div>
                <% } else if (activePage==='profile' ) { %>
                    <% if (typeof success !=='undefined' || (typeof query !=='undefined' && query.success)) { %>
                        <div
                            style="background:var(--sage); color:#fff; padding:15px 25px; border-radius:15px; margin-bottom:25px; display:flex; align-items:center; gap:15px; animation: slideIn 0.4s ease-out">
                            <i class="fas fa-check-circle" style="font-size:1.2rem"></i>
                            <div style="font-weight:600">Portfolio Updated Successfully! All changes are now live.</div>
                        </div>
                        <% } %>
                            <header class="header">
                                <div class="header-left">
                                    <h1>My <span>Portfolio</span></h1>
                                    <p class="header-subtitle">Increase your visibility by completing your profile details.</p>
                                    <div style="display:flex; align-items:center; gap:15px; margin-top:10px">
                                        <div
                                            style="flex:1; max-width:200px; height:6px; background:var(--border); border-radius:10px; overflow:hidden">
                                            <div
                                                style="width:<%= profile.completionPercentage || 0 %>%; height:100%; background:var(--coral); transition:.5s">
                                            </div>
                                        </div>
                                        <span style="font-size:12px; font-weight:800; color:var(--coral)">
                                            <%= profile.completionPercentage || 0 %>% Complete
                                        </span>
                                    </div>
                                </div>
                            </header>

                            <div style="margin-top:20px">
                                <div class="card reveal" style="padding: 40px; border-radius: 30px;">
                                    <form id="profileForm" action="/student/profile/update" method="POST" enctype="multipart/form-data">
                                        <div
                                            style="display:flex; align-items:center; gap:30px; margin-bottom:40px; padding-bottom:30px; border-bottom:1px solid var(--border)">
                                            <div class="profile-avatar"
                                                style="width:120px; height:120px; font-size:3rem; flex-shrink:0">
                                                <%= user.name.charAt(0).toUpperCase() %>
