                                                                <div class="portfolio-group">
                                                                    <label class="portfolio-label">Current
                                                                        Password</label>
                                                                    <input type="password" name="currentPassword"
                                                                        class="portfolio-input" required
                                                                        placeholder="Enter current password">
                                                                </div>
                                                                <div class="portfolio-group">
                                                                    <label class="portfolio-label">New Password</label>
                                                                    <input type="password" name="newPassword"
                                                                        class="portfolio-input" required
                                                                        placeholder="Enter new password">
                                                                </div>
                                                                <div class="portfolio-group">
                                                                    <label class="portfolio-label">Confirm New
                                                                        Password</label>
                                                                    <input type="password" name="confirmPassword"
                                                                        class="portfolio-input" required
                                                                        placeholder="Confirm new password">
                                                                </div>
                                                                <div style="margin-top:20px;">
                                                                    <button type="submit" class="view-btn"
                                                                        style="background:var(--coral); color:#fff; padding:12px 30px; font-size:1rem; border-radius:12px; border:none; cursor:pointer">
                                                                        Update Password
                                                                    </button>
                                                                </div>
                                                            </form>
                                        </div>
                                        <% } %>
