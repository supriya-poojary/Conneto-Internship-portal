<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | Conneto — Internship Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,800;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script>
      (function(){
        const t = localStorage.getItem('conneto-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style>
    :root {
      --coral:       #D95F3B;
      --coral-light: #F07A56;
      --rose:        #B5384A;
      --amber:       #C8831A;
      --amber-light: #E8A030;
      --sage:        #5A7A5C;
      --sage-light:  #7A9E7C;
      --terra:       #A0522D;
      --terra-light: #C4723F;
      --cream:       #FAF3E8;
      --cream2:      #F5EAD8;
      --warm-white:  #FFF8F0;
      --ink:         #2C1A0E;
      --ink2:        #4A2E1A;
      --text:        #3D2B1F;
      --text-muted:  #7A5C4A;
      --border:      rgba(160,82,45,0.15);
      --shadow:      rgba(44,26,14,0.12);
      --card-bg:     rgba(255,248,240,0.95);
      --auth-overlay: linear-gradient(135deg, rgba(42,20,8,0.85) 0%, rgba(181,56,74,0.4) 100%);
    }
    [data-theme="dark"] {
      --cream:       #1C0F08;
      --cream2:      #251508;
      --warm-white:  #1A0D06;
      --ink:         #FAF3E8;
      --ink2:        #F0E0C8;
      --text:        #E8D5BC;
      --text-muted:  #B8937A;
      --border:      rgba(200,131,26,0.2);
      --shadow:      rgba(0,0,0,0.4);
      --card-bg:     rgba(37,21,8,0.95);
      --auth-overlay: linear-gradient(135deg, rgba(14,7,3,0.95) 0%, rgba(85,26,35,0.85) 100%);
    }

    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);transition:background 0.4s,color 0.4s;min-height:100vh;display:flex}

    /* AUTH LAYOUT */
    .auth-container { display: flex; width: 100%; min-height: 100vh; overflow: hidden; }

    .auth-left {
      width: 50%;
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px;
      overflow: hidden;
      background: var(--ink);
    }
    .auth-left-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1497215728101-856f4ea42174?w=1200&q=85');
      background-size: cover;
      background-position: center;
      opacity: 0.6;
    }
    .auth-left-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--auth-overlay);
      transition: background 0.4s;
    }
    .auth-content { position: relative; z-index: 2; max-width: 480px; }
    .auth-logo { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 800; color: #fff; margin-bottom: 24px; text-decoration: none; display: block; }
    .auth-logo span { color: var(--coral-light); }
    .auth-title { font-family: 'Playfair Display', serif; font-size: 3rem; font-weight: 800; color: #fff; line-height: 1.1; margin-bottom: 24px; }
    .auth-title em { font-style: italic; color: var(--amber-light); }
    .auth-desc { font-size: 18px; color: rgba(255,255,255,0.8); line-height: 1.7; margin-bottom: 40px; }

    .auth-right {
      width: 50%;
      background: var(--cream);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px;
      position: relative;
    }
    .form-box { width: 100%; max-width: 420px; }
    .theme-toggle-wrap { position: absolute; top: 40px; right: 40px; }
    .theme-btn { width: 44px; height: 44px; border-radius: 12px; border: 1px solid var(--border); background: var(--card-bg); color: var(--amber); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 18px; transition: .3s; }
    .theme-btn:hover { background: var(--amber); color: #fff; transform: rotate(15deg); }

    .back-home { display: flex; align-items: center; gap: 8px; color: var(--text-muted); text-decoration: none; font-weight: 700; font-size: 14px; margin-bottom: 32px; transition: .3s; }
    .back-home:hover { color: var(--coral); transform: translateX(-5px); }

    .form-header { margin-bottom: 36px; }
    .form-header h2 { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 800; color: var(--ink); margin-bottom: 8px; }
    .form-header p { color: var(--text-muted); font-size: 16px; font-weight: 500; line-height: 1.6; }

    .form-group { margin-bottom: 24px; }
    .form-group label { display: block; font-size: 13px; font-weight: 700; color: var(--ink); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
    .input-wrap { position: relative; }
    .input-wrap i { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 16px; }
    .form-input { width: 100%; padding: 14px 16px 14px 48px; background: var(--warm-white); border: 1.5px solid var(--border); border-radius: 14px; font-family: inherit; font-size: 15px; color: var(--ink); transition: .3s; outline: none; }
    .form-input:focus { border-color: var(--coral); background: #fff; box-shadow: 0 0 0 4px rgba(217,95,59,0.1); }

    .btn-submit { width: 100%; padding: 16px; background: linear-gradient(135deg, var(--coral), var(--rose)); color: #fff; border: none; border-radius: 14px; font-family: inherit; font-size: 16px; font-weight: 700; cursor: pointer; transition: .3s; box-shadow: 0 8px 24px rgba(217,95,59,0.3); margin-top: 10px; }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(217,95,59,0.4); }

    .form-footer { text-align: center; margin-top: 32px; font-size: 15px; font-weight: 500; color: var(--text-muted); }
    .form-footer a { color: var(--coral); font-weight: 700; text-decoration: none; }

    .box-msg { padding: 14px 18px; border-radius: 12px; margin-bottom: 24px; font-size: 14px; font-weight: 600; display: flex; align-items: center; gap: 10px; }
    .error-box { background: rgba(181,56,74,0.1); color: var(--rose); border: 1px solid var(--rose); }
    .success-box { background: rgba(90,122,92,0.1); color: var(--sage); border: 1px solid var(--sage); }

    @media (max-width: 1024px) {
      .auth-left { display: none; }
      .auth-right { width: 100%; padding: 40px 24px; }
    }
    </style>
</head>
<body>

<div class="auth-container">
    <div class="auth-left">
        <div class="auth-left-bg"></div>
        <div class="auth-content">
            <a href="/" class="auth-logo">Conn<span>eto</span></a>
            <h1 class="auth-title">Never Lose <em>Access</em> to Your Account.</h1>
            <p class="auth-desc">Reset your password to stay connected with top companies and exciting new internship opportunities.</p>
        </div>
    </div>

    <div class="auth-right">
        <div class="theme-toggle-wrap">
            <button class="theme-btn" id="themeToggle"><i class="fas fa-moon"></i></button>
        </div>
        
        <div class="form-box">
            <a href="/auth/login" class="back-home"><i class="fas fa-arrow-left"></i> Back to Login</a>
            
            <div class="form-header">
                <h2>Reset Password</h2>
                <p>Provide your registered email address and define your new password.</p>
            </div>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="box-msg success-box"><i class="fas fa-check-circle"></i> <%= success %></div>
            <% } %>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="box-msg error-box"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
            <% } %>

            <form method="POST" action="/auth/forgot-password">
                <div class="form-group">
                    <label for="email">Account Email</label>
                    <div class="input-wrap">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="email" name="email" class="form-input" placeholder="e.g. alex@example.com" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="newPassword">New Password</label>
                    <div class="input-wrap">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="newPassword" name="newPassword" class="form-input" placeholder="Create a strong password" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Confirm Password</label>
                    <div class="input-wrap">
                        <i class="fas fa-shield-alt"></i>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" placeholder="Repeat your new password" required>
                    </div>
                </div>

                <button type="submit" class="btn-submit">Reset Password <i class="fas fa-arrow-right" style="margin-left:8px"></i></button>
            </form>

            <p class="form-footer">
                Don't have an account? <a href="/auth/register">Create one here</a>
            </p>
        </div>
    </div>
</div>

<script>
const themeToggle = document.getElementById('themeToggle');
const html = document.documentElement;

function updateTheme() {
    const t = html.getAttribute('data-theme');
    themeToggle.innerHTML = t==='dark' ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
}

themeToggle.addEventListener('click', () => {
    const current = html.getAttribute('data-theme');
    const next = current==='dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('conneto-theme', next);
    updateTheme();
});
updateTheme();
</script>
</body>
</html>
