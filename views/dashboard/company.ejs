                    </div>
                    <div class="stat-value">
                        <%= stats ? stats.rescheduleRequests : 0 %>
                    </div>
                    <div class="stat-label">Reschedule Requests</div>
                </div>
                <div class="stat-card reveal">
                    <div class="stat-top">
                        <div class="stat-icon sky"><i class="fas fa-user-tie"></i></div>
                        <span class="stat-badge up">Hiring</span>
