                                            <label class="portfolio-label">Upload Resume (PDF) *</label>
                                            <input type="file" name="resume" class="portfolio-input" accept="application/pdf" style="padding: 12px 20px; font-size: 15px; border-style: dashed;" <%= !profile.resumeUrl ? 'required' : '' %>>
                                            <p style="font-size:12px; color:var(--text-muted); margin-top:8px">
                                                <% if (profile.resumeUrl) { %>
                                                    <i class="fas fa-check-circle" style="color:var(--sage)"></i> Resume already uploaded. Upload only if you want to update it.
                                                <% } else { %>
