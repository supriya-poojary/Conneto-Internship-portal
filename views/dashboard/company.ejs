                        </div>
                        <div class="item-list">
                            <% if (myInternships && myInternships.length> 0) { %>
                                <% myInternships.slice(0, 4).forEach(function(item) { %>
                                    <div class="item-row">
                                        <div class="item-icon">
                                            <%= item.title.charAt(0).toUpperCase() %>
                                        </div>
                                        <div style="flex:1">
                                            <div style="font-weight:700; color:var(--ink); font-size:15px">
                                                <%= item.title %>
                                            </div>
                                            <div style="font-size:13px; color:var(--text-muted); font-weight:600">
                                                <%= item.location || 'Remote' %> &bull; <%= item.type || 'Internship' %>
