                                                    onchange="window.location.href='/student/dashboard?tab=diary_history&viewInternshipId=' + this.value;">
                                                    <option value="">-- View All Logs --</option>
                                                    <% selectedInternships.forEach(app=> { %>
                                                        <option value="<%= app.internship._id %>" <%=typeof
                                                            viewInternshipId !=='undefined' &&
                                                            viewInternshipId==app.internship._id ? 'selected' : '' %>>
                                                            <%= app.internship.title %> at <%= app.internship.company ?
                                                                    app.internship.company.companyName || 'Company'
                                                                    : 'Company' %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>

                                            <% if (viewInternshipId) { 
                                                const selectedApp = selectedInternships.find(a => a.internship._id.toString() === viewInternshipId.toString());
