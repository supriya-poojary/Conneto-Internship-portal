                                                if (urlParams.get('success') === 'Password updated successfully.') {
                                                    Swal.fire({
                                                        icon: 'success',
                                                        title: 'Privacy Secured',
                                                        text: 'Your password has been updated successfully.',
                                                        confirmButtonColor: '#D95F3B',
                                                        iconColor: '#D95F3B'
                                                    });
                                                } else if (urlParams.get('success') === '1' || urlParams.get('success') ===
                                                    'Password updated successfully.') {
                                                    Swal.fire({
                                                        icon: 'success',
                                                        title: 'Great Job!',
                                                        text: 'Your portfolio is now updated and live.',
                                                        confirmButtonColor: '#D95F3B',
                                                        iconColor: '#D95F3B'
                                                    });
                                                } else if (urlParams.get('error')) {
                                                    Swal.fire({
                                                        icon: 'error',
                                                        title: 'Oops!',
                                                        text: decodeURIComponent(urlParams.get('error')),
                                                        confirmButtonColor: '#D95F3B'
                                                    });
                                                }

                                                const reveals = document.querySelectorAll('.reveal');
                                                reveals.forEach((el, i) => {
                                                    setTimeout(() => el.classList.add('visible'), i * 100);
                                                });

                                                const search = document.getElementById('globalSearch');
                                                if (search) {
                                                    search.addEventListener('keypress', (e) => {
                                                        if (e.key === 'Enter' && search.value.trim()) {
                                                            window.location.href = '/internships?q=' + encodeURIComponent(search.value);
                                                        }
                                                    });
                                                }
                                            </script>

                                            <!-- Application Details Modal -->
                                            <div id="appDetailsModal" class="app-modal">
                                                <div class="app-modal-content">
                                                    <i class="fas fa-times app-modal-close" onclick="closeAppModal()"></i>
                                                    <div id="appModalBody">
                                                        <!-- Dynamic Content -->
                                                    </div>
                                                </div>
                                            </div>

                                            <script>
                                                const studentApps = <%- JSON.stringify(applications || []) %>;
                                                
                                                function showAppDetails(appId) {
                                                    const app = studentApps.find(a => a._id === appId);
                                                    if (!app) return;

                                                    const modal = document.getElementById('appDetailsModal');
                                                    const body = document.getElementById('appModalBody');
                                                    
                                                    const statusText = app.status === 'applied' ? 'In Processing' : app.status.replace(/_/g, ' ');
                                                    const dateStr = new Date(app.appliedAt).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' });
                                                    
                                                    let interviewHtml = '';
                                                    if (app.status === 'interview_scheduled') {
                                                        const iDate = new Date(app.interviewDate).toLocaleString('en-IN', { 
                                                            day: '2-digit', month: 'short', year: 'numeric', 
                                                            hour: '2-digit', minute: '2-digit' 
                                                        });
                                                        interviewHtml = `
                                                            <div style="background:rgba(90,122,92,0.1); border-radius:15px; padding:20px; margin-top:20px">
                                                                <h4 style="color:var(--sage); margin-bottom:10px; display:flex; align-items:center; gap:10px">
                                                                    <i class="fas fa-calendar-check"></i> Interview Scheduled
                                                                </h4>
                                                                <p style="font-size:18px; font-weight:700; color:var(--ink)">${iDate}</p>
                                                                ${app.interviewNote ? `<p style="font-size:13px; color:var(--text-muted); margin-top:10px">Note: ${app.interviewNote}</p>` : ''}
                                                            </div>
                                                        `;

                                                        if (!app.rescheduleRequest) {
                                                            interviewHtml += `
                                                                <div class="reschedule-box">
                                                                    <h5 style="color:var(--coral); margin-bottom:12px; font-size:14px">Need to Reschedule?</h5>
                                                                    <form action="/student/applications/${app._id}/reschedule" method="POST">
                                                                        <div style="margin-bottom:10px">
                                                                            <label style="font-size:11px; font-weight:700; color:var(--text-muted); display:block; margin-bottom:5px">Suggested New Time:</label>
                                                                            <input type="datetime-local" name="suggestedDate" required style="width:100%; border:1px solid var(--border); border-radius:10px; padding:10px; font-size:13px; background:#fff">
                                                                        </div>
                                                                        <textarea name="reason" placeholder="Please provide a suitable reason for rescheduling..." required 
                                                                            style="width:100%; border:1px solid var(--border); border-radius:10px; padding:10px; font-size:13px; min-height:80px; margin-bottom:10px; background:#fff"></textarea>
                                                                        <button type="submit" class="view-btn" style="background:var(--coral); color:#fff; border:none; padding:8px 15px; font-size:12px; cursor:pointer">Send Request</button>
                                                                    </form>
                                                                </div>
                                                            `;
                                                        } else {
                                                            interviewHtml += `
                                                                <div style="margin-top:15px; background:rgba(217,95,59,0.05); padding:15px; border-radius:10px; border:1px solid var(--coral)">
                                                                    <div style="color:var(--coral); font-weight:700; font-size:13px">
                                                                        <i class="fas fa-hourglass-half"></i> Reschedule Requested
                                                                    </div>
                                                                    <p style="font-size:12px; color:var(--text-muted); margin-top:5px">Reason: ${app.rescheduleReason}</p>
                                                                </div>
                                                            `;
                                                        }
                                                    }

                                                    body.innerHTML = `
                                                        <h2 style="font-family:'Playfair Display', serif; margin-bottom:10px">${app.internship.title}</h2>
                                                        <p style="color:var(--text-muted); margin-bottom:25px; font-weight:600">${app.internship.company ? (app.internship.company.companyName || 'Company') : 'Company'}</p>
                                                        
                                                        <div style="display:flex; gap:30px; margin-bottom:25px">
                                                            <div>
                                                                <div style="font-size:11px; font-weight:800; color:var(--text-muted); text-transform:uppercase">Status</div>
                                                                <div style="font-weight:700; color:var(--coral); margin-top:5px; font-size:16px">${statusText}</div>
                                                            </div>
                                                            <div>
                                                                <div style="font-size:11px; font-weight:800; color:var(--text-muted); text-transform:uppercase">Applied On</div>
                                                                <div style="font-weight:700; color:var(--ink); margin-top:5px; font-size:16px">${dateStr}</div>
                                                            </div>
                                                        </div>

                                                        ${interviewHtml}

                                                        <div style="margin-top:30px; padding-top:20px; border-top:1px solid var(--border)">
                                                            <h4 style="font-size:14px; margin-bottom:10px; color:var(--ink)">Application Summary</h4>
                                                            <div style="font-size:13px; color:var(--text); line-height:1.6">
                                                                <p><strong>Cover Letter:</strong> ${app.coverLetter || 'N/A'}</p>
                                                                <p style="margin-top:10px"><strong>Skills Provided:</strong> ${app.studentSkills || 'N/A'}</p>
                                                            </div>
                                                        </div>
                                                    `;

                                                    modal.classList.add('active');
                                                }

                                                function closeAppModal() {
                                                    document.getElementById('appDetailsModal').classList.remove('active');
                                                }

                                                window.onclick = function(event) {
                                                    const modal = document.getElementById('appDetailsModal');
                                                    if (event.target == modal) {
                                                        modal.classList.remove('active');
                                                    }
                                                }
                                            </script>
</body>

</html>