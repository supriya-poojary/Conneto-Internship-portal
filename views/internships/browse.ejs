<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Internships | Conneto</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/conneto.css">
    <style>
        /* ===== BROWSE PAGE VARS ===== */
        :root {
            --primary: #2563EB;
            --primary-dark: #1D4ED8;
            --primary-light: #DBEAFE;
            --secondary: #7C3AED;
            --success: #10B981;
            --success-light: #D1FAE5;
            --warning: #F59E0B;
            --warning-light: #FEF3C7;
            --text: #0F172A;
            --text-muted: #64748B;
            --border: #E2E8F0;
            --bg: #F1F5F9;
            --card-bg: #FFFFFF;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body.browse-body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            transition: background 0.3s, color 0.3s;
        }

        /* ===== HEADER ===== */
        .browse-header {
            background: white;
            padding: 16px 40px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
            transition: background 0.3s, border-color 0.3s;
            gap: 16px;
            flex-wrap: wrap;
        }

        .browse-header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .browse-back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 9px 18px;
            background: linear-gradient(135deg, #f8fafc, #f1f5f9);
            border: 1.5px solid var(--border);
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text);
            text-decoration: none;
            transition: all 0.25s ease;
            white-space: nowrap;
        }

        .browse-back-btn i {
            font-size: 0.8rem;
            color: var(--primary);
            transition: transform 0.25s;
        }

        .browse-back-btn:hover {
            background: linear-gradient(135deg, #dbeafe, #ede9fe);
            border-color: var(--primary);
            color: var(--primary);
            transform: translateX(-3px);
        }

        .browse-back-btn:hover i {
            transform: translateX(-3px);
        }

        .browse-logo-link {
            font-family: 'Poppins', sans-serif;
            font-size: 1.4rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
        }

        .browse-nav-links {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .browse-nav-link {
            color: var(--text);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            transition: color 0.3s;
        }

        .browse-nav-link:hover {
            color: var(--primary);
        }

        .browse-btn-action {
            padding: 9px 20px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.85rem;
            text-decoration: none;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .browse-btn-login {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            box-shadow: 0 4px 14px rgba(37, 99, 235, 0.3);
        }

        .browse-btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.4);
            color: white;
        }

        .browse-btn-dashboard {
            background: linear-gradient(135deg, var(--secondary), #6d28d9);
            color: white;
            box-shadow: 0 4px 14px rgba(124, 58, 237, 0.3);
        }

        .browse-btn-dashboard:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(124, 58, 237, 0.4);
            color: white;
        }

        /* ===== CONTAINER / PAGE HEADER ===== */
        .browse-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .browse-page-header {
            margin-bottom: 32px;
            animation: fadeSlideUp 0.6s ease;
        }

        .browse-page-title {
            font-family: 'Poppins', sans-serif;
            font-size: clamp(1.7rem, 4vw, 2.4rem);
            font-weight: 800;
            margin-bottom: 6px;
            background: linear-gradient(135deg, var(--text), var(--primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .browse-page-subtitle {
            color: var(--text-muted);
            font-size: 1rem;
        }

        /* ===== FILTERS CARD ===== */
        .browse-filters-card {
            background: white;
            border-radius: 18px;
            padding: 24px;
            margin-bottom: 28px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
            border: 1px solid transparent;
            animation: fadeSlideUp 0.7s ease;
            transition: background 0.3s, border-color 0.3s;
        }

        .browse-filters-form {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
        }

        .browse-filter-input {
            flex: 1;
            min-width: 180px;
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: 12px;
            font-size: 0.95rem;
            font-family: 'Inter', sans-serif;
            transition: all 0.3s;
            background: #f8fafc;
        }

        .browse-filter-input:focus {
            outline: none;
            border-color: var(--primary);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

        .browse-filter-select {
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: 12px;
            font-size: 0.95rem;
            background: #f8fafc;
            min-width: 150px;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            transition: all 0.3s;
        }

        .browse-filter-select:focus {
            outline: none;
            border-color: var(--primary);
        }

        .browse-btn-filter {
            padding: 12px 28px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 14px rgba(37, 99, 235, 0.3);
            transition: all 0.3s;
            white-space: nowrap;
        }

        .browse-btn-filter:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.4);
        }

        /* ===== INTERNSHIP CARDS ===== */
        .browse-grid {
            display: grid;
            gap: 20px;
        }

        .browse-internship-card {
            background: white;
            border-radius: 18px;
            padding: 24px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
            display: flex;
            gap: 20px;
            transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid transparent;
            animation: fadeSlideUp 0.5s ease both;
            position: relative;
            overflow: hidden;
        }

        .browse-internship-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 0;
            background: linear-gradient(180deg, var(--primary), var(--secondary));
            border-radius: 0 0 4px 4px;
            transition: height 0.35s ease;
        }

        .browse-internship-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 40px rgba(37, 99, 235, 0.12);
            border-color: rgba(37, 99, 235, 0.2);
        }

        .browse-internship-card:hover::before {
            height: 100%;
        }

        .browse-company-logo {
            width: 64px;
            height: 64px;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--primary-light), #ede9fe);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--primary);
            flex-shrink: 0;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.15);
        }

        .browse-internship-content {
            flex: 1;
            min-width: 0;
        }

        .browse-internship-title {
            font-family: 'Poppins', sans-serif;
            font-size: 1.15rem;
            font-weight: 700;
            margin-bottom: 3px;
        }

        .browse-company-name {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 14px;
        }

        .browse-internship-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            margin-bottom: 14px;
        }

        .browse-meta-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .browse-meta-item i {
            color: var(--primary);
            width: 14px;
            text-align: center;
        }

        .browse-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 18px;
        }

        .browse-tag {
            padding: 4px 12px;
            background: var(--primary-light);
            color: var(--primary);
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .browse-tag.type-remote {
            background: #DCFCE7;
            color: #166534;
        }

        .browse-tag.type-on-site {
            background: #FEE2E2;
            color: #991B1B;
        }

        .browse-tag.type-hybrid {
            background: #FEF3C7;
            color: #92400E;
        }

        .browse-card-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .browse-btn-view {
            padding: 10px 22px;
            background: white;
            color: var(--primary);
            border: 2px solid var(--primary);
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.88rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            transition: all 0.3s;
            flex: 1;
            justify-content: center;
        }

        .browse-btn-view:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-2px);
        }

        .browse-applied-badge {
            padding: 10px 18px;
            background: var(--success-light);
            color: var(--success);
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.88rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        /* ===== EMPTY STATE ===== */
        .browse-empty-state {
            text-align: center;
            padding: 72px 20px;
            background: white;
            border-radius: 18px;
            animation: fadeSlideUp 0.5s ease;
        }

        .browse-empty-icon {
            font-size: 4rem;
            color: var(--border);
            margin-bottom: 20px;
        }

        .browse-empty-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .browse-empty-text {
            color: var(--text-muted);
        }

        /* ===== ANIMATIONS ===== */
        @keyframes fadeSlideUp {
            from {
                opacity: 0;
                transform: translateY(28px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Stagger animation for cards */
        .browse-internship-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .browse-internship-card:nth-child(2) {
            animation-delay: 0.18s;
        }

        .browse-internship-card:nth-child(3) {
            animation-delay: 0.26s;
        }

        .browse-internship-card:nth-child(4) {
            animation-delay: 0.34s;
        }

        .browse-internship-card:nth-child(5) {
            animation-delay: 0.42s;
        }

        .browse-internship-card:nth-child(n+6) {
            animation-delay: 0.5s;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .browse-header {
                padding: 14px 16px;
            }

            .browse-nav-links {
                gap: 10px;
            }

            .browse-nav-link {
                display: none;
            }

            .browse-internship-card {
                flex-direction: column;
                gap: 16px;
            }

            .browse-company-logo {
                width: 52px;
                height: 52px;
                font-size: 1.3rem;
            }

            .browse-btn-view {
                flex: auto;
            }

            .browse-container {
                padding: 24px 14px;
            }
        }

        @media (max-width: 480px) {
            .browse-filters-form {
                flex-direction: column;
            }

            .browse-filter-input,
            .browse-filter-select {
                width: 100%;
                min-width: unset;
            }

            .browse-btn-filter {
                width: 100%;
                justify-content: center;
            }

            .browse-back-btn span {
                display: none;
            }

            .browse-page-title {
                font-size: 1.5rem;
            }
        }
    </style>

    <!-- Prevent FOUT -> Pre-load Theme -->
    <script>
        (function () {
            var saved = localStorage.getItem('conneto-theme');
            if (saved !== 'light') {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>

<body class="browse-body">
    <!-- THEME TOGGLE -->
    <button class="c-theme-toggle" onclick="toggleTheme()" title="Toggle dark/light mode" aria-label="Toggle theme">
        <i class="fas fa-sun icon-sun"></i>
        <i class="fas fa-moon icon-moon"></i>
    </button>

    <header class="browse-header">
        <div class="browse-header-left">
            <a href="/" class="browse-back-btn">
                <i class="fas fa-arrow-left"></i>
                <span>Home</span>
            </a>
            <a href="/" class="browse-logo-link">Conneto</a>
        </div>
        <nav class="browse-nav-links">
            <a href="/internships" class="browse-nav-link">Browse</a>
            <% if (user) { %>
                <% if (user.role==='student' ) { %>
                    <a href="/student/dashboard" class="browse-btn-action browse-btn-dashboard"><i
                            class="fas fa-th-large"></i> Dashboard</a>
                    <% } else { %>
                        <a href="/company/dashboard" class="browse-btn-action browse-btn-dashboard"><i
                                class="fas fa-th-large"></i> Dashboard</a>
                        <% } %>
                            <% } else { %>
                                <a href="/auth/login" class="browse-btn-action browse-btn-login"><i
                                        class="fas fa-sign-in-alt"></i> Login</a>
                                <% } %>
        </nav>
    </header>

    <div class="browse-container">
        <div class="browse-page-header">
            <h1 class="browse-page-title">Find Your Dream Internship</h1>
            <p class="browse-page-subtitle">Explore opportunities from top companies</p>
        </div>

        <div class="browse-filters-card">
            <form class="browse-filters-form" action="/internships" method="GET">
                <input type="text" name="search" class="browse-filter-input" placeholder="Search by title or skills..."
                    value="<%= filters.search || '' %>">
                <input type="text" name="location" class="browse-filter-input" placeholder="Location..."
                    value="<%= filters.location || '' %>">
                <select name="type" class="browse-filter-select">
                    <option value="">All Types</option>
                    <option value="remote" <%=filters.type==='remote' ? 'selected' : '' %>>Remote</option>
                    <option value="on-site" <%=filters.type==='on-site' ? 'selected' : '' %>>On-site</option>
                    <option value="hybrid" <%=filters.type==='hybrid' ? 'selected' : '' %>>Hybrid</option>
                </select>
                <button type="submit" class="browse-btn-filter">
                    <i class="fas fa-search"></i> Search
                </button>
            </form>
        </div>

        <% if (internships && internships.length> 0) { %>
            <div class="browse-grid">
                <% internships.forEach(function(internship) { %>
                    <div class="browse-internship-card">
                        <div class="browse-company-logo">
                            <% var cName=(internship.company && internship.company.companyName) ?
                                internship.company.companyName : (internship.companyName || '' ); %>
                                <%= cName ? cName.charAt(0).toUpperCase() : 'C' %>
                        </div>
                        <div class="browse-internship-content">
                            <h3 class="browse-internship-title">
                                <%= internship.title %>
                            </h3>
                            <p class="browse-company-name">
                                <%= cName || 'Company' %>
                            </p>

                            <div class="browse-internship-meta">
                                <span class="browse-meta-item">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <%= internship.location || 'Remote' %>
                                </span>
                                <span class="browse-meta-item">
                                    <i class="fas fa-clock"></i>
                                    <%= internship.duration || 'Flexible' %>
                                </span>
                                <span class="browse-meta-item">
                                    <i class="fas fa-rupee-sign"></i>
                                    <%= internship.stipend ? internship.stipend + '/month' : 'Unpaid' %>
                                </span>
                                <span class="browse-meta-item">
                                    <i class="fas fa-users"></i>
                                    <%= internship.openings %> opening<%= internship.openings> 1 ? 's' : '' %>
                                </span>
                            </div>

                            <div class="browse-tags">
                                <span class="browse-tag type-<%= internship.type %>">
                                    <%= internship.type %>
                                </span>
                                <% if (internship.skills && internship.skills.length> 0) { %>
                                    <% internship.skills.slice(0, 3).forEach(function(skill) { %>
                                        <span class="browse-tag">
                                            <%= skill %>
                                        </span>
                                        <% }); %>
                                            <% } %>
                            </div>

                            <div class="browse-card-actions">
                                <a href="/internships/<%= internship._id %>" class="browse-btn-view">
                                    <i class="fas fa-arrow-right"></i> View Details & Apply
                                </a>
                                <% if (user && user.role==='student' ) { %>
                                    <% if (appliedIds && appliedIds.includes(internship._id.toString())) { %>
                                        <span class="browse-applied-badge">
                                            <i class="fas fa-check-circle"></i> Applied
                                        </span>
                                        <% } %>
                                            <% } %>
                            </div>
                        </div>
                    </div>
                    <% }); %>
            </div>
            <% } else { %>
                <div class="browse-empty-state">
                    <div class="browse-empty-icon"><i class="fas fa-briefcase"></i></div>
                    <h2 class="browse-empty-title">No internships found</h2>
                    <p class="browse-empty-text">Try adjusting your search filters or check back later</p>
                </div>
                <% } %>
    </div>

    <script>
        // Theme toggle — sync with global preference
        

        function toggleTheme() {
            var html = document.documentElement;
            var isDark = html.getAttribute('data-theme') === 'dark';
            if (isDark) {
                html.removeAttribute('data-theme');
                localStorage.setItem('conneto-theme', 'light');
            } else {
                html.setAttribute('data-theme', 'dark');
                localStorage.setItem('conneto-theme', 'dark');
            }
        }
    </script>
</body>

</html>