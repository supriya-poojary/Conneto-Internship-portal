            <div class="marquee-content">LUXURY • TIMELESS • BESPOKE • ELEVATED • </div>
            <div class="marquee-content">LUXURY • TIMELESS • BESPOKE • ELEVATED • </div>
        </div>
    </section>

    <!-- Projects Grid -->
    <section class="projects">
        <div class="section-header">
            <h2 class="section-title">Selected<br>Works</h2>
            <a href="#" class="section-link">View complete archive</a>
