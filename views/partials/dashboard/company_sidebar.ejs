<!-- Background Blobs -->
<div class="dashboard-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
</div>

<!-- Topbar -->
<nav class="topbar">
    <a href="/" class="logo">Conn<span>eto</span></a>

    <div class="topbar-right">
        <button class="topbar-btn" id="themeToggle" title="Toggle Theme">
            <i class="fas fa-moon"></i>
        </button>
        <button class="topbar-btn">
            <i class="fas fa-search"></i>
        </button>
        <button class="topbar-btn">
            <i class="fas fa-bell"></i>
            <span class="badge"></span>
        </button>
        <div class="user-menu">
            <div class="user-avatar">
                <%= user.name.charAt(0).toUpperCase() %>
            </div>
            <div class="user-info">
                <div class="user-name">
                    <%= user.name %>
                </div>
                <div class="user-role">
                    <%= user.companyName || 'Employer' %>
                </div>
            </div>
            <a href="/auth/logout" class="topbar-btn" style="width: 36px; height: 36px; margin-left:8px">
                <i class="fas fa-power-off"></i>
            </a>
        </div>
    </div>
</nav>

<div class="main-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-section">
            <div class="sidebar-title">Management Hub</div>
            <div class="nav-list">
                <a href="/company/dashboard"
                    class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
                    <i class="fas fa-chart-pie"></i>
                    <span>Overview</span>
                </a>
                <a href="/company/dashboard?tab=internships"
                    class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'internships' ? 'active' : '' %>">
                    <i class="fas fa-briefcase"></i>
                    <span>Postings</span>
                </a>
                <a href="/company/dashboard?tab=applications"
                    class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'applications' ? 'active' : '' %>">
                    <i class="fas fa-user-friends"></i>
                    <span>Candidates</span>
                    <% if (typeof stats !== 'undefined' && stats.rescheduleRequests > 0) { %>
                        <span style="background:var(--rose); color:#fff; padding:2px 8px; border-radius:100px; font-size:10px; font-weight:800; margin-left:auto">
                            <%= stats.rescheduleRequests %>
                        </span>
                    <% } %>
                </a>
            </div>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-title">Quick Actions</div>
            <div class="nav-list">
                <a href="/company/internships/create"
                    class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'create' ? 'active' : '' %>">
                    <i class="fas fa-plus-square"></i>
                    <span>New Listing</span>
                </a>

            </div>
        </div>
        <div class="sidebar-section">
            <div class="sidebar-title">Security</div>
            <div class="nav-list">
                <a href="/company/dashboard?tab=settings"
                    class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active' : '' %>">
                    <i class="fas fa-shield-alt"></i>
                    <span>Settings</span>
                </a>
                <a href="/auth/logout" class="nav-link" style="color:var(--rose)">
                    <i class="fas fa-door-open"></i>
                    <span>Logout</span>
                </a>
            </div>
        </div>
    </aside>
    <main class="content">