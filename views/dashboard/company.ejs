<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <%- include('../partials/dashboard/company_head', { title: 'Partner Portal | Company Dashboard' }) %>
        <style>
            body {
                font-family: 'Inter', sans-serif;
                background: var(--bg);
                color: var(--text);
                line-height: 1.6;
                transition: all 0.4s;
                min-height: 100vh;
                position: relative;
                overflow-x: hidden;
            }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                z-index: -2;
                background-image: url('https://images.unsplash.com/photo-1497366216548-37526070297c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80');
                background-size: cover;
                background-position: center;
                filter: brightness(1);
                animation: slow-zoom 40s infinite alternate ease-in-out;
                transition: filter 0.4s;
            }

            [data-theme="dark"] body::before {
                filter: brightness(0.5);
            }




            .card {
                background: var(--card-bg) !important;
                backdrop-filter: blur(12px) saturate(180%);
                border: 1px solid var(--border);
                border-radius: 20px;
                padding: 24px;
                position: relative;
                overflow: hidden;
                z-index: 1;
            }

            [data-theme="light"] .card {
                background: rgba(255, 255, 255, 0.75) !important;
                border: 1px solid rgba(160, 82, 45, 0.1);
            }

            /* Diary Evaluation Master-Detail Layout */
            .diary-layout {
                display: grid;
                grid-template-columns: 320px 1fr;
                gap: 25px;
                min-height: 600px;
                margin-top: 20px;
            }
            .diary-selector {
                background: var(--card-bg);
                border: 1px solid var(--border);
                border-radius: 20px;
                padding: 15px;
                overflow-y: auto;
                max-height: calc(100vh - 200px);
            }
            .student-select-card {
                padding: 15px;
                border-radius: 12px;
                cursor: pointer;
                transition: 0.3s;
                border: 1px solid transparent;
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 12px;
                background: var(--cream);
            }
            .student-select-card:hover {
                background: rgba(217, 95, 59, 0.05);
                border-color: var(--coral);
            }
            .student-select-card.active {
                background: var(--coral);
                color: white;
            }
            .student-select-card.active p {
                color: rgba(255, 255, 255, 0.8) !important;
            }
            .student-select-card.active .item-icon {
                background: white !important;
                color: var(--coral);
            }

            .diary-content-panel {
                background: var(--card-bg);
                border: 1px solid var(--border);
                border-radius: 20px;
                padding: 30px;
                display: flex;
                flex-direction: column;
            }

            .empty-panel-msg {
                flex: 1;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                text-align: center;
                color: var(--text-muted);
                padding: 60px;
                background: rgba(0,0,0,0.01);
                border-radius: 20px;
                border: 2px dashed var(--border);
            }

            .diary-table {
                width: 100%;
                border-collapse: separate;
                border-spacing: 0 8px;
                margin-top: 15px;
            }
            .diary-table th {
                padding: 12px 16px;
                text-align: left;
                font-size: 11px;
                font-weight: 800;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 1px;
            }
            .diary-table td {
                padding: 16px;
                background: var(--cream);
                border-top: 1px solid var(--border);
                border-bottom: 1px solid var(--border);
            }
            .diary-table tr td:first-child { border-left: 1px solid var(--border); border-radius: 12px 0 0 12px; }
            .diary-table tr td:last-child { border-right: 1px solid var(--border); border-radius: 0 12px 12px 0; }
            
            .eye-btn {
                background: none;
                border: none;
                color: var(--coral);
                cursor: pointer;
                font-size: 1.1rem;
                transition: .3s;
                padding: 8px;
                border-radius: 8px;
            }
            .eye-btn:hover {
                background: rgba(217, 95, 59, 0.1);
                transform: scale(1.1);
            }

            .upload-section {
                margin-top: 30px;
                padding: 25px;
                border: 2px dashed var(--sage);
                border-radius: 20px;
                background: rgba(90, 122, 92, 0.03);
                text-align: center;
            }
            .upload-section.disabled {
                opacity: 0.5;
                pointer-events: none;
                border-color: var(--border);
                filter: grayscale(1);
            }

            .stats-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 24px;
                margin-bottom: 40px;
            }

            .stat-card {
                background: var(--card-bg) !important;
                border: 1px solid var(--border);
                border-radius: 24px;
                padding: 24px;
                box-shadow: none !important;
                position: relative;
                overflow: hidden;
                z-index: 1;
            }

            .stat-card::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image:
                    radial-gradient(circle at 10% 10%, rgba(217, 95, 59, 0.06) 0%, transparent 50%),
                    radial-gradient(circle at 90% 90%, rgba(90, 122, 92, 0.06) 0%, transparent 50%),
                    url('https://www.transparenttextures.com/patterns/cubes.png');
                opacity: 0.1;
                pointer-events: none;
                z-index: -1;
            }

            [data-theme="dark"] .stat-card::before {
                opacity: 0.2;
                filter: invert(1);
                background-image:
                    radial-gradient(circle at 10% 10%, rgba(217, 95, 59, 0.1) 0%, transparent 60%),
                    radial-gradient(circle at 90% 90%, rgba(90, 122, 92, 0.1) 0%, transparent 60%),
                    url('https://www.transparenttextures.com/patterns/cubes.png');
            }

            .stat-top {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                margin-bottom: 20px;
            }

            .stat-icon {
                width: 50px;
                height: 50px;
                border-radius: 14px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
            }

            .stat-icon.blue {
                background: rgba(217, 95, 59, 0.1);
                color: var(--coral);
            }

            .stat-icon.green {
                background: rgba(90, 122, 92, 0.1);
                color: var(--sage);
            }

            .stat-icon.yellow {
                background: rgba(200, 131, 26, 0.1);
                color: var(--amber);
            }

            .stat-icon.sky {
                background: rgba(160, 82, 45, 0.1);
                color: var(--terra);
            }

            .stat-badge {
                font-size: 10px;
                font-weight: 800;
                padding: 4px 10px;
                border-radius: 100px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .stat-badge.up {
                background: rgba(90, 122, 92, 0.15);
                color: var(--sage);
            }

            .stat-value {
                font-family: 'Playfair Display', serif;
                font-size: 2rem;
                font-weight: 800;
                color: var(--ink);
                margin-bottom: 4px;
            }

            .stat-label {
                font-size: 13px;
                font-weight: 600;
                color: var(--text-muted);
            }

            .dashboard-grid {
                display: grid;
                grid-template-columns: 1.6fr 1fr;
                gap: 30px;
            }

            .column {
                display: flex;
                flex-direction: column;
                gap: 30px;
            }

            .item-row {
                display: flex;
                align-items: center;
                gap: 16px;
                padding: 16px;
                background: var(--cream);
                border: 1px solid var(--border);
                border-radius: 18px;
                transition: .3s;
                margin-bottom: 12px;
            }

            .item-row:hover {
                border-color: var(--coral);
                transform: translateX(5px);
            }

            .item-icon {
                width: 48px;
                height: 48px;
                border-radius: 14px;
                background: linear-gradient(135deg, var(--coral), var(--rose));
                display: flex;
                align-items: center;
                justify-content: center;
                color: #fff;
                font-weight: 800;
                font-family: 'Playfair Display', serif;
            }

            .status-pill {
                padding: 4px 12px;
                border-radius: 20px;
                font-size: 12px;
                font-weight: 600;
                border: 1px solid var(--border);
            }

            .status-active {
                border-color: var(--sage);
                color: var(--sage);
                background: rgba(90, 122, 92, 0.1);
            }

            .status-draft {
                border-color: var(--border);
                color: var(--text-muted);
                background: rgba(0, 0, 0, 0.05);
            }

            .status-pill.applied {
                background: rgba(200, 131, 26, 0.1);
                color: var(--amber);
            }

            .status-pill.selected {
                background: rgba(90, 122, 92, 0.2);
                color: var(--sage);
                border: 1px solid var(--sage);
            }

            .company-profile-card {
                padding: 30px;
                background: linear-gradient(135deg, #1C0F08, #2C1A0E);
                border-radius: 24px;
                margin-bottom: 24px;
                position: relative;
                overflow: hidden;
                border: 1px solid var(--border);
                z-index: 1;
            }

            .company-profile-card::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image:
                    radial-gradient(circle at 20% 20%, rgba(217, 95, 59, 0.2) 0%, transparent 50%),
                    url('https://www.transparenttextures.com/patterns/cubes.png');
                opacity: 0.15;
                filter: invert(1);
                pointer-events: none;
                z-index: -1;
            }

            .company-profile-card::after {
                content: '';
                position: absolute;
                bottom: -20px;
                right: -20px;
                width: 150px;
                height: 150px;
                background: var(--coral);
                opacity: 0.2;
                filter: blur(50px);
            }

            .company-avatar-lg {
                width: 60px;
                height: 60px;
                border-radius: 16px;
                background: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #2C1A0E;
                font-size: 1.5rem;
                font-weight: 800;
                margin-bottom: 16px;
                font-family: 'Playfair Display', serif;
            }

            .company-display-name {
                font-family: 'Playfair Display', serif;
                font-size: 1.4rem;
                font-weight: 800;
                color: #fff;
                margin-bottom: 4px;
            }

            .company-display-email {
                font-size: 14px;
                color: rgba(255, 255, 255, 0.6);
            }

            .post-btn {
                width: 100%;
                padding: 16px;
                background: linear-gradient(135deg, var(--coral), var(--rose));
                color: #fff;
                border: none;
                border-radius: 16px;
                font-family: inherit;
                font-size: 15px;
                font-weight: 700;
                cursor: pointer;
                transition: .3s;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                text-decoration: none;
            }

            .post-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(217, 95, 59, 0.3);
            }

            .view-btn {
                padding: 8px 16px;
                background: rgba(217, 95, 59, 0.1);
                color: var(--coral);
                border-radius: 10px;
                font-size: 13px;
                font-weight: 700;
                text-decoration: none;
                transition: .3s;
            }

            .view-btn:hover {
                background: var(--coral);
                color: #fff;
                transform: translateY(-2px);
            }

            .reveal {
                opacity: 0;
                transform: translateY(20px);
                transition: .6s cubic-bezier(0.1, 0, 0, 1);
            }

            .reveal.visible {
                opacity: 1;
                transform: translateY(0);
            }

            @media (max-width: 1024px) {
                .stats-grid {
                    grid-template-columns: repeat(2, 1fr);
                    gap: 16px;
                }

                .dashboard-grid {
                    grid-template-columns: 1fr;
                    gap: 20px;
                }
            }

            @media (max-width: 768px) {
                .stats-grid {
                    grid-template-columns: 1fr !important;
                }
                
                .page-title {
                    font-size: 1.8rem;
                }

                .card {
                    padding: 20px !important;
                }

                .item-row {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 16px;
                }

                .item-row > div:last-of-type {
                    width: 100%;
                    flex-wrap: wrap;
                }
            }

            @media (max-width: 992px) {
                .modal-body {
                    flex-direction: column !important;
                    overflow-y: auto !important;
                }
                .modal-sidebar {
                    width: 100% !important;
                    border-right: none !important;
                    border-bottom: 1px solid var(--border) !important;
                    padding: 40px 20px !important;
                    overflow-y: visible !important;
                }
                .modal-main {
                    padding: 40px 20px !important;
                    overflow-y: visible !important;
                }
                .modal-close {
                    top: 20px !important;
                    right: 20px !important;
                    z-index: 1001;
                }
                .info-grid {
                    grid-template-columns: 1fr !important;
                }
            }

            /* Profile Modal Styles */
            .modal-overlay {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.85);
                display: none;
                align-items: center;
                justify-content: center;
                z-index: 1000;
                backdrop-filter: blur(20px);
                padding: 0;
            }

            .modal-content {
                background: var(--card-bg);
                width: 100%;
                max-width: 100%;
                height: 100vh;
                border-radius: 0;
                overflow: hidden;
                position: relative;
                box-shadow: none;
                border: none;
                display: flex;
                flex-direction: column;
                animation: modal-slide-up 0.5s cubic-bezier(0.16, 1, 0.3, 1);
            }

            @keyframes modal-slide-up {
                from { transform: translateY(100%); opacity: 0; }
                to { transform: translateY(0); opacity: 1; }
            }

            .modal-body {
                display: flex;
                flex: 1;
                overflow: hidden;
            }

            .modal-sidebar {
                width: 400px;
                background: var(--nav-bg);
                border-right: 1px solid var(--border);
                padding: 60px 40px;
                display: flex;
                flex-direction: column;
                align-items: center;
                text-align: center;
                overflow-y: auto;
            }

            .modal-main {
                flex: 1;
                padding: 60px 80px;
                overflow-y: auto;
            }

            .modal-close {
                position: absolute;
                top: 40px;
                right: 40px;
                width: 44px;
                height: 44px;
                background: rgba(255,255,255,0.1);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                cursor: pointer;
                color: var(--text-muted);
                z-index: 10;
                transition: .3s;
                border: 1px solid var(--border);
            }

            .modal-close:hover {
                color: #fff;
                background: var(--rose);
                border-color: var(--rose);
                transform: rotate(90deg);
            }

            .profile-avatar-xl {
                width: 120px;
                height: 120px;
                border-radius: 35px;
                background: linear-gradient(135deg, var(--coral), var(--rose));
                color: #fff;
                font-size: 3.5rem;
                font-weight: 800;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Playfair Display', serif;
                margin-bottom: 24px;
                box-shadow: 0 20px 40px rgba(217, 95, 59, 0.3);
            }

            .qual-badge {
                background: rgba(90, 122, 92, 0.1);
                color: var(--sage);
                padding: 8px 16px;
                border-radius: 100px;
                font-size: 11px;
                font-weight: 800;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                margin-top: 10px;
            }

            .section-box {
                background: var(--cream);
                padding: 30px;
                border-radius: 24px;
                margin-bottom: 30px;
                border: 1px solid var(--border);
            }

            .section-label {
                font-size: 11px;
                font-weight: 900;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 1.5px;
                margin-bottom: 20px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .section-label i {
                color: var(--coral);
            }

            .modal-actions {
                padding: 30px;
                background: var(--nav-bg);
                border-top: 1px solid var(--border);
                display: flex;
                justify-content: flex-end;
                gap: 15px;
            }

            .action-btn {
                padding: 12px 24px;
                border-radius: 14px;
                font-weight: 700;
                font-size: 14px;
                cursor: pointer;
                border: none;
                transition: .3s;
                display: flex;
                align-items: center;
                gap: 8px;
                text-decoration: none;
            }

            .btn-hire {
                background: var(--sage);
                color: #fff;
            }

            .btn-hire:hover {
                background: #4a6a4d;
                transform: translateY(-2px);
            }

            .btn-reject {
                background: rgba(181, 56, 74, 0.1);
                color: var(--rose);
            }

            .btn-reject:hover {
                background: var(--rose);
                color: #fff;
            }

            .btn-schedule {
                background: var(--coral);
                color: #fff;
            }

            /* Grid Layout Fixes */
            .info-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 24px;
            }

            @media (max-width: 768px) {
                .modal-body {
                    flex-direction: column;
                }

                .modal-sidebar {
                    width: 100%;
                    border-right: none;
                    border-bottom: 1px solid var(--border);
                }

                .info-grid {
                    grid-template-columns: 1fr;
                }
            }

            .app-modal {
                position: fixed;
                inset: 0;
                display: none;
                background: rgba(0, 0, 0, 0.85);
                backdrop-filter: blur(10px);
                z-index: 2000;
                align-items: center;
                justify-content: center;
                opacity: 0;
                transition: opacity 0.3s ease;
            }

            .app-modal.active {
                display: flex;
                opacity: 1;
            }

            .app-modal-content {
                background: var(--card-bg);
                width: 95%;
                max-width: 1000px;
                max-height: 95vh;
                border-radius: 28px;
                overflow: hidden;
                display: flex;
                flex-direction: column;
                transform: scale(0.95);
                transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
                box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.6);
                border: 1px solid var(--border);
                position: relative;
            }

            .app-modal.active .app-modal-content {
                transform: scale(1);
            }

            .app-modal-header {
                padding: 30px 50px;
                color: white;
                position: relative;
                flex-shrink: 0;
                overflow: hidden;
                background: linear-gradient(135deg, #1C0F08 0%, #2C1A0E 100%);
                border-bottom: 2px solid var(--coral);
                z-index: 10;
            }

            .app-modal-body-scroll {
                padding: 50px 80px;
                background: var(--bg);
                position: relative;
                flex: 1;
                overflow-y: auto;
                scrollbar-width: thin;
                scrollbar-color: var(--coral) transparent;
                z-index: 1;
            }

            .app-modal-body-scroll::after {
                content: '';
                position: absolute;
                inset: 0;
                background-image: radial-gradient(var(--border) 1px, transparent 1px);
                background-size: 32px 32px;
                opacity: 0.4;
                z-index: -1;
                pointer-events: none;
            }

            [data-theme="dark"] .app-modal-body-scroll::after {
                background-image: radial-gradient(rgba(217, 95, 59, 0.1) 1px, transparent 1px);
                opacity: 1;
            }

            .app-modal-body-scroll > * {
                position: relative;
                z-index: 2;
            }

            /* Improved Status Badges */
            .status-badge {
                padding: 6px 14px;
                border-radius: 20px;
                font-size: 10px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 1px;
                display: inline-block;
            }

            .status-badge.approved {
                background: #EBFDF5;
                color: #10B981;
                border: 1px solid rgba(16, 185, 129, 0.3);
            }

            .status-badge.rejected {
                background: #FEF2F2;
                color: #EF4444;
                border: 1px solid rgba(239, 68, 68, 0.3);
            }

            .status-badge.pending {
                background: #FFFBEB;
                color: #F59E0B;
                border: 1px solid rgba(245, 158, 11, 0.3);
            }

            [data-theme="dark"] .status-badge.approved { background: rgba(16, 185, 129, 0.15); }
            [data-theme="dark"] .status-badge.rejected { background: rgba(239, 68, 68, 0.15); }
            [data-theme="dark"] .status-badge.pending { background: rgba(245, 158, 11, 0.15); }

            @media (max-width: 900px) {
                .app-modal-content { width: 100%; height: 100%; border-radius: 0; }
                .app-modal-header { padding: 25px 20px; }
                .app-modal-body-scroll { padding: 40px 20px; }
            }

            @media (max-width: 768px) {
                .app-modal-content {
                    width: 100%;
                    max-width: 100%;
                    height: 100vh;
                    max-height: 100vh;
                    border-radius: 0;
                }
                
                .app-modal-header {
                    padding: 20px 25px !important;
                }

                .app-modal-body-scroll {
                    padding: 25px 20px !important;
                }

                .eval-btn-group {
                    grid-template-columns: 1fr !important;
                    gap: 12px !important;
                }

                .diary-row-content {
                    grid-template-columns: 1fr !important;
                    gap: 15px !important;
                }
                .diary-row-content > div:last-child {
                    justify-content: flex-start !important;
                    border-left: none !important;
                    padding-left: 0 !important;
                    border-top: 1px solid var(--border);
                    padding-top: 15px;
                    width: 100%;
                }
            }
        </style>
</head>

<body>
    <%- include('../partials/dashboard/company_sidebar', { activePage: activePage }) %>


        <div class="page-header">
            <% if (activePage==='dashboard' ) { %>
                <h1 class="page-title">Executive Sync, <span>
                        <%= user.name.split(' ')[0] %></span></h1>
            <p class="page-subtitle">Manage your internship pipeline and coordinate with top talent.</p>
        <% } else if (activePage === 'applications') { %>
                            <h1 class="page-title">Candidate Pipeline</h1>
                            <p class="page-subtitle">Review applications and manage recruitment stages.</p>
                            <% } %>
        </div>

        <% if (activePage==='dashboard' ) { %>
            <div class="stats-grid">
                <div class="stat-card reveal">
                    <div class="stat-top">
                        <div class="stat-icon blue"><i class="fas fa-briefcase"></i></div>
                        <span class="stat-badge up"><i class="fas fa-check"></i> Live</span>
                    </div>
