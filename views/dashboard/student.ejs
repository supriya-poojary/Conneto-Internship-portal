                                                <button type="button" onclick="filterStudentDiaries(this, 'pending')" class="filter-btn" style="padding: 6px 15px; border-radius: 20px; border: 1px solid var(--border); background: var(--card-bg); color: var(--text-muted); cursor:pointer; font-size:12px; font-weight:700; transition:0.3s">Pending</button>
                                                <button type="button" onclick="filterStudentDiaries(this, 'approved')" class="filter-btn" style="padding: 6px 15px; border-radius: 20px; border: 1px solid var(--border); background: var(--card-bg); color: var(--text-muted); cursor:pointer; font-size:12px; font-weight:700; transition:0.3s">Approved</button>
                                                <button type="button" onclick="filterStudentDiaries(this, 'rejected')" class="filter-btn" style="padding: 6px 15px; border-radius: 20px; border: 1px solid var(--border); background: var(--card-bg); color: var(--text-muted); cursor:pointer; font-size:12px; font-weight:700; transition:0.3s">Rejected</button>
                                            </div>
                                        </div>
                                        <% if (diaryEntries && diaryEntries.length > 0) { %>
                                            <div style="display: flex; flex-direction: column; gap: 15px;">
                                                <% 
                                                    const internshipIds = [...new Set(diaryEntries.filter(e => e.internship).map(e => e.internship._id.toString()))];
                                                    diaryEntries.forEach((entry, idx) => {
                                                        const companyId = entry.internship ? entry.internship._id.toString() : 'default';
                                                        const colorIdx = internshipIds.indexOf(companyId) !== -1 ? internshipIds.indexOf(companyId) : 0;
                                                        const companyName = (entry.internship ?
                                                            (entry.internship.companyName || (entry.internship.company ?
                                                            (entry.internship.company.companyName || entry.internship.company.name) : '')) :
                                                            '') || 'Company';
                                                        const role = entry.internship ? entry.internship.title : 'Software Developer';
                                                        
                                                        const colors = [
                                                            { accent: '#6366F1', grad: 'linear-gradient(135deg, #6366F1, #4338CA)' }, // Indigo
                                                            { accent: '#10B981', grad: 'linear-gradient(135deg, #10B981, #065F46)' }, // Emerald
                                                            { accent: '#F59E0B', grad: 'linear-gradient(135deg, #F59E0B, #B45309)' }, // Amber
                                                            { accent: '#EF4444', grad: 'linear-gradient(135deg, #EF4444, #991B1B)' }, // Crimson
                                                            { accent: '#8B5CF6', grad: 'linear-gradient(135deg, #8B5CF6, #5B21B6)' }, // Violet
                                                            { accent: '#06B6D4', grad: 'linear-gradient(135deg, #06B6D4, #155E75)' }  // Cyan
                                                        ];
                                                        const color = colors[colorIdx % colors.length];
                                                %>
                                                <div class="diary-row-item" data-status="<%= entry.status %>" style="position: relative; background: var(--card-bg); border-radius: 16px; border: 1px solid var(--border); overflow: hidden; display: flex; align-items: stretch; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 4px 15px rgba(0,0,0,0.02);" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 15px 35px rgba(0,0,0,0.08)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(0,0,0,0.02)';">
                                                    
                                                    <!-- Dynamic Color Accent Ribbon -->
                                                    <div style="width: 8px; background: <%= color.grad %>; flex-shrink: 0;"></div>
                                                    
                                                    <div class="diary-row-content" style="flex: 1; padding: 18px 25px; display: grid; grid-template-columns: minmax(180px, 1.5fr) 3fr auto; gap: 20px; align-items: center;">
                                                        
                                                        <!-- Meta Column -->
                                                        <div style="display: flex; gap: 15px; align-items: center;">
                                                            <div style="width: 45px; height: 45px; border-radius: 12px; background: <%= color.accent %>15; display: flex; align-items: center; justify-content: center; color: <%= color.accent %>; font-weight: 900; font-size: 1.1rem; box-shadow: inset 0 0 0 1px <%= color.accent %>33;">
                                                                <%= companyName.charAt(0).toUpperCase() %>
                                                            </div>
                                                            <div>
                                                                <div style="font-weight: 800; color: var(--ink); font-size: 14px; margin-bottom: 3px;">
                                                                    <%= new Date(entry.date).toLocaleDateString('en-GB', { day: '2-digit' , month: 'short' , year: 'numeric' }) %>
                                                                </div>
                                                                <div style="font-size: 11px; color: <%= color.accent %>; font-weight: 700; text-transform: uppercase;"><%= role %></div>
                                                            </div>
                                                        </div>

                                                        <!-- Summary Column -->
                                                        <div>
                                                            <p style="font-size: 13.5px; color: var(--text); line-height: 1.5; font-weight: 500; display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin: 0;">
                                                                <%= entry.workSummary %>
                                                            </p>
                                                            <% if (entry.remarks) { %>
                                                                <div style="font-size: 11px; color: var(--rose); margin-top: 6px; font-weight: 600; font-style: italic; background: rgba(181, 56, 74, 0.05); padding: 4px 10px; border-radius: 6px; display: inline-block;">Note: <%= entry.remarks.substring(0, 50) %>...</div>
                                                            <% } %>
                                                        </div>

                                                        <!-- Actions & Status Column -->
                                                        <div style="display: flex; align-items: center; gap: 20px; justify-content: flex-end;">
                                                            <div style="display: flex; flex-direction: column; align-items: center; gap: 8px;">
                                                                <div style="background: <%= color.accent %>10; color: <%= color.accent %>; padding: 4px 12px; border-radius: 8px; font-size: 12px; font-weight: 800; font-family: 'Outfit'; border: 1px solid <%= color.accent %>20;">
                                                                    <%= entry.hoursWorked %>H
                                                                </div>
                                                                <span class="status-badge <%= entry.status %>" style="font-size: 9px; padding: 3px 10px;"><%= entry.status %></span>
                                                            </div>

                                                            <div style="display: flex; flex-direction: column; gap: 8px; border-left: 1px solid var(--border); padding-left: 20px;">
                                                                <% if (entry.status !== 'approved') { %>
                                                                    <div style="display: flex; gap: 8px;">
                                                                        <button onclick="editDiary('<%= entry._id %>', `<%= (entry.workSummary || '').replace(/`/g, '\\`') %>`, '<%= entry.hoursWorked %>', `<%= (entry.links || '').replace(/`/g, '\\`') %>`, `<%= (entry.learnings || '').replace(/`/g, '\\`') %>`, `<%= (entry.blockers || '').replace(/`/g, '\\`') %>`, `<%= (entry.skillsUsed || '').replace(/`/g, '\\`') %>`, '<%= new Date(entry.date).toISOString().split('T')[0] %>')" class="header-btn" title="Edit Log" style="width: 35px; height: 35px; font-size: 13px; border-radius: 10px; background: rgba(217,95,59,0.1); color: var(--coral); border: none; cursor: pointer; transition: 0.2s;" onmouseover="this.style.background='var(--coral)'; this.style.color='#fff';" onmouseout="this.style.background='rgba(217,95,59,0.1)'; this.style.color='var(--coral)';">
                                                                            <i class="fas fa-edit"></i>
                                                                        </button>
                                                                        <form action="/student/diary/delete/<%= entry._id %>" method="POST" onsubmit="return confirm('Delete this record?')" style="display: inline;">
                                                                            <button type="submit" class="header-btn" title="Delete Log" style="width: 35px; height: 35px; font-size: 13px; border-radius: 10px; background: rgba(181,56,74,0.1); color: var(--rose); border: none; cursor: pointer; transition: 0.2s;" onmouseover="this.style.background='var(--rose)'; this.style.color='#fff';" onmouseout="this.style.background='rgba(181,56,74,0.1)'; this.style.color='var(--rose)';">
                                                                                <i class="fas fa-trash"></i>
                                                                            </button>
                                                                        </form>
                                                                    </div>
                                                                <% } else { %>
                                                                    <div style="display: flex; align-items: center; justify-content: center; width: 35px; height: 35px; background: rgba(90, 122, 92, 0.1); border-radius: 10px; color: var(--sage);">
                                                                        <i class="fas fa-lock"></i>
                                                                    </div>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                        
                                                    </div>
                                                </div>
                                                <% }) %>
                                            </div>
                                            <% } else { %>
                                                <div
                                                    style="text-align:center; padding: 40px 0; border: 1px dashed var(--border); border-radius:15px;">
                                                    <p style="color:var(--text-muted)">No diary entries mapped for this
                                                        view. Start writing above!</p>
                                                </div>
                                                <% } %>
                                    </div>
                                </div>
                                <!-- Edit Diary Modal -->
                                <div id="editDiaryModal" class="app-modal">
                                    <div class="app-modal-content"
                                        style="max-width: 1000px; width: 90%; max-height: 90vh; border-radius: 30px; background: var(--bg); overflow-y: auto; display: flex; flex-direction: column; padding: 0; box-shadow: 0 40px 100px rgba(0,0,0,0.5) !important;">

                                        <!-- Professional Header -->
                                        <div class="diary-modal-header"
                                            style="background: linear-gradient(135deg, rgba(217, 95, 59, 0.08), rgba(181, 56, 74, 0.03)); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                                            <div>
                                                <h2
                                                    style="font-family: 'Outfit', sans-serif; font-size: 2rem; color: var(--ink); font-weight: 800; line-height: 1; margin: 0;">
                                                    <i class="fas fa-edit"
                                                        style="color:var(--coral); margin-right:15px;"></i>Edit Diary
                                                    Log
                                                </h2>
                                                <p
                                                    style="color: var(--text-muted); font-size: 0.95rem; margin-top: 5px;">
                                                    Update your technical record comprehensively.</p>
                                            </div>
                                            <button
                                                onclick="document.getElementById('editDiaryModal').classList.remove('active')"
                                                style="background: none; border: none; color: var(--text); font-size: 1.5rem; cursor: pointer; opacity: 0.5; transition: 0.3s;"
                                                onmouseover="this.style.opacity='1'; this.style.transform='rotate(90deg)';"
                                                onmouseout="this.style.opacity='0.5'; this.style.transform='rotate(0deg)';">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </div>

                                        <!-- Editor Workspace -->
                                        <div class="diary-modal-body">
                                            <form id="editDiaryForm" method="POST"
                                                onsubmit="return validateDiaryDate('editDiaryDate')">

                                                <!-- Metadata Row (Date) -->
                                                <div class="portfolio-grid"
                                                    style="grid-template-columns: 1fr 1fr; gap:30px; margin-bottom: 25px;">
                                                    <div class="portfolio-group">
                                                        <div
                                                            style="display:flex; align-items:center; gap:10px; margin-bottom:10px">
                                                            <i class="fas fa-calendar-day"
                                                                style="color:var(--coral); font-size: 0.9rem;"></i>
                                                            <label class="portfolio-label" style="margin:0">Date of
                                                                Activity *</label>
                                                        </div>
                                                        <input type="date" id="editDiaryDate" name="date"
                                                            class="portfolio-input"
                                                            style="height: 50px; font-size: 1rem;" required>
                                                        <p
                                                            style="font-size:11px; color:var(--text-muted); margin-top:6px">
                                                            Sundays are strictly restricted for VTU logs.</p>
                                                    </div>
                                                    <div class="portfolio-group"
                                                        style="visibility: hidden; pointer-events: none;">
                                                        <label class="portfolio-label">Placeholder</label>
                                                        <div class="portfolio-input"></div>
                                                    </div>
                                                </div>

                                                <!-- Work Summary & Hours -->
                                                <h4 class="portfolio-section-title"
                                                    style="font-size:1rem; margin-bottom: 15px;"><i
                                                        class="fas fa-briefcase"></i> What I worked on?</h4>
                                                <div class="portfolio-grid"
                                                    style="grid-template-columns: 3fr 1fr; gap:30px; margin-bottom: 25px;">
                                                    <div class="portfolio-group">
                                                        <label class="portfolio-label">Work Summary *</label>
                                                        <textarea id="editDiaryWorkSummary" name="workSummary"
                                                            class="portfolio-input portfolio-textarea"
                                                            placeholder="Briefly describe the work you did today..."
                                                            maxlength="2000"
                                                            style="min-height:100px; padding: 15px; font-size: 1rem;"
                                                            required></textarea>
                                                    </div>
                                                    <div class="portfolio-group">
                                                        <label class="portfolio-label">Hours worked *</label>
                                                        <input type="number" id="editDiaryHours" name="hoursWorked"
                                                            class="portfolio-input" min="0" max="24" step="0.25"
                                                            style="height: 100px; font-size: 1.4rem; text-align: center;"
                                                            required>
                                                    </div>
                                                </div>

                                                <!-- Links -->
                                                <h4 class="portfolio-section-title"
                                                    style="font-size:1rem; margin-bottom: 15px;"><i
                                                        class="fas fa-link"></i> Show Your Work</h4>
                                                <div class="portfolio-group" style="margin-bottom: 25px;">
                                                    <label class="portfolio-label">Reference Links</label>
                                                    <textarea id="editDiaryLinks" name="links" class="portfolio-input"
                                                        placeholder="Paste links separated by commas" maxlength="5000"
                                                        style="min-height:60px; padding: 15px; font-size: 1rem;"></textarea>
                                                </div>

                                                <!-- Learnings & Blockers -->
                                                <h4 class="portfolio-section-title"
                                                    style="font-size:1rem; margin-bottom: 15px;"><i
                                                        class="fas fa-brain"></i> Blockers & Learnings</h4>
                                                <div class="portfolio-grid"
                                                    style="grid-template-columns: 1fr 1fr; gap:30px; margin-bottom: 25px;">
                                                    <div class="portfolio-group">
                                                        <label class="portfolio-label">Learnings / Outcomes *</label>
                                                        <textarea id="editDiaryLearnings" name="learnings"
                                                            class="portfolio-input portfolio-textarea"
                                                            placeholder="What did you learn today?" maxlength="2000"
                                                            style="min-height:100px; padding: 15px; font-size: 1rem;"
                                                            required></textarea>
                                                    </div>
                                                    <div class="portfolio-group">
                                                        <label class="portfolio-label">Blockers / Risks</label>
                                                        <textarea id="editDiaryBlockers" name="blockers"
                                                            class="portfolio-input portfolio-textarea"
                                                            placeholder="Hurdlrs encountered?" maxlength="1000"
                                                            style="min-height:100px; padding: 15px; font-size: 1rem;"></textarea>
                                                    </div>
                                                </div>

                                                <!-- Skills -->
                                                <h4 class="portfolio-section-title"
                                                    style="font-size:1rem; margin-bottom: 15px;"><i
                                                        class="fas fa-code"></i> Skills</h4>
                                                <div class="portfolio-group" style="margin-bottom: 40px;">
                                                    <label class="portfolio-label">Skills Used *</label>
                                                    <input type="text" id="editDiarySkills" name="skillsUsed"
                                                        class="portfolio-input" placeholder="e.g. React, Node.js"
                                                        style="height: 50px; font-size: 1rem; padding: 0 20px;"
                                                        required>
                                                </div>

                                                <!-- ActionBar -->
                                                <div
                                                    style="display: flex; justify-content: flex-end; gap: 15px; padding-top: 25px; border-top: 1px solid var(--border);">
                                                    <button type="button"
                                                        onclick="document.getElementById('editDiaryModal').classList.remove('active')"
                                                        class="view-btn"
                                                        style="background: none; border: 1px solid var(--border); color: var(--text); padding: 10px 25px; font-weight: 700; font-size: 0.9rem; border-radius: 12px;">Discard</button>
                                                    <button type="submit" class="view-btn"
                                                        style="background: var(--coral); border: none; color: #fff; padding: 10px 40px; font-weight: 800; font-size: 1rem; border-radius: 12px; box-shadow: 0 10px 30px rgba(217, 95, 59, 0.15) !important;">
                                                        <i class="fas fa-save" style="margin-right:8px"></i>Save Record
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                </div>
                                </div>
                                </div>
                                </div>
                                <script>
                                    function editDiary(id, workSummary, hoursWorked, links, learnings, blockers, skillsUsed, date) {
                                        const modal = document.getElementById('editDiaryModal');
                                        document.getElementById('editDiaryForm').action = '/student/diary/edit/' + id;
                                        document.getElementById('editDiaryDate').value = date;
                                        document.getElementById('editDiaryHours').value = hoursWorked;
                                        document.getElementById('editDiaryWorkSummary').value = workSummary;
                                        document.getElementById('editDiaryLearnings').value = learnings;
                                        document.getElementById('editDiaryBlockers').value = blockers;
                                        document.getElementById('editDiarySkills').value = skillsUsed;
                                        document.getElementById('editDiaryLinks').value = links;
                                        modal.classList.add('active');
                                    }
                                </script>
                                <% } else if (activePage==='settings' ) { %>
                                    <header class="header">
                                        <div class="header-left">
                                            <h1>Settings & <span>Security</span></h1>
                                            <p>Manage your account password.</p>
                                        </div>
                                    </header>

                                    <div class="card reveal" style="margin-top:20px; max-width:600px">
                                        <div class="card-header">
                                            <h2 class="card-title"><i class="fas fa-lock"></i> Change Password</h2>
                                        </div>

                                        <% if (typeof success !=='undefined' && success && success.includes('Password'))
                                            { %>
                                            <div style="background:rgba(90,122,92,0.1); color:var(--sage); padding:15px; border-radius:12px; margin-bottom:20px; font-weight:700"
                                                id="passwordSuccessMsg">
                                                <i class="fas fa-check-circle"></i>
                                                <%= success %>
                                            </div>
                                            <% } %>
                                                <% if (typeof error !=='undefined' && error &&
                                                    error.includes('assword')) { %>
                                                    <div
                                                        style="background:rgba(181,56,74,0.1); color:var(--rose); padding:15px; border-radius:12px; margin-bottom:20px; font-weight:700">
                                                        <i class="fas fa-exclamation-circle"></i>
                                                        <%= error %>
                                                    </div>
                                                    <% } %>

                                                        <form action="/auth/change-password" method="POST">
                                                            <div class="portfolio-group">
                                                                <label class="portfolio-label">Current
                                                                    Password</label>
                                                                <input type="password" name="currentPassword"
                                                                    class="portfolio-input" required
                                                                    placeholder="Enter current password">
                                                            </div>
                                                            <div class="portfolio-group">
                                                                <label class="portfolio-label">New Password</label>
                                                                <input type="password" name="newPassword"
                                                                    class="portfolio-input" required
                                                                    placeholder="Enter new password">
                                                            </div>
                                                            <div class="portfolio-group">
                                                                <label class="portfolio-label">Confirm New
                                                                    Password</label>
                                                                <input type="password" name="confirmPassword"
                                                                    class="portfolio-input" required
                                                                    placeholder="Confirm new password">
                                                            </div>
                                                            <div style="margin-top:20px;">
                                                                <button type="submit" class="view-btn"
                                                                    style="background:var(--coral); color:#fff; padding:12px 30px; font-size:1rem; border-radius:12px; border:none; cursor:pointer">
                                                                    Update Password
                                                                </button>
                                                            </div>
                                                        </form>
                                    </div>
                                    <% } %>
                                        </main>

                                        <script>
                                            // URL Search Params handler for SweetAlerts
                                            const urlParams = new URLSearchParams(window.location.search);
                                            if (urlParams.get('success') === 'Password updated successfully.') {
                                                Swal.fire({
                                                    icon: 'success',
                                                    title: 'Privacy Secured',
                                                    text: 'Your password has been updated successfully.',
                                                    confirmButtonColor: '#D95F3B',
                                                    iconColor: '#D95F3B'
                                                });
                                            } else if (urlParams.get('success') === '1' || urlParams.get('success') ===
                                                'Password updated successfully.') {
                                                Swal.fire({
                                                    icon: 'success',
                                                    title: 'Great Job!',
                                                    text: 'Your portfolio is now updated and live.',
                                                    confirmButtonColor: '#D95F3B',
                                                    iconColor: '#D95F3B'
                                                });
                                            } else if (urlParams.get('error')) {
                                                Swal.fire({
                                                    icon: 'error',
                                                    title: 'Oops!',
                                                    text: decodeURIComponent(urlParams.get('error')),
                                                    confirmButtonColor: '#D95F3B'
                                                });
                                            }

                                            const reveals = document.querySelectorAll('.reveal');
                                            reveals.forEach((el, i) => {
                                                setTimeout(() => el.classList.add('visible'), i * 100);
                                            });

                                            const search = document.getElementById('globalSearch');
                                            if (search) {
                                                search.addEventListener('keypress', (e) => {
                                                    if (e.key === 'Enter' && search.value.trim()) {
                                                        window.location.href = '/internships?q=' + encodeURIComponent(search.value);
                                                    }
                                                });
                                            }
                                        </script>

                                        <!-- Application Details Modal -->
                                        <div id="appDetailsModal" class="app-modal">
                                            <div class="app-modal-content">
                                                <i class="fas fa-times app-modal-close" onclick="closeAppModal()"></i>
                                                <div id="appModalBody">
                                                    <!-- Dynamic Content -->
                                                </div>
                                            </div>
                                        </div>

                                        <script>
                                            const studentApps = <% - JSON.stringify(applications || []) %>;

                                            function showAppDetails(appId) {
                                                const app = studentApps.find(a => a._id === appId);
                                                if (!app) return;

                                                const modal = document.getElementById('appDetailsModal');
                                                const body = document.getElementById('appModalBody');

                                                const statusText = app.status === 'applied' ? 'In Processing' : app.status.replace(/_/g, ' ');
                                                const dateStr = new Date(app.appliedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });

                                                let interviewHtml = '';
                                                if (app.status === 'interview_scheduled') {
                                                    const iDate = new Date(app.interviewDate).toLocaleString('en-IN', {
                                                        day: '2-digit', month: 'short', year: 'numeric',
                                                        hour: '2-digit', minute: '2-digit'
                                                    });
                                                    interviewHtml = `
                                                            <div style="background:rgba(90,122,92,0.1); border-radius:15px; padding:20px; margin-top:20px">
                                                                <h4 style="color:var(--sage); margin-bottom:10px; display:flex; align-items:center; gap:10px">
                                                                    <i class="fas fa-calendar-check"></i> Interview Scheduled
                                                                </h4>
                                                                <p style="font-size:18px; font-weight:700; color:var(--ink)">${iDate}</p>
                                                                ${app.interviewNote ? `<p style="font-size:13px; color:var(--text-muted); margin-top:10px">Note: ${app.interviewNote}</p>` : ''}
                                                            </div>
                                                        `;

                                                    if (!app.rescheduleRequest) {
                                                        interviewHtml += `
                                                                <div class="reschedule-box">
                                                                    <h5 style="color:var(--coral); margin-bottom:12px; font-size:14px">Need to Reschedule?</h5>
                                                                    <form action="/student/applications/${app._id}/reschedule" method="POST">
                                                                        <div style="margin-bottom:10px">
                                                                            <label style="font-size:11px; font-weight:700; color:var(--text-muted); display:block; margin-bottom:5px">Suggested New Time:</label>
                                                                            <input type="datetime-local" name="suggestedDate" required style="width:100%; border:1px solid var(--border); border-radius:10px; padding:10px; font-size:13px; background:var(--bg); color:var(--text);">
                                                                        </div>
                                                                        <textarea name="reason" placeholder="Please provide a suitable reason for rescheduling..." required 
                                                                            style="width:100%; border:1px solid var(--border); border-radius:10px; padding:10px; font-size:13px; min-height:80px; margin-bottom:10px; background:var(--bg); color:var(--text);"></textarea>
                                                                        <button type="submit" class="view-btn" style="background:var(--coral); color:#fff; border:none; padding:8px 15px; font-size:12px; cursor:pointer">Send Request</button>
                                                                    </form>
                                                                </div>
                                                            `;
                                                    } else {
                                                        interviewHtml += `
                                                                <div style="margin-top:15px; background:rgba(217,95,59,0.05); padding:15px; border-radius:10px; border:1px solid var(--coral)">
                                                                    <div style="color:var(--coral); font-weight:700; font-size:13px">
                                                                        <i class="fas fa-hourglass-half"></i> Reschedule Requested
                                                                    </div>
                                                                    <p style="font-size:12px; color:var(--text-muted); margin-top:5px">Reason: ${app.rescheduleReason}</p>
                                                                </div>
                                                            `;
                                                    }
                                                }

                                                body.innerHTML = `
                                                        <h2 style="font-family:'Playfair Display', serif; margin-bottom:10px">${app.internship.title}</h2>
                                                        <p style="color:var(--text-muted); margin-bottom:25px; font-weight:600">${app.internship.company ? (app.internship.company.companyName || 'Company') : 'Company'}</p>
                                                        
                                                        <div style="display:flex; gap:30px; margin-bottom:25px">
                                                            <div>
                                                                <div style="font-size:11px; font-weight:800; color:var(--text-muted); text-transform:uppercase">Status</div>
                                                                <div style="font-weight:700; color:var(--coral); margin-top:5px; font-size:16px">${statusText}</div>
                                                            </div>
                                                            <div>
                                                                <div style="font-size:11px; font-weight:800; color:var(--text-muted); text-transform:uppercase">Applied On</div>
                                                                <div style="font-weight:700; color:var(--ink); margin-top:5px; font-size:16px">${dateStr}</div>
                                                            </div>
                                                        </div>

                                                        ${interviewHtml}

                                                        <div style="margin-top:30px; padding-top:20px; border-top:1px solid var(--border)">
                                                            <h4 style="font-size:14px; margin-bottom:10px; color:var(--ink)">Application Summary</h4>
                                                            <div style="font-size:13px; color:var(--text); line-height:1.6">
                                                                <p><strong>Cover Letter:</strong> ${app.coverLetter || 'N/A'}</p>
                                                                <p style="margin-top:10px"><strong>Skills Provided:</strong> ${app.studentSkills || 'N/A'}</p>
                                                            </div>
                                                        </div>
                                                    `;

                                                modal.classList.add('active');
                                            }

                                            function closeAppModal() {
                                                document.getElementById('appDetailsModal').classList.remove('active');
                                            }

                                            window.onclick = function (event) {
                                                const modal = document.getElementById('appDetailsModal');
                                                if (event.target == modal) {
                                                    modal.classList.remove('active');
                                                }
                                            }
                                        </script>
</body>

</html>