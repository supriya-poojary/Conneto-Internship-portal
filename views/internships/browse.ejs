<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Internships | Conneto</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Poppins:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #2563EB;
            --primary-dark: #1D4ED8;
            --primary-light: #DBEAFE;
            --secondary: #7C3AED;
            --success: #10B981;
            --success-light: #D1FAE5;
            --warning: #F59E0B;
            --warning-light: #FEF3C7;
            --text: #0F172A;
            --text-muted: #64748B;
            --border: #E2E8F0;
            --bg: #F1F5F9;
            --card-bg: #FFFFFF;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        .header {
            background: white;
            padding: 20px 40px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: var(--shadow);
        }

        .logo {
            font-family: 'Poppins', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .nav-link {
            color: var(--text);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav-link:hover {
            color: var(--primary);
        }

        .btn-login {
            padding: 10px 20px;
            background: var(--primary);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
        }

        .btn-dashboard {
            padding: 10px 20px;
            background: var(--secondary);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .page-header {
            margin-bottom: 32px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .page-subtitle {
            color: var(--text-muted);
        }

        .filters-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: var(--shadow);
        }

        .filters-form {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .filter-input {
            flex: 1;
            min-width: 200px;
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: 10px;
            font-size: 1rem;
        }

        .filter-input:focus {
            outline: none;
            border-color: var(--primary);
        }

        .filter-select {
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: 10px;
            font-size: 1rem;
            background: white;
            min-width: 150px;
        }

        .btn-filter {
            padding: 12px 24px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
        }

        .internships-grid {
            display: grid;
            gap: 20px;
        }

        .internship-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            box-shadow: var(--shadow);
            display: flex;
            gap: 20px;
            transition: all 0.3s ease;
        }

        .internship-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        }

        .company-logo {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            flex-shrink: 0;
        }

        .internship-content {
            flex: 1;
        }

        .internship-title {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 4px;
            color: var(--text);
        }

        .company-name {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 12px;
        }

        .internship-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 16px;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .meta-item i {
            color: var(--primary);
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 16px;
        }

        .tag {
            padding: 4px 12px;
            background: var(--primary-light);
            color: var(--primary);
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .tag.type-remote {
            background: #DCFCE7;
            color: #166534;
        }

        .tag.type-onsite {
            background: #FEE2E2;
            color: #991B1B;
        }

        .tag.type-hybrid {
            background: #FEF3C7;
            color: #92400E;
        }

        .card-actions {
            display: flex;
            gap: 12px;
        }

        .btn-apply {
            padding: 10px 20px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-apply:hover {
            background: var(--primary-dark);
        }

        .btn-apply:disabled {
            background: var(--text-muted);
            cursor: not-allowed;
        }

        .btn-view {
            padding: 10px 20px;
            background: white;
            color: var(--primary);
            border: 2px solid var(--primary);
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
        }

        .btn-view:hover {
            background: var(--primary-light);
        }

        .applied-badge {
            padding: 10px 20px;
            background: var(--success-light);
            color: var(--success);
            border-radius: 8px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 16px;
        }

        .empty-icon {
            font-size: 4rem;
            color: var(--border);
            margin-bottom: 16px;
        }

        .empty-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .empty-text {
            color: var(--text-muted);
        }

        @media (max-width: 768px) {
            .internship-card {
                flex-direction: column;
            }

            .header {
                padding: 16px 20px;
                flex-wrap: wrap;
                gap: 16px;
            }

            .filters-form {
                flex-direction: column;
            }

            .filter-input,
            .filter-select {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <header class="header">
        <a href="/" class="logo">Conneto</a>
        <nav class="nav-links">
            <a href="/internships" class="nav-link">Browse</a>
            <% if (user) { %>
                <% if (user.role==='student' ) { %>
                    <a href="/student/dashboard" class="btn-dashboard">Dashboard</a>
                    <% } else { %>
                        <a href="/company/dashboard" class="btn-dashboard">Dashboard</a>
                        <% } %>
                            <% } else { %>
                                <a href="/auth/login" class="btn-login">Login</a>
                                <% } %>
        </nav>
    </header>

    <div class="container">
        <div class="page-header">
            <h1 class="page-title">Find Your Dream Internship</h1>
            <p class="page-subtitle">Explore opportunities from top companies</p>
        </div>

        <div class="filters-card">
            <form class="filters-form" action="/internships" method="GET">
                <input type="text" name="search" class="filter-input" placeholder="Search by title or skills..."
                    value="<%= filters.search || '' %>">
                <input type="text" name="location" class="filter-input" placeholder="Location..."
                    value="<%= filters.location || '' %>">
                <select name="type" class="filter-select">
                    <option value="">All Types</option>
                    <option value="remote" <%=filters.type==='remote' ? 'selected' : '' %>>Remote</option>
                    <option value="on-site" <%=filters.type==='on-site' ? 'selected' : '' %>>On-site</option>
                    <option value="hybrid" <%=filters.type==='hybrid' ? 'selected' : '' %>>Hybrid</option>
                </select>
                <button type="submit" class="btn-filter">
                    <i class="fas fa-search"></i> Search
                </button>
            </form>
        </div>

        <% if (internships && internships.length> 0) { %>
            <div class="internships-grid">
                <% internships.forEach(function(internship) { %>
                    <div class="internship-card">
                        <div class="company-logo">
                            <% var cName=(internship.company && internship.company.companyName) ?
                                internship.company.companyName : (internship.companyName || '' ); %>
                                <%= cName ? cName.charAt(0).toUpperCase() : 'C' %>
                        </div>
                        <div class="internship-content">
                            <h3 class="internship-title">
                                <%= internship.title %>
                            </h3>
                            <p class="company-name">
                                <%= cName || 'Company' %>
                            </p>

                            <div class="internship-meta">
                                <span class="meta-item">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <%= internship.location || 'Remote' %>
                                </span>
                                <span class="meta-item">
                                    <i class="fas fa-clock"></i>
                                    <%= internship.duration || 'Flexible' %>
                                </span>
                                <span class="meta-item">
                                    <i class="fas fa-rupee-sign"></i>
                                    <%= internship.stipend ? internship.stipend + '/month' : 'Unpaid' %>
                                </span>
                                <span class="meta-item">
                                    <i class="fas fa-users"></i>
                                    <%= internship.openings %> opening<%= internship.openings> 1 ? 's' : '' %>
                                </span>
                            </div>

                            <div class="tags">
                                <span class="tag type-<%= internship.type %>">
                                    <%= internship.type %>
                                </span>
                                <% if (internship.skills && internship.skills.length> 0) { %>
                                    <% internship.skills.slice(0, 3).forEach(function(skill) { %>
                                        <span class="tag">
                                            <%= skill %>
                                        </span>
                                        <% }); %>
                                            <% } %>
                            </div>

                            <div class="card-actions">
                                <a href="/internships/<%= internship._id %>" class="btn-view"
                                    style="width: 100%; text-align: center;">View Details & Apply</a>
                                <% if (user && user.role==='student' ) { %>
                                    <% if (appliedIds && appliedIds.includes(internship._id.toString())) { %>
                                        <span class="applied-badge" style="margin-left: 10px;">
                                            <i class="fas fa-check-circle"></i> Applied
                                        </span>
                                        <% } %>
                                            <% } %>
                            </div>
                        </div>
                    </div>
                    <% }); %>
            </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-briefcase"></i></div>
                    <h2 class="empty-title">No internships found</h2>
                    <p class="empty-text">Try adjusting your search filters or check back later</p>
                </div>
                <% } %>
    </div>
</body>

</html>