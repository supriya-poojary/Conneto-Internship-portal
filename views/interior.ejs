            <div class="project-img-wrapper plx-wrapper">
                <img src="https://images.unsplash.com/photo-1600607688969-a5bfcd646154?auto=format&fit=crop&q=80&w=1600"
                    alt="The Grand Hotel" class="project-img plx-img">
            </div>
        </div>
    </section>

    <!-- Marquee 2 (Right to Left) -->
    <section class="marquee-wrapper">
        <div class="marquee-inner" id="marquee2">
            <div class="marquee-content">ARCHITECTURE • DESIGN • CURATION • STYLING • </div>
            <div class="marquee-content">ARCHITECTURE • DESIGN • CURATION • STYLING • </div>
            <div class="marquee-content">ARCHITECTURE • DESIGN • CURATION • STYLING • </div>
        </div>
    </section>

    <!-- Full Screen Reveal -->
    <section class="reveal-section">
        <div class="reveal-img-wrapper">
            <img src="https://images.unsplash.com/photo-1600607686527-6fb886090705?auto=format&fit=crop&q=80&w=2400"
                alt="Reveal Image" class="reveal-img">
        </div>
        <div class="reveal-content">
            <h2 class="reveal-title">Spatial<br>Poetry.</h2>
        </div>
