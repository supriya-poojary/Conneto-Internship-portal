<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conneto — Connecting Companies with Students</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script>
        (function () {
            const t = localStorage.getItem('conneto-theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    <style>
        :root {
            --coral: #D95F3B;
            --coral-light: #F07A56;
            --rose: #B5384A;
            --amber: #C8831A;
            --amber-light: #E8A030;
            --sage: #5A7A5C;
            --sage-light: #7A9E7C;
            --terra: #A0522D;
            --terra-light: #C4723F;
            --cream: #FAF3E8;
            --cream2: #F5EAD8;
            --warm-white: #FFF8F0;
            --ink: #2C1A0E;
            --ink2: #4A2E1A;
            --text: #3D2B1F;
            --text-muted: #7A5C4A;
            --border: rgba(160, 82, 45, 0.15);
            --shadow: rgba(44, 26, 14, 0.12);
            --card-bg: rgba(255, 248, 240, 0.95);
            --nav-bg: rgba(250, 243, 232, 0.97);
            --section-alt: #F5EAD8;
            --footer-bg: #1E0E05;
        }

        [data-theme="dark"] {
            --cream: #1C0F08;
            --cream2: #251508;
            --warm-white: #1A0D06;
            --ink: #FAF3E8;
            --ink2: #F0E0C8;
            --text: #E8D5BC;
            --text-muted: #B8937A;
            --border: rgba(200, 131, 26, 0.2);
            --shadow: rgba(0, 0, 0, 0.4);
            --card-bg: rgba(37, 21, 8, 0.95);
            --nav-bg: rgba(28, 15, 8, 0.98);
            --section-alt: #201008;
            --footer-bg: #0E0704;
        }


        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--cream);
            color: var(--text);
            transition: background 0.4s, color 0.4s;
            overflow-x: hidden
        }

        /* LOADER */
        .loader {
            position: fixed;
            inset: 0;
            background: var(--cream);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.5s, visibility 0.5s
        }

        .loader.hide {
            opacity: 0;
            visibility: hidden;
            pointer-events: none
        }

        .loader-logo {
            font-family: 'Outfit', sans-serif;
            font-size: 3.5rem;
            font-weight: 800;
            color: var(--ink);
            letter-spacing: -1px
        }

        .loader-logo span {
            color: var(--coral)
        }

        .loader-dots {
            display: flex;
            gap: 10px;
            margin-top: 18px
        }

        .loader-dots div {
            width: 11px;
            height: 11px;
            border-radius: 50%;
            background: var(--coral);
            animation: dotBounce 0.6s infinite alternate
        }

        .loader-dots div:nth-child(2) {
            animation-delay: .15s;
            background: var(--amber)
        }

        .loader-dots div:nth-child(3) {
            animation-delay: .3s;
            background: var(--sage)
        }

        @keyframes dotBounce {
            from {
                transform: translateY(0)
            }

            to {
                transform: translateY(-10px);
                opacity: .5
            }
        }

        /* SHINE EFFECT */
        .shine-box {
            position: relative;
            overflow: hidden;
        }

        .shine-box::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -150%;
            width: 200%;
            height: 200%;
            background: linear-gradient(to right,
                    rgba(255, 255, 255, 0) 0%,
                    rgba(255, 255, 255, 0.4) 50%,
                    rgba(255, 255, 255, 0) 100%);
            transform: rotate(30deg);
            animation: shine-anim 4s infinite;
            pointer-events: none;
        }

        @keyframes shine-anim {
            0% {
                left: -150%;
            }

            20% {
                left: 150%;
            }

            100% {
                left: 150%;
            }
        }

        /* COLOR ANIMATE EFFECT */
        .color-animate {
            animation: color-glow 5s infinite alternate;
            border-width: 2px !important;
        }

        @keyframes color-glow {
            0% {
                border-color: var(--coral);
                box-shadow: 0 0 10px rgba(217, 95, 59, 0.3);
            }

            50% {
                border-color: var(--amber);
                box-shadow: 0 0 15px rgba(200, 131, 26, 0.4);
            }

            100% {
                border-color: var(--sage);
                box-shadow: 0 0 10px rgba(90, 122, 92, 0.3);
            }
        }

        /* DARK MODE DYNAMIC BACKGROUND */
        .dm-bg-blobs {
            position: fixed;
            inset: 0;
            z-index: -1;
            overflow: hidden;
            display: none;
            pointer-events: none;
        }

        [data-theme="dark"] .dm-bg-blobs {
            display: block;
        }

        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.15;
            animation: move-blobs 25s infinite alternate ease-in-out;
        }

        .blob-1 {
            width: 400px;
            height: 400px;
            background: var(--coral);
            top: -100px;
            left: -100px;
            animation-duration: 30s;
        }

        .blob-2 {
            width: 500px;
            height: 500px;
            background: var(--amber);
            bottom: -150px;
            right: -150px;
            animation-delay: -5s;
            animation-duration: 35s;
        }

        .blob-3 {
            width: 300px;
            height: 300px;
            background: var(--sage);
            top: 50%;
            left: 60%;
            animation-delay: -10s;
        }

        @keyframes move-blobs {
            0% {
                transform: translate(0, 0) scale(1) rotate(0deg);
            }

            33% {
                transform: translate(100px, 50px) scale(1.1) rotate(120deg);
            }

            66% {
                transform: translate(-50px, 100px) scale(0.9) rotate(240deg);
            }

            100% {
                transform: translate(0, 0) scale(1) rotate(360deg);
            }
        }

        /* Float animation for cards */
        [data-theme="dark"] .card-float {
            animation: float-dm 6s infinite ease-in-out;
        }

        @keyframes float-dm {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        .topbar {
            background: var(--terra);
            color: #fff;
            padding: 8px 0;
            font-size: 13px;
            font-weight: 500
        }

        .topbar .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 8px
        }

        .topbar-msg {
            letter-spacing: .3px
        }

        .topbar-contact {
            display: flex;
            gap: 20px;
            flex-wrap: wrap
        }

        .topbar-contact a {
            color: rgba(255, 255, 255, 0.85);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: color .3s
        }

        .topbar-contact a:hover {
            color: #fff
        }

        .topbar-contact i {
            opacity: .7;
            font-size: 12px
        }

        /* NAV */
        .nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: var(--nav-bg);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
            transition: all .3s
        }

        .nav.scrolled {
            box-shadow: 0 4px 24px var(--shadow)
        }

        .nav .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            max-width: 1260px;
            margin: 0 auto
        }

        .logo {
            font-family: 'Outfit', sans-serif;
            font-size: 1.9rem;
            font-weight: 800;
            color: var(--ink);
            text-decoration: none;
            letter-spacing: -0.5px
        }

        .logo span {
            color: var(--coral)
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 10px;
            list-style: none
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text);
            font-weight: 600;
            font-size: 14.5px;
            padding: 7px 14px;
            border-radius: 8px;
            transition: all .3s;
            position: relative
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 2px;
            left: 14px;
            right: 14px;
            height: 2px;
            background: var(--coral);
            border-radius: 2px;
            transform: scaleX(0);
            transition: transform .3s
        }

        .nav-links a:hover::after,
        .nav-links a.active::after {
            transform: scaleX(1)
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: var(--coral)
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 10px
        }

        .theme-btn {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: var(--card-bg);
            color: var(--amber);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            transition: all .3s
        }

        .theme-btn:hover {
            background: var(--amber);
            color: #fff;
            transform: rotate(20deg)
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 11px 26px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            text-decoration: none;
            cursor: pointer;
            border: none;
            transition: all .3s;
            font-family: 'Inter', sans-serif
        }

        .btn-outline {
            background: transparent;
            border: 1.5px solid var(--coral);
            color: var(--coral)
        }

        .btn-outline:hover {
            background: var(--coral);
            color: #fff
        }

        .btn-fill {
            background: linear-gradient(135deg, var(--coral), var(--rose));
            color: #fff;
            box-shadow: 0 4px 16px rgba(217, 95, 59, 0.3)
        }

        .btn-fill:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(217, 95, 59, 0.4)
        }

        .btn-amber {
            background: linear-gradient(135deg, var(--amber), var(--terra));
            color: #fff;
            box-shadow: 0 4px 16px rgba(200, 131, 26, 0.3)
        }

        .btn-amber:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(200, 131, 26, 0.4)
        }

        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 8px;
            border: none;
            background: transparent
        }

        .hamburger span {
            display: block;
            width: 24px;
            height: 2px;
            background: var(--ink);
            border-radius: 2px;
            transition: all .3s
        }

        /* CONTAINER */
        .container {
            max-width: 1260px;
            margin: 0 auto;
            padding: 0 24px
        }

        /* HERO */
        .hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            overflow: hidden
        }

        .hero-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1600&q=85');
            background-size: cover;
            background-position: center;
            background-attachment: fixed
        }

        .hero-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(42, 20, 8, 0.78) 0%, rgba(160, 82, 45, 0.45) 60%, rgba(90, 122, 92, 0.3) 100%)
        }

        .hero-content {
            position: relative;
            z-index: 2;
            padding: 140px 0 100px;
            max-width: 780px
        }

        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 248, 240, 0.15);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 248, 240, 0.25);
            padding: 8px 18px;
            border-radius: 50px;
            color: #fff;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 28px;
            letter-spacing: .5px
        }

        .hero-tag i {
            color: var(--amber-light)
        }

        .hero h1 {
            font-family: 'Outfit', sans-serif;
            font-size: clamp(2.6rem, 6vw, 4.2rem);
            font-weight: 800;
            color: #fff;
            line-height: 1.12;
            letter-spacing: -1px;
            margin-bottom: 22px;
            text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3)
        }

        .hero h1 em {
            font-style: italic;
            color: var(--amber-light)
        }

        .hero p {
            font-size: 17px;
            color: rgba(255, 255, 255, 0.85);
            line-height: 1.75;
            max-width: 560px;
            margin-bottom: 36px;
            font-weight: 400
        }

        .hero-btns {
            display: flex;
            gap: 14px;
            flex-wrap: wrap
        }

        .hero-stats {
            position: relative;
            z-index: 2;
            display: flex;
            gap: 32px;
            margin-top: 60px;
            flex-wrap: wrap
        }

        .hero-stat {
            text-align: center
        }

        .hero-stat-num {
            font-family: 'Outfit', sans-serif;
            font-size: 2.4rem;
            font-weight: 800;
            color: var(--amber-light);
            line-height: 1
        }

        .hero-stat-label {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.7);
            margin-top: 4px;
            font-weight: 500;
            letter-spacing: .5px;
            text-transform: uppercase
        }

        .hero-stat-div {
            width: 1px;
            background: rgba(255, 255, 255, 0.2);
            align-self: stretch;
            margin: 4px 0
        }

        /* BRANDS */
        .brands {
            background: var(--terra);
            padding: 18px 0;
            overflow: hidden
        }

        .brands-track {
            display: flex;
            gap: 60px;
            animation: scrollBrands 20s linear infinite;
            width: max-content
        }

        .brands-track span {
            color: rgba(255, 255, 255, 0.7);
            font-weight: 700;
            font-size: 15px;
            white-space: nowrap;
            letter-spacing: .5px
        }

        @keyframes scrollBrands {
            from {
                transform: translateX(0)
            }

            to {
                transform: translateX(-50%)
            }
        }

        /* SECTION COMMON */
        .section {
            padding: 100px 0
        }

        .section-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--coral);
            margin-bottom: 14px
        }

        .section-tag::before,
        .section-tag::after {
            content: '';
            width: 28px;
            height: 2px;
            background: var(--coral);
            border-radius: 2px
        }

        .section-title {
            font-family: 'Outfit', sans-serif;
            font-size: clamp(1.9rem, 4vw, 3rem);
            font-weight: 800;
            color: var(--ink);
            line-height: 1.18;
            letter-spacing: -0.5px;
            margin-bottom: 18px
        }

        .section-title em {
            font-style: italic;
            color: var(--coral)
        }

        .section-title span {
            color: var(--amber)
        }

        .section-sub {
            font-size: 16px;
            color: var(--text-muted);
            line-height: 1.75;
            max-width: 560px
        }

        /* ABOUT */
        .about {
            background: var(--warm-white)
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center
        }

        .about-imgs {
            position: relative;
            height: 520px
        }

        .about-img1 {
            position: absolute;
            top: 0;
            left: 0;
            width: 72%;
            height: 76%;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px var(--shadow)
        }

        .about-img1 img,
        .about-img2 img {
            width: 100%;
            height: 100%;
            object-fit: cover
        }

        .about-img2 {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 55%;
            height: 52%;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 16px 48px var(--shadow);
            border: 4px solid var(--warm-white)
        }

        .about-badge {
            position: absolute;
            top: 50%;
            left: 55%;
            transform: translate(-50%, -50%);
            background: linear-gradient(135deg, var(--coral), var(--rose));
            color: #fff;
            padding: 18px 24px;
            border-radius: 16px;
            text-align: center;
            box-shadow: 0 12px 40px rgba(217, 95, 59, 0.35);
            z-index: 3
        }

        .about-badge-num {
            font-family: 'Outfit', sans-serif;
            font-size: 2.4rem;
            font-weight: 800;
            line-height: 1
        }

        .about-badge-text {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 3px;
            opacity: .9
        }

        .about-points {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin: 28px 0
        }

        .about-point {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            font-size: 14px;
            font-weight: 500;
            color: var(--text)
        }

        .about-point i {
            color: var(--sage);
            margin-top: 3px;
            flex-shrink: 0
        }

        /* STATS BAR */
        .stats-bar {
            background: linear-gradient(135deg, var(--coral) 0%, var(--rose) 50%, var(--terra) 100%);
            padding: 64px 0
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0
        }

        .stat-item {
            text-align: center;
            padding: 10px 24px;
            border-right: 1px solid rgba(255, 255, 255, 0.2);
            position: relative
        }

        .stat-item:last-child {
            border-right: none
        }

        .stat-num {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 800;
            color: #fff;
            line-height: 1;
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 2px
        }

        .stat-num sup {
            font-size: 1.4rem;
            font-weight: 700
        }

        .stat-label {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.8);
            margin-top: 6px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px
        }

        /* FEATURES */
        .features {
            background: var(--section-alt)
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
            margin-top: 56px
        }

        .feature-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 36px 28px;
            border: 1px solid var(--border);
            transition: all .4s;
            position: relative;
            overflow: hidden
        }

        .feature-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--coral), var(--amber))
        }

        .feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 60px var(--shadow)
        }

        .feature-icon {
            width: 60px;
            height: 60px;
            border-radius: 16px;
            background: linear-gradient(135deg, rgba(217, 95, 59, 0.12), rgba(200, 131, 26, 0.12));
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 22px
        }

        .feature-icon i {
            font-size: 24px;
            color: var(--coral)
        }

        .feature-num {
            position: absolute;
            top: 28px;
            right: 28px;
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            font-weight: 800;
            color: rgba(217, 95, 59, 0.07);
            line-height: 1
        }

        .feature-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 12px;
            line-height: 1.3
        }

        .feature-text {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.7
        }

        .feature-list {
            list-style: none;
            margin-top: 16px;
            display: flex;
            flex-direction: column;
            gap: 7px
        }

        .feature-list li {
            font-size: 13px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 7px
        }

        .feature-list li i {
            color: var(--sage);
            font-size: 11px
        }

        /* WHY */
        .why {
            background: var(--warm-white)
        }

        .why-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center
        }

        .why-img {
            position: relative;
            border-radius: 24px;
            overflow: hidden;
            height: 500px;
            box-shadow: 0 24px 80px var(--shadow)
        }

        .why-img img {
            width: 100%;
            height: 100%;
            object-fit: cover
        }

        .why-img::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, transparent 50%, rgba(42, 20, 8, 0.5))
        }

        .why-img-badge {
            position: absolute;
            bottom: 28px;
            left: 28px;
            z-index: 2;
            background: rgba(255, 248, 240, 0.95);
            backdrop-filter: blur(8px);
            padding: 14px 20px;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2)
        }

        .why-img-badge-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--coral)
        }

        .why-img-badge-sub {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 600
        }

        .progress-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 24px;
            margin: 32px 0
        }

        .progress-item-label {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 600;
            color: var(--ink)
        }

        .progress-track {
            height: 8px;
            background: var(--cream2);
            border-radius: 8px;
            overflow: hidden
        }

        .progress-fill {
            height: 100%;
            border-radius: 8px;
            background: linear-gradient(90deg, var(--coral), var(--amber));
            width: 0;
            transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1)
        }

        .why-ceo {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-top: 28px;
            padding-top: 28px;
            border-top: 1px solid var(--border)
        }

        .why-ceo img {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--coral)
        }

        .why-ceo-name {
            font-weight: 700;
            color: var(--ink);
            font-size: 15px
        }

        .why-ceo-role {
            font-size: 12px;
            color: var(--text-muted)
        }

        /* PROCESS */
        .process {
            position: relative;
            padding: 100px 0;
            overflow: hidden
        }

        .process-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1497366754035-f200968a6e72?w=1600&q=80');
            background-size: cover;
            background-position: center;
            background-attachment: fixed
        }

        .process-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(42, 20, 8, 0.9), rgba(90, 122, 92, 0.75))
        }

        .process-inner {
            position: relative;
            z-index: 2
        }

        .process-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
            margin-top: 56px
        }

        .process-card {
            background: rgba(255, 248, 240, 0.08);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 248, 240, 0.15);
            border-radius: 20px;
            padding: 40px 32px;
            text-align: center;
            transition: all .4s;
            position: relative
        }

        .process-card:hover {
            background: rgba(255, 248, 240, 0.12);
            transform: translateY(-6px)
        }

        .process-num {
            font-family: 'Playfair Display', serif;
            font-size: 4rem;
            font-weight: 800;
            color: rgba(255, 248, 240, 0.08);
            position: absolute;
            top: 20px;
            right: 24px;
            line-height: 1
        }

        .process-icon {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--coral), var(--amber));
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 22px;
            box-shadow: 0 8px 24px rgba(217, 95, 59, 0.4)
        }

        .process-icon i {
            font-size: 26px;
            color: #fff
        }

        .process-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.3rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 12px
        }

        .process-text {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.75);
            line-height: 1.7
        }

        .process .section-tag {
            justify-content: center
        }

        .process .section-title,
        .process .section-sub {
            color: #fff;
            text-align: center
        }

        .process .section-sub {
            color: rgba(255, 255, 255, 0.75);
            margin: 0 auto
        }

        /* TESTIMONIALS */
        .testimonials {
            background: var(--section-alt)
        }

        .testi-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-top: 56px
        }

        .testi-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 36px 30px;
            border: 1px solid var(--border);
            position: relative;
            transition: all .4s
        }

        .testi-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 60px var(--shadow)
        }

        .testi-quote {
            font-size: 2.8rem;
            font-family: 'Playfair Display', serif;
            color: var(--coral);
            opacity: .3;
            line-height: 1;
            margin-bottom: 14px
        }

        .testi-text {
            font-size: 15px;
            color: var(--text);
            line-height: 1.75;
            font-style: italic;
            margin-bottom: 24px
        }

        .testi-stars {
            display: flex;
            gap: 3px;
            color: var(--amber);
            margin-bottom: 16px
        }

        .testi-author {
            display: flex;
            align-items: center;
            gap: 12px;
            border-top: 1px solid var(--border);
            padding-top: 18px
        }

        .testi-author img {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--coral)
        }

        .testi-author-name {
            font-weight: 700;
            color: var(--ink);
            font-size: 15px
        }

        .testi-author-role {
            font-size: 12px;
            color: var(--text-muted)
        }

        /* EVENTS */
        .events {
            background: var(--warm-white)
        }

        .events-inner {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 64px;
            align-items: start
        }

        .event-img {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            height: 400px;
            box-shadow: 0 16px 48px var(--shadow)
        }

        .event-img img {
            width: 100%;
            height: 100%;
            object-fit: cover
        }

        .event-play {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(42, 20, 8, 0.3);
            transition: .3s
        }

        .event-play:hover {
            background: rgba(42, 20, 8, 0.5)
        }

        .event-play-btn {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: var(--coral);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            box-shadow: 0 8px 32px rgba(217, 95, 59, 0.5);
            transition: .3s
        }

        .event-play:hover .event-play-btn {
            transform: scale(1.1)
        }

        .event-list {
            display: flex;
            flex-direction: column;
            gap: 22px;
            margin-top: 12px
        }

        .event-item {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 22px 24px;
            border: 1px solid var(--border);
            transition: all .4s;
            cursor: pointer
        }

        .event-item:hover {
            border-color: var(--coral);
            box-shadow: 0 8px 32px var(--shadow)
        }

        .event-item-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 8px
        }

        .event-item-desc {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 12px
        }

        .event-meta {
            display: flex;
            gap: 18px;
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500
        }

        .event-meta i {
            color: var(--coral);
            margin-right: 4px
        }

        /* PRICING */
        .pricing {
            background: var(--section-alt)
        }

        .pricing-tabs {
            display: flex;
            gap: 0;
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 4px;
            width: fit-content;
            margin: 0 auto 52px;
            box-shadow: inset 0 2px 8px var(--shadow)
        }

        .pricing-tab {
            padding: 10px 28px;
            border-radius: 9px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all .3s;
            border: none;
            background: transparent;
            color: var(--text-muted);
            font-family: 'DM Sans', sans-serif
        }

        .pricing-tab.active {
            background: linear-gradient(135deg, var(--coral), var(--rose));
            color: #fff;
            box-shadow: 0 4px 14px rgba(217, 95, 59, 0.3)
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px
        }

        .pricing-panel {
            display: none
        }

        .pricing-panel.active {
            display: block
        }

        .pricing-card {
            background: var(--card-bg);
            border-radius: 24px;
            padding: 44px 36px;
            border: 2px solid var(--border);
            transition: all .4s;
            position: relative;
            overflow: hidden
        }

        .pricing-card.featured {
            border-color: var(--coral);
            box-shadow: 0 20px 60px rgba(217, 95, 59, 0.2)
        }

        .pricing-card.featured::before {
            content: 'Most Popular';
            position: absolute;
            top: 24px;
            right: -28px;
            background: var(--coral);
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            padding: 5px 42px;
            transform: rotate(45deg);
            letter-spacing: .5px;
            text-transform: uppercase
        }

        .pricing-card:not(.featured):hover {
            border-color: var(--amber);
            transform: translateY(-6px);
            box-shadow: 0 16px 48px var(--shadow)
        }

        .pricing-badge {
            display: inline-block;
            background: rgba(217, 95, 59, 0.1);
            color: var(--coral);
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 5px 14px;
            border-radius: 50px;
            margin-bottom: 18px
        }

        .pricing-price {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            font-weight: 800;
            color: var(--ink);
            line-height: 1;
            margin-bottom: 6px
        }

        .pricing-price sub {
            font-size: 1rem;
            font-weight: 500;
            color: var(--text-muted);
            vertical-align: baseline
        }

        .pricing-desc {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 26px;
            line-height: 1.6
        }

        .pricing-features {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 11px;
            margin-bottom: 32px
        }

        .pricing-features li {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            color: var(--text)
        }

        .pricing-features li i {
            font-size: 14px;
            color: var(--sage)
        }

        .pricing-features li.off {
            opacity: .5;
            text-decoration: line-through
        }

        .pricing-features li.off i {
            color: var(--text-muted)
        }

        /* BLOG */
        .blog {
            background: var(--warm-white)
        }

        .blog-grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr 1fr;
            gap: 28px;
            margin-top: 52px
        }

        .blog-card {
            background: var(--card-bg);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--border);
            transition: all .4s
        }

        .blog-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 60px var(--shadow)
        }

        .blog-img {
            height: 220px;
            overflow: hidden;
            position: relative
        }

        .blog-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .6s
        }

        .blog-card:hover .blog-img img {
            transform: scale(1.05)
        }

        .blog-tags {
            position: absolute;
            bottom: 14px;
            left: 14px;
            display: flex;
            gap: 6px
        }

        .blog-tag {
            background: var(--coral);
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 50px;
            letter-spacing: .3px
        }

        .blog-tag.alt {
            background: var(--amber)
        }

        .blog-body {
            padding: 24px
        }

        .blog-meta {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 12px;
            font-size: 12px;
            color: var(--text-muted)
        }

        .blog-meta-author {
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: 600
        }

        .blog-meta-author img {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            object-fit: cover
        }

        .blog-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--ink);
            line-height: 1.35;
            margin-bottom: 10px
        }

        .blog-title:hover {
            color: var(--coral)
        }

        .blog-excerpt {
            font-size: 13px;
            color: var(--text-muted);
            line-height: 1.65;
            margin-bottom: 16px
        }

        .blog-read {
            font-size: 13px;
            font-weight: 600;
            color: var(--coral);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: .3s
        }

        .blog-read:hover {
            gap: 10px
        }

        /* NEWSLETTER */
        .newsletter {
            position: relative;
            padding: 90px 0;
            overflow: hidden
        }

        .nl-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=1600&q=80');
            background-size: cover;
            background-position: center
        }

        .nl-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(160, 82, 45, 0.92), rgba(90, 122, 92, 0.85))
        }

        .nl-inner {
            position: relative;
            z-index: 2;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 64px;
            align-items: center
        }

        .nl-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.2;
            margin-bottom: 12px
        }

        .nl-sub {
            font-size: 15px;
            color: rgba(255, 255, 255, 0.8);
            line-height: 1.65
        }

        .nl-form {
            display: flex;
            gap: 12px;
            flex-direction: column
        }

        .nl-input-wrap {
            display: flex;
            gap: 0;
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 12px;
            overflow: hidden;
            backdrop-filter: blur(8px)
        }

        .nl-input {
            flex: 1;
            padding: 15px 20px;
            background: transparent;
            border: none;
            outline: none;
            color: #fff;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif
        }

        .nl-input::placeholder {
            color: rgba(255, 255, 255, 0.6)
        }

        .nl-submit {
            padding: 15px 28px;
            background: var(--amber);
            color: #fff;
            font-weight: 700;
            font-size: 14px;
            border: none;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            transition: .3s
        }

        .nl-submit:hover {
            background: var(--amber-light)
        }

        .nl-note {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.65)
        }

        /* INTERNSHIP CARDS */
        .internships {
            background: var(--warm-white)
        }

        .int-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-top: 48px
        }

        .int-card {
            background: var(--card-bg);
            border-radius: 22px;
            border: 1px solid var(--border);
            padding: 30px;
            transition: all .4s;
            position: relative
        }

        .int-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 50px var(--shadow);
            border-color: var(--coral)
        }

        .int-badge {
            position: absolute;
            top: 24px;
            right: 24px;
            padding: 5px 12px;
            background: rgba(90, 122, 92, 0.1);
            color: var(--sage);
            border-radius: 30px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase
        }

        .int-company {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px
        }

        .int-logo {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--coral), var(--rose));
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-family: 'Playfair Display', serif;
            font-weight: 800;
            font-size: 20px
        }

        .int-name {
            font-weight: 700;
            color: var(--ink);
            font-size: 14px
        }

        .int-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--ink);
            margin-bottom: 12px;
            line-height: 1.3
        }

        .int-meta {
            display: flex;
            gap: 15px;
            margin-bottom: 22px;
            color: var(--text-muted);
            font-size: 12.5px;
            font-weight: 500
        }

        .int-meta i {
            color: var(--coral);
            margin-right: 4px
        }

        .int-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 20px;
            border-top: 1px solid var(--border)
        }

        .int-price {
            font-weight: 800;
            color: var(--ink);
            font-size: 15px
        }

        .int-price span {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500
        }

        /* FOOTER */
        .footer {
            background: var(--footer-bg);
            color: rgba(255, 248, 240, 0.75);
            padding: 80px 0 0
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.4fr 1fr 1fr;
            gap: 60px;
            padding-bottom: 60px
        }

        .footer-brand p {
            font-size: 14px;
            line-height: 1.75;
            margin: 18px 0 24px;
            color: rgba(255, 248, 240, 0.65)
        }

        .footer-contact-item {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 14px;
            font-size: 13px
        }

        .footer-contact-item i {
            color: var(--coral);
            margin-top: 2px;
            flex-shrink: 0
        }

        .footer-contact-item a {
            color: rgba(255, 248, 240, 0.75);
            text-decoration: none
        }

        .footer-contact-item a:hover {
            color: var(--amber-light)
        }

        .footer-col h4 {
            font-family: 'Playfair Display', serif;
            font-size: 1.05rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 22px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--coral);
            display: inline-block
        }

        .footer-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px
        }

        .footer-links a {
            font-size: 13.5px;
            color: rgba(255, 248, 240, 0.65);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: .3s
        }

        .footer-links a::before {
            content: '';
            width: 6px;
            height: 6px;
            background: var(--coral);
            border-radius: 50%;
            flex-shrink: 0;
            transition: .3s
        }

        .footer-links a:hover {
            color: var(--amber-light);
            padding-left: 4px
        }

        .footer-bottom {
            border-top: 1px solid rgba(255, 248, 240, 0.08);
            padding: 22px 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 14px
        }

        .footer-copy {
            font-size: 13px
        }

        .footer-copy a {
            color: var(--amber-light);
            text-decoration: none
        }

        .footer-social {
            display: flex;
            gap: 10px
        }

        .footer-social a {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: rgba(255, 248, 240, 0.07);
            color: rgba(255, 248, 240, 0.6);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            text-decoration: none;
            transition: .3s
        }

        .footer-social a:hover {
            background: var(--coral);
            color: #fff
        }

        /* SCROLL TO TOP */
        .scroll-top {
            position: fixed;
            bottom: 28px;
            right: 28px;
            width: 46px;
            height: 46px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--coral), var(--rose));
            color: #fff;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            box-shadow: 0 6px 24px rgba(217, 95, 59, 0.4);
            opacity: 0;
            visibility: hidden;
            transform: translateY(20px);
            transition: .4s;
            z-index: 500
        }

        .scroll-top.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0)
        }

        .scroll-top:hover {
            transform: translateY(-3px)
        }

        /* MOBILE NAV */
        .mobile-nav {
            position: fixed;
            inset: 0;
            background: var(--ink);
            z-index: 2000;
            display: flex;
            flex-direction: column;
            padding: 32px 28px;
            transform: translateX(100%);
            transition: transform .4s cubic-bezier(0.4, 0, 0.2, 1)
        }

        .mobile-nav.open {
            transform: translateX(0)
        }

        .mobile-nav-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 40px
        }

        .mobile-close {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: rgba(255, 248, 240, 0.08);
            color: #fff;
            border: none;
            cursor: pointer;
            font-size: 20px;
            display: flex;
            align-items: center;
            justify-content: center
        }

        .mobile-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 6px
        }

        .mobile-links a {
            text-decoration: none;
            color: rgba(255, 248, 240, 0.85);
            font-size: 1.5rem;
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            padding: 10px 0;
            display: block;
            border-bottom: 1px solid rgba(255, 248, 240, 0.08);
            transition: .3s
        }

        .mobile-links a:hover {
            color: var(--coral)
        }

        .mobile-nav-bottom {
            margin-top: auto;
            display: flex;
            flex-direction: column;
            gap: 12px
        }

        /* ANIMATIONS */
        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity .7s ease, transform .7s ease
        }

        .fade-up.visible {
            opacity: 1;
            transform: translateY(0)
        }

        .scale-in {
            opacity: 0;
            transform: scale(0.95);
            transition: opacity .6s ease, transform .6s ease
        }

        .scale-in.visible {
            opacity: 1;
            transform: scale(1)
        }

        .stagger:nth-child(1) {
            transition-delay: .1s
        }

        .stagger:nth-child(2) {
            transition-delay: .2s
        }

        .stagger:nth-child(3) {
            transition-delay: .3s
        }

        .stagger:nth-child(4) {
            transition-delay: .4s
        }

        /* MARQUEE */
        .marquee-section {
            background: var(--amber);
            padding: 16px 0;
            overflow: hidden
        }

        .marquee-track {
            display: flex;
            gap: 48px;
            animation: marquee 18s linear infinite;
            width: max-content
        }

        .marquee-track span {
            color: rgba(255, 255, 255, 0.9);
            font-weight: 700;
            font-size: 14px;
            letter-spacing: .5px;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 12px
        }

        .marquee-track span::after {
            content: '★';
            opacity: .6
        }

        @keyframes marquee {
            from {
                transform: translateX(0)
            }

            to {
                transform: translateX(-50%)
            }
        }

        /* TEXT CENTER UTIL */
        .text-center {
            text-align: center
        }

        .text-center .section-sub {
            margin-left: auto;
            margin-right: auto
        }

        .text-center .section-tag {
            justify-content: center
        }

        /* RESPONSIVE */
        @media(max-width:1024px) {

            .about-grid,
            .why-grid,
            .events-inner,
            .nl-inner {
                grid-template-columns: 1fr
            }

            .features-grid,
            .team-grid {
                grid-template-columns: repeat(2, 1fr)
            }

            .blog-grid {
                grid-template-columns: 1fr 1fr
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr)
            }

            .about-imgs {
                height: 400px
            }
        }

        @media(max-width:768px) {

            .nav-links,
            .nav-right .btn-outline,
            .nav-right .btn-fill {
                display: none
            }

            .hamburger {
                display: flex
            }

            .hero-stats {
                gap: 15px;
                justify-content: center;
                flex-wrap: wrap;
            }

            .hero-stat {
                flex: 1 1 140px;
                padding: 10px;
            }

            .hero h1 {
                font-size: 2.2rem;
                text-align: center;
                line-height: 1.2;
            }

            .hero p {
                text-align: center;
                margin: 0 auto 30px;
                font-size: 15px;
            }

            .hero-btns {
                justify-content: center;
                width: 100%;
            }

            .hero-btns .btn {
                padding: 12px 24px !important;
                font-size: 14px !important;
                flex: 1;
                justify-content: center;
            }

            .hero-content {
                padding-top: 60px;
                text-align: center;
                margin: 0 auto;
            }

            .process-grid,
            .testi-grid,
            .pricing-grid,
            .blog-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                text-align: center;
                gap: 40px;
            }

            .footer-links {
                align-items: center;
            }

            .features-grid,
            .team-grid {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .topbar .container {
                justify-content: center;
                text-align: center;
            }

            .topbar-msg {
                font-size: 11px;
            }

            .topbar-contact {
                display: none
            }

            .container {
                padding: 0 20px;
            }

            .logo {
                font-size: 1.6rem;
            }
        }

        @media(max-width:480px) {
            .hero h1 {
                font-size: 1.8rem;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .about-badge {
                left: 50%;
                width: 80%;
                transform: translateX(-50%);
            }

            .btn {
                width: 100%;
            }
        }
    </style>
