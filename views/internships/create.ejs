<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/dashboard/company_head', { title: 'Post Internship | Conneto' }) %>
    <style>
        body::before {
            background-image: url('https://images.unsplash.com/photo-1517842645767-c639042777db?w=1600&q=80') !important;
            filter: brightness(1) !important;
        }
        [data-theme="dark"] body::before {
            filter: brightness(0.5) !important;
        }

            .form-card {
                background: var(--card-bg);
                border: 1px solid var(--border);
                border-radius: 24px;
                padding: 40px;
                max-width: 900px;
                margin: 0 auto;
                box-shadow: 0 20px 60px var(--shadow);
            }

            .form-header {
                margin-bottom: 32px;
                border-bottom: 1px solid var(--card-border);
                padding-bottom: 20px;
            }

            .form-header h2 {
                font-size: 1.75rem;
                font-weight: 700;
                color: var(--text);
                font-family: 'Outfit', sans-serif;
            }

            .form-header p {
                color: var(--text-muted);
                margin-top: 4px;
            }

            .form-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 24px;
            }

            .form-group {
                margin-bottom: 20px;
            }

            .form-group.full {
                grid-column: span 2;
            }

            .label {
                display: block;
                margin-bottom: 10px;
                font-weight: 600;
                color: var(--text);
                font-size: 0.95rem;
            }

            .label span {
                color: var(--primary);
            }

            .inp,
            .sel,
            .txt {
                width: 100%;
                padding: 14px 16px;
                background: var(--bg-alt);
                border: 1.5px solid var(--border);
                border-radius: 12px;
                color: var(--ink);
                font-family: inherit;
                font-size: 1rem;
                transition: all 0.3s;
            }

            .inp::placeholder {
                color: var(--text-muted);
                opacity: 0.7;
            }

            .inp:focus,
            .sel:focus,
            .txt:focus {
                border-color: var(--primary);
                outline: none;
                box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1);
            }

            .txt {
                min-height: 120px;
                resize: vertical;
            }

            .btn-post {
                width: 100%;
                padding: 16px;
                background: var(--gradient-primary);
                color: white;
                border: none;
                border-radius: 14px;
                font-size: 1.1rem;
                font-weight: 700;
                cursor: pointer;
                transition: all 0.3s;
                margin-top: 20px;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
            }

            .btn-post:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(124, 58, 237, 0.3);
            }

            @media (max-width: 768px) {
                .form-grid {
                    grid-template-columns: 1fr;
                }

                .form-group.full {
                    grid-column: span 1;
                }
            }
        </style>
</head>

<body>
    <%- include('../partials/dashboard/company_sidebar', { activePage: 'internships' }) %>

        <div class="page-header">
            <h1 class="page-title">Create New Opening</h1>
            <p class="page-subtitle">Post a new internship opportunity to reach thousands of students</p>
        </div>

        <div class="form-card">
            <div class="form-header">
                <h2>Internship Details</h2>
                <p>Please provide comprehensive information about the role.</p>
            </div>

            <form action="/company/internships" method="POST">
                <div class="form-grid">
                    <div class="form-group full">
                        <label class="label">Internship Title <span>*</span></label>
                        <input type="text" name="title" class="inp" placeholder="e.g. Frontend Developer Intern"
                            required>
                    </div>

                    <div class="form-group full">
                        <label class="label">Company Name <span>*</span></label>
                        <input type="text" name="companyName" class="inp" value="<%= user.companyName || user.name %>" required>
                    </div>

                    <div class="form-group full">
                        <label class="label">Internship Image URL (Unsplash recommended)</label>
                        <input type="text" name="image" class="inp" placeholder="https://images.unsplash.com/photo-...">
                    </div>

                    <div class="form-group">
                        <label class="label">Location <span>*</span></label>
                        <input type="text" name="location" class="inp" placeholder="e.g. Mumbai, Remote" required>
                    </div>

                    <div class="form-group">
                        <label class="label">Work Type</label>
                        <select name="type" class="sel">
                            <option value="remote">Remote</option>
                            <option value="on-site">On-site</option>
                            <option value="hybrid">Hybrid</option>
                        </select>
                    </div>

                    <div class="form-group full">
                        <label class="label">Role Description <span>*</span></label>
                        <textarea name="description" class="txt"
                            placeholder="Explain responsibilities, requirements, and benefits..." required></textarea>
                    </div>

                    <div class="form-group">
                        <label class="label">Duration <span>*</span></label>
                        <input type="text" name="duration" class="inp" placeholder="e.g. 3 Months" required>
                    </div>

                    <div class="form-group full">
                        <label class="label">Internship Category <span>*</span></label>
                        <div style="display: flex; gap: 24px; margin-top: 10px; flex-wrap: wrap;">
                            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; color: var(--text);">
                                <input type="radio" name="paymentCategory" value="unpaid" checked onclick="handlePaymentDisplay('unpaid')"> Unpaid
                            </label>
                            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; color: var(--text);">
                                <input type="radio" name="paymentCategory" value="stipend" onclick="handlePaymentDisplay('stipend')"> Stipend (Company pays Student)
                            </label>
                            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; color: var(--text);">
                                <input type="radio" name="paymentCategory" value="paid" onclick="handlePaymentDisplay('paid')"> Paid (Student pays Company)
                            </label>
                        </div>
                    </div>

                    <div class="form-group" id="stipendGroup" style="display: none;">
                        <label class="label">Stipend (INR/Month) <span>*</span></label>
                        <input type="number" name="stipend" id="stipendInput" class="inp" placeholder="e.g. 15000">
                    </div>

                    <div class="form-group" id="feeGroup" style="display: none;">
                        <label class="label">Training/Registration Fee (INR) <span>*</span></label>
                        <input type="number" name="fee" id="feeInput" class="inp" placeholder="e.g. 5000">
                    </div>

                    <div class="form-group full">
                        <label class="label">Internship Image URL</label>
                        <input type="text" name="image" class="inp" value="" placeholder="https://images.unsplash.com/...">
                    </div>

                    <div class="form-group">
                        <label class="label">Openings</label>
                        <input type="number" name="openings" class="inp" value="1" min="1">
                    </div>

                    <div class="form-group">
                        <label class="label">Application Deadline (Date & Time)</label>
                        <input type="datetime-local" name="deadline" class="inp">
                    </div>

                    <div class="form-group full">
                        <label class="label">Required Skills (Comma separated)</label>
                        <input type="text" name="skills" class="inp" placeholder="e.g. React, Node.js, TypeScript">
                    </div>
                </div>

                <button type="submit" class="btn-post">
                    <i class="fas fa-paper-plane"></i> Publish Internship
                </button>
            </form>
        </div>

        <script>
            // Tab animation
            const formCard = document.querySelector('.form-card');
            formCard.style.opacity = '0';
            formCard.style.transform = 'translateY(20px)';
            formCard.style.transition = 'all 0.6s ease';
            setTimeout(() => {
                formCard.style.opacity = '1';
                formCard.style.transform = 'translateY(0)';
            }, 100);

            function handlePaymentDisplay(category) {
                const stipendGroup = document.getElementById('stipendGroup');
                const feeGroup = document.getElementById('feeGroup');
                const stipendInput = document.getElementById('stipendInput');
                const feeInput = document.getElementById('feeInput');

                stipendGroup.style.display = 'none';
                feeGroup.style.display = 'none';
                stipendInput.required = false;
                feeInput.required = false;

                if (category === 'stipend') {
                    stipendGroup.style.display = 'block';
                    stipendInput.required = true;
                    feeInput.value = '';
                } else if (category === 'paid') {
                    feeGroup.style.display = 'block';
                    feeInput.required = true;
                    stipendInput.value = '';
                } else {
                    stipendInput.value = '';
                    feeInput.value = '';
                }
            }
        </script>
        </script>
        </main>
        </div>
</body>

</html>