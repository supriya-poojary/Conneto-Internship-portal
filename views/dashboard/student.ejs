                                                <h3 style="color:var(--ink)">Diary Locked</h3>
                                                <p style="color:var(--text-muted)">You need to be selected for at least
                                                    one internship to start logging entries.</p>
                                            </div>
                                            <% } %>
                                </div>
                            </div>
                            <% } else if (activePage==='diary_history' ) { %>
