                                                style="padding: 15px 20px; font-size: 16px;"
                                                value="<%= profile.bio || '' %>"
                                                placeholder="Aspiring Software Engineer passionate about..." required>
                                        </div>

                                        <h4 class="portfolio-section-title"><i class="fas fa-file-pdf"></i> Resume Documents</h4>
