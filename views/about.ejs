    <style>
        .mission-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 28px
        }

        .mission-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 40px;
            position: relative;
            overflow: hidden;
            transition: var(--transition)
        }

        .mission-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--gold), var(--brown));
            transform: scaleX(0);
            transform-origin: left;
            transition: var(--transition)
        }

        .mission-card:hover {
            box-shadow: 0 16px 48px rgba(58, 42, 8, .12);
            transform: translateY(-4px)
        }

        .mission-card:hover::before {
            transform: scaleX(1)
        }

        .mission-card h3 {
            font-family: 'Lora', serif;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--brown);
            margin-bottom: 12px
        }

        .mission-card p {
            color: var(--text-muted);
            font-size: .9rem;
            line-height: 1.8
        }

        .feat-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px
        }

        .feat-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 32px;
            transition: var(--transition);
            overflow: hidden;
            position: relative
        }

        .feat-card::after {
            content: '';
            position: absolute;
            top: -100%;
            left: -60%;
            width: 40%;
            height: 300%;
            background: linear-gradient(105deg, transparent 20%, rgba(255, 255, 255, .7) 50%, transparent 80%);
            transform: rotate(25deg);
            transition: 0s
        }

        .feat-card:hover::after {
            left: 130%;
            transition: left .5s ease
        }

        .feat-card:hover {
            box-shadow: 0 16px 40px rgba(58, 42, 8, .1);
            transform: translateY(-5px);
            border-color: rgba(168, 149, 32, .3)
        }

        .team-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px
        }

        .team-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            transition: var(--transition);
            text-align: center
        }

        .team-card:hover {
            box-shadow: 0 20px 56px rgba(58, 42, 8, .14);
            transform: translateY(-6px)
        }

        .team-card img {
            width: 100%;
            height: 220px;
            object-fit: cover
        }

        .team-info {
            padding: 20px
        }

        .team-info h3 {
            font-family: 'Lora', serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--brown);
            margin-bottom: 4px
        }

        .team-info p {
            font-size: .8rem;
            color: var(--gold);
            font-weight: 600
        }

        .testi-grid-4 {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px
        }

        .marquee-section {
            background: var(--gold-light);
            border-top: 1px solid rgba(168, 149, 32, .2);
            border-bottom: 1px solid rgba(168, 149, 32, .2);
            padding: 32px 0;
            overflow: hidden
        }

        .mq-row {
            display: flex;
            width: max-content;
            animation: mqani 28s linear infinite
        }

        .mq-row-rev {
            animation-direction: reverse;
            margin-top: 14px
        }

        .mq-item {
            padding: 0 36px;
            white-space: nowrap;
            font-family: 'Lora', serif;
            font-size: .95rem;
            font-weight: 600;
            color: var(--brown-mid);
            display: flex;
            align-items: center;
            gap: 8px
        }

        .mq-item::before {
            content: '⬦';
            color: var(--gold);
            font-size: 1.2rem
        }

        @keyframes mqani {
            from {
                transform: translateX(0)
            }

            to {
                transform: translateX(-50%)
            }
        }

        @media(max-width:1024px) {

            .mission-grid,
            .feat-grid {
                grid-template-columns: 1fr 1fr
            }

            .team-grid {
                grid-template-columns: repeat(2, 1fr)
            }

            .testi-grid-4 {
                grid-template-columns: 1fr 1fr
            }
        }

        @media(max-width:768px) {

            .mission-grid,
            .feat-grid,
            .testi-grid-4 {
                grid-template-columns: 1fr
            }

            .team-grid {
                grid-template-columns: 1fr 1fr
            }
        }

        @media(max-width:480px) {
            .team-grid {
                grid-template-columns: 1fr
            }
        }
    </style>
</head>

