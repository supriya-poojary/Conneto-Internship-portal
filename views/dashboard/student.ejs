                                                    <label class="portfolio-label">Select Internship *</label>
                                                    <select name="internshipId" class="portfolio-input" required
                                                        onchange="window.location.href='/student/dashboard?tab=diary&viewInternshipId=' + this.value;">
                                                        <option value="">-- Choose Active Internship --</option>
                                                        <% selectedInternships.forEach(app=> { %>
                                                            <option value="<%= app.internship._id %>" <%=typeof
                                                                viewInternshipId !=='undefined' &&
                                                                viewInternshipId==app.internship._id ? 'selected' : ''
                                                                %>>
                                                                <%= app.internship.title %> at <%=
                                                                        app.internship.company ?
                                                                        app.internship.company.companyName || 'Company'
                                                                        : 'Company' %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                                <div class="portfolio-group">
                                                    <label class="portfolio-label">Date of Activity *</label>
                                                    <input type="date" id="date" name="date" class="portfolio-input"
                                                        value="<%= new Date().toISOString().split('T')[0] %>"
                                                        max="<%= new Date().toISOString().split('T')[0] %>" required>
                                                    <p style="font-size:11px; color:var(--text-muted); margin-top:5px">
                                                        Sundays are not permitted for internship tracking.</p>
                                                </div>
                                            </div>

                                            <h4 class="portfolio-section-title"
                                                style="font-size:1.1rem; margin-top:10px;"><i
                                                    class="fas fa-briefcase"></i> What I worked on?</h4>
                                            <div class="diary-form-grid-3-1">
