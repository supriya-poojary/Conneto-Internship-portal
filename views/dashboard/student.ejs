                                                , "Maharashtra" , "Manipur" , "Meghalaya" , "Mizoram" , "Nagaland"
                                                , "Odisha" , "Punjab" , "Rajasthan" , "Sikkim" , "Tamil Nadu"
                                                , "Telangana" , "Tripura" , "Uttar Pradesh" , "Uttarakhand"
                                                , "West Bengal" , "Andaman and Nicobar" , "Chandigarh"
                                                , "Dadra and Nagar Haveli" , "Daman and Diu" , "Delhi" , "Lakshadweep"
                                                , "Puducherry" ]; states.forEach(s=> { %>
                                                <option value="<%= s %>" <%=profile.state===s ? 'selected' : '' %>><%= s
                                                        %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Country *</label>
                                        <select name="country" class="portfolio-input"
                                            style="padding: 15px 20px; font-size: 16px; height: auto;" required>
                                            <option value="India" <%=profile.country==='India' || !profile.country
                                                ? 'selected' : '' %>>India</option>
                                            <option value="Other" <%=profile.country && profile.country !=='India'
                                                ? 'selected' : '' %>>Other</option>
                                        </select>
                                    </div>
                                </div>

                                <h4 class="portfolio-section-title"><i class="fas fa-briefcase"></i>
                                    Professional Experience</h4>
                                <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Experience Summary</label>
                                        <textarea name="experience" class="portfolio-input portfolio-textarea"
                                            style="min-height:120px; padding: 15px 20px; font-size: 16px;"
                                            placeholder="Previous internships or roles..."><%= profile.experience || '' %></textarea>
                                    </div>
                                    <div class="portfolio-group">
                                        <label class="portfolio-label">Key Projects</label>
                                        <textarea name="projects" class="portfolio-input portfolio-textarea"
                                            style="min-height:120px; padding: 15px 20px; font-size: 16px;"
                                            placeholder="List your best technical work..."><%= profile.projects || '' %></textarea>
                                    </div>
                                </div>

                                <h4 class="portfolio-section-title"><i class="fas fa-award"></i> Skills &
                                    Achievements</h4>
