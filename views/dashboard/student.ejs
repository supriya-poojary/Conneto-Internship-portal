<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <%- include('../partials/dashboard/student_head', { title: 'Member Portal | Student Dashboard' }) %>
        <style>
            .search-box {
                position: relative;
                width: 300px;
            }

            .search-box i {
                position: absolute;
                left: 16px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 14px;
            }

            .search-box input {
                width: 100%;
                padding: 12px 16px 12px 45px;
                border: 1.5px solid var(--border);
                border-radius: 12px;
                background: var(--card-bg);
                font-family: inherit;
                font-size: 14px;
                outline: none;
                transition: .3s;
            }

            .search-box input:focus {
                border-color: var(--coral);
                box-shadow: 0 0 0 4px rgba(217, 95, 59, 0.08);
            }

            .header-btn {
                width: 44px;
                height: 44px;
                border-radius: 12px;
                border: 1px solid var(--border);
                background: var(--card-bg);
                color: var(--text-muted);
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 18px;
                transition: .3s;
                position: relative;
            }

            .header-btn:hover {
                background: var(--border);
                color: var(--coral);
                transform: translateY(-2px);
            }

            .dot {
                position: absolute;
                top: 10px;
                right: 10px;
                width: 8px;
                height: 8px;
                background: var(--rose);
                border-radius: 50%;
                border: 2px solid var(--card-bg);
            }

            .status-badge {
                padding: 4px 12px;
                border-radius: 100px;
                font-size: 11px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .status-badge.applied {
                background: rgba(200, 131, 26, 0.1);
                color: var(--amber);
            }

            .status-badge.under_review {
                background: rgba(160, 82, 45, 0.1);
                color: var(--terra);
            }

            .status-badge.shortlisted {
                background: rgba(90, 122, 92, 0.1);
                color: var(--sage);
            }

            .status-badge.interview_scheduled {
                background: rgba(217, 95, 59, 0.1);
                color: var(--coral);
                border: 1.5px solid var(--coral);
            }

            .status-badge.selected {
                background: rgba(90, 122, 92, 0.2);
                color: var(--sage);
                border: 1px solid var(--sage);
            }

            .status-badge.rejected {
                background: rgba(181, 56, 74, 0.1);
                color: var(--rose);
            }

            /* Animation for cards */
            .reveal {
                opacity: 0;
                transform: translateY(20px);
                transition: .6s cubic-bezier(0.1, 0, 0, 1);
            }

            .reveal.visible {
                opacity: 1;
                transform: translateY(0);
            }

            @media (max-width: 1024px) {
                .stats-row {
                    grid-template-columns: repeat(2, 1fr);
                    gap: 16px;
                }

                .dashboard-grid {
                    grid-template-columns: 1fr;
                    gap: 20px;
                }

                .header {
                    flex-direction: column;
                    align-items: stretch;
                    gap: 20px;
                    text-align: center;
                }

                .header-right {
                    flex-wrap: wrap;
                    justify-content: center;
                    gap: 12px;
                }

                .search-box {
                    width: 100%;
                    order: -1;
                }
            }

            @media (max-width: 768px) {
                .internship-item {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 16px;
                }

                .internship-meta {
                    flex-direction: column;
                    gap: 8px;
                }

                .action-buttons {
                    width: 100%;
                }

                .action-buttons button,
                .view-btn {
                    width: 100%;
                    text-align: center;
                }

                .header-left h1 {
                    font-size: 1.8rem;
                }

                .stat-value {
                    font-size: 1.5rem;
                }
            }

            @media (max-width: 500px) {
                .stats-row {
                    grid-template-columns: 1fr;
                }

                .stat-card {
                    padding: 20px;
                }
            }

            /* Portfolio Specific Styles */
            .portfolio-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 20px;
                margin-top: 10px;
            }

            .portfolio-group {
                margin-bottom: 20px;
            }

            .portfolio-label {
                display: block;
                font-size: 11px;
                font-weight: 800;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 8px;
            }

            .portfolio-input {
                width: 100%;
                padding: 12px 16px;
                border: 1.5px solid var(--border);
                border-radius: 12px;
                background: var(--card-bg);
                font-family: inherit;
                font-size: 14px;
                outline: none;
                transition: .3s;
            }

            .portfolio-input:focus {
                border-color: var(--coral);
                box-shadow: 0 0 0 4px rgba(217, 95, 59, 0.08);
            }

            .portfolio-textarea {
                min-height: 120px;
                resize: vertical;
            }

            .portfolio-section-title {
                font-family: 'Playfair Display', serif;
                font-size: 1.3rem;
                margin: 20px 0 15px;
                display: flex;
                align-items: center;
                gap: 10px;
                color: var(--ink);
            }

            .portfolio-section-title i {
                color: var(--coral);
                font-size: 1.1rem;
            }

            .skill-tags {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
                margin-top: 10px;
            }

            .skill-tag {
                background: rgba(217, 95, 59, 0.1);
                color: var(--coral);
                padding: 4px 12px;
                border-radius: 100px;
                font-size: 12px;
                font-weight: 600;
            }

            .browse-filters {
                display: flex;
                gap: 15px;
                margin-bottom: 25px;
                flex-wrap: wrap;
            }

            .filter-select {
                padding: 10px 15px;
                border-radius: 10px;
                border: 1.5px solid var(--border);
                background: var(--card-bg);
                font-size: 13px;
                font-weight: 600;
                color: var(--text);
                outline: none;
            }
        </style>
</head>

<body>
    <%- include('../partials/dashboard/student_sidebar', { activePage: activePage }) %>

        <div class="dashboard-bg">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
            <div class="blob blob-3"></div>
        </div>


        <% if (activePage==='dashboard' ) { %>
            <header class="header">
                <div class="header-left">
                    <h1>Member <span>Portal</span></h1>
                    <p>Track your applications and explore new opportunities.</p>
                </div>
                <div class="header-right">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="globalSearch" placeholder="Search internships...">
                    </div>
                    <button class="header-btn" id="themeToggle" title="Toggle Theme">
                        <i class="fas fa-moon"></i>
                    </button>
                    <button class="header-btn">
                        <i class="fas fa-bell"></i>
                        <span class="dot"></span>
                    </button>
                    <a href="/student/dashboard?tab=profile" style="text-decoration:none">
                        <div class="user-avatar" title="My Portfolio">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                    </a>
                </div>
            </header>

            <div class="stats-row">
                <div class="stat-card reveal">
                    <div class="stat-icon blue"><i class="fas fa-file-invoice"></i></div>
                    <div class="stat-value">
                        <%= stats ? stats.total : 0 %>
                    </div>
                    <div class="stat-label">Applications</div>
                </div>
                <div class="stat-card reveal">
                    <div class="stat-icon green"><i class="fas fa-calendar-check"></i></div>
                    <div class="stat-value">
                        <%= stats ? stats.interviews : 0 %>
                    </div>
                    <div class="stat-label">Interviews</div>
                </div>
                <div class="stat-card reveal">
                    <div class="stat-icon yellow"><i class="fas fa-hourglass-half"></i></div>
                    <div class="stat-value">
                        <%= stats ? stats.pending : 0 %>
                    </div>
                    <div class="stat-label">In Review</div>
                </div>
                <div class="stat-card reveal">
                    <div class="stat-icon purple"><i class="fas fa-award"></i></div>
                    <div class="stat-value">
                        <%= stats ? stats.hired : 0 %>
                    </div>
                    <div class="stat-label">Offers</div>
                </div>
            </div>

            <div class="dashboard-grid">
                <div class="column">
                    <div class="card reveal">
                        <div class="card-header">
                            <h2 class="card-title"><i class="fas fa-magic"></i> Recent Openings</h2>
                            <a href="/student/dashboard?tab=browse" class="view-btn">Explore All</a>
                        </div>
                        <div class="internship-list">
                            <% if (internships && internships.length> 0) { %>
                                <% internships.forEach(function(item) { %>
                                    <div class="internship-item">
                                        <div class="company-logo">
                                            <% const cName=item.companyName || (item.company &&
                                                (item.company.companyName || item.company.name)) || 'CO' ; %>
                                                <%= cName.charAt(0).toUpperCase() %>
                                        </div>
                                        <div class="internship-details">
                                            <h4>
                                                <%= item.title %>
                                            </h4>
                                            <div class="company-name">
                                                <%= cName %>
                                            </div>
                                            <div class="internship-meta">
                                                <span class="meta-tag"><i class="fas fa-location-arrow"></i>
                                                    <%= item.location || 'Remote' %>
                                                </span>
                                                <span class="meta-tag"><i class="fas fa-calendar"></i>
                                                    <%= item.duration || '3 Months' %>
                                                </span>
                                            </div>
                                        </div>
                                        <a href="/internships/<%= item._id %>" class="view-btn">Apply Now</a>
                                    </div>
                                    <% }); %>
                                        <% } else { %>
                                            <div style="text-align:center; padding: 50px 0; color:var(--text-muted)">
                                                <i class="fas fa-folder-open"
                                                    style="font-size:3rem; opacity:0.2; margin-bottom:15px"></i>
                                                <p>No matches yet. Keep exploring!</p>
                                            </div>
                                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="column">
                    <div class="card reveal">
                        <div class="profile-card">
                            <div class="profile-avatar">
                                <%= user.name.charAt(0).toUpperCase() %>
                            </div>
                            <div class="profile-name">
                                <%= user.name %>
                            </div>
                            <div class="profile-email">
                                <%= user.email %>
                            </div>
                            <span class="profile-status">Verified Scholar</span>
                        </div>
                        <div class="progress-section">
                            <div class="progress-title">
                                <span>Portfolio Strength</span>
                                <span>
                                    <%= profile.completionPercentage || 0 %>%
                                </span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width:<%= profile.completionPercentage || 0 %>%;">
                                </div>
                            </div>
                            <p style="font-size:12px; color:var(--text-muted); margin-top:12px; font-weight:500">Refine
                                your bio and certifications for 2x more visibility.</p>
                        </div>
                        <a href="/student/dashboard?tab=profile" class="btn-primary"
                            style="display:flex; align-items:center; justify-content:center; gap:10px; width:100%; margin-top:24px;">
                            <i class="fas fa-magic"></i> Optimize Profile
                        </a>
                    </div>

                    <div class="card reveal"
                        style="background: linear-gradient(135deg, var(--coral), var(--rose)); border: none;">
                        <h4
                            style="color:#fff; font-family:'Playfair Display', serif; font-size:1.2rem; margin-bottom:10px">
                            Need Assistance?</h4>
                        <p style="color:rgba(255,255,255,0.8); font-size:13px; line-height:1.6; margin-bottom:15px">Our
                            career experts are here to help you land your first role.</p>
                        <a href="/contact"
                            style="display:inline-block; background:rgba(255,255,255,0.2); color:#fff; padding:10px 20px; border-radius:10px; text-decoration:none; font-weight:700; font-size:12px; border:1px solid rgba(255,255,255,0.3)">Book
                            Consultation</a>
                    </div>
                </div>
            </div>
            <% } else if (activePage==='applications' ) { %>
                <header class="header">
                    <div class="header-left">
                        <h1>My Applications</h1>
                        <p>Track all your internship applications in one place</p>
                    </div>
                    <div class="header-right">
                        <a href="/internships" class="view-btn"
                            style="padding:12px 20px; background:var(--coral); color:#fff">
                            <i class="fas fa-search"></i> Browse More
                        </a>
                    </div>
                </header>

                <div class="card reveal" style="margin-top:20px">
                    <% if (applications && applications.length> 0) { %>
                        <div class="internship-list">
                            <% applications.forEach(function(app) { %>
                                <div class="internship-item">
                                    <div class="company-logo">
                                        <% var cName=app.internship ? ((app.internship.company &&
                                            app.internship.company.companyName) ? app.internship.company.companyName :
                                            (app.internship.companyName || '' )) : '' ; %>
                                            <%= cName ? cName.charAt(0).toUpperCase() : 'C' %>
                                    </div>
                                    <div class="internship-details">
                                        <h4>
                                            <%= app.internship ? app.internship.title : 'Internship' %>
                                        </h4>
                                        <div class="company-name">
                                            <%= cName || 'Company' %>
                                        </div>
                                        <div class="internship-meta">
                                            <span class="meta-tag"><i class="fas fa-calendar"></i> Applied on <%= new
                                                    Date(app.appliedAt).toLocaleDateString() %></span>
                                            <span class="status-badge <%= app.status %>">
                                                <%= app.status.replace(/_/g, ' ' ) %>
                                            </span>
                                        </div>
                                        <% if (app.status==='interview_scheduled' ) { %>
                                            <div
                                                style="margin-top:15px; background:rgba(217,95,59,0.05); padding:12px; border-radius:12px; border:1px dashed var(--coral)">
                                                <div
                                                    style="font-weight:700; color:var(--coral); font-size:13px; margin-bottom:4px">
                                                    <i class="fas fa-clock"></i> INTERVIEW SCHEDULED
                                                </div>
                                                <div style="font-size:14px; color:var(--ink); font-weight:600">
                                                    <%= new Date(app.interviewDate).toLocaleString([], {
                                                        dateStyle: 'long' , timeStyle: 'short' }) %>
                                                </div>
                                                <% if (app.interviewNote) { %>
                                                    <p style="font-size:12px; color:var(--text-muted); margin-top:5px">
                                                        <%= app.interviewNote %>
                                                    </p>
                                                    <% } %>
                                            </div>
                                            <% } %>
                                    </div>
                                    <div class="action-buttons">
                                        <% if (app.status==='applied' || app.status==='under_review' ) { %>
                                            <form action="/student/applications/<%= app._id %>/withdraw" method="POST"
                                                onsubmit="return confirm('Withdraw application?')">
                                                <button type="submit" class="view-btn"
                                                    style="background:rgba(181,56,74,0.1); color:var(--rose)">Withdraw</button>
                                            </form>
                                            <% } %>
                                    </div>
                                </div>
                                <% }); %>
                        </div>
                        <% } else { %>
                            <div style="text-align:center; padding:60px 20px">
                                <i class="fas fa-file-alt"
                                    style="font-size:3rem; color:var(--border); margin-bottom:20px"></i>
                                <h2>No applications yet</h2>
                                <p style="color:var(--text-muted); margin-bottom:30px">Start applying to see them here.
                                </p>
                                <a href="/student/dashboard?tab=browse" class="view-btn"
                                    style="background:var(--coral); color:#fff; padding:12px 24px">Explore
                                    Internships</a>
                            </div>
                            <% } %>
                </div>
                <% } else if (activePage==='profile' ) { %>
                    <% if (typeof success !=='undefined' || (typeof query !=='undefined' && query.success)) { %>
                        <div
                            style="background:var(--sage); color:#fff; padding:15px 25px; border-radius:15px; margin-bottom:25px; display:flex; align-items:center; gap:15px; animation: slideIn 0.4s ease-out">
                            <i class="fas fa-check-circle" style="font-size:1.2rem"></i>
                            <div style="font-weight:600">Portfolio Updated Successfully! All changes are now live.</div>
                        </div>
                        <% } %>
                            <header class="header">
                                <div class="header-left">
                                    <h1>My <span>Portfolio</span></h1>
                                    <p>Increase your visibility by completing your profile details.</p>
                                    <div style="display:flex; align-items:center; gap:15px; margin-top:10px">
                                        <div
                                            style="flex:1; max-width:200px; height:6px; background:var(--border); border-radius:10px; overflow:hidden">
                                            <div
                                                style="width:<%= profile.completionPercentage || 0 %>%; height:100%; background:var(--coral); transition:.5s">
                                            </div>
                                        </div>
                                        <span style="font-size:12px; font-weight:800; color:var(--coral)">
                                            <%= profile.completionPercentage || 0 %>% Complete
                                        </span>
                                    </div>
                                </div>
                            </header>

                            <div style="margin-top:20px">
                                <div class="card reveal" style="padding: 40px; border-radius: 30px;">
                                    <form id="profileForm" action="/student/profile/update" method="POST">
                                        <div
                                            style="display:flex; align-items:center; gap:30px; margin-bottom:40px; padding-bottom:30px; border-bottom:1px solid var(--border)">
                                            <div class="profile-avatar"
                                                style="width:120px; height:120px; font-size:3rem; flex-shrink:0">
                                                <%= user.name.charAt(0).toUpperCase() %>
                                            </div>
                                            <div style="flex:1">
                                                <h2
                                                    style="font-size:2rem; margin-bottom:5px; font-family:'Playfair Display', serif">
                                                    <%= user.name %>
                                                </h2>
                                                <p style="color:var(--text-muted); font-weight:600; font-size:1.1rem">
                                                    <%= user.email %>
                                                </p>
                                                <div class="skill-tags" style="margin-top:10px">
                                                    <% if (profile && profile.skills && profile.skills.length> 0) { %>
                                                        <% profile.skills.forEach(s=> { %>
                                                            <span class="skill-tag"
                                                                style="padding: 6px 15px; font-size: 13px;">
                                                                <%= s %>
                                                            </span>
                                                            <% }) %>
                                                                <% } %>
                                                </div>
                                            </div>
                                        </div>

                                        <h4 class="portfolio-section-title" style="margin-top:0"><i
                                                class="fas fa-user-circle"></i> Identity & Contact</h4>
                                        <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Full Name</label>
                                                <input type="text" name="name" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= user.name %>">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Email Address (Used for Login)</label>
                                                <input type="email" name="email" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= user.email %>">
                                            </div>
                                        </div>
                                        <div class="portfolio-grid"
                                            style="grid-template-columns: 1fr 1fr 1fr; gap: 30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Date of Birth</label>
                                                <input type="date" name="dob" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.dob ? new Date(profile.dob).toISOString().split('T')[0] : '' %>">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Gender</label>
                                                <select name="gender" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px; height: auto;">
                                                    <option value="">Select Gender</option>
                                                    <option value="Male" <%=profile.gender==='Male' ? 'selected' : '' %>
                                                        >Male</option>
                                                    <option value="Female" <%=profile.gender==='Female' ? 'selected'
                                                        : '' %>>Female</option>
                                                    <option value="Other" <%=profile.gender==='Other' ? 'selected' : ''
                                                        %>>Other</option>
                                                </select>
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Phone Number</label>
                                                <input type="text" name="phone" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.phone || '' %>" placeholder="+91 99000 00000">
                                            </div>
                                        </div>

                                        <h4 class="portfolio-section-title"><i class="fas fa-university"></i> Academic
                                            Standing</h4>
                                        <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">USN / Roll Number</label>
                                                <input type="text" name="usn" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.usn || '' %>" placeholder="e.g. 4MT22CS009">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">University / College</label>
                                                <input type="text" name="college" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.college || '' %>"
                                                    placeholder="Where do you study?">
                                            </div>
                                        </div>
                                        <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Degree Program</label>
                                                <input type="text" name="degree" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.degree || '' %>"
                                                    placeholder="e.g. Bachelor of Engineering">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Department / Branch</label>
                                                <input type="text" name="department" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.department || '' %>"
                                                    placeholder="e.g. Computer Science & Engineering">
                                            </div>
                                        </div>
                                        <div class="portfolio-grid"
                                            style="grid-template-columns: 1fr 1fr 1fr; gap:30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Current Semester</label>
                                                <input type="number" name="semester" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.semester || '' %>" placeholder="7">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Graduation Year</label>
                                                <input type="number" name="year" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.year || '' %>" placeholder="2024">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">GPA / CGPA</label>
                                                <input type="text" name="gpa" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.gpa || '' %>" placeholder="9.0">
                                            </div>
                                        </div>

                                        <h4 class="portfolio-section-title"><i class="fas fa-globe-americas"></i>
                                            Geographic Location</h4>
                                        <div class="portfolio-group">
                                            <label class="portfolio-label">Permanent / Current Address</label>
                                            <input type="text" name="address" class="portfolio-input"
                                                style="padding: 15px 20px; font-size: 16px;"
                                                value="<%= profile.address || '' %>"
                                                placeholder="Flat, Building, Street Name...">
                                        </div>
                                        <div class="portfolio-grid"
                                            style="grid-template-columns: 1fr 1fr 1fr; gap:30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">City</label>
                                                <input type="text" name="city" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.city || '' %>" placeholder="e.g. Udupi">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">State / Region</label>
                                                <input type="text" name="state" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.state || '' %>" placeholder="e.g. Karnataka">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Country</label>
                                                <input type="text" name="country" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.country || '' %>" placeholder="e.g. India">
                                            </div>
                                        </div>

                                        <h4 class="portfolio-section-title"><i class="fas fa-briefcase"></i>
                                            Professional Experience</h4>
                                        <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Experience Summary</label>
                                                <textarea name="experience" class="portfolio-input portfolio-textarea"
                                                    style="min-height:120px; padding: 15px 20px; font-size: 16px;"
                                                    placeholder="Previous internships or roles..."><%= profile.experience || '' %></textarea>
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Key Projects</label>
                                                <textarea name="projects" class="portfolio-input portfolio-textarea"
                                                    style="min-height:120px; padding: 15px 20px; font-size: 16px;"
                                                    placeholder="List your best technical work..."><%= profile.projects || '' %></textarea>
                                            </div>
                                        </div>

                                        <h4 class="portfolio-section-title"><i class="fas fa-award"></i> Skills &
                                            Achievements</h4>
                                        <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Technical Skills (Comma
                                                    separated)</label>
                                                <input type="text" name="skills" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.skills ? profile.skills.join(', ') : '' %>"
                                                    placeholder="Python, React, AWS, Docker...">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Certifications</label>
                                                <input type="text" name="certifications" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.certifications || '' %>"
                                                    placeholder="Google Cloud, AWS, Cisco...">
                                            </div>
                                        </div>
                                        <div class="portfolio-grid" style="grid-template-columns: 1fr 1fr; gap: 30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Known Languages</label>
                                                <input type="text" name="languages" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.languages || '' %>"
                                                    placeholder="English, Hindi, Spanish...">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Interests / Hobbies</label>
                                                <input type="text" name="interests" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.interests ? profile.interests.join(', ') : '' %>"
                                                    placeholder="Open Source, AI Research, Photography...">
                                            </div>
                                        </div>

                                        <h4 class="portfolio-section-title"><i class="fas fa-link"></i> Social Proof &
                                            Links</h4>
                                        <div class="portfolio-grid"
                                            style="grid-template-columns: 1fr 1fr 1fr; gap: 30px;">
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">LinkedIn URL</label>
                                                <input type="text" name="linkedin" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.linkedin || '' %>"
                                                    placeholder="linkedin.com/in/username">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">GitHub Profile</label>
                                                <input type="text" name="github" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.github || '' %>"
                                                    placeholder="github.com/username">
                                            </div>
                                            <div class="portfolio-group">
                                                <label class="portfolio-label">Portfolio / Bio Link</label>
                                                <input type="text" name="portfolio" class="portfolio-input"
                                                    style="padding: 15px 20px; font-size: 16px;"
                                                    value="<%= profile.portfolio || '' %>"
                                                    placeholder="yourwebsite.com">
                                            </div>
                                        </div>
                                        <div class="portfolio-group">
                                            <label class="portfolio-label">Professional Bio / Tagline</label>
                                            <input type="text" name="bio" class="portfolio-input"
                                                style="padding: 15px 20px; font-size: 16px;"
                                                value="<%= profile.bio || '' %>"
                                                placeholder="Aspiring Software Engineer passionate about...">
                                        </div>

                                        <div style="margin-top:50px; text-align:right">
                                            <button type="submit" class="view-btn"
                                                style="background:var(--coral); color:#fff; padding:18px 50px; font-size:1.1rem; border-radius:15px">
                                                <i class="fas fa-cloud-upload-alt"></i> Save & Finish Portfolio
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            <% } else if (activePage==='browse' ) { %>
                                <header class="header">
                                    <div class="header-left">
                                        <h1>Opportunity <span>Hub</span></h1>
                                        <p>Find your next career leap from over <%= internships.length %>+ active
                                                listings.</p>
                                    </div>
                                    <div class="header-right">
                                        <div class="browse-filters">
                                            <select class="filter-select">
                                                <option>All Types</option>
                                                <option>Full Time</option>
                                                <option>Remote</option>
                                                <option>Part Time</option>
                                            </select>
                                            <select class="filter-select">
                                                <option>Any Location</option>
                                                <option>Remote</option>
                                                <option>Bangalore</option>
                                                <option>Mumbai</option>
                                            </select>
                                        </div>
                                    </div>
                                </header>

                                <div class="card reveal" style="margin-top:20px">
                                    <div class="internship-list">
                                        <% if (internships && internships.length> 0) { %>
                                            <% internships.forEach(function(item) { %>
                                                <div class="internship-item">
                                                    <div class="company-logo"
                                                        style="width:60px; height:60px; font-size:1.5rem">
                                                        <% const cName=item.companyName || (item.company &&
                                                            (item.company.companyName || item.company.name)) || 'CO' ;
                                                            %>
                                                            <%= cName.charAt(0).toUpperCase() %>
                                                    </div>
                                                    <div class="internship-details">
                                                        <h4 style="font-size:1.2rem; margin-bottom:5px">
                                                            <%= item.title %>
                                                        </h4>
                                                        <div class="company-name"
                                                            style="font-size:15px; margin-bottom:12px"><i
                                                                class="fas fa-building"></i>
                                                            <%= cName %>
                                                        </div>
                                                        <div class="internship-meta">
                                                            <span class="meta-tag"><i class="fas fa-map-marker-alt"></i>
                                                                <%= item.location || 'Remote' %>
                                                            </span>
                                                            <span class="meta-tag"><i class="fas fa-clock"></i>
                                                                <%= item.duration || '3 Months' %>
                                                            </span>
                                                            <span class="meta-tag"><i
                                                                    class="fas fa-money-bill-wave"></i> ₹<%=
                                                                    item.stipend || 'Competitive' %></span>
                                                            <span class="meta-tag"><i class="fas fa-tags"></i>
                                                                <%= item.type || 'Internship' %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div class="action-buttons">
                                                        <a href="/internships/<%= item._id %>" class="view-btn"
                                                            style="background:var(--coral); color:#fff; padding:12px 30px">View
                                                            Details</a>
                                                    </div>
                                                </div>
                                                <% }); %>
                                                    <% } else { %>
                                                        <div
                                                            style="text-align:center; padding: 100px 0; color:var(--text-muted)">
                                                            <i class="fas fa-search"
                                                                style="font-size:4rem; opacity:0.1; margin-bottom:20px"></i>
                                                            <h3>No matching internships found</h3>
                                                            <p>Try adjusting your search or check back later.</p>
                                                        </div>
                                                        <% } %>
                                    </div>
                                </div>
                                <% } else if (activePage==='saved' ) { %>
                                    <header class="header">
                                        <div class="header-left">
                                            <h1>Saved Jobs</h1>
                                            <p>Internships you've bookmarked for later</p>
                                        </div>
                                        <div class="header-right">
                                            <a href="/internships" class="view-btn"
                                                style="background:var(--coral); color:#fff">
                                                <i class="fas fa-search"></i> Browse Jobs
                                            </a>
                                        </div>
                                    </header>

                                    <div class="card reveal"
                                        style="margin-top:20px; text-align:center; padding:80px 40px">
                                        <div
                                            style="width:80px; height:80px; background:rgba(217,95,59,0.1); color:var(--coral); border-radius:20px; display:flex; align-items:center; justify-content:center; margin:0 auto 24px; font-size:2rem">
                                            <i class="fas fa-bookmark"></i>
                                        </div>
                                        <h2>No saved jobs yet</h2>
                                        <p style="color:var(--text-muted); margin-bottom:30px">Bookmark internships to
                                            track them here.</p>
                                        <a href="/internships" class="view-btn"
                                            style="background:var(--coral); color:#fff; padding:12px 24px">Explore
                                            Now</a>
                                    </div>
                                    <% } else if (activePage==='settings' ) { %>
                                        <header class="header">
                                            <div class="header-left">
                                                <h1>Settings & <span>Security</span></h1>
                                                <p>Manage your account password.</p>
                                            </div>
                                        </header>

                                        <div class="card reveal" style="margin-top:20px; max-width:600px">
                                            <div class="card-header">
                                                <h2 class="card-title"><i class="fas fa-lock"></i> Change Password</h2>
                                            </div>

                                            <% if (typeof success !=='undefined' && success &&
                                                success.includes('Password')) { %>
                                                <div style="background:rgba(90,122,92,0.1); color:var(--sage); padding:15px; border-radius:12px; margin-bottom:20px; font-weight:700"
                                                    id="passwordSuccessMsg">
                                                    <i class="fas fa-check-circle"></i>
                                                    <%= success %>
                                                </div>
                                                <% } %>
                                                    <% if (typeof error !=='undefined' && error &&
                                                        error.includes('assword')) { %>
                                                        <div
                                                            style="background:rgba(181,56,74,0.1); color:var(--rose); padding:15px; border-radius:12px; margin-bottom:20px; font-weight:700">
                                                            <i class="fas fa-exclamation-circle"></i>
                                                            <%= error %>
                                                        </div>
                                                        <% } %>

                                                            <form action="/auth/change-password" method="POST">
                                                                <div class="portfolio-group">
                                                                    <label class="portfolio-label">Current
                                                                        Password</label>
                                                                    <input type="password" name="currentPassword"
                                                                        class="portfolio-input" required
                                                                        placeholder="Enter current password">
                                                                </div>
                                                                <div class="portfolio-group">
                                                                    <label class="portfolio-label">New Password</label>
                                                                    <input type="password" name="newPassword"
                                                                        class="portfolio-input" required
                                                                        placeholder="Enter new password">
                                                                </div>
                                                                <div class="portfolio-group">
                                                                    <label class="portfolio-label">Confirm New
                                                                        Password</label>
                                                                    <input type="password" name="confirmPassword"
                                                                        class="portfolio-input" required
                                                                        placeholder="Confirm new password">
                                                                </div>
                                                                <div style="margin-top:20px;">
                                                                    <button type="submit" class="view-btn"
                                                                        style="background:var(--coral); color:#fff; padding:12px 30px; font-size:1rem; border-radius:12px; border:none; cursor:pointer">
                                                                        Update Password
                                                                    </button>
                                                                </div>
                                                            </form>
                                        </div>
                                        <% } %>
                                            </main>

                                            <script>
                                                // URL Search Params handler for SweetAlerts
                                                const urlParams = new URLSearchParams(window.location.search);
                                                if (urlParams.get('success') === 'Password updated successfully.') {
                                                    Swal.fire({
                                                        icon: 'success',
                                                        title: 'Privacy Secured',
                                                        text: 'Your password has been updated successfully.',
                                                        confirmButtonColor: '#D95F3B',
                                                        iconColor: '#D95F3B'
                                                    });
                                                } else if (urlParams.get('success') === '1' || urlParams.get('success') ===
                                                    'Password updated successfully.') {
                                                    Swal.fire({
                                                        icon: 'success',
                                                        title: 'Great Job!',
                                                        text: 'Your portfolio is now updated and live.',
                                                        confirmButtonColor: '#D95F3B',
                                                        iconColor: '#D95F3B'
                                                    });
                                                } else if (urlParams.get('error')) {
                                                    Swal.fire({
                                                        icon: 'error',
                                                        title: 'Oops!',
                                                        text: decodeURIComponent(urlParams.get('error')),
                                                        confirmButtonColor: '#D95F3B'
                                                    });
                                                }

                                                const reveals = document.querySelectorAll('.reveal');
                                                reveals.forEach((el, i) => {
                                                    setTimeout(() => el.classList.add('visible'), i * 100);
                                                });

                                                const search = document.getElementById('globalSearch');
                                                if (search) {
                                                    search.addEventListener('keypress', (e) => {
                                                        if (e.key === 'Enter' && search.value.trim()) {
                                                            window.location.href = '/internships?q=' + encodeURIComponent(search.value);
                                                        }
                                                    });
                                                }
                                            </script>
</body>

</html>