<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Applications | Conneto</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Poppins:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/conneto.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #2563EB;
            --primary-dark: #1D4ED8;
            --primary-light: #DBEAFE;
            --secondary: #7C3AED;
            --success: #10B981;
            --success-light: #D1FAE5;
            --warning: #F59E0B;
            --warning-light: #FEF3C7;
            --danger: #EF4444;
            --danger-light: #FEE2E2;
            --info: #06B6D4;
            --info-light: #CFFAFE;
            --text: #0F172A;
            --text-muted: #64748B;
            --border: #E2E8F0;
            --bg: #F1F5F9;
            --card-bg: #FFFFFF;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        /* DARK MODE OVERRIDES */
        [data-theme="dark"] body {
            background: linear-gradient(135deg, #0d1117, #161b22) !important;
            color: #c9d1d9 !important;
        }

        [data-theme="dark"] .header {
            background: #161b22 !important;
            border-bottom-color: rgba(255, 255, 255, 0.08) !important;
        }

        [data-theme="dark"] .logo {
            background: linear-gradient(135deg, #60a5fa, #a78bfa) !important;
        }

        [data-theme="dark"] .stat-card {
            background: #1c2128 !important;
            box-shadow: none !important;
        }

        [data-theme="dark"] .stat-number {
            color: #60a5fa;
        }

        [data-theme="dark"] .stat-label {
            color: #8b949e !important;
        }

        [data-theme="dark"] .applications-card {
            background: #161b22 !important;
            box-shadow: none !important;
        }

        [data-theme="dark"] .section-title {
            color: #f0f6fc !important;
        }

        [data-theme="dark"] .page-title {
            color: #f0f6fc !important;
        }

        [data-theme="dark"] .application-item {
            background: #1c2128 !important;
        }

        [data-theme="dark"] .internship-title {
            color: #f0f6fc !important;
        }

        [data-theme="dark"] .company-name {
            color: #8b949e !important;
        }

        [data-theme="dark"] .application-date {
            color: #8b949e !important;
        }

        [data-theme="dark"] .empty-title {
            color: #f0f6fc !important;
        }

        [data-theme="dark"] .nav-link {
            color: #c9d1d9 !important;
        }

        [data-theme="dark"] .nav-link:hover {
            color: #60a5fa !important;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
            color: var(--text);
            min-height: 100vh;
        }

        .header {
            background: white;
            padding: 20px 40px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: var(--shadow);
        }

        .logo {
            font-family: 'Poppins', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .nav-link {
            color: var(--text);
            text-decoration: none;
            font-weight: 500;
        }

        .nav-link:hover,
        .nav-link.active {
            color: var(--primary);
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 700;
        }

        .btn-browse {
            padding: 12px 24px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-browse:hover {
            background: var(--primary-dark);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }

        .stat-card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            box-shadow: var(--shadow);
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
        }

        .stat-label {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .applications-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            box-shadow: var(--shadow);
        }

        .section-title {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .application-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .application-item {
            display: flex;
            gap: 16px;
            padding: 20px;
            background: var(--bg);
            border-radius: 12px;
            align-items: center;
        }

        .company-avatar {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--primary);
            flex-shrink: 0;
        }

        .application-info {
            flex: 1;
        }

        .internship-title {
            font-weight: 600;
            margin-bottom: 4px;
        }

        .company-name {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .application-date {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-top: 4px;
        }

        .status-badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            white-space: nowrap;
        }

        .status-badge.applied {
            background: var(--info-light);
            color: #0891B2;
        }

        .status-badge.under_review {
            background: var(--warning-light);
            color: #B45309;
        }

        .status-badge.shortlisted {
            background: var(--primary-light);
            color: var(--primary);
        }

        .status-badge.interview_scheduled {
            background: var(--success-light);
            color: #047857;
        }

        .status-badge.selected {
            background: #DCFCE7;
            color: #166534;
        }

        .status-badge.rejected {
            background: var(--danger-light);
            color: #B91C1C;
        }

        .interview-info {
            margin-top: 8px;
            padding: 8px 12px;
            background: var(--success-light);
            border-radius: 8px;
            font-size: 0.85rem;
            color: #047857;
        }

        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .btn-withdraw {
            padding: 8px 14px;
            background: var(--danger-light);
            color: var(--danger);
            border: none;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
        }

        .btn-withdraw:hover {
            background: var(--danger);
            color: white;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }

        .empty-icon {
            font-size: 4rem;
            color: var(--border);
            margin-bottom: 16px;
        }

        .empty-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .empty-text {
            color: var(--text-muted);
            margin-bottom: 20px;
        }

        @media (max-width: 768px) {
            .application-item {
                flex-direction: column;
                align-items: flex-start;
            }

            .action-buttons {
                width: 100%;
                margin-top: 12px;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .header {
                padding: 14px 16px;
                flex-wrap: wrap;
                gap: 12px;
            }

            .nav-links {
                gap: 10px;
            }

            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
            }
        }

        @media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }

            .nav-links .nav-link {
                display: none;
            }
        }
    </style>

    <!-- Prevent FOUT -> Pre-load Theme -->
    <script>
        (function () {
            var saved = localStorage.getItem('conneto-theme');
            if (saved !== 'light') {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>

<body>
    <script>
        (function () {
            var t = localStorage.getItem('conneto-theme');
            if (t) document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    <header class="header">
        <a href="/" class="logo" style="-webkit-background-clip:text;background-clip:text;">Conneto</a>
        <nav class="nav-links">
            <a href="/" class="nav-link" style="font-size:0.85rem;"><i class="fas fa-arrow-left"></i> Home</a>
            <a href="/student/dashboard" class="nav-link">Dashboard</a>
            <a href="/student/applications" class="nav-link active">My Applications</a>
            <a href="/internships" class="nav-link">Browse</a>
            <a href="/auth/logout" class="btn-browse" style="background: var(--danger);">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </nav>
    </header>

    <div class="container">
        <div class="page-header">
            <h1 class="page-title">My Applications</h1>
            <a href="/internships" class="btn-browse">
                <i class="fas fa-search"></i> Browse More
            </a>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number">
                    <%= stats.total %>
                </div>
                <div class="stat-label">Total Applied</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" style="color: var(--warning);">
                    <%= stats.under_review %>
                </div>
                <div class="stat-label">Under Review</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" style="color: var(--secondary);">
                    <%= stats.shortlisted %>
                </div>
                <div class="stat-label">Shortlisted</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" style="color: var(--success);">
                    <%= stats.interview_scheduled %>
                </div>
                <div class="stat-label">Interviews</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" style="color: #166534;">
                    <%= stats.selected %>
                </div>
                <div class="stat-label">Selected</div>
            </div>
        </div>

        <div class="applications-card">
            <h2 class="section-title">All Applications</h2>

            <% if (applications && applications.length> 0) { %>
                <div class="application-list">
                    <% applications.forEach(function(app) { %>
                        <div class="application-item">
                            <div class="company-avatar">
                                <% var cName=app.internship ? ((app.internship.company &&
                                    app.internship.company.companyName) ? app.internship.company.companyName :
                                    (app.internship.companyName || '' )) : '' ; %>
                                    <%= cName ? cName.charAt(0).toUpperCase() : 'C' %>
                            </div>
                            <div class="application-info">
                                <div class="internship-title">
                                    <%= app.internship ? app.internship.title : 'Internship' %>
                                </div>
                                <div class="company-name">
                                    <%= cName || 'Company' %>
                                </div>
                                <div class="application-date">
                                    Applied on <%= new Date(app.appliedAt).toLocaleDateString() %>
                                </div>
                                <% if (app.status==='interview_scheduled' && app.interviewDate) { %>
                                    <div class="interview-info">
                                        <i class="fas fa-calendar-check"></i> Interview scheduled: <%= new
                                            Date(app.interviewDate).toLocaleString() %>
                                    </div>
                                    <% } %>
                            </div>
                            <span class="status-badge <%= app.status %>">
                                <%= app.status.replace('_', ' ' ) %>
                            </span>
                            <div class="action-buttons">
                                <% if (app.status==='applied' || app.status==='under_review' ) { %>
                                    <form action="/student/applications/<%= app._id %>/withdraw" method="POST"
                                        style="display: inline;">
                                        <button type="submit" class="btn-withdraw"
                                            onclick="return confirm('Are you sure you want to withdraw this application?')">
                                            <i class="fas fa-times"></i> Withdraw
                                        </button>
                                    </form>
                                    <% } %>
                            </div>
                        </div>
                        <% }); %>
                </div>
                <% } else { %>
                    <div class="empty-state">
                        <div class="empty-icon"><i class="fas fa-file-alt"></i></div>
                        <h2 class="empty-title">No applications yet</h2>
                        <p class="empty-text">Start applying for internships to see them here</p>
                        <a href="/internships" class="btn-browse">
                            <i class="fas fa-search"></i> Browse Internships
                        </a>
                    </div>
                    <% } %>
        </div>
    </div>

    <!-- Floating Theme Toggle -->
    <button class="c-theme-toggle" onclick="toggleTheme()" title="Toggle dark/light mode" aria-label="Toggle theme">
        <i class="fas fa-sun icon-sun"></i>
        <i class="fas fa-moon icon-moon"></i>
    </button>

    <script>
        function toggleTheme() {
            var html = document.documentElement;
            var isDark = html.getAttribute('data-theme') === 'dark';
            if (isDark) { html.removeAttribute('data-theme'); localStorage.setItem('conneto-theme', 'light'); }
            else { html.setAttribute('data-theme', 'dark'); localStorage.setItem('conneto-theme', 'dark'); }
        }
    </script>
</body>

</html>