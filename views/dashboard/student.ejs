                                </div>

                                <div style="margin-top:50px; text-align:right">
                                    <button type="submit" class="view-btn"
                                        style="background:var(--coral); color:#fff; padding:18px 50px; font-size:1.1rem; border-radius:15px">
                                        <i class="fas fa-cloud-upload-alt"></i> Save & Finish Portfolio
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                    <script>
                        (function () {
                            const statusSelect = document.getElementById('memberStatus');
                            const studentFields = document.getElementById('studentOnlyFields');
                            const studentInputs = document.querySelectorAll('.student-req');

                            function toggleFields() {
                                if (statusSelect.value === 'Student') {
                                    studentFields.style.display = 'block';
                                    studentInputs.forEach(input => input.setAttribute('required', 'true'));
                                } else {
                                    studentFields.style.display = 'none';
                                    studentInputs.forEach(input => input.removeAttribute('required'));
                                }
                            }

                            statusSelect.addEventListener('change', toggleFields);
                            // Initial load
                            toggleFields();
                        })();
                    </script>
                    <% } else if (activePage==='browse' ) { %>
                        <header class="header">
                            <div class="header-left">
                                <h1>Opportunity <span>Hub</span></h1>
                                <p>Find your next career leap from over <%= internships.length %>+ active
                                        listings.</p>
                            </div>
                            <div class="header-right">
                                <div class="browse-filters">
                                    <select class="filter-select">
                                        <option>All Types</option>
                                        <option>Full Time</option>
                                        <option>Remote</option>
                                        <option>Part Time</option>
                                    </select>
                                    <select class="filter-select">
                                        <option>Any Location</option>
                                        <option>Remote</option>
                                        <option>Bangalore</option>
                                        <option>Mumbai</option>
                                    </select>
                                </div>
                            </div>
                        </header>

                        <div class="card reveal" style="margin-top:20px">
                            <div class="internship-list">
                                <% if (internships && internships.length> 0) { %>
