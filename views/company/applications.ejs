<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Applications | Conneto</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Poppins:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #7C3AED;
            --primary-dark: #6D28D9;
            --primary-light: #EDE9FE;
            --secondary: #2563EB;
            --success: #10B981;
            --success-light: #D1FAE5;
            --warning: #F59E0B;
            --warning-light: #FEF3C7;
            --danger: #EF4444;
            --danger-light: #FEE2E2;
            --info: #06B6D4;
            --info-light: #CFFAFE;
            --text: #0F172A;
            --text-muted: #64748B;
            --border: #E2E8F0;
            --bg: #F8FAFC;
            --card-bg: #FFFFFF;
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #F5F3FF 0%, #EDE9FE 100%);
            color: var(--text);
            min-height: 100vh;
        }

        .header {
            background: white;
            padding: 20px 40px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: var(--shadow);
        }

        .logo {
            font-family: 'Poppins', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .nav-link {
            color: var(--text);
            text-decoration: none;
            font-weight: 500;
        }

        .nav-link:hover {
            color: var(--primary);
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 700;
        }

        .btn-primary {
            padding: 12px 24px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
        }

        .internship-tabs {
            display: flex;
            gap: 12px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .internship-tab {
            padding: 12px 20px;
            background: white;
            border: 2px solid var(--border);
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 500;
        }

        .internship-tab:hover,
        .internship-tab.active {
            border-color: var(--primary);
            background: var(--primary-light);
            color: var(--primary);
        }

        .applications-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            box-shadow: var(--shadow);
        }

        .section-title {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .application-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .application-item {
            display: flex;
            gap: 16px;
            padding: 20px;
            background: var(--bg);
            border-radius: 12px;
            align-items: center;
        }

        .student-avatar {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--primary);
            flex-shrink: 0;
        }

        .application-info {
            flex: 1;
        }

        .student-name {
            font-weight: 600;
            margin-bottom: 4px;
        }

        .application-date {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .status-badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .status-badge.applied {
            background: var(--info-light);
            color: #0891B2;
        }

        .status-badge.under_review {
            background: var(--warning-light);
            color: #B45309;
        }

        .status-badge.shortlisted {
            background: var(--primary-light);
            color: var(--primary);
        }

        .status-badge.interview_scheduled {
            background: var(--success-light);
            color: #047857;
        }

        .status-badge.selected {
            background: #DCFCE7;
            color: #166534;
        }

        .status-badge.rejected {
            background: var(--danger-light);
            color: #B91C1C;
        }

        .action-buttons {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .btn-action {
            padding: 8px 14px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all 0.3s;
        }

        .btn-shortlist {
            background: var(--primary-light);
            color: var(--primary);
        }

        .btn-shortlist:hover {
            background: var(--primary);
            color: white;
        }

        .btn-interview {
            background: var(--success-light);
            color: var(--success);
        }

        .btn-interview:hover {
            background: var(--success);
            color: white;
        }

        .btn-reject {
            background: var(--danger-light);
            color: var(--danger);
        }

        .btn-reject:hover {
            background: var(--danger);
            color: white;
        }

        .btn-select {
            background: #DCFCE7;
            color: #166534;
        }

        .btn-select:hover {
            background: #166534;
            color: white;
        }

        .empty-state {
            text-align: center;
            padding: 40px;
            color: var(--text-muted);
        }

        .interview-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: white;
            padding: 32px;
            border-radius: 16px;
            max-width: 500px;
            width: 90%;
        }

        .modal-title {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .modal-input {
            width: 100%;
            padding: 12px;
            border: 2px solid var(--border);
            border-radius: 8px;
            margin-bottom: 16px;
            font-size: 1rem;
        }

        .modal-actions {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
        }

        .btn-cancel {
            padding: 10px 20px;
            background: var(--bg);
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
        }

        .btn-submit {
            padding: 10px 20px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
        }

        @media (max-width: 768px) {
            .application-item {
                flex-direction: column;
                align-items: flex-start;
            }

            .action-buttons {
                width: 100%;
            }

            .btn-action {
                flex: 1;
                text-align: center;
            }
        }
    </style>
</head>

<body>
    <header class="header">
        <a href="/" class="logo">Conneto</a>
        <nav class="nav-links">
            <a href="/company/dashboard" class="nav-link">Dashboard</a>
            <a href="/company/applications" class="nav-link" style="color: var(--primary);">Applications</a>
            <a href="/company/internships/create" class="btn-primary">
                <i class="fas fa-plus"></i> Post Internship
            </a>
        </nav>
    </header>

    <div class="container">
        <div class="page-header">
            <h1 class="page-title">Applications</h1>
            <a href="/company/internships/create" class="btn-primary">
                <i class="fas fa-plus"></i> Post New Internship
            </a>
        </div>

        <% if (groupedApplications && groupedApplications.length> 0) { %>
            <% groupedApplications.forEach(function(group) { %>
                <div class="applications-card" style="margin-bottom: 24px;">
                    <h2 class="section-title">
                        <i class="fas fa-briefcase"></i>
                        <%= group.internship.title %>
                            <span style="font-size: 0.9rem; font-weight: 500; color: var(--text-muted);">
                                (<%= group.applications.length %> applicant<%= group.applications.length !==1 ? 's' : ''
                                        %>)
                            </span>
                    </h2>

                    <% if (group.applications && group.applications.length> 0) { %>
                        <div class="application-list">
                            <% group.applications.forEach(function(app) { %>
                                <div class="application-item">
                                    <div class="student-avatar">
                                        <%= app.student ? app.student.name.charAt(0).toUpperCase() : 'S' %>
                                    </div>
                                    <div class="application-info">
                                        <div class="student-name">
                                            <%= app.student ? app.student.name : 'Student' %>
                                        </div>
                                        <div class="application-date">
                                            Applied on <%= new Date(app.appliedAt).toLocaleDateString() %>
                                        </div>
                                        <% if (app.resumeUrl) { %>
                                            <div style="margin-top: 8px;">
                                                <a href="<%= app.resumeUrl %>" target="_blank"
                                                    style="color: var(--primary); font-size: 0.9rem; text-decoration: none; font-weight: 500;">
                                                    <i class="fas fa-file-pdf"></i> View Resume
                                                </a>
                                            </div>
                                            <% } %>
                                                <% if (app.extractedSkills && app.extractedSkills.length> 0) { %>
                                                    <div style="margin-top: 8px; font-size: 0.85rem;">
                                                        <strong>Skills Match:</strong>
                                                        <% app.extractedSkills.forEach(skill=> { %>
                                                            <span
                                                                style="display:inline-block; padding: 2px 8px; background:var(--primary-light); color:var(--primary); border-radius:12px; margin-right:4px;">
                                                                <%= skill %>
                                                            </span>
                                                            <% }) %>
                                                    </div>
                                                    <% } %>
                                                        <% if (app.studentSkills) { %>
                                                            <div style="margin-top: 8px; font-size: 0.85rem;">
                                                                <strong>Self-Reported Skills:</strong> <span
                                                                    style="color: var(--text-muted);">
                                                                    <%= app.studentSkills %>
                                                                </span>
                                                            </div>
                                                            <% } %>
                                                                <% if (app.question1Answer || app.question2Answer) { %>
                                                                    <div
                                                                        style="margin-top: 12px; font-size: 0.85rem; background: var(--bg); border: 1px solid var(--border); padding: 12px; border-radius: 8px;">
                                                                        <% if (app.question1Answer) { %>
                                                                            <p style="margin-bottom: 8px;"><strong>Why
                                                                                    should you be hired?</strong><br>
                                                                                <span style="color: var(--text-muted);">
                                                                                    <%= app.question1Answer %>
                                                                                </span>
                                                                            </p>
                                                                            <% } %>
                                                                                <% if (app.question2Answer) { %>
                                                                                    <p><strong>Available for
                                                                                            duration?</strong><br>
                                                                                        <span
                                                                                            style="color: var(--text-muted);">
                                                                                            <%= app.question2Answer %>
                                                                                        </span>
                                                                                    </p>
                                                                                    <% } %>
                                                                    </div>
                                                                    <% } %>
                                                                        <% if (app.interviewDate) { %>
                                                                            <div
                                                                                style="margin-top: 8px; font-size: 0.9rem; color: var(--success);">
                                                                                <i class="fas fa-calendar"></i>
                                                                                Interview: <%= new
                                                                                    Date(app.interviewDate).toLocaleString()
                                                                                    %>
                                                                            </div>
                                                                            <% } %>
                                    </div>
                                    <span class="status-badge <%= app.status %>">
                                        <%= app.status.replace('_', ' ' ) %>
                                    </span>
                                    <div class="action-buttons">
                                        <% if (app.status==='applied' || app.status==='under_review' ) { %>
                                            <form action="/company/applications/<%= app._id %>/shortlist" method="POST"
                                                style="display: inline;">
                                                <button type="submit" class="btn-action btn-shortlist">
                                                    <i class="fas fa-check"></i> Shortlist
                                                </button>
                                            </form>
                                            <button class="btn-action btn-interview"
                                                onclick="openInterviewModal('<%= app._id %>')">
                                                <i class="fas fa-calendar"></i> Schedule
                                            </button>
                                            <form action="/company/applications/<%= app._id %>/reject" method="POST"
                                                style="display: inline;">
                                                <button type="submit" class="btn-action btn-reject">
                                                    <i class="fas fa-times"></i> Reject
                                                </button>
                                            </form>
                                            <% } else if (app.status==='shortlisted' ) { %>
                                                <button class="btn-action btn-interview"
                                                    onclick="openInterviewModal('<%= app._id %>')">
                                                    <i class="fas fa-calendar"></i> Schedule Interview
                                                </button>
                                                <form action="/company/applications/<%= app._id %>/select" method="POST"
                                                    style="display: inline;">
                                                    <button type="submit" class="btn-action btn-select">
                                                        <i class="fas fa-user-check"></i> Hire
                                                    </button>
                                                </form>
                                                <% } else if (app.status==='interview_scheduled' ) { %>
                                                    <form action="/company/applications/<%= app._id %>/select"
                                                        method="POST" style="display: inline;">
                                                        <button type="submit" class="btn-action btn-select">
                                                            <i class="fas fa-user-check"></i> Hire
                                                        </button>
                                                    </form>
                                                    <% } %>
                                    </div>
                                </div>
                                <% }); %>
                        </div>
                        <% } else { %>
                            <div class="empty-state">
                                <p>No applications yet for this internship</p>
                            </div>
                            <% } %>
                </div>
                <% }); %>
                    <% } else { %>
                        <div class="applications-card">
                            <div class="empty-state">
                                <i class="fas fa-users"
                                    style="font-size: 3rem; margin-bottom: 16px; color: var(--border);"></i>
                                <p>No applications yet. Post an internship to receive applications.</p>
                                <a href="/company/internships/create" class="btn-primary"
                                    style="margin-top: 20px; display: inline-flex;">
                                    <i class="fas fa-plus"></i> Post Internship
                                </a>
                            </div>
                        </div>
                        <% } %>
    </div>

    <!-- Interview Modal -->
    <div class="interview-modal" id="interviewModal">
        <div class="modal-content">
            <h2 class="modal-title">Schedule Interview</h2>
            <form id="interviewForm" action="" method="POST">
                <input type="datetime-local" name="interviewDate" class="modal-input" required>
                <textarea name="interviewNote" class="modal-input" placeholder="Add notes (optional)"
                    rows="3"></textarea>
                <div class="modal-actions">
                    <button type="button" class="btn-cancel" onclick="closeInterviewModal()">Cancel</button>
                    <button type="submit" class="btn-submit">Schedule</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openInterviewModal(applicationId) {
            const modal = document.getElementById('interviewModal');
            const form = document.getElementById('interviewForm');
            form.action = '/company/applications/' + applicationId + '/interview';
            modal.style.display = 'flex';
        }

        function closeInterviewModal() {
            const modal = document.getElementById('interviewModal');
            modal.style.display = 'none';
        }

        // Close modal when clicking outside
        document.getElementById('interviewModal').addEventListener('click', function (e) {
            if (e.target === this) {
                closeInterviewModal();
            }
        });
    </script>
</body>

</html>