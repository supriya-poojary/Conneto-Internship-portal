<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description"
        content="Get in touch with the Conneto team. We help students find internships and companies find exceptional talent." />
    <title>Contact Us | Conneto — Internship Portal</title>
    <link rel="shortcut icon" type="image/x-icon" href="/solvior/images/fav.png" />

    <link rel="stylesheet" href="/solvior/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/solvior/css/font-awesome-pro.min.css" />
    <link rel="stylesheet" href="/css/conneto.css" />
    <link
        href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&family=Libre+Franklin:wght@400;600;700;800&display=swap"
        rel="stylesheet" />

    <style>
        :root {
            --tj-primary: #0075ff;
            --tj-dark: #051229;
        }

        /* ===== NAV AUTH ===== */
        .conneto-nav-auth {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn-nav-login {
            color: var(--tj-dark);
            font-weight: 600;
            font-size: 15px;
            text-decoration: none;
            transition: color 0.3s;
        }

        .btn-nav-login:hover {
            color: var(--tj-primary);
        }

        .btn-nav-signup {
            background: var(--tj-primary);
            color: var(--text-main);
            padding: 10px 22px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 14px;
            transition: all 0.3s;
            text-decoration: none;
        }

        .btn-nav-signup:hover {
            background: #005ecc;
            color: var(--text-main);
            transform: translateY(-1px);
        }

        /* ===== PAGE HEADER ===== */
        .contact-page-header {
            background: linear-gradient(rgba(5, 18, 41, 0.78), rgba(5, 18, 41, 0.78)),
                url('https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=1400&q=80') center/cover no-repeat;
            padding: 100px 0 80px;
            text-align: center;
        }

        .contact-page-header h1 {
            font-family: 'Libre Franklin', serif;
            font-size: clamp(2rem, 5vw, 3.2rem);
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 16px;
        }

        .contact-page-header p {
            font-size: 1.1rem;
            color: rgba(255, 255, 255, 0.8);
            max-width: 520px;
            margin: 0 auto 20px;
            line-height: 1.7;
        }

        .breadcrumb-bar {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.6);
        }

        .breadcrumb-bar a {
            color: var(--tj-primary);
            text-decoration: none;
        }

        .breadcrumb-bar span {
            color: rgba(255, 255, 255, 0.4);
        }

        /* ===== CONTACT GRID ===== */
        .contact-section {
            background: #f8fafe;
            padding: 80px 0;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1.3fr;
            gap: 56px;
            align-items: flex-start;
        }

        @media (max-width: 900px) {
            .contact-grid {
                grid-template-columns: 1fr;
                gap: 40px;
            }
        }

        /* Info cards */
        .info-card {
            display: flex;
            align-items: flex-start;
            gap: 18px;
            background: #fff;
            border-radius: 14px;
            padding: 22px 24px;
            box-shadow: 0 2px 16px rgba(5, 18, 41, 0.06);
            margin-bottom: 18px;
            border-left: 4px solid var(--tj-primary);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .info-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(5, 18, 41, 0.1);
        }

        .info-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: rgba(0, 117, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--tj-primary);
            font-size: 1.3rem;
            flex-shrink: 0;
        }

        .info-card h4 {
            font-family: 'Libre Franklin', serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--tj-dark);
            margin: 0 0 6px;
        }

        .info-card p,
        .info-card a {
            font-size: 14px;
            color: #7e8590;
            margin: 0;
            line-height: 1.6;
            text-decoration: none;
        }

        .info-card a:hover {
            color: var(--tj-primary);
        }

        /* Contact form box */
        .contact-form-box {
            background: #fff;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 4px 32px rgba(5, 18, 41, 0.08);
        }

        .contact-form-box h3 {
            font-family: 'Libre Franklin', serif;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--tj-dark);
            margin-bottom: 8px;
        }

        .contact-form-box .sub {
            color: #7e8590;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        @media (max-width: 560px) {
            .form-row {
                grid-template-columns: 1fr;
            }
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            font-size: 14px;
            color: var(--tj-dark);
            margin-bottom: 8px;
        }

        .form-input,
        .form-select,
        .form-textarea {
            width: 100%;
            padding: 13px 16px;
            border: 1.5px solid #e0e6f0;
            border-radius: 10px;
            font-size: 14px;
            color: #364052;
            background: #f8fafe;
            outline: none;
            font-family: 'Lato', sans-serif;
            transition: border-color 0.3s, box-shadow 0.3s;
            box-sizing: border-box;
        }

        .form-input:focus,
        .form-select:focus,
        .form-textarea:focus {
            border-color: var(--tj-primary);
            box-shadow: 0 0 0 3px rgba(0, 117, 255, 0.1);
            background: #fff;
        }

        .form-textarea {
            min-height: 120px;
            resize: vertical;
        }

        .btn-submit {
            width: 100%;
            background: var(--tj-primary);
            color: var(--text-main);
            border: none;
            padding: 15px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Lato', sans-serif;
        }

        .btn-submit:hover {
            background: #005ecc;
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(0, 117, 255, 0.35);
        }

        .success-msg {
            display: none;
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.3);
            padding: 14px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            margin-top: 16px;
            text-align: center;
        }

        /* ===== STATS BAR ===== */
        .stats-band {
            background: var(--tj-dark);
            padding: 56px 0;
        }

        .stats-band-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            text-align: center;
            gap: 0;
        }

        @media (max-width: 768px) {
            .stats-band-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        .stat-band-num {
            font-family: 'Libre Franklin', serif;
            font-size: 2.8rem;
            font-weight: 800;
            color: var(--text-main);
            line-height: 1;
        }

        .stat-band-num span {
            color: var(--tj-primary);
        }

        .stat-band-label {
            color: rgba(255, 255, 255, 0.6);
            font-size: 14px;
            margin-top: 8px;
        }

        .stats-band-grid>div {
            padding: 20px;
            border-right: 1px solid var(--border-color);
        }

        .stats-band-grid>div:last-child {
            border-right: none;
        }

        /* Map section */
        .map-section {
            background: #f8fafe;
            padding: 0 0 80px;
        }

        .map-wrap {
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 32px rgba(5, 18, 41, 0.1);
        }

        /* ===== SECTION HEADING THEME ===== */
        .sec-tag {
            font-size: 13px;
            font-weight: 700;
            color: var(--tj-primary);
            text-transform: uppercase;
            letter-spacing: 1px;
            display: block;
            margin-bottom: 12px;
        }

        .sec-h2 {
            font-family: 'Libre Franklin', serif;
            font-size: clamp(1.6rem, 3vw, 2.2rem);
            font-weight: 800;
            color: var(--tj-dark);
            margin-bottom: 16px;
        }

        .sec-p {
            color: #7e8590;
            font-size: 15px;
            line-height: 1.7;
        }
    </style>

    <!-- Prevent FOUT -> Pre-load Theme -->
    <script>
        (function () {
            var saved = localStorage.getItem('conneto-theme');
            if (saved !== 'light') {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>

<body>

    <!-- ===== HEADER (same as index.ejs) ===== -->
