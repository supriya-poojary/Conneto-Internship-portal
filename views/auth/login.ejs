<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In | Conneto — Internship Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script>
        (function () {
            const t = localStorage.getItem('conneto-theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    <style>
        :root {
            --coral: #D95F3B;
            --coral-light: #F07A56;
            --rose: #B5384A;
            --amber: #C8831A;
            --amber-light: #E8A030;
            --sage: #5A7A5C;
            --sage-light: #7A9E7C;
            --terra: #A0522D;
            --terra-light: #C4723F;
            --cream: #FAF3E8;
            --cream2: #F5EAD8;
            --warm-white: #FFF8F0;
            --ink: #2C1A0E;
            --ink2: #4A2E1A;
            --text: #3D2B1F;
            --text-muted: #7A5C4A;
            --border: rgba(160, 82, 45, 0.15);
            --shadow: rgba(44, 26, 14, 0.12);
            --card-bg: rgba(255, 248, 240, 0.95);
            --auth-overlay: linear-gradient(135deg, rgba(217, 95, 59, 0.4) 0%, rgba(181, 56, 74, 0.2) 100%);
        }

        [data-theme="dark"] {
            --cream: #1C0F08;
            --cream2: #251508;
            --warm-white: #1A0D06;
            --ink: #FAF3E8;
            --ink2: #F0E0C8;
            --text: #E8D5BC;
            --text-muted: #B8937A;
            --border: rgba(200, 131, 26, 0.2);
            --shadow: rgba(0, 0, 0, 0.4);
            --card-bg: rgba(37, 21, 8, 0.95);
            --auth-overlay: linear-gradient(135deg, rgba(28, 15, 8, 0.85) 0%, rgba(14, 7, 3, 0.7) 100%);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--cream);
            color: var(--text);
            transition: background 0.4s, color 0.4s;
            min-height: 100vh;
            display: flex
        }

        /* AUTH LAYOUT */
        .auth-container {
            display: flex;
            width: 100%;
            min-height: 100vh;
            overflow: hidden;
        }

        .auth-left {
            width: 50%;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 80px;
            overflow: hidden;
            background: var(--ink);
        }

        .auth-left-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1200&q=85');
            background-size: cover;
            background-position: center;
            opacity: 0.8;
        }

        .auth-left-bg::after {
            content: '';
            position: absolute;
            inset: 0;
            background: var(--auth-overlay);
            transition: background 0.4s;
        }

        .auth-content {
            position: relative;
            z-index: 2;
            max-width: 480px;
        }

        .auth-logo {
            font-family: 'Outfit', sans-serif;
            font-size: 2.5rem;
            font-weight: 800;
            color: #fff;
            margin-bottom: 24px;
            text-decoration: none;
            display: block;
        }

        .auth-logo span {
            color: var(--coral-light);
        }

        .auth-title {
            font-family: 'Outfit', sans-serif;
            font-size: 3rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.1;
            margin-bottom: 24px;
        }

        .auth-title em {
            font-style: italic;
            color: var(--amber-light);
        }

        .auth-desc {
            font-size: 18px;
            color: rgba(255, 255, 255, 0.8);
            line-height: 1.7;
            margin-bottom: 40px;
        }

        .auth-right {
            width: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px;
            position: relative;
            overflow: hidden;
            background: #0d0a1a;
        }

        /* Dark mesh gradient background */
        .auth-right::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse at 20% 20%, rgba(217, 95, 59, 0.45) 0%, transparent 55%),
                radial-gradient(ellipse at 80% 80%, rgba(168, 85, 247, 0.4) 0%, transparent 55%),
                radial-gradient(ellipse at 75% 15%, rgba(59, 130, 246, 0.35) 0%, transparent 50%),
                radial-gradient(ellipse at 15% 85%, rgba(200, 131, 26, 0.4) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(90, 122, 92, 0.2) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
            animation: orb-shift 12s infinite alternate ease-in-out;
        }

        /* Subtle grid overlay */
        .auth-right::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
            z-index: 0;
        }

        [data-theme="light"] .auth-right {
            background: #f0e8ff;
        }

        [data-theme="light"] .auth-right::before {
            background:
                radial-gradient(ellipse at 20% 20%, rgba(217, 95, 59, 0.25) 0%, transparent 55%),
                radial-gradient(ellipse at 80% 80%, rgba(168, 85, 247, 0.2) 0%, transparent 55%),
                radial-gradient(ellipse at 75% 15%, rgba(59, 130, 246, 0.18) 0%, transparent 50%),
                radial-gradient(ellipse at 15% 85%, rgba(200, 131, 26, 0.22) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(90, 122, 92, 0.12) 0%, transparent 60%);
        }

        [data-theme="light"] .auth-right::after {
            background-image:
                linear-gradient(rgba(80, 40, 20, 0.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(80, 40, 20, 0.06) 1px, transparent 1px);
        }

        @keyframes orb-shift {
            0% {
                filter: hue-rotate(0deg) brightness(1);
            }

            50% {
                filter: hue-rotate(15deg) brightness(1.1);
            }

            100% {
                filter: hue-rotate(-10deg) brightness(0.95);
            }
        }

        /* Floating glow orbs */
        .moving-dots {
            position: absolute;
            inset: 0;
            z-index: 0;
            pointer-events: none;
        }

        .dot {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            animation: float-orb linear infinite;
            opacity: 0.7;
        }

        .dot:nth-child(1) {
            background: rgba(217, 95, 59, 0.55);
            width: 200px;
            height: 200px;
            top: 5%;
            right: 5%;
            animation-duration: 18s;
            animation-delay: 0s;
        }

        .dot:nth-child(2) {
            background: rgba(168, 85, 247, 0.5);
            width: 160px;
            height: 160px;
            bottom: 10%;
            left: 2%;
            animation-duration: 22s;
            animation-delay: -6s;
        }

        .dot:nth-child(3) {
            background: rgba(59, 130, 246, 0.45);
            width: 180px;
            height: 180px;
            top: 45%;
            left: 10%;
            animation-duration: 25s;
            animation-delay: -12s;
        }

        .dot:nth-child(4) {
            background: rgba(200, 131, 26, 0.5);
            width: 140px;
            height: 140px;
            bottom: 5%;
            right: 8%;
            animation-duration: 20s;
            animation-delay: -4s;
        }

        @keyframes float-orb {
            0% {
                transform: translate(0px, 0px) scale(1);
            }

            25% {
                transform: translate(20px, -30px) scale(1.05);
            }

            50% {
                transform: translate(-15px, 20px) scale(0.95);
            }

            75% {
                transform: translate(25px, 15px) scale(1.08);
            }

            100% {
                transform: translate(0px, 0px) scale(1);
            }
        }

        .form-box {
            width: 100%;
            max-width: 420px;
            position: relative;
            z-index: 2;
            padding: 40px;
            background: rgba(255, 252, 248, 0.92);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 24px;
            backdrop-filter: blur(24px) saturate(180%);
            -webkit-backdrop-filter: blur(24px) saturate(180%);
            box-shadow:
                0 8px 48px rgba(0, 0, 0, 0.25),
                0 2px 8px rgba(217, 95, 59, 0.12),
                inset 0 1px 0 rgba(255, 255, 255, 0.8);
            overflow: hidden;
            margin: 20px 0;
        }

        [data-theme="dark"] .form-box {
            background: rgba(28, 18, 10, 0.88);
            border-color: rgba(255, 255, 255, 0.08);
            box-shadow:
                0 8px 48px rgba(0, 0, 0, 0.5),
                0 2px 8px rgba(217, 95, 59, 0.15),
                inset 0 1px 0 rgba(255, 255, 255, 0.05);
        }

        /* Rainbow highlight bar at top of form */
        .form-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--coral), var(--amber), #a855f7, #3b82f6, var(--sage));
            border-radius: 24px 24px 0 0;
            z-index: 1;
        }

        .theme-toggle-wrap {
            position: absolute;
            top: 40px;
            right: 40px;
            z-index: 10;
        }

        .theme-btn {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--card-bg);
            color: var(--amber);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            transition: .3s;
        }

        .theme-btn:hover {
            background: var(--amber);
            color: #fff;
            transform: rotate(15deg);
        }

        .back-home {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            margin-bottom: 32px;
            transition: .3s;
        }

        .back-home:hover {
            color: var(--coral);
            transform: translateX(-5px);
        }

        .form-header {
            margin-bottom: 36px;
        }

        .form-header h2 {
            font-family: 'Outfit', sans-serif;
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--ink);
            margin-bottom: 8px;
        }

        .form-header p {
            color: var(--text-muted);
            font-size: 16px;
            font-weight: 500;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .input-wrap {
            position: relative;
        }

        .input-wrap i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 16px;
        }

        .form-input {
            width: 100%;
            padding: 14px 16px 14px 48px;
            background: var(--warm-white);
            border: 1.5px solid var(--border);
            border-radius: 14px;
            font-family: inherit;
            font-size: 15px;
            color: var(--ink);
            transition: .3s;
            outline: none;
        }

        .form-input:focus {
            border-color: var(--coral);
            background: #fff;
            box-shadow: 0 0 0 4px rgba(217, 95, 59, 0.1);
        }

        [data-theme="dark"] .form-input {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            border-color: rgba(255, 255, 255, 0.1);
        }

        [data-theme="dark"] .form-input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        [data-theme="dark"] .form-input:focus {
            background: rgba(255, 255, 255, 0.08);
            border-color: var(--coral);
            color: #fff;
        }

        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
        }

        .remember-me input {
            width: 18px;
            height: 18px;
            accent-color: var(--coral);
        }

        .forgot-pass {
            font-size: 14px;
            font-weight: 700;
            color: var(--coral);
            text-decoration: none;
        }

        .btn-submit {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--coral), var(--rose));
            color: #fff;
            border: none;
            border-radius: 14px;
            font-family: inherit;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: .3s;
            box-shadow: 0 8px 24px rgba(217, 95, 59, 0.3);
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 32px rgba(217, 95, 59, 0.4);
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 15px;
            margin: 32px 0;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .google-btn {
            width: 100%;
            padding: 14px;
            background: var(--warm-white);
            border: 1.5px solid var(--border);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            font-family: inherit;
            font-size: 15px;
            font-weight: 700;
            color: var(--ink);
            cursor: pointer;
            transition: .3s;
        }

        .google-btn:hover {
            background: #fff;
            border-color: var(--coral);
        }

        .google-btn img {
            width: 22px;
        }

        .form-footer {
            text-align: center;
            margin-top: 32px;
            font-size: 15px;
            font-weight: 500;
            color: var(--text-muted);
        }

        .form-footer a {
            color: var(--coral);
            font-weight: 700;
            text-decoration: none;
        }

        .box-msg {
            padding: 14px 18px;
            border-radius: 12px;
            margin-bottom: 24px;
            font-size: 14px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .error-box {
            background: rgba(181, 56, 74, 0.1);
            color: var(--rose);
            border: 1px solid var(--rose);
        }

        .success-box {
            background: rgba(90, 122, 92, 0.1);
            color: var(--sage);
            border: 1px solid var(--sage);
        }

        @media (max-width: 1024px) {
            .auth-left {
                display: none;
            }

            .auth-right {
                width: 100%;
                padding: 40px 24px;
            }

            .form-box {
                width: 100%;
                margin: 0;
                padding: 30px 20px;
                border: 1px solid rgba(255, 255, 255, 0.2);
                background: rgba(255, 252, 248, 0.95);
                box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
            }

            [data-theme="dark"] .form-box {
                background: rgba(28, 18, 10, 0.95);
                border-color: rgba(255, 255, 255, 0.08);
            }
        }
    </style>
</head>

<body>

    <div class="auth-container">
        <div class="auth-left">
            <div class="auth-left-bg"></div>
            <div class="auth-content">
                <a href="/" class="auth-logo">Conn<span>eto</span></a>
                <h1 class="auth-title">Launch Your <em>Dream</em> Career Today.</h1>
                <p class="auth-desc">Connect with top-tier companies and discover internship opportunities that match
                    your skills and ambition.</p>
                <div style="display:flex;gap:30px;color:#fff">
                    <div>
                        <div style="font-size:24px;font-weight:800">500+</div>
                        <div style="font-size:12px;opacity:0.7;text-transform:uppercase;font-weight:700">Partners</div>
                    </div>
                    <div>
                        <div style="font-size:24px;font-weight:800">15K+</div>
                        <div style="font-size:12px;opacity:0.7;text-transform:uppercase;font-weight:700">Students</div>
                    </div>
                    <div>
                        <div style="font-size:24px;font-weight:800">92%</div>
                        <div style="font-size:12px;opacity:0.7;text-transform:uppercase;font-weight:700">Placement</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-right">
            <div class="moving-dots">
                <div class="dot" style="width: 100px; height:100px; top: 10%; right: 10%; animation-delay: 0s;"></div>
                <div class="dot" style="width: 60px; height:60px; bottom: 20%; left: 5%; animation-delay: -5s;"></div>
                <div class="dot" style="width: 120px; height:120px; top: 40%; left: 15%; animation-delay: -10s;"></div>
                <div class="dot" style="width: 80px; height:80px; bottom: 10%; right: 5%; animation-delay: -15s;"></div>
            </div>

            <div class="theme-toggle-wrap">
                <button class="theme-btn" id="themeToggle"><i class="fas fa-moon"></i></button>
            </div>

            <div class="form-box">
                <a href="/" class="back-home"><i class="fas fa-arrow-left"></i> Back to Homepage</a>

                <div class="form-header">
                    <h2>Welcome Back</h2>
                    <p>Please enter your details to sign in.</p>
                </div>

                <% if (typeof success !=='undefined' && success) { %>
                    <div class="box-msg success-box"><i class="fas fa-check-circle"></i>
                        <%= success %>
                    </div>
                    <% } %>

                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="box-msg error-box"><i class="fas fa-exclamation-circle"></i>
                                <%= error %>
                            </div>
                            <% } %>

                                <form method="POST" action="/auth/login">
                                    <div class="form-group">
                                        <label for="email">Email Address</label>
                                        <div class="input-wrap">
                                            <i class="fas fa-envelope"></i>
                                            <input type="email" id="email" name="email" class="form-input"
                                                placeholder="e.g. alex@example.com" required>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label for="password">Security Password</label>
                                        <div class="input-wrap">
                                            <i class="fas fa-lock"></i>
                                            <input type="password" id="password" name="password" class="form-input"
                                                placeholder="Enter your password" required>
                                        </div>
                                    </div>

                                    <div class="form-options">
                                        <label class="remember-me">
                                            <input type="checkbox" name="remember"> Remember for 30 days
                                        </label>
                                        <a href="/auth/forgot-password" class="forgot-pass">Forgot Password?</a>
                                    </div>

                                    <button type="submit" class="btn-submit">Sign In Account <i
                                            class="fas fa-arrow-right" style="margin-left:8px"></i></button>
                                </form>

                                <div class="divider">or continue with</div>

                                <a href="/auth/google" style="text-decoration: none;">
                                    <div class="google-btn">
                                        <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google">
                                        Sign in with Google
                                    </div>
                                </a>

                                <p class="form-footer">
                                    New to Conneto? <a href="/auth/register">Create a free account</a>
                                </p>
            </div>
        </div>
    </div>

    <script>
        const themeToggle = document.getElementById('themeToggle');
        const html = document.documentElement;

        function updateTheme() {
            const t = html.getAttribute('data-theme');
            themeToggle.innerHTML = t === 'dark' ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
        }

        themeToggle.addEventListener('click', () => {
            const current = html.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('conneto-theme', next);
            updateTheme();
        });
        updateTheme();
    </script>
</body>

</html>