<div class="dashboard-bg dark-moving-bg">
</div>

<!-- Topbar -->
<nav class="topbar">
    <a href="/" class="logo" style="margin-bottom:0; padding:0">Conn<span>eto</span></a>

    <div class="topbar-right">
        <button class="topbar-btn" id="themeToggle" title="Toggle Theme">
            <i class="fas fa-moon"></i>
        </button>
        <button class="topbar-btn">
            <i class="fas fa-search"></i>
        </button>
        <div class="user-menu">
            <div class="user-avatar" style="width:34px; height:34px; font-size:16px">
                <%= user.name.charAt(0).toUpperCase() %>
            </div>
            <div class="user-info">
                <div class="user-name" style="font-size:13px">
                    <%= user.name.split(' ')[0] %>
                </div>
                <div class="user-role" style="font-size:9px">
                    Scholar
                </div>
            </div>
            <a href="/auth/logout" class="topbar-btn" style="width: 32px; height: 32px; margin-left:8px; border:none; background:rgba(181, 56, 74, 0.1); color:var(--rose)">
                <i class="fas fa-power-off" style="font-size:14px"></i>
            </a>
        </div>
    </div>
</nav>

<!-- Sidebar -->
<aside class="sidebar" style="top:70px; height:calc(100vh - 70px); padding-top:20px">

    <div class="nav-section">
        <div class="nav-section-label">Opportunity Hub</div>
        <nav class="nav-menu">
            <a href="/student/dashboard"
                class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
                <i class="fas fa-th-large"></i>
                <span>Member Home</span>
            </a>
            <a href="/internships"
                class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'browse' ? 'active' : '' %>">
                <i class="fas fa-search"></i>
                <span>Explore Internships</span>
            </a>
            <a href="/student/dashboard?tab=applications"
                class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'applications' ? 'active' : '' %>">
                <i class="fas fa-file-invoice"></i>
                <span>My Applications</span>
            </a>
            <a href="/student/dashboard?tab=diary"
                class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'diary' ? 'active' : '' %>">
                <i class="fas fa-pen-nib"></i>
                <span>Log Diary</span>
            </a>
            <a href="/student/dashboard?tab=diary_history"
                class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'diary_history' ? 'active' : '' %>">
                <i class="fas fa-chart-line"></i>
                <span>Diary Tracking</span>
            </a>
            <a href="/student/dashboard?tab=leaves"
                class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'leaves' ? 'active' : '' %>">
                <i class="fas fa-calendar-plus"></i>
                <span>Apply for Leave</span>
            </a>
            <a href="/student/dashboard?tab=leave_history"
                class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'leave_history' ? 'active' : '' %>">
                <i class="fas fa-history"></i>
                <span>Leave Status</span>
            </a>
        </nav>
    </div>

    <div class="nav-section">
        <div class="nav-section-label">Student Account</div>
        <nav class="nav-menu">
            <a href="/student/dashboard?tab=profile"
                class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'profile' ? 'active' : '' %>">
                <i class="fas fa-user-circle"></i>
                <span>Portfolio</span>
            </a>

            <a href="/student/dashboard?tab=settings"
                class="nav-item <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active' : '' %>">
                <i class="fas fa-cog"></i>
                <span>Settings</span>
            </a>
        </nav>
    </div>

    </div>
</aside>

<!-- Main Content Wrapper -->
<main class="main-content">