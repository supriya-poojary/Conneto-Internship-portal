<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lumina | Luxury Interior Architecture</title>
    <!-- Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <style>
        /* CSS Reset & Variables */
        :root {
            --bg-color: #050505;
            --text-color: #f4f4f5;
            --accent-color: #d4af37;
            /* Gold */
            --secondary-bg: #111111;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            font-family: 'Playfair Display', serif;
            font-weight: 400;
        }

        a {
            color: var(--text-color);
            text-decoration: none;
        }

        /* Smooth Scroll Setup (Lenis) */
        html.lenis {
            height: auto;
        }

        .lenis.lenis-smooth {
            scroll-behavior: auto;
        }

        .lenis.lenis-smooth [data-lenis-prevent] {
            overscroll-behavior: contain;
        }

        .lenis.lenis-stopped {
            overflow: hidden;
        }

        /* Loading Screen */
        .loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: var(--bg-color);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent-color);
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 2.5rem 5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
            mix-blend-mode: difference;
        }

        .nav-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .nav-links {
            display: flex;
            gap: 3rem;
        }

        .nav-links a {
            font-size: 0.85rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            font-weight: 500;
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            width: 0;
            height: 1px;
            bottom: -4px;
            left: 50%;
            background-color: var(--text-color);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        /* Main Hero Section */
        .hero {
            height: 100vh;
            width: 100vw;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .hero-img {
            position: absolute;
            top: -10%;
            left: 0;
            width: 100%;
            height: 120%;
            object-fit: cover;
            z-index: -1;
            opacity: 0.6;
            filter: brightness(0.8);
        }

        .hero-content {
            text-align: center;
            z-index: 10;
        }

        .hero-title {
            font-size: clamp(4rem, 10vw, 10rem);
            line-height: 0.9;
            text-transform: uppercase;
            letter-spacing: -0.02em;
            margin-bottom: 2rem;
            mix-blend-mode: difference;
        }

        .hero-subtitle {
            font-size: clamp(1rem, 2vw, 1.25rem);
            font-weight: 300;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--accent-color);
        }

        .scroll-indicator {
            position: absolute;
            bottom: 3rem;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            opacity: 0.7;
        }

        .scroll-indicator span {
            font-size: 0.75rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
        }

        .scroll-line {
            width: 1px;
            height: 60px;
            background: rgba(255, 255, 255, 0.2);
            position: relative;
            overflow: hidden;
        }

        .scroll-line::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #fff;
            transform: translateY(-100%);
            animation: scrollDown 2s infinite cubic-bezier(0.77, 0, 0.175, 1);
        }

        @keyframes scrollDown {
            0% {
                transform: translateY(-100%);
            }

            100% {
                transform: translateY(100%);
            }
        }

        /* Introduction Section */
        .intro {
            padding: 12rem 5rem;
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }

        .intro p {
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.5rem, 4vw, 3.5rem);
            line-height: 1.4;
            color: #888;
        }

        .intro p span {
            color: var(--text-color);
        }

        /* Marquee Sections */
        .marquee-wrapper {
            padding: 6rem 0;
            background: var(--secondary-bg);
            overflow: hidden;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            white-space: nowrap;
            display: flex;
            align-items: center;
        }

        .marquee-wrapper.accent {
            background: var(--accent-color);
            color: var(--bg-color);
        }

        .marquee-content {
            display: flex;
            font-family: 'Playfair Display', serif;
            font-size: clamp(4rem, 8vw, 8rem);
            text-transform: uppercase;
            font-style: italic;
            padding: 0 2vw;
        }

        .marquee-inner {
            display: flex;
        }

        /* Featured Projects (Parallax Grid) */
        .projects {
            padding: 10rem 5rem;
        }

        .section-header {
            margin-bottom: 8rem;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .section-title {
            font-size: clamp(3rem, 6vw, 6rem);
            line-height: 1;
        }

        .section-link {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            border-bottom: 1px solid var(--accent-color);
            padding-bottom: 0.5rem;
            color: var(--accent-color);
            transition: color 0.3s;
        }

        .section-link:hover {
            color: #fff;
            border-color: #fff;
        }

        .project {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6rem;
            margin-bottom: 12rem;
            align-items: center;
        }

        .project:nth-child(even) {
            grid-template-columns: 1.2fr 0.8fr;
        }

        .project:nth-child(odd) .project-info {
            order: -1;
        }

        .project-img-wrapper {
            width: 100%;
            height: 90vh;
            overflow: hidden;
            border-radius: 4px;
            position: relative;
        }

        .project-img {
            width: 100%;
            height: 130%;
            object-fit: cover;
            position: absolute;
            top: -15%;
            filter: grayscale(20%);
            transition: filter 0.5s ease, transform 0.5s ease;
        }

        .project-img-wrapper:hover .project-img {
            filter: grayscale(0%);
            transform: scale(1.03);
        }

        .project-info {
            padding: 2rem 0;
        }

        .project-num {
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            letter-spacing: 0.1em;
            color: var(--accent-color);
            margin-bottom: 1.5rem;
            display: block;
        }

        .project-name {
            font-size: clamp(2.5rem, 4vw, 4.5rem);
            margin-bottom: 2rem;
            line-height: 1.1;
        }

        .project-desc {
            font-size: 1.1rem;
            color: #999;
            line-height: 1.8;
            max-width: 85%;
            margin-bottom: 3rem;
            font-weight: 300;
        }

        .btn-view {
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            font-weight: 500;
        }

        .btn-view span {
            width: 40px;
            height: 1px;
            background: var(--accent-color);
            display: block;
            transition: width 0.3s ease;
        }

        .btn-view:hover span {
            width: 60px;
        }

        /* Full Screen Image Reveal */
        .reveal-section {
            height: 100vh;
            width: 100vw;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            color: var(--bg-color);
        }

        .reveal-img-wrapper {
            position: absolute;
            inset: 0;
            overflow: hidden;
            clip-path: inset(15% 15% 15% 15%);
        }

        .reveal-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: brightness(0.7);
        }

        .reveal-content {
            z-index: 10;
            text-align: center;
        }

        .reveal-title {
            font-size: clamp(4rem, 10vw, 12rem);
            line-height: 0.85;
            color: #fff;
            font-style: italic;
        }

        /* Process Section */
        .process {
            padding: 10rem 5rem;
            background: var(--bg-color);
        }

        .process-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 4rem;
            margin-top: 6rem;
        }

        .process-item {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 2rem;
        }

        .process-num {
            font-size: 0.85rem;
            color: var(--accent-color);
            margin-bottom: 1rem;
            letter-spacing: 0.1em;
        }

        .process-title {
            font-size: 2rem;
            margin-bottom: 1.5rem;
        }

        .process-desc {
            color: #888;
            line-height: 1.7;
            font-size: 1.05rem;
            font-weight: 300;
        }

        /* Footer */
        footer {
            padding: 8rem 5rem 2rem;
            background: var(--secondary-bg);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .footer-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8rem;
        }

        .footer-title {
            font-size: clamp(3rem, 6vw, 6rem);
            line-height: 1;
        }

        .footer-cta {
            font-size: 1.5rem;
            font-family: 'Playfair Display', serif;
            font-style: italic;
            color: var(--accent-color);
            border: 1px solid var(--accent-color);
            padding: 1rem 3rem;
            border-radius: 50px;
            transition: all 0.3s;
        }

        .footer-cta:hover {
            background: var(--accent-color);
            color: var(--bg-color);
        }

        .footer-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 2rem;
        }

        .footer-links {
            display: flex;
            gap: 2rem;
        }

        .footer-links a {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #888;
            transition: color 0.3s;
        }

        .footer-links a:hover {
            color: #fff;
        }

        .copyright {
            font-size: 0.85rem;
            color: #555;
            letter-spacing: 0.05em;
        }

        /* Responsive */
        @media (max-width: 991px) {
            nav {
                padding: 2rem;
            }

            .nav-links {
                display: none;
            }

            .intro {
                padding: 8rem 2rem;
            }

            .projects {
                padding: 6rem 2rem;
            }

            .project {
                grid-template-columns: 1fr;
                gap: 3rem;
                margin-bottom: 8rem;
            }

            .project:nth-child(even),
            .project:nth-child(odd) {
                grid-template-columns: 1fr;
            }

            .project:nth-child(odd) .project-info {
                order: 1;
            }

            .project-img-wrapper {
                height: 60vh;
            }

            .process {
                padding: 6rem 2rem;
            }

            .process-grid {
                grid-template-columns: 1fr;
                gap: 3rem;
            }

            footer {
                padding: 6rem 2rem 2rem;
            }

            .footer-top {
                flex-direction: column;
                align-items: flex-start;
                gap: 4rem;
            }

            .footer-bottom {
                flex-direction: column;
                gap: 2rem;
                align-items: flex-start;
            }

            .reveal-img-wrapper {
                clip-path: inset(5%);
            }
        }
    </style>

    <!-- Prevent FOUT -> Pre-load Theme -->
    <script>
        (function () {
            var saved = localStorage.getItem('conneto-theme');
            if (saved !== 'light') {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>

<body>

