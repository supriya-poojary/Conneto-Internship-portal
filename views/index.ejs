    <!-- BACK TO TOP -->
    <button id="back-top" aria-label="Back to top">&#8593;</button>

    <script>
        const ham = document.getElementById('hamburger');
        const mNav = document.getElementById('mobileNav');
        const close = document.getElementById('closeNav');
        ham.addEventListener('click', () => mNav.classList.add('open'));
        close.addEventListener('click', () => mNav.classList.remove('open'));

        // Back to top
        const bt = document.getElementById('back-top');
        window.addEventListener('scroll', () => {
            bt.classList.toggle('visible', window.scrollY > 400);
        });
        bt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        // AOS
        (function () {
            const els = document.querySelectorAll('[data-aos]');
            const obs = new IntersectionObserver(entries => {
                entries.forEach(e => {
                    if (e.isIntersecting) {
                        const d = parseInt(e.target.dataset.aosDelay || 0);
                        setTimeout(() => e.target.classList.add('aos-animate'), d);
                    }
                });
            }, { threshold: 0, rootMargin: '0px 0px -40px 0px' });
            els.forEach(el => obs.observe(el));
        })();

        // Counters
        function runCounters() {
            document.querySelectorAll('.stat-num[data-count]').forEach(el => {
                const target = parseInt(el.dataset.count);
                const plus = el.querySelector('.stat-plus')?.outerHTML || '';
                const dur = 2000;
                const start = performance.now();
                const tick = now => {
                    const p = Math.min((now - start) / dur, 1);
                    const v = Math.round((1 - Math.pow(1 - p, 3)) * target);
                    el.innerHTML = v + plus;
                    if (p < 1) requestAnimationFrame(tick);
                };
                requestAnimationFrame(tick);
            });
        }
        let counted = false;
        new IntersectionObserver(e => { if (e[0].isIntersecting && !counted) { counted = true; runCounters(); } }, { threshold: .4 }).observe(document.querySelector('.stats-bar'));
    </script>
